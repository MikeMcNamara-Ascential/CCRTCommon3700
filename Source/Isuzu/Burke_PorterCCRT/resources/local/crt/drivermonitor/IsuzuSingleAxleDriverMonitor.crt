<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
  First stab at writing a config file for the GUI panels.
  Config for specific XMLWidgetPanels is under the
  $Revision: 1.2 $
-->

<RtGuiConfig>
    <Metadata author="Burke Porter, Inc" version="1.0"
      description="Standard implementation of the Driver Monitor view."/>
    <XmlWidgetPanel id="DriverMonitor">
        <Layout bgcolor="white">
            <!-- END OF Trafficlight ========================================== -->
            <!-- START OF radial gauges ================================= -->
            <HBox posX="10" posY="0" width="700" height="270">
                <!-- Speedometer gauge -->
                <Widget id="speed" height="300" width="300" class="com.bepco.gui.RadialGauge">
                    <DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
                    <DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
                    <DataSource tagname="SpeedActive" messagetype="Subscribe" tagrole="enabled"/>
                    <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
                        <Font size="30" name="sans-serif" style="plain"/>
                    </RadialGaugeConfig>
                </Widget>
                <!-- Brake force gauge -->
                <VBox>
                    <Widget id="brakeforce" height="240" width="240" class="com.bepco.gui.RadialGauge">
                        <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10"/>
                        <DataSource tagname="BrakeTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <DataSource tagname="BrakeActive" messagetype="Subscribe" tagrole="enabled"/>
                        <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="1500" targetlow="0" targethigh="0" >
                            <Font size="30" name="sans-serif" style="plain"/>
                        </RadialGaugeConfig>
                    </Widget>
                    <Widget id="_brakeForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10" />
                        <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig>
                            <Font size="28" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                </VBox>
                <!-- END OF Three radial gauges =================================== -->
            </HBox>
            <!--
            <Widget id="_brakeForce" class="com.bepco.gui.NumberBox" height="40" width='80' posX="600" posY="230">
                <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10" />
                <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="28" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            -->

            <!-- Wheel Speeds ======================================================================== -->
            <VBox posX="620" posY="60" width="350" height="400">
                <HBox width="200" border="false">
                    <VBox width="75">
                        <Label name="left">
                            <Font size="24" name="sans-serif" style="bold"/>
                        </Label>
                    </VBox>
                    <VBox width="75">
                        <Label name="right">
                            <Font size="24" name="sans-serif" style="bold"/>
                        </Label>
                    </VBox>
                </HBox>
            </VBox>
            <VBox posX="640" posY="90" width="350" height="400">
                <HBox width="200" border="false">
                    <VBox width="55">
                        
                        <Widget id="_rf" class="com.bepco.gui.NumberBox" width='80'>
                            <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                            <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig>
                                <Font size="38" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox height="100"/>
                        <!--Widget id="_lf" class="com.bepco.gui.NumberBox" width="80">
                            <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                            <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig>
                                <Font size="38" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget-->
                    </VBox>

                    <VBox width="55">
                        
                        <Widget id="_lr" class="com.bepco.gui.NumberBox" width="80">
                            <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                            <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig>
                                <Font size="38" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox height="100"/>
                        <!--Widget id="_rr" class="com.bepco.gui.NumberBox" width='80'>
                            <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                            <DataSource tagname="RRSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig>
                                <Font size="38" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget-->
                    </VBox>
                </HBox>
            </VBox>
            <HBox posX="680" posY="205" height="80" width="360">
                <!-- subsystem test pass/fail widgets 
                    TestStates:
                        TestInProgress 	- Blue
                        Timeout		- Orange
                        Pass		- Green
                        Fail		- Red
                        Abort		- Yellow
                -->
                <VBox>
                    <Widget width='165' height='30' posY="0" id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                        <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                        <TextBoxConfig>
                            <Font size="22" name="serif" style="plain"></Font>
                        </TextBoxConfig>
                    </Widget>
                    <Widget width='165' height='30' posY="0" id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                        <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                        <TextBoxConfig>
                            <Font size="22" name="serif" style="plain"></Font>
                        </TextBoxConfig>
                    </Widget>
                </VBox>
                <VBox>
                    <Widget width='165' height='30' id="engine" class="com.bepco.gui.OverallTestPhaseBox" >
                        <DataSource tagname="EmissionsOverallTest" messagetype="Subscribe"/>
                        <TextBoxConfig>
                            <Font size="22" name="serif" style="plain"></Font>
                        </TextBoxConfig>
                    </Widget>
                    <Widget width='165' height='30' id="cruise" class="com.bepco.gui.OverallTestPhaseBox" >
                        <DataSource tagname="SpeedControlOverallTest" messagetype="Subscribe"/>
                        <TextBoxConfig>
                            <Font size="22" name="serif" style="plain"></Font>
                        </TextBoxConfig>
                    </Widget>
                </VBox>
            </HBox>
            <!-- END of Wheel Speeds ================================================================ -->



            <!-- START OF Driver Prompt Boxes ================================= -->
            <Widget id="prompts1" class="com.bepco.gui.PromptBox" posX="7" posY="275" width="1005" height="90" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe" />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts2" class="com.bepco.gui.PromptBox" posX="7" posY="370" width="1005" height="90" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe" />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <!-- END OF Driver Prompt Boxes ================================= -->
            <!-- Row 2 of 3 -->
            <HBox border="false" posX="7" posY="430" width="610" height="300">
                <!-- END OF subsystem test pass/fail widgets ========================================== -->
                <!-- START of Test Failures Box===================================================== -->
                <HBox height="195" width="580" border="true">
                    <VBox width="580">
                        <HBox>
                            <Label name="testfailures">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </Label>
                        </HBox>
                        <Widget height="180" width="580" id="testfailures" class="com.bepco.gui.ListBox">
                            <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                            <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings" scrollbar="false">
                                <Font style="plain" name="serif" size="20"/>
                            </ScrollBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
            </HBox>
            <!-- END of Test Failures Box ===================================================== -->
            <!-- Machine Faults -->
            <HBox border="false" posX="610" posY="442" width="400" height="300">
                <VBox>
                    <HBox height="145" width="375" border="true">
                        <VBox width="375">
                            <HBox>
                                <Label name="machinefaults">
                                    <Font size="24" name="sans-serif" style="plain"/>
                                </Label>
                            </HBox>
                            <Widget height="140" width="375" id="machine_faults" class="com.bepco.gui.MachineFaultView">
                                <DataSource tagname="AllFaults" messagetype="Subscribe"/>
                                <ListBoxConfig stringmap="com.bepco.rtc.properties.MachineFaultStrings">
                                    <Font style="bold" name="sans-serif" size="18"/>
                                </ListBoxConfig>
                            </Widget>
                        </VBox>
                    </HBox>
                    <HBox>
                        <VBox>
                            <Label name="cycletime">
                                <Font size="25" name="sans-seriff" style="plain"/>
                            </Label>
                            <Label name="enginetemp">
                                <Font size="25" name="sans-seriff" style="plain"/>
                            </Label>
                        </VBox>
                        <VBox width="20"/>
                        <VBox>
                            <Widget id="_cycleTime" class="com.bepco.gui.NumberBox">
                                <DataSource tagname="CycleTime" messagetype="Subscribe"/>
                                <TextBoxConfig>
                                    <Font size="25" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                            <Widget id="_engineTemp" class="com.bepco.gui.NumberBox">
                                <DataSource tagname="EngineOperatingTemp" messagetype="Subscribe"/>
                                <TextBoxConfig>
                                    <Font size="25" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>
            <!-- START of VIN BOX ============================================================== -->
            <HBox posX='7' posY='700' width='1012' height='68' border="false">
                <!-- VIN -->
                <Label name="vin" border="false" height='68' width='100'>
                    <Font size="45" name="sans-serif" style="plain"/>
                </Label>
                <Widget id="_vin" height='68' width="500" class="com.bepco.gui.TextBox">
                    <DataSource tagname="VINDisplay" messagetype="Subscribe" />
                    <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
                      tagrole="backgroundcolor" />
                    <TextBoxConfig>
                        <Font size="45" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
            </HBox>
            <!-- END of VIN Box ============================================================== -->
        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>
