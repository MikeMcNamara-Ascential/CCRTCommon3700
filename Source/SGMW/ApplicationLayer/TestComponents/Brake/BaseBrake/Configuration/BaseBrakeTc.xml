        <Parameters>
            <BaseBrakeSampleCount>0</BaseBrakeSampleCount>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <DisplayBrakeMeterUntilZeroSpeed>1</DisplayBrakeMeterUntilZeroSpeed>
            <ExcessiveBrakeForceLimit>500.0</ExcessiveBrakeForceLimit>
            <FailForExcessiveBrakeForce>1</FailForExcessiveBrakeForce>
            <ForcedAccelerateSpeedStep>10</ForcedAccelerateSpeedStep>
            <ForcedAccelerateSpeedStepDelay>500</ForcedAccelerateSpeedStepDelay>
            <FrontToRearBalanceUseFront>1</FrontToRearBalanceUseFront>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <ICMName>mgr/ICM</ICMName>
            <IgnoreMachineConditions>0</IgnoreMachineConditions>
            <IncludeDragInBrakeForce>0</IncludeDragInBrakeForce>
            <KeepTestStatusOnExit>1</KeepTestStatusOnExit>
            <LogTaskStatInfo>Yes</LogTaskStatInfo>
            <MaintainSpeedMaxSpeed>35</MaintainSpeedMaxSpeed>
            <MaintainSpeedMinSpeed>25</MaintainSpeedMinSpeed>
            <MaintainSpeedTime>1000</MaintainSpeedTime>
            <MinimumStartForce>150.0</MinimumStartForce>
            <MotorLoadingAccelConst>0.0</MotorLoadingAccelConst>
            <MotorLoadingSpeedConst>0.0</MotorLoadingSpeedConst>
            <NumberOfSamplesAboveLimit>10</NumberOfSamplesAboveLimit>
            <PreForcedAccelerateWait>3000</PreForcedAccelerateWait>
            <ScanDelayParameter>500</ScanDelayParameter>
            <SpeedRangeParameter>30 35</SpeedRangeParameter>
            <StartSamplingAtMinimumForce>1</StartSamplingAtMinimumForce>
            <TargetSpeedParameter>30</TargetSpeedParameter>

            <!-- Park Brake Parameters -->
            <ParkBrakeArmSpeed Units="mph">9</ParkBrakeArmSpeed>
            <ParkBrakeMaxForce Units="lbf">400</ParkBrakeMaxForce>
            <ParkBrakeMinForce Units="lbf">18</ParkBrakeMinForce>
            <ParkBrakeStartSampleSpeed Units="mph">8</ParkBrakeStartSampleSpeed>
            <ParkBrakeEndSampleSpeed Units="mph">0</ParkBrakeEndSampleSpeed>
            <ParkBrakeStartSamplingAtMinimumForce>True</ParkBrakeStartSamplingAtMinimumForce>
            <ParkBrakeMinimumStartForce Units="lbf">15</ParkBrakeMinimumStartForce>
            <ParkBrakeForceSampleCount>0</ParkBrakeForceSampleCount>
            <DisplaySpeedTimeGraph>True</DisplaySpeedTimeGraph>
            <SpeedGraphLowerSeries UnitsX="s" UnitsY="km/h">0 -5,20 15,30 15,50 40,60 40,80 60,90 60,120 90</SpeedGraphLowerSeries>
            <SpeedGraphUpperSeries UnitsX="s" UnitsY="km/h">0 10,20 30,30 30,50 70,60 70,80 100,90 100,120 120</SpeedGraphUpperSeries>
        </Parameters>
        <FaultList>/Configuration/Components/Common/SampleFaultList.xml</FaultList>
        <Prompts>
            <SlowDownToTargetSpeed PromptBox="1" Priority="0">SlowDownToTargetSpeed</SlowDownToTargetSpeed>
            <AccelerateToTargetSpeed PromptBox="1" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <NeutralPrompt PromptBox="1" Priority="0">ShiftToNeutral</NeutralPrompt>
            <RemoveFootFromBrake PromptBox="1" Priority="0">RemoveFootFromBrake</RemoveFootFromBrake>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
            <EnterYesOrNo PromptBox="1" Priority="0">EnterYesOrNo</EnterYesOrNo>
            <PassOrFail PromptBox="1" Priority="0">OverallPassOrFail</PassOrFail>
            <MaintainSpeed PromptBox="1" Priority="0">MaintainSpeed</MaintainSpeed>
            <ShiftToReverse PromptBox="1" Priority="0">ApplyBrakeShiftToReverse</ShiftToReverse>
        </Prompts>
        <StatusCheckItems>
            <VehiclePresent>1</VehiclePresent>
            <RollsUpElevDown>1</RollsUpElevDown>
        </StatusCheckItems>
        <TestDomain>Foreground</TestDomain>
        <SystemTagsToReset>
            <BrakeActive>0</BrakeActive>
            <FrontBalanceBGColor>white</FrontBalanceBGColor>
            <FrontBalanceValue>0</FrontBalanceValue>
            <FrontToRearBalanceBGColor>white</FrontToRearBalanceBGColor>
            <FrontToRearBalanceValue>0</FrontToRearBalanceValue>
            <LeftRearParkBrakeForceBGColor>white</LeftRearParkBrakeForceBGColor>
            <LeftRearParkBrakeForceValue>0</LeftRearParkBrakeForceValue>
