<TestResultServerConfig>
  <Setup>
    <Debug>Off</Debug>
    <IncludeAbortInAllFailures Value="Yes or No">Yes</IncludeAbortInAllFailures>
    <VINLength>12</VINLength>
    <UpdateTestLampStatus Value="Yes or No">Yes</UpdateTestLampStatus>
    <Communication>
      <Comm>IPC</Comm>
      <Debug>Off</Debug>
      <Name>core/TestResultServer</Name>
      <BufferSize>2000</BufferSize>
      <Timeout>1000</Timeout>
      <Type>Server</Type>
    </Communication>
    <DataTags>
      <StartTest>StartVehicleTest2</StartTest>
      <AllFailures>AllFailures2</AllFailures>
      <OverallTest>OverallTest2</OverallTest>
      <VehicleBuild>VehicleBuild2</VehicleBuild>
      <Vin>VIN2</Vin>
      <ClearScrollBox>ClearScrollBox2</ClearScrollBox>
      <DriverNumber>DriverNumber2</DriverNumber>
      <DriveCurve>DriveCurve2</DriveCurve>
    </DataTags>
    <Logging>
      <Debug>Off</Debug>
      <AdditionalLogFile>/Servers/TestResultServer.log</AdditionalLogFile>
      <ProcessName>core/TestResultServer</ProcessName>
      <Status>Disabled</Status>
      <LocalEcho>Disabled</LocalEcho>
      <Verbose>0x1F</Verbose>
    </Logging>
    <TagList>
      <SubscribeTags>
        <StartVehicleTest/>
        <StartLossCompensation/>
        <OverallTest/>
        <VehicleBuild/>
        <DriverNumber/>
        <VIN/>
        <DriveCurve/>
        <KeyPress/>
      </SubscribeTags>
    </TagList>
    <VehicleBuildItems>
      <DriveCurve2/>
    </VehicleBuildItems>
    <TestResults>
      <TestResultPath>/TestResults/Vehicle1/</TestResultPath>
      <TestResultFile>TestResultIndex1</TestResultFile>
      <NumberOfTests>1001</NumberOfTests>
      <ClearBuildOnOverall>1</ClearBuildOnOverall>
    </TestResults>
    <ThreadPool>
      <Debug>Off</Debug>
      <Increment>2</Increment>
      <MaxBlockedLimit>7</MaxBlockedLimit>
      <Maximum>10</Maximum>
      <MinBlockedLimit>2</MinBlockedLimit>
    </ThreadPool>
    <NotificationList>
      <Setup>
        <Debug>Off</Debug>
        <HighWater>3</HighWater>
        <Increment>1</Increment>
        <LowWater>1</LowWater>
        <Maximum>5</Maximum>
        <StartOnCreate>No</StartOnCreate>
      </Setup>
    </NotificationList>
  </Setup>
</TestResultServerConfig>
