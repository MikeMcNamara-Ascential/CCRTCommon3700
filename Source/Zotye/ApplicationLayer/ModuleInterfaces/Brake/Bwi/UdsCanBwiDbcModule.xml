<DcuModuleInterface>

    <Setup>
        <AutomaticallyEnterDiagnosticMode>Yes</AutomaticallyEnterDiagnosticMode>
        <Communication>
            <Debug>Off</Debug>
            <Name>/home/CCRT/Rewrite/GryphonCCan</Name>
            <BufferSize>4096</BufferSize>
            <CommSize>1</CommSize>
            <Timeout>10000000</Timeout>
            <Retries>3</Retries>
        </Communication>
        <CheckSumLength>1</CheckSumLength>
        <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
        <DataByteCountIndex>3</DataByteCountIndex>
        <DataHeaderLength>2</DataHeaderLength>
        <DataStartIndex>6</DataStartIndex>
        <DTCData>
            <DTCCountIndex>-1</DTCCountIndex>
            <BytesPerDTC>4</BytesPerDTC>
            <FirstDTCByteIndex>3</FirstDTCByteIndex>
        </DTCData>
        <EnterDiagnosticModeMessageTag>EnterDiagnosticMode</EnterDiagnosticModeMessageTag>
        <KeepAlivePriority>10</KeepAlivePriority>
        <KeepAliveResponseRequired>No</KeepAliveResponseRequired>
        <KeepAliveResponseTime>500</KeepAliveResponseTime>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>UdsBwiDbcModule</ProcessName>
            <AdditionalLogFile>/Communication/UdsBwiDbcModule.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
        <ModuleKeepAliveTime>250</ModuleKeepAliveTime>
        <ModuleRequestID>0x731</ModuleRequestID>
        <ModuleResponseDelay>500</ModuleResponseDelay>
        <ModuleResponseEndDelay>0</ModuleResponseEndDelay>

        <IgnoreCalibarateGSensorResult>False</IgnoreCalibarateGSensorResult>
        <SkipRequestGSensorResult>False</SkipRequestGSensorResult>

        <NegativeResponseCodes>
            <Code_0x10>General Reject</Code_0x10>
            <Code_0x11>Service Not Supported</Code_0x11>
            <Code_0x12>Sub-Function Not Supported</Code_0x12>
            <Code_0x13>Incorrect Message Length</Code_0x13>
            <Code_0x21>Busy / Repeat Request</Code_0x21>
            <Code_0x22>Conditions not correct - EEPROM error</Code_0x22>
            <Code_0x23>Routine Not Complete</Code_0x23>
            <Code_0x24>Request Sequence Error</Code_0x24>
            <Code_0x31>Request Out Of Range</Code_0x31>
            <Code_0x33>Security Access Denied / Security Access Requested</Code_0x33>
            <Code_0x35>Invalid Key</Code_0x35>
            <Code_0x36>Exceed Number Of Attempts</Code_0x36>
            <Code_0x37>Required Time Delay Not Expired</Code_0x37>
            <Code_0x40>Download Not Accepted</Code_0x40>
            <Code_0x50>Upload Not Accepted</Code_0x50>
            <Code_0x71>Transfer Suspended</Code_0x71>
            <Code_0x78>Request Correctly Received - Response Pending</Code_0x78>
            <Code_0x7F>Service Not Supported In Active Session</Code_0x7F>
            <Code_0x80>Service Not Supported In Active Diagnostic Session</Code_0x80>
            <Code_0x9A>Data Decompression Failed</Code_0x9A>
            <Code_0x9B>Data Decryption Failed</Code_0x9B>
            <Code_0xA0>ECU Not Responding</Code_0xA0>
            <Code_0xA1>ECU Address Unknown</Code_0xA1>
            <EnterDiagnosticMode>0x80</EnterDiagnosticMode>
            <ResponsePending>0x78</ResponsePending>
            <ModuleBusy>0x21</ModuleBusy>
        </NegativeResponseCodes>
        <NegativeResponseValue>0x7F</NegativeResponseValue>
        <NegativeResponseCodeIndex>2</NegativeResponseCodeIndex>
        <NumberOfRetries>3</NumberOfRetries>
        <ResponsePendingReads>3</ResponsePendingReads>
        <SentMessageIdentifierIndex>0</SentMessageIdentifierIndex>
        <SwitchMonitorDelay>500</SwitchMonitorDelay>
        <ValidResponseOffset>0x40</ValidResponseOffset>
    </Setup>



    <SerialMessages>

        <VehicleMessages>

            <ActuateLeftFrontRecovery>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateLFInletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftFrontRecovery>

            <ActuateLeftFrontReduction>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateLFOutletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftFrontReduction>

            <ActuateLeftRearRecovery>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateLRInletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftRearRecovery>

            <ActuateLeftRearReduction>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateLROutletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftRearReduction>

            <ActuateRightFrontRecovery>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateRFInletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightFrontRecovery>

            <ActuateRightFrontReduction>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateRFOutletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightFrontReduction>

            <ActuateRightRearRecovery>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateRRInletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightRearRecovery>

            <ActuateRightRearReduction>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivateRROutletValve</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightRearReduction>

            <AllInletValvesOff>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>AllActuatorsOff</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </AllInletValvesOff>

            <AllInletValvesOn>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>AllActuatorsOn</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </AllInletValvesOn>

            <DumpAllValves>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>AllOutletValvesOn</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </DumpAllValves>

            <EnterDiagnosticMode>
                <TransmitMessage>EnterDiagnosticMode</TransmitMessage>
                <TransmitInterpretation>ExtendedSession</TransmitInterpretation>
                <ReplyMessage>EnterDiagnosticMode</ReplyMessage>
                <ReplyInterpretation/>
            </EnterDiagnosticMode>

            <HoldAllValves>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>AllOutletValvesOff</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </HoldAllValves>

            <ModuleKeepAlive>
                <TransmitMessage>TesterPresent</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>TesterPresent</ReplyMessage>
                <ReplyInterpretation/>
            </ModuleKeepAlive>

            <ReadFaults>
                <TransmitMessage>ReadFaults</TransmitMessage>
                <TransmitInterpretation>ReadFaults</TransmitInterpretation>
                <ReplyMessage>ReadFaults</ReplyMessage>
                <ReplyInterpretation/>
            </ReadFaults>

            <ReadSensorSpeeds>
                <TransmitMessage>ReadEcuId</TransmitMessage>
                <TransmitInterpretation>WheelSpeeds</TransmitInterpretation>
                <ReplyMessage>ReadWheelSpeeds</ReplyMessage>
                <ReplyInterpretation>SensorSpeeds</ReplyInterpretation>
            </ReadSensorSpeeds>

            <RunPumpMotor>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>ActivatePumpMotor</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </RunPumpMotor>

            <StopPumpMotor>
                <TransmitMessage>ActuatorOperation</TransmitMessage>
                <TransmitInterpretation>DeactivatePumpMotor</TransmitInterpretation>
                <ReplyMessage>StartRoutineResponse</ReplyMessage>
                <ReplyInterpretation/>
            </StopPumpMotor>

        </VehicleMessages>


        <TransmitMessages>
            <EnterDiagnosticMode>0x10,0x??</EnterDiagnosticMode>
            <ActuatorOperation>0x2F,0x31,0x07,0x??,0x??,0x??,0x??</EspActuatorOperation>
            <ReadEcuId>0x22,0x??,0x??</ReadEcuId>
            <ReadFaults>0x19,0x??,0x??</ReadFaults>
            <TesterPresent>0x3E,0x00</TesterPresent>
        </TransmitMessages>


        <TransmitInterpretations>
            <ActivateLFInletValve>0x01,0x02,0x00,0x00</ActivateLFInletValve>
            <ActivateLFOutletValve>0x02,0x02,0x00,0x00</ActivateLFOutletValve>
            <ActivateLRInletValve>0x10,0x02,0x00,0x00</ActivateLRInletValve>
            <ActivateLROutletValve>0x20,0x02,0x00,0x00</ActivateLROutletValve>
            <ActivatePumpMotor>0x00,0x02,0x00,0x00</ActivatePumpMotor>
            <ActivateRFInletValve>0x04,0x02,0x00,0x00</ActivateRFInletValve>
            <ActivateRFOutletValve>0x08,0x02,0x00,0x00</ActivateRFOutletValve>
            <ActivateRRInletValve>0x40,0x02,0x00,0x00</ActivateRRInletValve>
            <ActivateRROutletValve>0x80,0x02,0x00,0x00</ActivateRROutletValve>
            <AllActuatorsOff>0x00,0x00,0x00,0x00</AllActuatorsOff>
            <AllActuatorsOn>0x55,0x02,0x00,0x00</AllActuatorsOn>
            <AllOutletValvesOn>0xAA,0x02,0x00,0x00</AllOutletValvesOn>
            <AllOutletValvesOff>0x00,0x02,0x00,0x00</AllOutletValvesOff>
            <DeactivatePumpMotor>0x00,0x00,0x00,0x00</DeactivatePumpMotor>
            <ExtendedSession>0x03</ExtendedSession>
            <PumpMotorOn>0x00,0x03,0x00,0x00</PumpMotorOn>
            <ReadFaults>0x02,0x8B</ReadFaults>
            <WheelSpeeds>0x30,0x07</WheelSpeeds>
        </TransmitInterpretations>


        <ReplyMessages>

            <EnterDiagnosticMode>
                <Reply_03>0x50,0x03,0x??,0x??,0x??,0x??</Reply_03>
                <Reply_04>0x7F,0x10,0x??</Reply_04>
            </EnterDiagnosticMode>

            <ReadFaults>
                <Reply_00 lengthType="Variable" ReplyTimeout="500" endGapTime="0">0x59,0x02,0x??</Reply_00>
                <Reply_02>0x7F,0x19,0x??</Reply_02>
            </ReadFaults>

            <ReadWheelSpeeds>
                <Reply_00 lengthType="Variable" ReplyTimeout="500" endGapTime="0">0x62,0x2D,0x00,0x??,0x??</Reply_00>
                <Reply_01>0x7F,0x22,0x??</Reply_01>
            </ReadWheelSpeeds>

            <StartRoutineResponse>
                <Reply_00 lengthType="Variable" ReplyTimeout="500" endGapTime="0">0x6F,0x31,0x07,0x??</Reply_00>
                <Reply_01>0x7F,0x2F,0x??</Reply_01>
            </StartRoutineResponse>

            <TesterPresent>
                <Reply_00>0x7E,0x00</Reply_00>
                <Reply_01>0x7F,0x3E,0x??</Reply_01>
            </TesterPresent>

        </ReplyMessages>


        <ReplyInterpretations>

            <SensorSpeeds>
                <Vector type="fixed">
                    <Subvector00 Description="Front Left Speed">
                        <Float scale="0.00485" offset="0">
                            <!--km/h-->
                            <Integer type="unsigned" bits="16" scale="1" offset="0">
                                <Byte1 input_index="3" mask="0xFF" output_index="1"/>
                                <Byte2 input_index="4" mask="0xFF" output_index="0"/>
                            </Integer>
                        </Float>
                    </Subvector00>
                    <Subvector01 Description="Front Right Speed">
                        <Float scale="0.00485" offset="0">
                            <!--km/h-->
                            <Integer type="unsigned" bits="16" scale="1" offset="0">
                                <Byte1 input_index="5" mask="0xFF" output_index="1"/>
                                <Byte2 input_index="6" mask="0xFF" output_index="0"/>
                            </Integer>
                        </Float>
                    </Subvector01>
                    <Subvector02 Description="Rear Left Speed">
                        <Float scale="0.00485" offset="0">
                            <!--km/h-->
                            <Integer type="unsigned" bits="16" scale="1" offset="0">
                                <Byte1 input_index="7" mask="0xFF" output_index="1"/>
                                <Byte2 input_index="8" mask="0xFF" output_index="0"/>
                            </Integer>
                        </Float>
                    </Subvector02>
                    <Subvector03 Description="Rear Right Speed">
                        <Float scale="0.00485" offset="0">
                            <!--km/h-->
                            <Integer type="unsigned" bits="16" scale="1" offset="0">
                                <Byte1 input_index="9" mask="0xFF" output_index="1"/>
                                <Byte2 input_index="10" mask="0xFF" output_index="0"/>
                            </Integer>
                        </Float>
                    </Subvector03>
                </Vector>
            </SensorSpeeds>

        </ReplyInterpretations>

    </SerialMessages>
</DcuModuleInterface>
