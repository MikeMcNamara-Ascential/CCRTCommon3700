            <ReplyMessage>LearnVIN</ReplyMessage>
            <ReplyInterpretation/>
         </LearnVIN>
         <LockSteeringTune>
            <TransmitMessage>LockSteeringTune</TransmitMessage>
            <TransmitInterpretation/>
            <ReplyMessage>LockSteeringTune</ReplyMessage>
            <ReplyInterpretation/>
         </LockSteeringTune>
         <GetVinRoutineStatus>
            <TransmitMessage>VINStatus</TransmitMessage>
            <TransmitInterpretation/>
            <ReplyMessage>VINStatus</ReplyMessage>
            <ReplyInterpretation>VINStatus</ReplyInterpretation>
         </GetVinRoutineStatus>
         <GetTuneRoutineStatus>
            <TransmitMessage>TuneStatus</TransmitMessage>
            <TransmitInterpretation/>
            <ReplyMessage>TuneStatus</ReplyMessage>
            <ReplyInterpretation>TuneStatus</ReplyInterpretation>
         </GetTuneRoutineStatus>
         <ReadPartNumber>
            <TransmitMessage>ReadPartNumber</TransmitMessage>
            <TransmitInterpretation/>
            <ReplyMessage>ReadPartNumber</ReplyMessage>
            <ReplyInterpretation>ReadPartNumber</ReplyInterpretation>
         </ReadPartNumber>
         <ModuleKeepAlive>
            <TransmitMessage>TesterPresent</TransmitMessage>
            <TransmitInterpretation/>
            <ReplyMessage>TesterPresent</ReplyMessage>
            <ReplyInterpretation/>
         </ModuleKeepAlive>
      </VehicleMessages>
      <TransmitMessages>
         <ClearFaults>0x14,0xFF,0xFF,0xFF</ClearFaults>
         <ReadFaults>0x19,0x02,0xFF</ReadFaults>
         <EnterDiagnosticMode>0x10,0x03</EnterDiagnosticMode>
         <ReadByID>0x22,0xFD,0x40</ReadByID>
         <WriteByID>0x2E,0xFD,0x40,0x00,0x00</WriteByID>
         <ReadTraceData>0x22,0xFD,0x02</ReadTraceData>
         <LearnVIN>0x31,0x01,0x04,0x04</LearnVIN>
         <LockSteeringTune>0x31,0x01,0x30,0x38</LockSteeringTune>
         <ReadVIN>0x22,0xF1,0x90</ReadVIN>
         <ReadPartNumber>0x22,0xF1,0x87</ReadPartNumber>
         <VINStatus>0x31,0x03,0x04,0x04</VINStatus>
         <TuneStatus>0x31,0x03,0x30,0x38</TuneStatus>
         <TesterPresent>0x3E,0x00</TesterPresent>
      </TransmitMessages>
      <TransmitInterpretations/>
      <ReplyMessages>
         <ClearFaults>
            <Reply_01 lengthType="Variable">0x54,0x??</Reply_01>
            <Reply_02>0x7F,0x14,0x??</Reply_02>
         </ClearFaults>
         <EnterDiagnosticMode>
            <Reply_01 lengthType="Variable">0x50,0x03,0x??</Reply_01>
            <Reply_02>0x7F,0x10,0x??</Reply_02>
         </EnterDiagnosticMode>
         <CommandSecurityAccess>
            <Reply_01>0x67,0x01,0x??,0x??</Reply_01>
            <Reply_02>0x7F,0x27,0x??</Reply_02>
         </CommandSecurityAccess>
         <ReadByID>
            <Reply_01 lengthType="Variable">0x62,0xFD,0x40,0x??</Reply_01>
            <Reply_02>0x7F,0x22,0x??</Reply_02>
         </ReadByID>
         <WriteByID>
            <Reply_01>0x6E,0xFD,0x40</Reply_01>
            <Reply_02>0x7F,0x2E,0x??</Reply_02>
         </WriteByID>
         <ReadFaults>
            <Reply_01 lengthType="Variable">0x59,0x02,0x??</Reply_01>
            <Reply_02>0x7F,0x19,0x??</Reply_02>
         </ReadFaults>
         <TransmitSecurityKey>
            <Reply_01>0x67,0x02</Reply_01>
            <Reply_02>0x7F,0x27,0x??</Reply_02>
         </TransmitSecurityKey>
         <ReadTraceData>
            <Reply_01>0x62,0xFD,0x02,0x??,0x??,0x??,0x??</Reply_01>
            <Reply_02>0x7F,0x22,0x??</Reply_02>
         </ReadTraceData>
         <WriteVIN>
            <Reply_01>0x6E,0xF1,0x90</Reply_01>
            <Reply_02>0x7F,0x2E,0x??</Reply_02>
         </WriteVIN>
         <LearnVIN>
            <Reply_01 lengthType="Variable">0x71,0x01,0x04,0x04,0x??</Reply_01>
            <Reply_02>0x7F,0x31,0x??</Reply_02>
         </LearnVIN>
         <LockSteeringTune>
            <Reply_01 lengthType="Variable">0x71,0x01,0x30,0x38,0x??</Reply_01>
            <Reply_02>0x7F,0x31,0x??</Reply_02>
         </LockSteeringTune>
         <VINStatus>
            <Reply_01 lengthType="Variable">0x71,0x03,0x04,0x04,0x??</Reply_01>
            <Reply_02>0x7F,0x31,0x??</Reply_02>
