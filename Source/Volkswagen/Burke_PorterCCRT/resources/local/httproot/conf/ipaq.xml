<?xml version="1.0"?>
 <RtReportConfig>
	<ReportLayout>
	  <Title>Wireless CCRT Test Result</Title>
	  <TestIdBlock>
		<Column>
		  <ServerTag tagname="Vin" label="VIN"/>
		</Column>
	  </TestIdBlock>	

	  <HorizontalBar/>

 	  <BuildDataBlock label="Build Data">
		<Column>
		  <ServerTag tagname="Airbag" label="Airbag"/>
		  <ServerTag tagname="TireSize" label="Tires"/>
		  <ServerTag tagname="Transmission" label="Transmission"/>
		  <ServerTag tagname="Brake" label="Brake"/>
		  <ServerTag tagname="AbsPartNo" label="Abs"/>
		  <ServerTag tagname="Axle" label="Axle"/>
		  <ServerTag tagname="BuildDate" label="Date"/>
		  <ServerTag tagname="BuildTime" label="Time"/>
		</Column>
	  </BuildDataBlock>

	  <HorizontalBar/>

 	  <TestResultsBlock>
		<Column>
		  <TestProcess showfailures="true" tagname="EmissionsOverallPassFail" label="Emissions"/>
		  <TestProcess showfailures="true" tagname="AirbagOverallPassFail" label="Airbag"/>
		  <TestProcess showfailures="true" tagname="BrakeOverallPassFail" label="Brake"/>
		  <TestProcess showfailures="true" tagname="SpeedControlOverallPassFail" label="Speed Control"/>
		</Column>
		<Column>
		  <TestProcess showfailures="true" tagname="TransmissionOverallPassFail" label="Transmission"/>
		</Column>
	  </TestResultsBlock>

	</ReportLayout>
  

 </RtReportConfig>


