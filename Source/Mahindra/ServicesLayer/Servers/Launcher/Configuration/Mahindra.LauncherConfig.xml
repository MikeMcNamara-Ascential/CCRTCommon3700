            AddressValue="" PortValue="" VerboseMode="">Test Result Server</TestResultServer>

        <MachineDataBroker Name="MachineDataBroker.qxe" Path="/ServicesLayer/Bin/" 
            ConfigFile="MachineDataBrokerConfig.xml" ConfigPath="/Configuration/Servers/" 
            OrderToLaunch="0103" RegisteredName="core/MachineDataBroker" Register="Yes" DemoMode="Off" ConsoleMode="Off" 
            AddressValue="" PortValue="" VerboseMode="">Machine Data Broker</MachineDataBroker>

        <VehicleDataBroker Name="VehicleDataBroker.qxe" Path="/ServicesLayer/Bin/" 
