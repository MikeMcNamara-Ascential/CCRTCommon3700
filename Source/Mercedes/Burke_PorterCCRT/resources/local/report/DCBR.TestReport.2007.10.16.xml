<?xml version="1.0"?>
<!DOCTYPE RtReportConfig SYSTEM "resource:///com/bepco/rtc/report/rtreportconfig.dtd">

<RtReportConfig>
    <ReportLayout>
        <Title>Relatorio de Teste</Title>
        <TestIdBlock>
            <Column>
                <ServerTag tagname="DriverNumber" label="Nr.de Producao"/>
                <ServerTag tagname="ProductionNumber" label=""/>
                <ServerTag tagname="VehicleProgram" label="Programa Aplicado"/>
                <Timestamp/>
            </Column>
        </TestIdBlock>
        <TestResultsBlock>
            <Column>
                <TestProcess showdetail="failures" tagname="TachographOverallTest" label="Teste de Tacografo"/>
                <TestProcess showdetail="failures" tagname="EmissionsOverallTest" label="Teste de Torque"/>
                <TestProcess showdetail="failures" tagname="BrakeOverallTest" label="Teste de Freio"/>
                <TestProcess showdetail="failures" tagname="BrakeAnalyzeParkBrake" label="Freio de Estacionamento"/>
                <TestProcess showdetail="failures" tagname="TransmissionAccelerateInReverse" label="Marcha a Re"/>
                <TestProcess showdetail="failures" tagname="AxleOverallTest" label="Bloqueio de Eixo"/>
                <TestProcess showdetail="failures" tagname="MachineDriverPassFail" label="Interpretacao do Operador"/>
            </Column>
        </TestResultsBlock>

    </ReportLayout>

</RtReportConfig>



