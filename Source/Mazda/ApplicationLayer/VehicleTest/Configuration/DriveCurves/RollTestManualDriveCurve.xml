<DriveCurve Description="Mazda Roll Test drive curve">

    <Components Debug="Off">
        <Machine>
            <ComponentName>MazdaMachineTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
            <ConfigFile>MachineTC.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine</ConfigPath>
        </Machine>

        <Transmission>
            <ComponentName>MazdaTransTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
            <ConfigFile>MazdaManualTransmissionConfig.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Transmission</ConfigPath>
        </Transmission>
    </Components>

    <Test Result="Not Tested" Debug="Off">
        <TestPhase000 Description="Setup the system for testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Setup machine" Result="" Timeout="" Component="Machine">
                    <Initialize/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>
        
        <TestPhase010 Description="Setup the machine for testing: cable connect, start button etc" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Machine setup" Result="" Timeout="" Component="Machine">
                    <MachineStartup/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase010>
        
        <TestPhase020 Description="Perform forward gear / speed prompting" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Perform forward gear / speed prompting" Result="" Timeout="" Component="Transmission">
                    <FollowDriveCurve/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase020>

        <TestPhase030 Description="Reverse Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Reverse Test" Result="" Timeout="" Component="Transmission">
                    <ReverseTesting/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase030>

        <TestPhase040 Description="Brake to stop at the end of the cycle" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase040>

        <TestPhase050 Description="Rain / Light sensor operator verification" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Rain / Light sensor operator verification" Result="" Timeout="" Component="Machine">
                    <RainLightSensorVerification/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase050>

        <TestPhase060 Description="Final checks and operator pass / fail" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="FinishUp" Result="" Timeout="" Component="Transmission">
                    <FinishUp/>
                </Objective0>
                <Objective1 Description="Operator prompt and release vehicle" Result="" Timeout="" Component="Machine">
                    <FinishUp/>
                </Objective1>
            </ForegroundObjectives>
        </TestPhase060>

    </Test>

</DriveCurve>
