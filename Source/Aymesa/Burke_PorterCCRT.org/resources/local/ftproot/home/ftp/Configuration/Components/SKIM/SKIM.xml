<SKIMComponent>
   <Setup>
      <Name>SKIM</Name>
      <Debug>Off</Debug>
      <ProcessPriority>11</ProcessPriority>
      <ThreadPool>
         <Debug>Off</Debug>
         <MinBlockedLimit>2</MinBlockedLimit>
         <MaxBlockedLimit>4</MaxBlockedLimit>
         <Increment>2</Increment>
         <Maximum>50</Maximum>
      </ThreadPool>
      <NotificationList>
         <Setup>
            <Debug>Off</Debug>
            <StartOnCreate>Off</StartOnCreate>
            <LowWater>1</LowWater>
            <HighWater>3</HighWater>
            <Maximum>5</Maximum>
            <Increment>1</Increment>
         </Setup>
      </NotificationList>
      <Communication>
         <Comm>IPC</Comm>
         <Type>Server</Type>
         <Name>component/SKIM</Name>
         <Debug>Off</Debug>
         <BufferSize>1024</BufferSize>
         <Timeout>0</Timeout>
      </Communication>
      <TagList>
         <SubscribeTags>
            <SentryKeyImmobilizer/>
            <VIN/>
            <SKIMPin/>
            <ZerospeedToPLC/>
            <Abort/>
            <ForegroundTestInProgress/>
            <TestInProgress/>
            <EngineRPM/>
         </SubscribeTags>
      </TagList>
      <Logging>
         <Status>Enabled</Status>
         <ProcessName>SKIM</ProcessName>
         <AdditionalLogFile Types="/Component/SKIMTestComponent or Disabled">/Component/SKIM</AdditionalLogFile>
         <Debug>On</Debug>
         <LocalEcho>Disabled</LocalEcho>
         <Verbose>0x3F</Verbose>
      </Logging>
      <NamedDataBrokerComm>
         <Comm>IPC</Comm>
         <Type>Client</Type>
         <Name>core/NamedDataBroker</Name>
         <Debug>Off</Debug>
         <Timeout>0</Timeout>
         <BufferSize>1024</BufferSize>
      </NamedDataBrokerComm>
      <DataTags>
         <OverallTest>OverallTest</OverallTest>
         <Zerospeed>ZerospeedToPLC</Zerospeed>
         <SentryKeyImmobilizer>SentryKeyImmobilizer</SentryKeyImmobilizer>
         <VIN>VIN</VIN>
         <EngineRPM>EngineRPM</EngineRPM>
         <SKIMPin>SKIMPin</SKIMPin>
         <EMSStatus>EMSStatus</EMSStatus>
         <SecuredAccessRequest>SecuredAccessRequest</SecuredAccessRequest>
         <CountryCode>CountryCode</CountryCode>
         <ModuleDTCs>ModuleDTCs</ModuleDTCs>
         <Abort>Abort</Abort>
         <PromptBox1>PromptBox1</PromptBox1>
         <PromptBox2>PromptBox2</PromptBox2>
         <ForegroundTestInProgress>ForegroundTestInProgress</ForegroundTestInProgress>
         <TestInProgress>TestInProgress</TestInProgress>
         <SKIMJ1850>SKIM J1850</SKIMJ1850>
         <BUXJ1850>BUX J1850</BUXJ1850>
      </DataTags>
      <Parameters>
         <Retries>3</Retries>
         <CountryCodePID>0x2804</CountryCodePID>
         <ForceZeroSpeed>0</ForceZeroSpeed>
         <EngineONPrompt>KeyOn</EngineONPrompt>
         <EngineONPromptBox>1</EngineONPromptBox>
         <StopPromptBox>2</StopPromptBox>
         <StopPrompt>BrakeToStop</StopPrompt>
         <J2190ConfigFile>/Configuration/Components/SKIM/SKIMProtocol.xml</J2190ConfigFile>
         <J2190EngineInfoConfigFile>/Configuration/Components/Utility/EngineInformationProtocol.xml</J2190EngineInfoConfigFile>
         <J2190Port>AvtJ2190</J2190Port>
      </Parameters>
      <Faults>
         <Timeout Code="" Description="Communication timed out waiting for response from module">Communication timed out waiting for response from module</Timeout>
         <NegativeResponse Code="" Description="Modlule sent negative response">Modlule sent negative response</NegativeResponse>
         <SoftwareFail Code="0000" Description="Communication library returned J2190_STTS_SFTWR_FAIL">Communication library returned J2190_STTS_SFTWR_FAIL</SoftwareFail>
         <NoAck Code="2B0B" Description="No acknowledgement from hardware">No acknowledgement from hardware</NoAck>
         <Fault0x2800 Code="2800" Description="SKIM module failure">SKIM module failure</Fault0x2800>
         <VerifyModuleTypeFault Code="2801" Description="Country code does not match braodcast">Country code does not match braodcast</VerifyModuleTypeFault>
         <RecordModuleFaultsFault Code="2802" Description="Read Diagnostic Faults">Read Diagnostic Faults</RecordModuleFaultsFault>
         <RecordTraceabilityCode Code="2803" Description="Read tracability code">Read tracability code</RecordTraceabilityCode>
         <ReadVINFault Code="2804" Description="VIN read fault">VIN read fault</ReadVINFault>
         <SKIMPINFault Code="2805" Description="Verifying SKIM PIN number">Verifying SKIM PIN number</SKIMPINFault>
         <SecurityLevel Code="2806" Description="Security level not suported">Security level not suported</SecurityLevel>
         <Conditions Code="2807" Description="Conditions not correct for operation">Conditions not correct for operation</Conditions>
         <AntiScanLockout Code="2808" Description="Access denied, anti-scan lockout active">Access denied, anti-scan lockout active</AntiScanLockout>
         <InvalidPIN Code="2809" Description="ACCESS DENIED, INVALID PIN">ACCESS DENIED, INVALID PIN</InvalidPIN>
         <AntennaFault Code="2810" Description="DTC ANTENNA FAILURE" Mask="0x01">DTC ANTENNA FAILURE</AntennaFault>
         <TransponderCommFault Code="2811" Description="DTC TRANSPONDER COMM. FAILURE">DTC TRANSPONDER COMM. FAILURE</TransponderCommFault>
         <TransponderCRCFault Code="2812" Description="DTC TRANSPONDER CRC FAILURE">DTC TRANSPONDER CRC FAILURE</TransponderCRCFault>
         <TransponderIDFault Code="2813" Description="DTC TRANSPONDER ID MISMATCH">DTC TRANSPONDER ID MISMATCH</TransponderIDFault>
         <LowVoltageFault Code="2814" Description="DTC LOW VOLTAGE DETECT">DTC LOW VOLTAGE DETECT</LowVoltageFault>
         <SerialLinkInternalFault Code="2815" Description="DTC SERIAL LINK INTERNAL FAILURE">DTC SERIAL LINK INTERNAL FAILURE</SerialLinkInternalFault>
         <SerialLinkExternalFault Code="2816" Description="DTC SERIAL LINK EXTERNAL FAILURE">DTC SERIAL LINK EXTERNAL FAILURE</SerialLinkExternalFault>
         <EMSStatusFault Code="2817" Description="DTC EMS STATUS FAILURE">DTC EMS STATUS FAILURE</EMSStatusFault>
         <TransponderMismatchFault Code="2820" Description="DTC TRANSPONDER RESPONSE MISMATCH">DTC TRANSPONDER RESPONSE MISMATCH</TransponderMismatchFault>
         <VINMismatchFault Code="2821" Description="DTC VIN MISMATCH">DTC VIN MISMATCH</VINMismatchFault>
         <ROMFailure Code="2822" Description="DTC ROM FAILURE">DTC ROM FAILURE</ROMFailure>
         <EEPROMFailure Code="2823" Description="DTC EEPROM FAILURE">DTC EEPROM FAILURE</EEPROMFailure>
         <RAMFailure Code="2824" Description="DTC RAM FAILURE">DTC RAM FAILURE</RAMFailure>
         <COPFailure Code="2825" Description="DTC COP FAILURE">DTC COP FAILURE</COPFailure>
         <StackOverflowFault Code="2826" Description="DTC STACK OVERFLOW FAILURE">DTC STACK OVERFLOW FAILURE</StackOverflowFault>
         <RollingCodeFault Code="2827" Description="DTC ROLLING CODE FAILURE">DTC ROLLING CODE FAILURE</RollingCodeFault>
         <SKIMFaultNumKeys Code="280A" Description="WRONG NUMBER OF KEYS PROGD">WRONG NUMBER OF KEYS PROGD</SKIMFaultNumKeys>
         <Fault0x28F1 Code="28F1" Description="CANNOT EXIT DIAGNOSTICS MODE">CANNOT EXIT DIAGNOSTICS MODE</Fault0x28F1>
         <Fault0x28F2 Code="28F2" Description="CANNOT ENTER DIAGNOSTICS MODE">CANNOT ENTER DIAGNOSTICS MODE</Fault0x28F2>
         <Fault0x28F3 Code="28F3" Description="MODULE GAVE BUSY RESPONSE">MODULE GAVE BUSY RESPONSE</Fault0x28F3>
         <Fault0x28F4 Code="28F4" Description="UNDEFINED">UNDEFINED</Fault0x28F4>
         <Fault0x28F5 Code="28F5" Description="CONDITIONS NOT CORRECT FOR COMMAND">CONDITIONS NOT CORRECT FOR COMMAND</Fault0x28F5>
         <SKIMNoCommFault Code="28F6" Description="Module unplugged or not communicating">Module unplugged or not communicating</SKIMNoCommFault>
         <SKIMNotResponding Code="28F7" Description="J1850 BUS OR J2190 MODULE NOT RESPONDING">J1850 BUS OR J2190 MODULE NOT RESPONDING</SKIMNotResponding>
         <Fault0x28F8 Code="28F8" Description="CANNOT INITIALIZE J1850 MODULE">CANNOT INITIALIZE J1850 MODULE</Fault0x28F8>
      </Faults>
      <FaultPIDInformation Note="Type in Bit definitions are: Reserved=Reserved for future use, Unused=Not reserved but currently not defined, NotUsed=Not used on current car line, Internal=Internal fult code, External=Not an internal fault code">
         <ModuleTypes Description="This is the node whose children is saved in initialization">
            <Type0 Description="" Protocol="" Manufacturer="0x01">
               <SummaryFaultLocations>
                  <Location00 PID="0x2E00">
                     <Responses>
                        <Byte00>
                           <Bit00 Mask="0x01" PID="0x0000" Type="External" Fault="AntennaFault"/>
                           <Bit01 Mask="0x02" PID="0x0000" Type="External" Fault="TransponderCommFault"/>
                           <Bit02 Mask="0x04" PID="0x0000" Type="External" Fault="TransponderCRCFault"/>
                           <Bit03 Mask="0x08" PID="0x0000" Type="External" Fault="TransponderIDFault"/>
                           <Bit04 Mask="0x10" PID="0x0000" Type="External" Fault="LowVoltageFault"/>
                           <Bit05 Mask="0x20" PID="0x0000" Type="External" Fault="SerialLinkInternalFault"/>
                           <Bit06 Mask="0x40" PID="0x0000" Type="External" Fault="SerialLinkExternalFault"/>
                           <Bit07 Mask="0x80" PID="0x0000" Type="External" Fault="EMSStatusFault"/>
                        </Byte00>
                        <Byte01>
                           <Bit00 Mask="0x01" PID="0x0000" Type="Internal" Fault="TransponderMismatchFault"/>
                           <Bit01 Mask="0x02" PID="0x0000" Type="Internal" Fault="VINMismatchFault"/>
                           <Bit02 Mask="0x04" PID="0x0000" Type="Internal" Fault="ROMFailure"/>
                           <Bit03 Mask="0x08" PID="0x0000" Type="Internal" Fault="EEPROMFailure"/>
                           <Bit04 Mask="0x10" PID="0x0000" Type="Internal" Fault="RAMFailure"/>
                           <Bit05 Mask="0x20" PID="0x0000" Type="Internal" Fault="COPFailure"/>
                           <Bit06 Mask="0x40" PID="0x0000" Type="Internal" Fault="StackOverflowFault"/>
                           <Bit07 Mask="0x80" PID="0x0000" Type="Internal" Fault="RollingCodeFault"/>
                        </Byte01>
                     </Responses>
                  </Location00>
               </SummaryFaultLocations>
            </Type0>
         </ModuleTypes>
      </FaultPIDInformation>
      <DebugLevel>0</DebugLevel>
      <ValidSKIMTypes>
         <BUXJ1850 Type="BUX J1850" Description="BUX skim">0x14</BUXJ1850>
         <SKIMJ1850 Type="SKIM J1850" Description="US skim">0x00</SKIMJ1850>
      </ValidSKIMTypes>
   </Setup>
   <Objectives>
      <TestMode>
         <TestStep0>InitTest</TestStep0>
         <TestStep1>VerifyModuleType</TestStep1>
         <TestStep2>RecordModuleFaults</TestStep2>
         <TestStep3>RecordTraceabilityCode</TestStep3>
         <TestStep999>FinishUp</TestStep999>
      </TestMode>
      <SKIM>
         <TestStep0>InitTest</TestStep0>
         <TestStep1>VerifyModuleType</TestStep1>
         <TestStep2>RecordModuleFaults</TestStep2>
         <TestStep3>RecordTraceabilityCode</TestStep3>
         <TestStep4>CommandSecurityUnlock</TestStep4>
         <TestStep5>VerifyKeyCount</TestStep5>
         <TestStep999>FinishUp</TestStep999>
      </SKIM>
      <TestStepInitTest>
         <TestStep0>InitTest</TestStep0>
      </TestStepInitTest>
      <TestStepVerifyModuleType>
         <TestStep0>VerifyModuleType</TestStep0>
      </TestStepVerifyModuleType>
      <TestStepRecordModuleFaults>
         <TestStep0>RecordModuleFaults</TestStep0>
      </TestStepRecordModuleFaults>
      <TestStepRecordTraceabilityCode>
         <TestStep0>RecordTraceabilityCode</TestStep0>
      </TestStepRecordTraceabilityCode>
      <TestStepCommandSecurityUnlock>
         <TestStep0>CommandSecurityUnlock</TestStep0>
      </TestStepCommandSecurityUnlock>
      <TestStepVerifyKeyCount>
         <TestStep0>VerifyKeyCount</TestStep0>
      </TestStepVerifyKeyCount>
      <TestStepFinishUp>
         <TestStep0>FinishUp</TestStep0>
      </TestStepFinishUp>
   </Objectives>
   <TestSteps>
      <InitTest Result="Not Tested" Timeout="10000" Description="Initialize tests"/>
      <EngineOn Result="" Timeout="10000" Description="Prompt driver to start vehicle"/>
      <VerifyModuleType Result="Not Tested" Timeout="10000" Description="Verify Module Type (Country Code)"/>
      <RecordModuleFaults Result="Not Tested" Timeout="10000" Description="Read Module Faults" FaultPID="0x2E00" Manufacturer="0x01"/>
      <RecordTraceabilityCode Result="Not Tested" Timeout="10000" ForceZeroSpeed="0" Description="Record Traceability Code"/>
      <CommandSecurityUnlock Result="Not Tested" Timeout="10000" Description="Command Security Unlock (Use Broadcast PIN)" PromptBox1="KeyOff" Prompt1Priority="1" PromptBox2="" Prompt2Priority="" RunningRPM="500"/>
      <VerifyKeyCount Result="Not Tested" Timeout="10000" Description="Verify Key Count (Production = 2)" KeysExpected="2" BypassFailure="0"/>
      <FinishUp Result="Not Tested" Timeout="10000" Description="Clean up and set status."/>
   </TestSteps>
   <UnusedTestSteps>
      <VerifyVIN Result="Not Tested" Timeout="10000" Description="Verify VIN"/>
      <VerifyValidKey Result="Not Tested" Timeout="10000" Description="Verify Valid Key (OBSOLETE)"/>
   </UnusedTestSteps>
</SKIMComponent>
