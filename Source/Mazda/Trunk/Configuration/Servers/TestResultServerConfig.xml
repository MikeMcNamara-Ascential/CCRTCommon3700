<TestResultServerConfig>
    <Setup>
        <AddForceArray Value="Yes or No">Yes</AddForceArray>
        <AddSpeedArray Value="Yes or No">Yes</AddSpeedArray>
        <SpeedArrayPath>/TestResults/Machine/BrakeForceData/Speed1.log</SpeedArrayPath>
        <ForceArrayPath>/TestResults/Machine/BrakeForceData/BrakeForce1.log</ForceArrayPath>
        <ImportCcrtCommServerResults>Yes</ImportCcrtCommServerResults>
        <Debug>Off</Debug>
        <IncludeAbortInAllFailures Value="Yes or No">Yes</IncludeAbortInAllFailures>
        <VINLength>8</VINLength>
        <UpdateTestLampStatus Value="Yes or No">No</UpdateTestLampStatus>
        <FaultAlarm>
            <EnableFaultAlarm>Yes</EnableFaultAlarm>
            <FaultAlarmDuration Units="ms">3000</FaultAlarmDuration>
        </FaultAlarm>
        <TestCompleteSignal>
            <SignalTestComplete>Yes</SignalTestComplete>
            <TestCompleteSignalDuration Units="ms">500</TestCompleteSignalDuration>
        </TestCompleteSignal>
        <Communication>
            <Comm>IPC</Comm>
            <Debug>Off</Debug>
            <Name>core/TestResultServer</Name>
            <BufferSize>2000</BufferSize>
            <Timeout>1000</Timeout>
            <Type>Server</Type>
        </Communication>
        <DataTags>
            <AllFailures>AllFailures</AllFailures>
            <ClearScrollBox>ClearScrollBox</ClearScrollBox>
            <DriveCurve>DriveCurve</DriveCurve>
            <DriverNumber>DriverNumber</DriverNumber>
            <FailureAlarmTag>DriversFaultSignal</FailureAlarmTag>
            <KeyPress>KeyPress</KeyPress>
            <OverallTest>OverallTest</OverallTest>
            <StartTest>StartVehicleTest</StartTest>
            <TestCompleteSignalTag>CompleteLamp</TestCompleteSignalTag>
            <VehicleBuild>VehicleBuild</VehicleBuild>
            <Vin>AON</Vin>
        </DataTags>
        <Logging>
            <Debug>Off</Debug>
            <AdditionalLogFile>/Servers/TestResultServer.log</AdditionalLogFile>
            <ProcessName>core/TestResultServer</ProcessName>
            <Status>Enabled</Status>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <TagList>
            <SubscribeTags>
                <StartVehicleTest/>
                <StartLossCompensation/>
                <OverallTest/>
                <VehicleBuild/>
                <DriverNumber/>
                <VIN/>
                <Aon/>
                <DriveCurve/>
                <KeyPress/>
                <CycleTime/>
            </SubscribeTags>
        </TagList>
        <VehicleBuildItems>
            <DriveCurve/>
            <CycleTime/>
        </VehicleBuildItems>
        <TestResults>
            <TestResultPath>/TestResults/Vehicle/</TestResultPath>
            <TestResultFile>TestResultIndex</TestResultFile>
            <NumberOfTests>1000</NumberOfTests>
        </TestResults>
        <ThreadPool>
            <Debug>Off</Debug>
            <Increment>2</Increment>
            <MaxBlockedLimit>7</MaxBlockedLimit>
            <Maximum>10</Maximum>
            <MinBlockedLimit>2</MinBlockedLimit>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
    </Setup>
</TestResultServerConfig>
