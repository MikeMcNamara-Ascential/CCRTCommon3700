<HydraulicMotorController>
  <Setup>
    <Debug>Off</Debug>
    <ProcessPriority>10</ProcessPriority>
    <ClutchOnZeroSpeed>No</ClutchOnZeroSpeed>
    <DefaultDriveAxle>Front</DefaultDriveAxle>
    <ThreadPool>
      <Debug>Off</Debug>
      <MinBlockedLimit>2</MinBlockedLimit>
      <MaxBlockedLimit>4</MaxBlockedLimit>
      <Increment>2</Increment>
      <Maximum>50</Maximum>
    </ThreadPool>
    <NotificationList>
      <Setup>
        <Debug>Off</Debug>
        <HighWater>3</HighWater>
        <Increment>1</Increment>
        <LowWater>1</LowWater>
        <Maximum>5</Maximum>
        <StartOnCreate>No</StartOnCreate>
      </Setup>
    </NotificationList>
    <Communication>
      <Comm>IPC</Comm>
      <Type>Server</Type>
      <Name>core/MotorController</Name>
      <Debug>Off</Debug>
      <Timeout>0</Timeout>
      <BufferSize>1024</BufferSize>
    </Communication>
    <TagList>
      <SubscribeTags>
        <SimulatorSwitchStatus/>
        <LossCompensationSwitchStatusFromPLC/>
        <ZerospeedToPLC/>
        <Clutch/>
        <Declutch/>
        <Boost/>
        <RollsUpElevDown/>
        <DriveAxle/>
        <VehiclePresent/>
        <LeftFrontRollerDirection/>
        <RightFrontRollerDirection/>
        <LeftRearRollerDirection/>
        <RightRearRollerDirection/>
        <HydraulicCirculationMotorOvercurrent/>
        <HydraulicIntakeFilterBlocked/>
        <HydraulicMotorDisconnectOpen/>
        <HydraulicMotorOvercurrent/>
        <HydraulicMotorOverloadOpen/>
        <HydraulicOilCircPumpDiscOpen/>
        <HydraulicOilCircPumpOverloadOpen/>
        <HydraulicOilCoolingFanOvercurrent/>
        <HydraulicOilHeatExFanDiscOpen/>
        <HydraulicOilHeatExFanOverloadOpen/>
        <HydraulicOilLevelFault/>
        <HydraulicOilTemperatureFault/>
        <HydraulicSystemIdleTimeout/>
        <FrontHydraulicClutchEngagedFault/>
        <ReflectedVmeHeartBeat/>
        <MachineType3600/>
        <MotorControllerTaskHeartbeat/>
        <RollerCount/>
      </SubscribeTags>
      <PublishTags>
        <MotorMode>Boost</MotorMode>
        <CommandSpeed>0</CommandSpeed>
        <CommandTorque>0</CommandTorque>
        <SpeedValue>0</SpeedValue>
      </PublishTags>
    </TagList>
    <Logging>
      <Status>Disabled</Status>
      <ProcessName>MotorController</ProcessName>
      <AdditionalLogFile Types="/Servers/MotorController.log or Disabled">/Servers/MotorController.log</AdditionalLogFile>
      <LocalEcho>Disabled</LocalEcho>
      <Verbose>0x0F</Verbose>
      <Debug>Off</Debug>
    </Logging>
    <MotorParameters>
      <AccelerationLoading>1.0</AccelerationLoading>
      <SpeedLoading>2.0</SpeedLoading>
      <MotorLoadingMinSpeed>3.0</MotorLoadingMinSpeed>
      <MotorLoadingMaxSpeed>30.0</MotorLoadingMaxSpeed>
      <DisableSpeedMatching>1</DisableSpeedMatching>
      <MPHToRPM>28.30612546</MPHToRPM>
      <BrakeDetectLimit>-3.0</BrakeDetectLimit>
      <BrakeClearLimit>1.0</BrakeClearLimit>
      <SpeedDeltaForBoost>2.0</SpeedDeltaForBoost>
      <ReverseBoost>0</ReverseBoost>
      <TransferCaseMode>0</TransferCaseMode>
      <UpdateInterval>250</UpdateInterval>
      <MinimumSpeedForBoost>2.0</MinimumSpeedForBoost>
      <HeartbeatSamplingInterval>100</HeartbeatSamplingInterval>
      <HeartbeatInterval>500</HeartbeatInterval>
      <CurrentSpeeds>/dev/Icm/Block/Speed1</CurrentSpeeds>
      <CurrentAccelerations>/dev/Icm/Block/Acceleration1</CurrentAccelerations>
      <RollCount>4</RollCount>
    </MotorParameters>
    <HeartBeatParameters>
      <Setup>
        <Logging>
          <Status>Disabled</Status>
          <ProcessName>MotorControllerHb</ProcessName>
          <AdditionalLogFile Types="/Servers/MotorControllerHb.log or Disabled">Disabled</AdditionalLogFile>
          <Debug>Off</Debug>
          <LocalEcho>Disabled</LocalEcho>
          <Verbose>0x00</Verbose>
        </Logging>
        <HeartbeatSamplingInterval Description="Amount of time beween samples of heartbeat data" Units="ms">100</HeartbeatSamplingInterval>
        <ReflectedHeartbeatTag Description="Tag updated by remote system (reflection of task heartbeat)">ReflectedVmeHeartBeat</ReflectedHeartbeatTag>
        <HeartbeatTag Description="Task heartbeat tag">MotorControllerTaskHeartbeat</HeartbeatTag>
        <EnableNdbCommDebugging Description="If diagnostic information should be printed for communication for heatrbeat">0</EnableNdbCommDebugging>
      </Setup>
    </HeartBeatParameters>
    <HydraulicMotorParameters>
      <MinimumBoostPressure>600.0</MinimumBoostPressure>
      <MaximumBoostPressure>800.0</MaximumBoostPressure>
      <BoostPressure>600.0</BoostPressure>
      <PSIConversion>4.095</PSIConversion>
      <Boost>Boost</Boost>
    </HydraulicMotorParameters>
    <DataTags>
      <MachineType>MachineType3600</MachineType>
    </DataTags>
    <Faults>
      <HydraulicCirculationMotorOvercurrent PreviousState="-1">System Detected a HydraulicCirculationMotorOvercurrent Fault</HydraulicCirculationMotorOvercurrent>
    </Faults>
  </Setup>
</HydraulicMotorController>
