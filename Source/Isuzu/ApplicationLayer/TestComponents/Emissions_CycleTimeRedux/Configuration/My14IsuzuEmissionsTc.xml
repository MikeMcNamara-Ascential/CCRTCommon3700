<IsuzuEmissionsTc>
    <Setup>
        <Debug>Off</Debug>
        <Name>Emissions</Name>
        <TestDomain>Foreground</TestDomain>
        <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
        <Communication>
            <Debug>Off</Debug>
            <Type>Server</Type>
            <Comm>IPC</Comm>
            <Name>component/IsuzuEmissions</Name>
            <BufferSize>1024</BufferSize>
            <Timeout>2000</Timeout>
        </Communication>
        <TagList>
            <SubscribeTags>
                <Abort/>
                <CableConnect/>
                <PCMPartNo/>
                <VIN/>
                <Zerospeed/>
                <PCMSoftwareModule06PartNo/>
                <PCMSoftwareModule10PartNo/>
                <PCMSoftwareModule05PartNo/>
                <PCMSoftwareModule03PartNo/>
                <PCMSoftwareModule02PartNo/>
                <PCMSoftwareModule04PartNo/>
                <PCMSoftwareModule01PartNo/>
                <PCMSoftwareModule09PartNo/>
                <PCMUtilityFilePartNo/>
                <OverallTest/>
                <CurrentTestStatus/>
                <ESNLeadingCharacters/>
                <WriteESN/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>component/IsuzuEmissions</ProcessName>
            <AdditionalLogFile Types="/Components/NGC4KeywordEmissions or Disable">/Components/IsuzuEmissions.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <DataTags>
            <!-- Message Tags -->
            <EngineRunningMessage>ReadEngineIdleRPM</EngineRunningMessage>
            <ReadModulePartNumber>ReadPartNumber</ReadModulePartNumber>
            <ReadModuleVIN>ReadVIN</ReadModuleVIN>
            <!-- System Tags -->
            <EngineCoolantTemp>EngineOperatingTemp</EngineCoolantTemp>
            <ModulePartNumber>PCMPartNo</ModulePartNumber>
            <UseBypassPartNumberList TestSteps="CheckPartNumbers">UseBypassPartNumberList</UseBypassPartNumberList>
            <VehicleVIN>VIN</VehicleVIN>
            <!-- Static Tester Data Items -->
            <StaticTestResult>STTestResult</StaticTestResult>
            <StaticTesterName>core/StaticTesterServer</StaticTesterName>
            <StaticTesterServerName>StaticTesterServer</StaticTesterServerName>
            <!-- Oxygen Sensor Tags -->
            <OxygenSensor1Name>OxygenSensor1Bank1</OxygenSensor1Name>
            <OxygenSensor2Name>OxygenSensor2Bank1</OxygenSensor2Name>
            <OxygenSensor3Name>OxygenSensor1Bank2</OxygenSensor3Name>
            <OxygenSensor4Name>OxygenSensor2Bank2</OxygenSensor4Name>
        </DataTags>
        <Parameters>
            <!-- Test Component Behavior Parameters -->
            <AbortOnTestStepFailure>True</AbortOnTestStepFailure>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <DelayBeforeDtcRead>20000</DelayBeforeDtcRead>
            <DelayModuleInitialization>No</DelayModuleInitialization>
            <DeveloperTest>0</DeveloperTest>
            <ICMName>mgr/ICM</ICMName>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <KeepTestStatusOnExit>1</KeepTestStatusOnExit>
            <LoadStaticTestResults>False</LoadStaticTestResults>
            <!-- Module Parameters -->
            <ConfigFile>/Configuration/Components/Emissions/IsuzuEngineControllerModule.xml</ConfigFile>
            <!-- Diagnostic Mode Parameters -->
            <AlwaysEnterDiagnosticMode TestSteps="EnterDiagnosticMode" Comment="Enter diagnostic mode if module does not need to be tested">False</AlwaysEnterDiagnosticMode>
            <!-- DTC Parameters -->
            <AbortIfDTCPresent TestSteps="ReadFaultCount" Comment="Flag to determine if the test sequence will be aborted it DTCs are detected">False</AbortIfDTCPresent>
            <DtcStatusActiveBit>1</DtcStatusActiveBit>
            <DtcStatusHistoryBit>4</DtcStatusHistoryBit>
            <DtcStatusNotPassBit>2</DtcStatusNotPassBit>
            <ReportIgnoredFaults>False</ReportIgnoredFaults>
