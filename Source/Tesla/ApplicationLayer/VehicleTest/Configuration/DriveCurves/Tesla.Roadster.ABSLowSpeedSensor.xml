<DriveCurve Description="Drive Curve For The Roadster Test">
    <Components Debug="Off">
        <Brake>
            <ComponentName>TevesAbsTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>KwpIsoTevesAbsTc.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
            <Debug>Off</Debug>
        </Brake>
        <Machine>
            <ComponentName>MachineTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>MachineComponent.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
            <Debug>Off</Debug>
        </Machine>
    </Components>
    <Test Result="Overall Test result (Pass, Fail, Abort, ...)" Debug="Off">
        <TestPhase000 Description="Validate the driver numbrer" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Prompt the driver to input the driver number" Result="" Timeout="" Component="Machine">
                    <Initialize>DisableTractionControl</Initialize>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>
        <!-- ABS Static Testing -->
        <TestPhase100 Description="Prompt ABS testing in progress" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS static test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsStaticTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase100>
        <TestPhase110 Description="Initialize the test components" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Init Brake Component" Result="" Timeout="" Component="Brake">
                    <Setup/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase110>
        <TestPhase120 Description="Brake to stop" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase120>
        <TestPhase130 Description="Prompt ABS testing complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS static test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsStaticTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase130>
        <!-- ABS Low Speed Sensor Test -->
        <TestPhase200 Description="Prompt ABS low speed sensor test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS low speed sensor test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsLowSpeedSensorTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase200>
        <TestPhase210 Description="Low Speed ABS Sensor Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Brake">
                    <SensorTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase210>
        <TestPhase220 Description="Prompt ABS low speed sensor test complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS low speed sensor test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsLowSpeedSensorTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase220>
      <!-- Finish up processing -->
      <TestPhase999 Description="Finishup" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective1 Result="" Description="Perform module finish-up" Timeout="" Component="Machine">
                    <FinishUp>PerformingFinishUp</FinishUp>
                </Objective1>
                <Objective2 Result="" Description="Perform Brake finish-up" Timeout="" Component="Brake">
                    <FinishUp/>
                </Objective2>
            </ForegroundObjectives>
      </TestPhase999>
    </Test>
</DriveCurve>
