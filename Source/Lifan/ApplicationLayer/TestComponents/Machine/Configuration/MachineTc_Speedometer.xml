   <TestSteps>
      <Initialize Result="" Description="Initialize the machine for testing" Timeout="0"/>
      <DriverQuestion Description="Prompt the driver with a question and get a response of Pass/Fail or Yes/No">
         <CheckReverseLamps Result="" Timeout="30000" Description="Have operator shift to reverse and check lamps" Prompt1="ShiftToReverse" Prompt1Priority="0" Prompt2="CheckReverseLamps" Prompt2Priority="0" TestResultName="CheckReverseLamps"/>
         <DriverPassFail Result="" Timeout="30000" Prompt1="OverallPassOrFail" Prompt1Priority="0" TestResultName="DriverPassFail" Description="Driver test for overall pass or fail">Prompt the driver to enter the vehicle overall pass fail</DriverPassFail>
      </DriverQuestion>
      <PromptDriver Description="Display A Prompt To The Driver But Do Not Require Driver Input">
         <PerformingFinishUp Description="" Timeout="" Result="" Prompt1="PerformingFinishUp" Prompt1Priority="0"/>
         <InitializingVehicleModules Description="" Timeout="" Result="" Prompt1="Initialize" Prompt1Priority="0"/>
      </PromptDriver>
      <PromptDriverAlways Description="Display A Prompt To The Driver, Even On Retests, But Do Not Require Driver Input">
         <PerformingFinishUp Description="" Timeout="" Result="" Prompt1="PerformingFinishUp" Prompt1Priority="0"/>
         <PerformingFinalTesting Description="" Timeout="" Result="" Prompt1="PerformingFinalTesting" Prompt1Priority="0"/>
         <InitializingVehicleModules Description="" Timeout="" Result="" Prompt1="Initialize" Prompt1Priority="0"/>
      </PromptDriverAlways>
      <DriverNumber Result="" Description="Prompt the driver to input their ID and validate" Timeout="0" Prompt1="InputDriverID" Prompt1Priority="0" Validate="Skip" DriverNumberFile="/Configuration/Components/Machine/SampleDriverNumberList.xml" DefaultDriverNumber="T0000xx"/>
      <AccelerateToSpeed Result="" Description="Prompt the driver to accelerate to the commanded speed" Timeout="120000" Prompt1="AccelerateToTargetSpeed" Prompt1Priority="0"/>
      <BrakeToStop Result="" Description="Prompt the driver to brake to stop" Timeout="120000" Prompt1="BrakeToStop" Prompt1Priority="0"/>
      <QuickStop Result="" Description="Command the rollers to stop and verify that Zerospeed is achieved" Timeout="30000" Prompt1="BrakeToStop" Prompt1Priority="0" Prompt2="Blank" Prompt2Priority="0" SpeedTarget="0 0"/>
      <ConnectCable Result="" Description="Prompt the driver to connect the vehicle cable" Timeout="30000" Prompt1="ConnectCable" Prompt1Priority="0"/>
      <MachineReady Result="" Description="Wait until the machine is ready to perform a test" Timeout="15000" Prompt1="" Prompt1Priority="" Prompt2="" Prompt2Priority=""/>
      <DisableHydraulicPumpMotor Result="" Description="Turn off the hydraulic pump motor" PumpStatusChangeDelay="500" Timeout="1000"/>
      <EnableHydraulicPumpMotor Result="" Description="Turn off the hydraulic pump motor" PumpStatusChangeDelay="1000" Timeout="1000"/>
      <FinishUp Result="" Description="Machine Component FinishUp Test Step" Timeout="10000" Prompt1="PerformingFinishUp" Prompt1Priority="0"/>
      <AxleRatio Result="" Description="Four wheel drive Axle Ratio Test Step" Timeout="120000" SpeedTarget="20 30" TargetSpeed="25" AxleRatioMin="90.0" AxleRatioMax="105.0"/>
      <Speedometer Result="" Description="Speedometer Test Step" Timeout="30000" Prompt1="AccelerateToTargetSpeed" Prompt1Priority="0"/>
      <SelectDriverSide Result="" Description="Move the symbolic link for vehicle comms to proper side" Timeout="0" CommmonLogicalPort="/home/CCRT/Rewrite/GryphonCCan" LeftLogicalPort="/dev/LogicalPorts/GryphonCCanLeft" RightLogicalPort="/dev/LogicalPorts/GryphonCCanRight"/>
      <Reverse Result="" Description="Reverse Test Step" Timeout="30000"/>
      <MultiDriverQuestion Description="Prompt the driver with a set of questions and get a response of Pass/Fail or Yes/No">
         <MPBOStartControlMan TestResultName="MPBOStartControl">
            <Step01KeyOffShiftToNApplyParkBrake Result="" Timeout="60000" Prompt1="KeyOff" Prompt1Priority="0" Prompt2="ShiftToNeutralApplyParkBrake" Prompt2Priority="0" TestResultName="MPBOStartControl" Description="Driver Verifies can shift to park and apply park brake">Prompt the driver shift to park and apply parking brake</Step01KeyOffShiftToNApplyParkBrake>
            <Step02VerifyClutchStart Result="" Timeout="60000" Prompt1="ShiftTo1st" Prompt1Priority="0" Prompt2="VerifyClutchStart" Prompt2Priority="0" TestResultName="MPBOStartControl" Description="Driver verifies can not start until clutch engaged">Prompt the driver to verify can not start until clutch engaged</Step02VerifyClutchStart>
         </MPBOStartControlMan>
         <LampCheck TestResultName="OperatorLampCheck">
            <Step00_BrakeLamp Result="" Timeout="30000" Description="Verify brake lamps function" Prompt1="CheckBrakeLamps" Prompt1Priority="0" TestResultName="BrakeLampCheck"/>
            <Step05_LeftTurnSignal Result="" Timeout="30000" Description="Verify left turn signal lamp function" Prompt1="CheckLeftTurnSignal" Prompt1Priority="0" TestResultName="LeftTurnSignalLampCheck"/>
            <Step10_RightTurnSignal Result="" Timeout="30000" Description="Verify right turn signal lamp function" Prompt1="CheckRightTurnSignal" Prompt1Priority="0" TestResultName="RightTurnSignalLampCheck"/>
         </LampCheck>
      </MultiDriverQuestion>
      <DisengageMachine Result="" Description="Disengage the machine, clutchee, boost, etc." Timeout="1000"/>
      <EngageMachine Result="" Description="Engage the machine, clutches, boost, etc." Timeout="30000"/>
      <AccelerateToTestSpeed Result="" Timeout="10000" Description="Accelerate to test speed" TargetSpeedParameter="TargetSpeedParameter" SpeedRangeParameter="SpeedRangeParameter" ScanDelayParameter="ScanDelayParameter" Prompt1Value1="32"/>
      <MaintainSpeedForTime Result="" Description="Prompt the operator to accelerate to and maintain speed" Timeout="30000"/>
      <EnableMotorLoading Description="Apply a load to the drive axle of the vehicle" Result="" Timeout="2000"/>
      <DisableMotorLoading Description="Disable the loading of the drive axle of the vehicle" Result="" Timeout="2000"/>
      <ParkBrake Result="" Description="Park Brake Test Step (Calls The Appropriate Hydraulic or Electric TestStep" Timeout=""/>
      <ParkPawl Description="Park Pawl Test" Result="" Timeout=""/>
      <ParkBrakePawl Description="Combination Park Brake/Park Pawl Test" Result="" Timeout=""/>
      <AnalyzeParkBrake Result="" Timeout="10000" Description="Analyze the park brake test results"/>
      <AnalyzeParkPawl Result="" Timeout="10000" Description="Analyze the park pawl test results"/>
      <HydraulicParkBrake Result="" Description="Hydraulic Park Brake Test Step" Timeout="120000" Prompt1="ShiftToNeutralApplyParkBrake" Prompt1Priority="0" Prompt2="Blank" Prompt2Priority="0"/>
      <ElectricParkBrake Result="" Description="Electric Park Brake Test Step" Timeout="30000" Prompt1="ShiftToNeutralApplyParkBrake" Prompt1Priority="0" Prompt2="Blank" Prompt2Priority="0" RollerDirection="Front" TestTime="2000"/>
      <ReadMemoryStatistics Result="" Description="Read the current memory statistics" Timeout="10000"/>
   </TestSteps>
</MachineComponent>
