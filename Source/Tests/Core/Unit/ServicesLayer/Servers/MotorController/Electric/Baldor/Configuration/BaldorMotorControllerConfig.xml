            <RRRollMotorDriveCommFault/>
            <LFRollMotorOperationalFault/>
            <RFRollMotorOperationalFault/>
            <LRRollMotorOperationalFault/>
            <RRRollMotorOperationalFault/>
            <Start4WDTestSignalToPLC/>
            <MachineType3600/>
            <AllRollDrivesEnabled/>
            <EnableAllRollDrives/>
            <AllRollDrivesEnabled/>
            <LeftFrontRollMotorDriveFault/>
            <RightFrontRollMotorDriveFault/>
            <LeftRearRollMotorDriveFault/>
            <RightRearRollMotorDriveFault/>
            <PlcSystemIsReady/>
            <PowerSenseLostToIORack/>
            <MotorTaskHearbeatFault/>
            <MotorControllerTaskHeartbeat/>
            <ReflectedVmeHeartBeat/>
         </SubscribeTags>
         <PublishTags>
            <MotorMode>Boost</MotorMode>
            <CommandSpeed>0.0</CommandSpeed>
            <CommandTorque>0.0</CommandTorque>
            <SpeedValue>0.0</SpeedValue>
            <LeftFrontTorqueValue>0.0</LeftFrontTorqueValue>
            <RightFrontTorqueValue>0.0</RightFrontTorqueValue>
            <LeftRearTorqueValue>0.0</LeftRearTorqueValue>
            <RightRearTorqueValue>0.0</RightRearTorqueValue>
            <LeftFrontSpeedValue>0.0</LeftFrontSpeedValue>
            <RightFrontSpeedValue>0.0</RightFrontSpeedValue>
            <LeftRearSpeedValue>0.0</LeftRearSpeedValue>
            <RightRearSpeedValue>0.0</RightRearSpeedValue>
            <LeftFrontMotorMode>Boost</LeftFrontMotorMode>
            <RightFrontMotorMode>Boost</RightFrontMotorMode>
            <LeftRearMotorMode>Boost</LeftRearMotorMode>
            <RightRearMotorMode>Boost</RightRearMotorMode>
            <RollerCount>4</RollerCount>
         </PublishTags>
      </TagList>
      <Logging>
         <Status>Disabled</Status>
         <ProcessName>MotorController</ProcessName>
         <AdditionalLogFile Types="/Servers/MotorController.log or Disabled">/Servers/MotorController.log</AdditionalLogFile>
         <Debug>Off</Debug>
         <LocalEcho>Disabled</LocalEcho>
         <Verbose>0x0B</Verbose>
      </Logging>
      <MotorParameters>
         <BrakeDetectLimit Description="Accelleration value indicating that a roll is under excessive force (brakes probably applied)" Units="MPH/sec.">-30.0</BrakeDetectLimit>
         <BrakeClearLimit Description="Accelleration value indicating that a roll has stopped braking" Units="MPH/sec.">.01</BrakeClearLimit>
         <SpeedDeltaForBoost Description="Speed difference required to cause non-driven roll(s) to be commanded to follow master" Units="MPH">2.0</SpeedDeltaForBoost>
         <ReverseBoost Description="Whether or not to boost while in reverse 1=Boost in reverse, else do not boost in reverse">0</ReverseBoost>
         <UpdateInterval Description="Amount of time between commands (Main loop delay time)" Units="ms">250</UpdateInterval>
         <MinimumSpeedForBoost Description="Minimum speed master roll must acheive before boost is applied to non-driven rolls" Units="MPH">2.0</MinimumSpeedForBoost>
