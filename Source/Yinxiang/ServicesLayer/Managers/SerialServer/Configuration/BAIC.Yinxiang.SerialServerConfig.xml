<SerialServerConfig>
    <Verbose>0x1F</Verbose>
    <Setup>
        <Demo>0</Demo>
        <MgrPool lowWater="2" hiWater="5" maximum="10" increment="1"/>
        <Logging>
            <ProcessName>mgr/SerialServer</ProcessName>
            <AdditionalLogFile>/Servers/SerialServer.log</AdditionalLogFile>
            <Status>Enabled</Status>
            <LocalEcho>Disabled</LocalEcho>
            <Debug>Off</Debug>
            <Verbose>0x01</Verbose>
        </Logging>
        <LogicalPorts>

            <LeftScanner enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/sl7804/ser3</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
                    <Protocol>
                        <Baud>9600</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>Rx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/LeftScanner</ProcessName>
                        <AdditionalLogFile>LeftScannerComm.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>LeftScanner_Comm</ProcessName>
                                <AdditionalLogFile>LeftScanner_BusComm.log</AdditionalLogFile>
                                <Status>Disabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x09</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </LeftScanner>
            <RightScanner enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/sl7804/ser4</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
                    <Protocol>
                        <Baud>9600</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>Rx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/RightScanner</ProcessName>
                        <AdditionalLogFile>RightScannerComm.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>RightScanner_Comm</ProcessName>
                                <AdditionalLogFile>RightScanner_BusComm.log</AdditionalLogFile>
                                <Status>Disabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x09</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </RightScanner>

            <PlcRk512 enabled="0" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/ser1</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="35"/>
                    <Protocol>
                        <Baud>19200</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>TxRx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <Status>Disabled</Status>
                        <ProcessName>logport/PlcRk512</ProcessName>
                        <AdditionalLogFile>/Servers/PlcRk512.log</AdditionalLogFile>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>Rk512_Comm</ProcessName>
                                <AdditionalLogFile>/Communication/PlcRk512_Comm.log</AdditionalLogFile>
                                <Status>Disabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1f</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </PlcRk512>

            <GryphonCCan enabled="0" driver="$(USR_ROOT)/ServicesLayer/Bin/GryphonCANCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/socket</SerialDevice>
                    <MgrPool lowWater="2" hiWater="45" maximum="50" increment="2" priority="35"/>
                    <Protocol>
                        <Baud>19200</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>TxRx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/GryphonCAN</ProcessName>
                        <AdditionalLogFile>/Communication/GryphonCAN.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>CAN</ProcessName>
                                <AdditionalLogFile>/Communication/GryphonCANComm.log</AdditionalLogFile>
                                <Status>Enabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                    <Login>
                        <IPAddress>192.168.1.20</IPAddress>
                        <Port>7000</Port>
                        <UserID>gryphon</UserID>
                        <Password>gryphon</Password>
                    </Login>
                    <Alias>/home/CCRT/Rewrite/GryphonCCan</Alias>
                    <NodePairs>
                        <ABS Outgoing="0x702" Incoming="0x712"/>
                    </NodePairs>
                    <NodePairSetup>
                        <Range1 FirstRequestID="0x702" FirstResponseID="0x712" NumberOfPairs="1"/>
                    </NodePairSetup>
                </Setup>
            </GryphonCCan>

            <Host enabled="0" driver="$(USR_ROOT)/ServicesLayer/Bin/TcpCommProxy.qxe" relaunch="yes" needsReset="yes">
                <Setup>
                    <SerialDevice>/dev/socket</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
                    <IpAddress>192.168.10.10</IpAddress>
                    <!-- need to setup for hostname -->
                    <PortNo>10051</PortNo>
                    <TcpType>Client</TcpType>
                    <Protocol>
                        <Baud>19200</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>TxRx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/Host</ProcessName>
                        <AdditionalLogFile>/Communication/HostProxy.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>HostComm</ProcessName>
                                <AdditionalLogFile>/Communication/HostComm.log</AdditionalLogFile>
                                <Status>Enabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x3F</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </Host>
            <PlcDf1 enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
            <Setup>
               <!--
                    <SerialDevice>/dev/socket</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
                    <IpAddress>192.168.1.3</IpAddress>
                    <PortNo>44818</PortNo>
                    <TcpType>Client</TcpType>
                    -->
               <SerialDevice>/dev/ser1</SerialDevice>
               <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="35"/>
               <Protocol>
                  <Baud>19200</Baud>
                  <Parity>None</Parity>
                  <DataBits>8</DataBits>
                  <StopBits>1</StopBits>
                  <Reflection>0</Reflection>
                  <ByteGap>0</ByteGap>
                  <MssgGap>0</MssgGap>
                  <Interrupts>TxRx</Interrupts>
                  <FifoSize>1024</FifoSize>
               </Protocol>
               <Logging>
                  <ProcessName>logport/PlcDf1</ProcessName>
                  <AdditionalLogFile>/Servers/PlcDf1.log</AdditionalLogFile>
                  <Status>Disabled</Status>
                  <LocalEcho>Disabled</LocalEcho>
                  <Verbose>0x3F</Verbose>
               </Logging>
               <CommLog>
                  <ContentType>RAW</ContentType>
                  <Setup>
                     <Logging>
                        <ProcessName>DF1_Comm</ProcessName>
                        <AdditionalLogFile>/Communication/PlcDf1_Comm.log</AdditionalLogFile>
                        <Status>Disabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1f</Verbose>
                        <Debug>Off</Debug>
                     </Logging>
                  </Setup>
               </CommLog>
            </Setup>
         </PlcDf1>
        </LogicalPorts>
    </Setup>
</SerialServerConfig>
