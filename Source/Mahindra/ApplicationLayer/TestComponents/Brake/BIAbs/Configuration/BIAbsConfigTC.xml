<UdsBIAbsConfig>

    <Setup>
        <FaultList>/Configuration/Components/Brake/Tata.BrakeFaultList.xml</FaultList>

        <Prompts>
            <CableConnect PromptBox="1" Priority="0">CableDisconnected</CableConnect>
            <DepressBrake PromptBox="1" Priority="0">FootOnBrake</DepressBrake>
            <RemoveFootFromBrake PromptBox="2" Priority="0">FootOffBrake</RemoveFootFromBrake>
            <ShiftToNeutralMaintainBrake PromptBox="2" Priority="0">ShiftToNeutralMaintainBrake</ShiftToNeutralMaintainBrake>
            <TestingAbs PromptBox="1" Priority="0">TestingAbs</TestingAbs>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
            <LowSpeed_AbsNeutralPrompt PromptBox="1" Priority="0">ShiftToNeutral</LowSpeed_AbsNeutralPrompt>
            <NeutralPrompt PromptBox="1" Priority="0">ShiftToNeutral</NeutralPrompt>
        </Prompts>

        <StatusCheckItems>
            <RollsUpElevDown Comment="Must have retainers up to test anything">1</RollsUpElevDown>
        </StatusCheckItems>

        <Name>Brake</Name>
        <Debug>Off</Debug> 
        <CommunicationProtocol Default="KeywordProtocol2000 or KwpCAN">KwpCAN</CommunicationProtocol>
        <ICMName>mgr/ICM</ICMName>
        <CommunicationBus>CAN</CommunicationBus>

        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>50</Maximum>
        </ThreadPool>

        <Communication>
            <Comm>IPC</Comm>
            <Type>Server</Type>
            <Name>component/Brake</Name>
            <Debug>Off</Debug>
            <BufferSize>1024</BufferSize>
            <Timeout>0</Timeout>
        </Communication>

        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
            </Setup>
        </NotificationList>

        <TagList>
            <SubscribeTags>
                <CableConnect/>
                <Clutch/>
                <Declutch/>
                <DriveAxle/>
                <FrontAxleTestSelected/>
                <LiftAxleTestSelected/>
                <ModulePartNumber/>
                <MotorMode/>
                <NumberOfFrontAxles/>
                <NumberOfRearAxles/>
                <RollsUpElevDown/>
                <VehiclePresent/>
                <Zerospeed/>
            </SubscribeTags>
        </TagList>

        <Logging>
            <Status>Enabled</Status>
            <ProcessName>UdsBIAbsTC</ProcessName>
            <AdditionalLogFile Types="/Component/Generic or Disabled">/Components/UdsBIAbsTC.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>

        <NamedDataBrokerComm>
            <Comm>IPC</Comm>
            <Type>Client</Type>
            <Name>core/NamedDataBroker</Name>
            <Debug>Off</Debug>
            <Timeout>0</Timeout>
            <BufferSize>1024</BufferSize>
        </NamedDataBrokerComm>

        <DataTags>
            <Abort>Abort</Abort>
            <Boost>Boost</Boost>
            <BoostMode>Boost</BoostMode>
            <BrakeActive>BrakeActive</BrakeActive>
            <BrakeDomain>BrakeDomain</BrakeDomain>
            <BrakeForceValue>BrakeForceValue</BrakeForceValue>
            <BrakeTarget>BrakeTarget</BrakeTarget>
            <Clutch>Clutch</Clutch>
            <CommandTorque>CommandTorque</CommandTorque>
            <Declutch>Declutch</Declutch>
            <DriveAxle>DriveAxle</DriveAxle>
            <FrontAxleTestDriveAxle>None</FrontAxleTestDriveAxle>
            <FrontBalanceBGColor>FrontBalanceBGColor</FrontBalanceBGColor>
            <FrontBalanceTest>FrontBalanceTest</FrontBalanceTest>
            <FrontBalanceValue>FrontBalanceValue</FrontBalanceValue>
            <LeftFrontForceBGColor>LFForceBGColor</LeftFrontForceBGColor>
            <LeftFrontForceValue>LFForceValue</LeftFrontForceValue>
            <LeftRearForceBGColor>LRForceBGColor</LeftRearForceBGColor>
            <LeftRearForceValue>LRForceValue</LeftRearForceValue>
            <LeftFrontDragBGColor>LFDragBGColor</LeftFrontDragBGColor>
            <LeftFrontDragValue>LFDragValue</LeftFrontDragValue>
            <LeftRearDragBGColor>LRDragBGColor</LeftRearDragBGColor>
            <LeftRearDragValue>LRDragValue</LeftRearDragValue>
            <ModulePartNumber>ModulePartNumber</ModulePartNumber>
            <MotorMode>MotorMode</MotorMode>
            <PedalTransducerActiveTag>BrakeForceTransducerActive</PedalTransducerActiveTag>
            <PedalTransducerTarget>BrakeForceTransducerRange</PedalTransducerTarget>
            <ReadModuleFaults>UDSReadFaults</ReadModuleFaults>
            <ReadModulePartNumber>ReadPartNumber</ReadModulePartNumber>
            <ReadModuleVIN>ReadVIN</ReadModuleVIN>
            <RearBalanceBGColor>RearBalanceBGColor</RearBalanceBGColor>
            <RearBalanceTest>RearBalanceTest</RearBalanceTest>
            <RearBalanceValue>RearBalanceValue</RearBalanceValue>
            <RetainersUp>RollsUpElevDown</RetainersUp>
            <RightFrontDragBGColor>RFDragBGColor</RightFrontDragBGColor>
            <RightFrontDragValue>RFDragValue</RightFrontDragValue>
            <RightFrontForceBGColor>RFForceBGColor</RightFrontForceBGColor>
            <RightFrontForceValue>RFForceValue</RightFrontForceValue>
            <RightRearForceBGColor>RRForceBGColor</RightRearForceBGColor>
            <RightRearForceValue>RRForceValue</RightRearForceValue>
            <RightRearDragBGColor>RRDragBGColor</RightRearDragBGColor>
            <RightRearDragValue>RRDragValue</RightRearDragValue>
            <SpeedTarget>SpeedTarget</SpeedTarget>
            <TagIndex>TagIndex</TagIndex>
            <TestResultBox1>TestResultBox1</TestResultBox1>
            <TestResultBox2>TestResultBox2</TestResultBox2>
            <TestResultBox3>TestResultBox3</TestResultBox3>
            <TorqueMode>Torque</TorqueMode>
            <VehiclePresent>VehiclePresent</VehiclePresent>
            <Zerospeed>Zerospeed</Zerospeed>
            <!-- Vehicle Comm Bus Setup Tags -->
            <SelectIsoBusTag>IsoBusEnable</SelectIsoBusTag>
            <EnableCommBusTag>EnableCommBus</EnableCommBusTag>
            <ReadModuleVIN>ReadVIN</ReadModuleVIN>
            <ElectricMachineType>3700</ElectricMachineType>
        </DataTags>

        <SystemTagsToReset>
            <BrakeActive>0</BrakeActive>
            <FrontBalanceBGColor>white</FrontBalanceBGColor>
            <FrontBalanceValue>0</FrontBalanceValue>
            <FrontToRearBalanceBGColor>white</FrontToRearBalanceBGColor>
            <FrontToRearBalanceValue>0</FrontToRearBalanceValue>
            <LFABSRecoveryBGColor>white</LFABSRecoveryBGColor>
            <LFABSRecoveryValue>0</LFABSRecoveryValue>
            <LFABSReductionBGColor>white</LFABSReductionBGColor>
            <LFABSReductionValue>0</LFABSReductionValue>
            <LFDragBGColor>white</LFDragBGColor>
            <LFDragValue>0</LFDragValue>
            <LFForceBGColor>white</LFForceBGColor>
            <LFForceDomain>0 500</LFForceDomain>
            <LFForceTarget>200 400</LFForceTarget>
            <LFForceValue>0</LFForceValue>
            <LFTractionControlRecoveryBGColor>white</LFTractionControlRecoveryBGColor>
            <LFTractionControlRecoveryValue>0</LFTractionControlRecoveryValue>
            <LFTractionControlReductionBGColor>white</LFTractionControlReductionBGColor>
            <LFTractionControlReductionValue>0</LFTractionControlReductionValue>
            <LRABSRecoveryBGColor>white</LRABSRecoveryBGColor>
            <LRABSRecoveryValue>0</LRABSRecoveryValue>
            <LRABSReductionBGColor>white</LRABSReductionBGColor>
            <LRABSReductionValue>0</LRABSReductionValue>
            <LRDragBGColor>white</LRDragBGColor>
            <LRDragValue>0</LRDragValue>
            <LRForceBGColor>white</LRForceBGColor>
            <LRForceDomain>0 500</LRForceDomain>
            <LRForceTarget>200 400</LRForceTarget>
            <LRForceValue>0</LRForceValue>
            <LRTractionControlRecoveryBGColor>white</LRTractionControlRecoveryBGColor>
            <LRTractionControlRecoveryValue>0</LRTractionControlRecoveryValue>
            <LRTractionControlReductionBGColor>white</LRTractionControlReductionBGColor>
            <LRTractionControlReductionValue>0</LRTractionControlReductionValue>
            <RearBalanceBGColor>white</RearBalanceBGColor>
            <RearBalanceValue>0</RearBalanceValue>
            <RFABSRecoveryBGColor>white</RFABSRecoveryBGColor>
            <RFABSRecoveryValue>0</RFABSRecoveryValue>
            <RFABSReductionBGColor>white</RFABSReductionBGColor>
            <RFABSReductionValue>0</RFABSReductionValue>
            <RFDragBGColor>white</RFDragBGColor>
            <RFDragValue>0</RFDragValue>
            <RFForceBGColor>white</RFForceBGColor>
            <RFForceDomain>0 500</RFForceDomain>
            <RFForceTarget>200 400</RFForceTarget>
            <RFForceValue>0</RFForceValue>
            <RFTractionControlRecoveryBGColor>white</RFTractionControlRecoveryBGColor>
            <RFTractionControlRecoveryValue>0</RFTractionControlRecoveryValue>
            <RFTractionControlReductionBGColor>white</RFTractionControlReductionBGColor>
            <RFTractionControlReductionValue>0</RFTractionControlReductionValue>
            <RRABSRecoveryBGColor>white</RRABSRecoveryBGColor>
            <RRABSRecoveryValue>0</RRABSRecoveryValue>
            <RRABSReductionBGColor>white</RRABSReductionBGColor>
            <RRABSReductionValue>0</RRABSReductionValue>
            <RRDragBGColor>white</RRDragBGColor>
            <RRDragValue>0</RRDragValue>
            <RRForceBGColor>white</RRForceBGColor>
            <RRForceDomain>0 500</RRForceDomain>
            <RRForceTarget>200 400</RRForceTarget>
            <RRForceValue>0</RRForceValue>
            <RRTractionControlRecoveryBGColor>white</RRTractionControlRecoveryBGColor>
            <RRTractionControlRecoveryValue>0</RRTractionControlRecoveryValue>
            <RRTractionControlReductionBGColor>white</RRTractionControlReductionBGColor>
            <RRTractionControlReductionValue>0</RRTractionControlReductionValue>
            <TestResultBox1BGColor>white</TestResultBox1BGColor>
            <TestResultBox2BGColor>white</TestResultBox2BGColor>
            <TestResultBox3BGColor>white</TestResultBox3BGColor>
        </SystemTagsToReset>

        <Parameters>
            <!-- Component Behavior / Setup -->
            <WheelCount>4</WheelCount>
            <AbortIfDTCPresent>False</AbortIfDTCPresent>
            <AlwaysEnterDiagnosticMode>False</AlwaysEnterDiagnosticMode>     
            <AlwaysStartKeepAlive>False</AlwaysStartKeepAlive>
            <BypassPartNumberValidation>False</BypassPartNumberValidation>
            <ConfigFile>/Configuration/Components/Brake/UdsBIAbsProtocolConfig.xml</ConfigFile>
            <CurrentDistances>/dev/Icm/Block/PulseCount</CurrentDistances>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <DelayModuleInitialization>True</DelayModuleInitialization>
            <FrontAxleTestEnabled Description="Enable front axle test">True</FrontAxleTestEnabled>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <IgnoreMachineConditions>True</IgnoreMachineConditions>
            <SingleAxleMachine>True</SingleAxleMachine>
            <TandemAxleMachine Description="Flag to tell if we are testing on a tandem axle machine">True</TandemAxleMachine>
            <TestFrontAxlesIndependently>False</TestFrontAxlesIndependently>
            <ModulePartNumber>BBIA10CED2</ModulePartNumber>
            <ValidatePartNumberList>1</ValidatePartNumberList>
            <ValidPartNumbers>
                <PNBBIA10CED2>BBIA10CED2</PNBBIA10CED2>
            </ValidPartNumbers>

            <!-- Wheel speed sensor test -->
            <CheckWheelSpeedSensorVoltage>False</CheckWheelSpeedSensorVoltage>
            <MaximumSensorSpeed Descritpion="Maximum allowable sensor speed" Units="MPH">7.0</MaximumSensorSpeed>
            <MaxWheelSensorVoltageRatio>2.0</MaxWheelSensorVoltageRatio>
            <MinimumSensorSpeed Description="Minimum allowable sensor speed" Units="MPH">3.0</MinimumSensorSpeed>
            <SensorTestStartDelay Description="Amount of time to delay before starting the rolls for the sensor test" Units="mSec">3000</SensorTestStartDelay>
            <SensorTestSpeed Description="Roll speed for the sensor test" Units="MPH">5</SensorTestSpeed>

            <!-- ABS Valve Test -->
            <ABS4ChannelFiringSequence>
                <Wheel_1>LeftFront</Wheel_1>
                <Wheel_2>RightFront</Wheel_2>
            </ABS4ChannelFiringSequence>
            <LeftFrontRecoveryPulseLength Description="Duration to open inlet valve and close outlet valve during recovery" Units="ms">4000</LeftFrontRecoveryPulseLength>
            <LeftFrontReductionPulseLength Description="Duration to close inlet valve and open outlet valve during reduction" Units="ms">1500</LeftFrontReductionPulseLength>
            <LowSpeedAbs_LeftFrontTorque Description="Torque to apply to LF roller" Units="ft-lbs">-300</LowSpeedAbs_LeftFrontTorque>
            <LowSpeedAbs_PromptDelay Description="Delay before beginning ABS test" Units="ms">3000</LowSpeedAbs_PromptDelay>
            <LowSpeedAbs_ReductionCommandCount>1</LowSpeedAbs_ReductionCommandCount>
            <LowSpeedAbs_RightFrontTorque Description="Torque to apply to RF roller" Units="ft-lbs">-300</LowSpeedAbs_RightFrontTorque>
            <LowSpeedAbs_SafetyDelay Description="Delay before checking for runaways" Units="ms">2000</LowSpeedAbs_SafetyDelay>
            <LowSpeedAbs_SafetyMaxSpeed Description="Maximum allowable speed before flaging as a runaway" Units="mph">5</LowSpeedAbs_SafetyMaxSpeed>
            <LowSpeedAbs_WheelSpeedMinimum Description="Minimum speed indicating valve has reduced" Units="mph">1</LowSpeedAbs_WheelSpeedMinimum>
            <LowSpeedAbs_ZeroSpeedTolerance Description="Maximum speed considered zero" Units="mph">1</LowSpeedAbs_ZeroSpeedTolerance>
            <RightFrontRecoveryPulseLength Description="Duration to open inlet valve and close outlet valve during recovery" Units="ms">4000</RightFrontRecoveryPulseLength>
            <RightFrontReductionPulseLength Description="Duration to close inlet valve and open outlet valve during reduction" Units="ms">1500</RightFrontReductionPulseLength>
            <SendEnterDiagModeBeforeFiring>0</SendEnterDiagModeBeforeFiring>

            <!-- Drag Test Parameters -->
            <ArmSpeed Units="MPH">30</ArmSpeed>
            <DragDelay Units="ms">2000</DragDelay>
            <DragSamples>25</DragSamples>
            <DragSpeed Units="MPH">28</DragSpeed>
            <FrontMaxDragForce Units="lbs">300</FrontMaxDragForce>
            <IncludeDragInBrakeForce>False</IncludeDragInBrakeForce>
            <!--RearMaxDragForce Units="lbs">300</RearMaxDragForce-->

            <!-- Base Brake Parameters -->
            <BaseBrakeSampleCount Description="Number of base brake samples (at 100ms intervals) to use when calculating base brake forces">15</BaseBrakeSampleCount>
            <BrakeForceMultiplier>1.0</BrakeForceMultiplier>
            <DisplayBrakeMeterUntilZeroSpeed>True</DisplayBrakeMeterUntilZeroSpeed>
            <EndBrakeSampleSpeed Units="MPH">5</EndBrakeSampleSpeed>
            <FrontMaxBrakeForce Units="lbs">1100</FrontMaxBrakeForce>
            <FrontMinBrakeForce Units="lbs">200</FrontMinBrakeForce>
            <GetBrakeForcesFromBuildRecord>True</GetBrakeForcesFromBuildRecord>
            <MinimumStartForce Units="lbs">200</MinimumStartForce>
            <!--RearMaxBrakeForce Units="lbs">1100</RearMaxBrakeForce>
            <RearMinBrakeForce Units="lbs">125</RearMinBrakeForce-->
            <StartBrakeSampleSpeed Units="MPH">25</StartBrakeSampleSpeed>
            <StartSamplingAtMinimumForce>1</StartSamplingAtMinimumForce>

            <!-- Brake Pedal Parameters -->
            <MaxBrakePedalForce Units="LBF">10000</MaxBrakePedalForce>
            <MinBrakePedalForce Units="LBF">0</MinBrakePedalForce>
            <StoreBrakePedalForce>False</StoreBrakePedalForce>

            <!-- Brake Balance Parameters -->
            <BalanceFrontToRearMax Units="%">95</BalanceFrontToRearMax>
            <BalanceFrontToRearMin Units="%">5</BalanceFrontToRearMin>
            <BalanceTandemToRearMax Units="%">95</BalanceTandemToRearMax>
            <BalanceTandemToRearMin Units="%">5</BalanceTandemToRearMin>
            <DisplayBalanceDifference>False</DisplayBalanceDifference>
            <FrontSideToSideBalance Units="50%">17</FrontSideToSideBalance>
            <RearSideToSideBalance Units="50%">17</RearSideToSideBalance>
            <TandemSideToSideBalance Units="50%">17</TandemSideToSideBalance>

            <DeveloperTest>True</DeveloperTest>
            <BypassVINValidation>true</BypassVINValidation>
            <BypassPartNumberValidation>true</BypassPartNumberValidation>
            <ResetAxleAfterIndividualSensorTest>true</ResetAxleAfterIndividualSensorTest>
            <!-- ESP Valve Firing Parameters -->
            <CheckESPValvesCrossed>False</CheckESPValvesCrossed>
            <EspEvacAndFillCommands>
                <Command0010 Delay="250">ActivateFrontDumpValves</Command0010>
                <Command0020>DectivateDumpValves</Command0020>
                <Command0030 Delay="250">ActivateRearDumpValves</Command0030>
                <Command0040>DectivateDumpValves</Command0040>
            </EspEvacAndFillCommands>

            <AltLowSpeed_ValveFiringCommands>
                <!-- Actually ABS -->
                <Command0002 CommandType="Machine" Torque="-350">TorqueFrontAxle</Command0002>
                <Command0004 ArrayTag="ApplyFrontAxleTorque"/>
                <Command0005 Precondition="MinSpeed" MinSpeed="4.5" ArrayTag="Activate_ALL_ISO" Delay="1000">Activate_ALL_ISO</Command0005>
                <Command0008 ArrayTag="OperatorApplyBrake"/>
                <Command0010 CommandType="Prompt" Prompt2="ApplyBrake" Delay="2500"/>
                <Command0020 ArrayTag="Turn_MOTOR_ON" Delay="1000">Turn_MOTOR_ON</Command0020>
                <!-- Left Front -->
                <Command0025 ArrayTag="Deactivate_FL_ISO" Delay="1000">Deactivate_FL_ISO</Command0025>
                <Command0030 ArrayTag="Activate_ISOFL_DUMPFL" Delay="3000" RollerIndex="0" TagType="ReductionStart">Activate_ISOFL_DUMPFL</Command0030>  
                <Command0050 ArrayTag="LFPressureReductionEnd" Delay="10" RollerIndex="0" TagType="ReductionEnd"/>
                <Command0060 ArrayTag="Deactivate_ISOFR_DUMPFL" Delay="3000" RollerIndex="0" TagType="BuildStart">Deactivate_ISOFR_DUMPFL</Command0060>
                <Command0070 ArrayTag="LFPressureIncreaseEnd" RollerIndex="0" TagType="BuildEnd"/>
                <!-- Right Front -->
                <Command0090 ArrayTag="Activate_ISOFR_DUMPFR" Delay="3000" RollerIndex="1" TagType="ReductionStart">Activate_ISOFR_DUMPFR</Command0090>
                <Command0110 ArrayTag="RFPressureReductionEnd" Delay="10" RollerIndex="1" TagType="ReductionEnd"/>
                <Command0120 ArrayTag="Deactivate_DUMPFR" Delay="3000" RollerIndex="1" TagType="BuildStart">Deactivate_DUMPFR</Command0120>
                <Command0130 ArrayTag="RFPressureIncreaseEnd" RollerIndex="1" TagType="BuildEnd"/>
                <!-- Left Rear -->
                <Command0140 ArrayTag="Deactivate_ISORL">Deactivate_ISORL</Command0140>
                <Command0145 CommandType="Machine" Torque="0">RemoveTorque</Command0145>
                <Command0146 ArrayTag="RemoveFrontAxleTorque"/>
                <Command0147 CommandType="Machine" Torque="-350">TorqueRearAxle</Command0147>
                <Command0150 Precondition="MinSpeed" MinSpeed="4.5" ArrayTag="LRESPReductionStart" Delay="350" RollerIndex="2" TagType="ReductionStart">Activate_ISORL_DUMPRL</Command0150>
                <Command0170 ArrayTag="LRESPReductionEnd" RollerIndex="2" TagType="ReductionEnd"/>
                <Command0180 ArrayTag="LRESPBuildStart" Delay="200" RollerIndex="2" TagType="BuildStart">Deactivate_ISORR_DUMPRL</Command0180>
                <Command0190 ArrayTag="LRESPBuildEnd" RollerIndex="2" TagType="BuildEnd"/>
                <Command0210 ArrayTag="RRESPReductionStart" Delay="300" RollerIndex="3" TagType="ReductionStart">Activate_ISORR_DUMPRR</Command0210>
                <Command0230 ArrayTag="RRESPReductionEnd" RollerIndex="3" TagType="ReductionEnd"/>
                <Command0240 ArrayTag="RRESPBuildStart" Delay="600" RollerIndex="3" TagType="BuildStart">Deactivate_DUMP_RR</Command0240>
                <Command0250 ArrayTag="RRESPBuildEnd" RollerIndex="3" TagType="BuildEnd"/>
                <Command0260>Activate_ALL_ISO</Command0260>
                <Command0270>Deactivate_ALL_VALVES</Command0270>
                <Command0945 CommandType="Machine" Torque="0">RemoveTorque</Command0945>
            </AltLowSpeed_ValveFiringCommands>

            <LowSpeed_ValveFiringCommands>
                <!-- Actually ABS -->
                <Command0002 CommandType="Machine" Torque="-350">TorqueFrontAxle</Command0002>
                <Command0005 Precondition="MinSpeed" MinSpeed="4.5">Activate_ALL_ISO</Command0005>
                <Command0010 CommandType="Prompt" Prompt2="ApplyBrake" Delay="2500"/>
                <Command0020 ArrayTag="MotorOn" Delay="100">Turn_MOTOR_ON</Command0020>
                <!-- Left Front -->
                <Command0025 ArrayTag="LFPressure" Delay="100">Deactivate_FL_ISO</Command0025>
                <Command0030 ArrayTag="LFESPReductionStart" Delay="1000" RollerIndex="0" TagType="ReductionStart">Activate_ISOFL_DUMPFL</Command0030>  
                <Command0050 ArrayTag="LFESPReductionEnd" RollerIndex="0" TagType="ReductionEnd"/>
                <Command0060 ArrayTag="LFESPBuildStart" Delay="1000" RollerIndex="0" TagType="BuildStart">Deactivate_ISOFR_DUMPFL</Command0060>
                <Command0070 ArrayTag="LFESPBuildEnd" RollerIndex="0" TagType="BuildEnd"/>
                <!-- Right Front -->
                <Command0090 ArrayTag="RFESPReductionStart" Delay="1000" RollerIndex="1" TagType="ReductionStart">Activate_ISOFR_DUMPFR</Command0090>
                <Command0110 ArrayTag="RFESPReductionEnd" Delay="10" RollerIndex="1" TagType="ReductionEnd"/>
                <Command0120 ArrayTag="RFESPBuildStart" Delay="1000" RollerIndex="1" TagType="BuildStart">Deactivate_DUMPFR</Command0120>
                <Command0130 ArrayTag="RFESPBuildEnd" RollerIndex="1" TagType="BuildEnd"/>
                
                <Command0140>Deactivate_ISORL</Command0140>
                <Command0145 CommandType="Machine" Torque="0">RemoveTorque</Command0145>
                <Command0147 CommandType="Machine" Torque="-350">TorqueRearAxle</Command0147>
                
                <!-- Left Rear -->
                <Command0150 Precondition="MinSpeed" MinSpeed="4.5" ArrayTag="LRESPReductionStart" Delay="1000" RollerIndex="2" TagType="ReductionStart">Activate_ISORL_DUMPRL</Command0150>
                <Command0170 ArrayTag="LRESPReductionEnd" RollerIndex="2" TagType="ReductionEnd"/>
                <Command0180 ArrayTag="LRESPBuildStart" Delay="1000" RollerIndex="2" TagType="BuildStart">Deactivate_ISORR_DUMPRL</Command0180>
                <Command0190 ArrayTag="LRESPBuildEnd" RollerIndex="2" TagType="BuildEnd"/>
                
                <!-- Right Rear -->
                <Command0210 ArrayTag="RRESPReductionStart" Delay="1000" RollerIndex="3" TagType="ReductionStart">Activate_ISORR_DUMPRR</Command0210>
                <Command0230 ArrayTag="RRESPReductionEnd" RollerIndex="3" TagType="ReductionEnd"/>
                <Command0240 ArrayTag="RRESPBuildStart" Delay="1000" RollerIndex="3" TagType="BuildStart">Deactivate_DUMP_RR</Command0240>
                <Command0250 ArrayTag="RRESPBuildEnd" RollerIndex="3" TagType="BuildEnd"/>
                
                <Command0260>Activate_ALL_ISO</Command0260>
                <Command0270>Deactivate_ALL_VALVES</Command0270>
                <Command0945 CommandType="Machine" Torque="0">RemoveTorque</Command0945>
            </LowSpeed_ValveFiringCommands>
            <NoBrakeSwitchSignal>true</NoBrakeSwitchSignal>

            <DragAnalyzedBeforeESPTest>True</DragAnalyzedBeforeESPTest>
            <EvalEspUseEspEndIndex>False</EvalEspUseEspEndIndex>
            <FourChannelEspTest>True</FourChannelEspTest>
            <RecalculateDragBeforeESP>False</RecalculateDragBeforeESP>
            <UseMaxESPReductionPercentage>False</UseMaxESPReductionPercentage>
            <!-- ESP Build Parameters -->
            <LeftFrontMinESPBuildForce Units="lbf">225</LeftFrontMinESPBuildForce>
            <LeftRearMinESPBuildForce Units="lbf">225</LeftRearMinESPBuildForce>
            <RightFrontMinESPBuildForce Units="lbf">225</RightFrontMinESPBuildForce>
            <RightRearMinESPBuildForce Units="lbf">225</RightRearMinESPBuildForce>
            <!-- ESP Reduction Parameters -->
            <LeftFrontMaxESPReductionForce Units="lbf">40</LeftFrontMaxESPReductionForce>
            <LeftRearMaxESPReductionForce Units="lbf">40</LeftRearMaxESPReductionForce>
            <RightFrontMaxESPReductionForce Units="lbf">40</RightFrontMaxESPReductionForce>
            <RightRearMaxESPReductionForce Units="lbf">40</RightRearMaxESPReductionForce>
            <!-- 3700 Wheel Speed Sensor Parameter -->
            <LeftFrontSensorSpeedTarget Units="km/h">3.0</LeftFrontSensorSpeedTarget>
            <LeftRearSensorSpeedTarget Units="km/h">3.0</LeftRearSensorSpeedTarget>
            <ReadWheelSensorsIndividually>False</ReadWheelSensorsIndividually>
            <RightFrontSensorSpeedTarget Units="km/h">6.0</RightFrontSensorSpeedTarget>
            <RightRearSensorSpeedTarget Units="km/h">6.0</RightRearSensorSpeedTarget>
            <SensorSpeedTolerance Units="Percent">5.0</SensorSpeedTolerance>
            <!-- Park Brake Parameters -->
            <ParkBrakeArmSpeed Units="mph">6</ParkBrakeArmSpeed>
            <ParkBrakeEndSampleSpeed Units="mph">1</ParkBrakeEndSampleSpeed>
            <ParkBrakeForceSampleCount>0</ParkBrakeForceSampleCount>
            <ParkBrakeMaxForce Units="lbf">300</ParkBrakeMaxForce>
            <ParkBrakeMinForce Units="lbf">100</ParkBrakeMinForce>
            <ParkBrakeMinimumStartForce Units="lbf">100</ParkBrakeMinimumStartForce>
            <ParkBrakeStartSampleSpeed Units="mph">5</ParkBrakeStartSampleSpeed>
            <ParkBrakeStartSamplingAtMinimumForce>False</ParkBrakeStartSamplingAtMinimumForce>

            <SecurityUnlockAttempts>5</SecurityUnlockAttempts>
            <SecurityUnlockDelay>250</SecurityUnlockDelay>
        </Parameters>

    </Setup>

    <Objectives>
        <Setup>
            <TestStep000>Initialize</TestStep000>
            <TestStep010>Setup</TestStep010>
            <!--TestStep015 AltValue="CAN">SetupCommBus</TestStep015-->
