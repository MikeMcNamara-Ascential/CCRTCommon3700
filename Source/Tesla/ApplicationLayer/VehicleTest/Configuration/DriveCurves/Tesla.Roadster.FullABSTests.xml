<DriveCurve Description="Drive Curve For The Roadster Test">
    <Components Debug="Off">
        <Brake>
            <ComponentName>TevesAbsTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>KwpIsoTevesAbsTc.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
            <Debug>Off</Debug>
        </Brake>
        <Machine>
            <ComponentName>MachineTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>MachineComponent.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
            <Debug>Off</Debug>
        </Machine>
    </Components>
    <Test Result="Overall Test result (Pass, Fail, Abort, ...)" Debug="Off">
        <TestPhase000 Description="Validate the driver numbrer" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Prompt the driver to input the driver number" Result="" Timeout="" Component="Machine">
                    <Initialize>DisableTractionControl</Initialize>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>
        <!-- ABS Static Testing -->
        <TestPhase100 Description="Prompt ABS testing in progress" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS static test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsStaticTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase100>
        <TestPhase110 Description="Initialize the test components" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Init Brake Component" Result="" Timeout="" Component="Brake">
                    <Setup/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase110>
        <TestPhase120 Description="Brake to stop" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase120>
        <TestPhase130 Description="Prompt ABS testing complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS static test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsStaticTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase130>
        <!-- ABS Low Speed Sensor Test -->
        <TestPhase200 Description="Prompt ABS low speed sensor test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS low speed sensor test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsLowSpeedSensorTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase200>
        <TestPhase210 Description="Low Speed ABS Sensor Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Brake">
                    <SensorTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase210>
        <TestPhase220 Description="Prompt ABS low speed sensor test complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS low speed sensor test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsLowSpeedSensorTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase220>
        <!-- Brake Burnish Test -->
      <TestPhase500 Description="Prompt brake burnish test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display brake burnish test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>BrakeBurnishTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase500>
      <TestPhase510 Description="Brake burnish cycle" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Brake">
                    <BurnishCycle/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase510>
      <TestPhase520 Description="Prompt brake burnish test complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display brake burnish test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>BrakeBurnishTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase520>
      <!-- ABS Dynamic Brake Test -->
      <TestPhase600 Description="Disable the brake force meter for retests" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Disable the brake force meter" Result="" Timeout="" Component="Brake">
               <DisableForceMeter/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase600>
      <TestPhase605 Description="Prompt ABS testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase605>
      <TestPhase610 Description="Run The Brake Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Brake">
                    <BrakeTest/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase610>
      <!-- AnalyzeBrakeTest must be its own foreground test step after BrakeTest for incycle retesting-->
      <TestPhase615 Description="Analyze The Brake Test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Brake">
               <AnalyzeBrakeTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase615>
      <TestPhase620 Description="Brake to stop" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase620>
      <TestPhase630 Description="Disable the brake force meter" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Disable the brake force meter" Result="" Timeout="" Component="Brake">
                    <DisableForceMeter/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase630>
      <TestPhase640 Description="Prompt ABS testing complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display ABS test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>AbsTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase640>
        <!-- Park Brake Test -->
      <TestPhase700 Description="Prompt park brake testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display park brake test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>ParkBrakeTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase700>
      <TestPhase710 Description="Perform Park Brake Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Perform park brake test" Result="" Timeout="" Component="Brake">
                    <ParkBrakeTest/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase710>
      <TestPhase720 Description="Prompt park brake testing complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display park brake test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>ParkBrakeTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase720>
      <!--Brake Finishup-->
      <TestPhase840 Description="Finishup Brake Component" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Result="" Description="Perform Brake finish-up" Timeout="" Component="Brake">
                    <FinishUp/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase840>
      <!-- Finish up processing -->
      <TestPhase999 Description="Finishup" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective1 Result="" Description="Perform module finish-up" Timeout="" Component="Machine">
                    <FinishUp>PerformingFinishUp</FinishUp>
                </Objective1>
            </ForegroundObjectives>
      </TestPhase999>
    </Test>
</DriveCurve>
