<DriveCurve Description="Base brake drive curve">

    <Components Debug="Off">
        <Brake>
            <ComponentName>BoschAbsTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>KwpIsoBoschAbsTc.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
            <Debug>Off</Debug>
        </Brake>
        <EngineControl>
            <ComponentName>VwEngineControlTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>KwpIsoVwEngineControllerTc.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Emissions/</ConfigPath>
            <Debug>Off</Debug>
        </EngineControl>
        <Machine>
            <ComponentName>MachineTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>MachineTc.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
            <Debug>Off</Debug>
        </Machine>
    </Components>

    <Test Result="" Debug="Off">
        <!-- Initialize the system -->
        <TestPhase000 Description="Initialize the machine" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Init machine Component" Result="" Timeout="" Component="Machine">
                    <Initialize/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>
        <!-- Verify the proper vehicle is being tested -->
        <TestPhase001 Description="Verify the proper vehicle" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Validate module VIN to scanned VIN" Result="" Timeout="" Component="EngineControl">
                    <ValidateVin/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase001>

        <TestPhase005 Description="Initialize the brake test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Init brake Component" Result="" Timeout="" Component="Brake">
                    <Setup/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase005>

        <!-- Low speed Checks -->
        <TestPhase050 Description="Perform low speed brake sensor testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Sensor Quality Testing" Result="" Timeout="" Component="Brake">
                    <LowSpeedTesting/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase050>

        <!-- Perform the brake test -->
        <TestPhase100 Description="Perform the brake test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="run the base brake test" Result="" Timeout="" Component="Brake">
                    <BrakeTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase100>
        <TestPhase105 Description="Brake to stop and analyze results" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
            <BackgroundObjectives Result="" Timeout="">
                <Objective0 Description="Analyze brake test data" Result="" Timeout="" Component="Brake">
                    <AnalyzeBrakeTest/>
                </Objective0>
            </BackgroundObjectives>
        </TestPhase105>

        <!-- Perform the park brake test -->
        <TestPhase120 Description="Perform park brake testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Run the park brake test" Result="" Timeout="" Component="Brake">
                    <ParkBrakeTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase120>

        <!-- Finishup and set results -->
        <TestPhase200 Description="Set the result for the brake test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Set the brake test result" Result="" Timeout="" Component="Brake">
                    <FinishUp/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase200>

    </Test>

</DriveCurve>
