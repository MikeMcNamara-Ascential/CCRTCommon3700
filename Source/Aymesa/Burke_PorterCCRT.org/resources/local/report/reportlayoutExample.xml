<?xml version="1.0"?>
<!DOCTYPE RtReportConfig SYSTEM "resource:///com/bepco/rtc/report/rtreportconfig.dtd">

<RtReportConfig>
    <ReportLayout>
        <Title>CCRT Vehicle Test Result Report</Title>
        <TestIdBlock>
            <Column>
                <ServerTag tagname="VIN" label="VIN"/>
                <Timestamp/>
                <TestResultDetail tagname="MachineDriverNumber" childtagname="DriverNumber" label="Driver"/>
            </Column>
        </TestIdBlock>

        <HorizontalBar/>

        <BuildDataBlock label="Build Data">
            <Column>
                <ServerTag tagname="Airbag" label="Airbag"/>
                <ServerTag tagname="TireSize" label="Tires"/>
                <ServerTag tagname="Transmission" label="Transmission"/>
                <ServerTag tagname="BrakeType" label="Brake"/>
                <ServerTag tagname="ABSPartNo" label="Abs"/>
                <ServerTag tagname="Axle" label="Axle"/>
                <ServerTag tagname="BuildDate" label="Date"/>
                <ServerTag tagname="BuildTime" label="Time"/>
            </Column>
        </BuildDataBlock>

        <HorizontalBar/>

        <TestResultsBlock>
            <Column>
                <TestProcess showdetail="all" tagname="EmissionsOverallTest" label="Emissions"/>
                <TestProcess showdetail="all" tagname="AirbagOverallTest" label="Airbag"/>
                <TestProcess showdetail="all" tagname="BrakeOverallTest" label="Brake"/>
                <TestProcess showdetail="all" tagname="SpeedControlOverallTest" label="Speed Control"/>
                <TestProcess showdetail="all" tagname="TransmissionOverallTest" label="Transmission"/>
                <TestProcess showdetail="all" tagname="SKIMOverallTest" label="SKIM"/>
                <TestProcess showdetail="all" tagname="CruiseOverallTest" label="Cruise"/>
                <TestProcess showdetail="all" tagname="ClusterOverallTest" label="Cluster"/>
                <TestProcess showdetail="all" tagname="DTC" label="Diagnostic Trouble Codes"/>
                <TestProcess showdetail="all" tagname="AllFailures" label="All Failures"/>
            </Column>
        </TestResultsBlock>
    </ReportLayout>
</RtReportConfig>



