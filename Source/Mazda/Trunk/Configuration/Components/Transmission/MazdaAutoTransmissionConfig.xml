                    <EndTime Units="Seconds">30.6</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment051>

                <Segment053>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">107</TargetSpeed>
                    <EndTime Units="Seconds">31.8</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment053>

                <Segment055>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">120</TargetSpeed>
                    <EndTime Units="Seconds">33</EndTime>
