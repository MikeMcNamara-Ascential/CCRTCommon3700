            <MinimumBatteryVoltage Units="V" TestSteps="CheckBatteryVoltage" Comment="Minimum operating battery voltage">12.5</MinimumBatteryVoltage>
            <MaximumBatteryVoltage Units="V" TestSteps="CheckBatteryVoltage" Comment="Maximum operating battery voltage">16.0</MaximumBatteryVoltage>
            <!-- ManifoldAbsolutePressure Parameters -->
