         <LeftTandemSpeedValue>LeftTandemSpeedValue</LeftTandemSpeedValue>
         <RightTandemSpeedValue>RightTandemSpeedValue</RightTandemSpeedValue>
         <LeftFrontTorqueValue>LeftFrontTorqueValue</LeftFrontTorqueValue>
         <RightFrontTorqueValue>RightFrontTorqueValue</RightFrontTorqueValue>
         <LeftRearTorqueValue>LeftRearTorqueValue</LeftRearTorqueValue>
