<VehicleTest>
    <Setup>
        <Debug>0ff</Debug>
        <DebugLevel>0</DebugLevel>
        <ProcessPriority>11</ProcessPriority>
        <UseVinAsTestLogSuffix>No</UseVinAsTestLogSuffix>
        <SuffixExtension>log</SuffixExtension>
        <MaxLogFileIndex>10000</MaxLogFileIndex>
        <LogIndexFile>/TestResults/Machine/NextTestLogIndex.dat</LogIndexFile>
        <TerminateTestComponentsAtEnd>Yes</TerminateTestComponentsAtEnd>
        <DataTags>
            <VehicleBuild>VehicleBuild</VehicleBuild>
            <OverallPassFail>OverallTest</OverallPassFail>
            <CommandTest>CommandTest</CommandTest>
            <TestInProgress>TestInProgress</TestInProgress>
            <ForegroundTestInProgress>ForegroundTestInProgress</ForegroundTestInProgress>
            <DriveCurve>DriveCurve</DriveCurve>
            <RetainersDown>RollsDownElevUp</RetainersDown>
            <StartVehicleTest>StartVehicleTest</StartVehicleTest>
            <Vin>VIN</Vin>
        </DataTags>
        <TagList>
            <SubscribeTags>
                <RollsDownElevUp/>
            </SubscribeTags>
            <PublishTags>
                <OverallTest>Testing</OverallTest>
                <CommandTest/>
                <TestInProgress>0</TestInProgress>
                <ForegroundTestInProgress>0</ForegroundTestInProgress>
                <VehicleTestStatus/>
                <DriveCurve/>
                <StartVehicleTest>0</StartVehicleTest>
            </PublishTags>
        </TagList>
        <Selector>
            <Table>/Configuration/VehicleTest/SelectionTable.xml</Table>
            <Setup>
                <Debug>Off</Debug>
                <Logging>
                    <Status>Enabled</Status>
                    <ProcessName>TestSelector</ProcessName>
                    <AdditionalLogFile Type="/VehicleTest/TestSelector.log or Disabled">/VehicleTest/VehicleTest</AdditionalLogFile>
                    <Debug>Off</Debug>
                    <LocalEcho>Enabled</LocalEcho>
                    <Verbose>0x1F</Verbose>
                </Logging>
                <ThreadPool>
                    <Debug>Off</Debug>
                    <MinBlockedLimit>2</MinBlockedLimit>
                    <MaxBlockedLimit>4</MaxBlockedLimit>
                    <Increment>2</Increment>
                    <Maximum>50</Maximum>
                </ThreadPool>
            </Setup>
            <CommandableDriveCurves/>
        </Selector>
        <Sequencer>
            <Debug>Off</Debug>
            <RetestType Type="ReRun, Incycle, None">Incycle</RetestType>
            <MaxRetests Value="0,1,2,...">1</MaxRetests>
            <RetestQuestionTimeout Value="The ammount of time in miliseconds to wait for the drive to respond to the retest question.">60000</RetestQuestionTimeout>
            <RetestYesOrNoPromptBox>2</RetestYesOrNoPromptBox>
            <OverallTestResultPromptBox>1</OverallTestResultPromptBox>
            <LoadingParametersPromptBox>1</LoadingParametersPromptBox>
            <UsePlcResultButtons>True</UsePlcResultButtons>
            <ReuseComponents>True</ReuseComponents>
            <Setup>
                <Debug>Off</Debug>
                <DebugLevel>0</DebugLevel>
                <ProcessPriority>11</ProcessPriority>
                <Logging>
                    <Status>Enabled</Status>
                    <ProcessName>TestSequencer</ProcessName>
                    <AdditionalLogFile Type="/VehicleTest/TestSequencer.log or Disabled">/VehicleTest/VehicleTest</AdditionalLogFile>
                    <Debug>Off</Debug>
                    <LocalEcho>Disabled</LocalEcho>
                    <Verbose>0x1F</Verbose>
                </Logging>
                <ThreadPool>
                    <Debug>Off</Debug>
                    <MinBlockedLimit>2</MinBlockedLimit>
                    <MaxBlockedLimit>4</MaxBlockedLimit>
                    <Increment>2</Increment>
                    <Maximum>50</Maximum>
                </ThreadPool>
            </Setup>
        </Sequencer>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>50</Maximum>
        </ThreadPool>
        <NotificationList>
            <Debug>Off</Debug>
            <StartOnCreate>Off</StartOnCreate>
            <LowWater>1</LowWater>
            <HighWater>3</HighWater>
            <Maximum>5</Maximum>
            <Increment>1</Increment>
        </NotificationList>
        <Communication>
            <Comm>IPC</Comm>
            <Type>Server</Type>
            <Name>application/VehicleTest</Name>
            <Debug>Off</Debug>
            <Timeout>0</Timeout>
            <BufferSize>4096</BufferSize>
        </Communication>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>VehicleTest</ProcessName>
            <AdditionalLogFile Type="/VehicleTest/VehicleTest or Disabled">/VehicleTest/VehicleTest</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <SequencerComm>
            <Comm>IPC</Comm>
            <Type>Server</Type>
            <Name>application/Sequencer</Name>
            <Debug>Off</Debug>
            <BufferSize>2048</BufferSize>
            <Timeout>0</Timeout>
        </SequencerComm>
        <ResetOverallResults>
            <BrakeTractionControlTest>TestNotStarted</BrakeTractionControlTest>
        </ResetOverallResults>
        <ResetDataTags>
            <LRParkBrakeForce>0</LRParkBrakeForce>
            <LRParkBrakeBGColor>white</LRParkBrakeBGColor>
            <LFBrakeDistance>0</LFBrakeDistance>
            <RFBrakeDistance>0</RFBrakeDistance>
            <LRBrakeDistance>0</LRBrakeDistance>
            <RRBrakeDistance>0</RRBrakeDistance>
            <LFBrakeDistanceBGColor>white</LFBrakeDistanceBGColor>
            <RFBrakeDistanceBGColor>white</RFBrakeDistanceBGColor>
            <LRBrakeDistanceBGColor>white</LRBrakeDistanceBGColor>
            <RRBrakeDistanceBGColor>white</RRBrakeDistanceBGColor>
            <AxleRatio>0</AxleRatio>
            <AxleRatioBGColor>white</AxleRatioBGColor>
            <LFForceValue>0</LFForceValue>
            <RFForceValue>0</RFForceValue>
            <LRForceValue>0</LRForceValue>
            <RRForceValue>0</RRForceValue>
            <FrontBalanceValue>0</FrontBalanceValue>
            <FrontBalanceBGColor>white</FrontBalanceBGColor>
            <LFForceBGColor>white</LFForceBGColor>
            <RFForceBGColor>white</RFForceBGColor>
            <LRForceBGColor>white</LRForceBGColor>
            <RRForceBGColor>white</RRForceBGColor>
            <TotalParkBrakeForceValue>0</TotalParkBrakeForceValue>
            <ParkBrakeForce>0</ParkBrakeForce>
            <ParkBrakeForceBGColor>white</ParkBrakeForceBGColor>
        </ResetDataTags>
    </Setup>
</VehicleTest>
