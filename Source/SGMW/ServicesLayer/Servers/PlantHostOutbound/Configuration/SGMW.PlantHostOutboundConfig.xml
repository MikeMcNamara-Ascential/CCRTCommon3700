<PlantHostOutboundConfig>
    <!-- PlantHostOutbound config items -->
    <Setup>
        <Debug>Off</Debug>
        <ReportAbortedTestResults>True</ReportAbortedTestResults>
        <Communication>
            <Type>Server</Type>
            <Debug>Off</Debug>
            <Name>core/PlantHostOutbound</Name>
            <Comm>IPC</Comm>
            <Timeout>1000</Timeout>
            <BufferSize>2000</BufferSize>
        </Communication>
        <DataTags>
            <ErrorCodeTest>ErrorCodeTest</ErrorCodeTest>
            <Error>Error</Error>
        </DataTags>
        <Logging>
            <Debug>Off</Debug>
            <ProcessName>core/Pho</ProcessName>
            <Status>Enabled</Status>
            <AdditionalLogFile Types="/Server/PlantHostOutbound or Disabled">/Servers/FawPho.log</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <TagList>
            <SubscribeTags>
                <RollsDownElevUp/>
                <TestResult/>
                <VehiclePresent/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>7</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>


        <!-- External Host Interface List -->
        <HostInterfaces>
            <!-- ============================================================== -->
            <!-- MQS Interface                                                  -->
            <!-- ============================================================== -->
            <MqsInterface Enabled="1" Process="$(USR_ROOT)/ServicesLayer/Bin/MqsResultInterface.qxe">
                <Setup>
                    <SendResultsToHost>Yes</SendResultsToHost>
                    <VinIndex>-1</VinIndex>
                    <MaxResponseTime>20000</MaxResponseTime>
                    <MaxAttempts>3</MaxAttempts>
                    <ResultMap>/Configuration/Servers/MqsResultMap.xml</ResultMap>
                    <FailedResultTransmitFile>/TestResults/FailedTransmits.txt</FailedResultTransmitFile>
                    <MessageID>0x13</MessageID>
                    <SkipPerformAbortCheck>True</SkipPerformAbortCheck>
                    <TestResultConversion>
                        <Pass>Pass</Pass>
                        <Fail>Fail</Fail>
                        <Abort>Abrt</Abort>
                        <NotTested>NTst</NotTested>
                        <TestInProgress>Abrt</TestInProgress>
                        <Timeout>Fail</Timeout>
                    </TestResultConversion>

                    <ResultTypes>
                        <AbsResults VehicleOption="BrakeType" ValidOptions="Bosch 9 CAN,Bosch 9 K-Line,Bosch 9 ESP">/Configuration/Servers/MqsAbsResultMap.xml</AbsResults>
                        <CruiseResults VehicleOption="Cruise" ValidOptions="Yes">/Configuration/Servers/MqsCruiseResultMap.xml</CruiseResults>
                        <SoundLevelResults>/Configuration/Servers/MqsSoundLevelResultMap.xml</SoundLevelResults>
                        <SpeedometerResults>/Configuration/Servers/MqsSpeedometerResultMap.xml</SpeedometerResults>
                        <!--
                        <TpmResults VehicleOption="TPM" ValidOptions="Equipped">/Configuration/Servers/MqsTpmResultMap.xml</TpmResults>
                        -->
                    </ResultTypes>

                    <ComponentNameMapping/>
                    <DataTags>
                        <OverallTest>OverallTest</OverallTest>
                        <MachineNumber>MachineNumber</MachineNumber>
                    </DataTags>
                    <HostCommunication>
                        <Setup>
                            <Communication>
                                <Name>/dev/LogicalPorts/MQS</Name>
                                <BufferSize>2048</BufferSize>
                                <Timeout>3000</Timeout>
                                <Debug>Off</Debug>
                            </Communication>
                            <Logging>
                                <Debug>Off</Debug>
                                <ProcessName>MqsHostInterface</ProcessName>
                                <Status>Enabled</Status>
                                <AdditionalLogFile Types="/Server/HostInterface.log">/Communication/MqsHostInterface.log</AdditionalLogFile>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                            </Logging>
                        </Setup>
                    </HostCommunication>
                    <Communication>
                        <Debug>Off</Debug>
                        <Name>core/MqsHostInterface</Name>
                        <Type>Server</Type>
                        <Comm>IPC</Comm>
                        <BufferSize>2000</BufferSize>
                        <Timeout>1000</Timeout>
                    </Communication>
                    <Logging>
                        <Status>Enabled</Status>
                        <ProcessName>core/MqsHostInterface</ProcessName>
                        <AdditionalLogFile>/Servers/MqsHostInterface.log</AdditionalLogFile>
                        <Debug>Off</Debug>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <ThreadPool>
                        <Debug>Off</Debug>
                        <MinBlockedLimit>1</MinBlockedLimit>
                        <MaxBlockedLimit>3</MaxBlockedLimit>
                        <Increment>1</Increment>
                        <Maximum>5</Maximum>
                    </ThreadPool>
                    <NotificationList>
                        <Setup>
                            <Debug>Off</Debug>
                            <HighWater>3</HighWater>
                            <Increment>1</Increment>
                            <LowWater>1</LowWater>
                            <Maximum>5</Maximum>
                            <StartOnCreate>No</StartOnCreate>
                        </Setup>
                    </NotificationList>
                </Setup>
            </MqsInterface>

        </HostInterfaces>
    </Setup>
</PlantHostOutboundConfig>
