<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
  First stab at writing a config file for the GUI panels.
  Config for specific XMLWidgetPanels is under the
  $Revision: 1.2 $
-->

<RtGuiConfig>
   <Metadata author="Burke Porter, Inc" version="1.0"
     description="Standard implementation of the Driver Monitor view."/>
   <XmlWidgetPanel id="DriverMonitor">
      <Layout bgcolor="white">
         <!-- END OF Trafficlight ========================================== -->
         <!-- START OF Three radial gauges ================================= -->
         <HBox posX="210" posY="0" width="800" height="270">
            <!-- space -->
            <VBox width="10"/>
            <!-- Speedometer gauge -->
            <Widget id="speed" height="300" width="300" class="com.bepco.gui.RadialGauge">
               <DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
               <DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
               <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
                  <Font size="30" name="sans-serif" style="plain"/>
               </RadialGaugeConfig>
            </Widget>
            <!-- Brake force gauge -->
            <Widget id="brakeforce" height="300" width="300" class="com.bepco.gui.RadialGauge">
               <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10"/>
               <DataSource tagname="BrakeTarget" tagrole="targetrange" messagetype="Subscribe"/>
               <DataSource tagname="BrakeActive" messagetype="Subscribe" tagrole="enabled"/>
               <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="2000" targetlow="0" targethigh="0" >
                  <Font size="30" name="sans-serif" style="plain"/>
               </RadialGaugeConfig>
            </Widget>
         </HBox>
         <!-- END OF Three radial gauges =================================== -->
         <!-- START OF Driver Prompt Boxes ================================= -->
         <Widget id="prompts1" class="com.bepco.gui.PromptBox" posX="7" posY="275" width="1005" height="90" border="true">
            <DataSource tagname="PromptBox1" messagetype="Subscribe" />
            <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
            <TextBoxConfig>
               <Font size="48" name="sans-serif" style="plain"/>
            </TextBoxConfig>
         </Widget>
         <Widget id="prompts2" class="com.bepco.gui.PromptBox" posX="7" posY="370" width="1005" height="90" border="true">
            <DataSource tagname="PromptBox2" messagetype="Subscribe" />
            <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
            <TextBoxConfig>
               <Font size="48" name="sans-serif" style="plain"/>
            </TextBoxConfig>
         </Widget>
         <!-- END OF Driver Prompt Boxes ================================= -->
         <!-- Row 2 of 3 -->
         <HBox border="false" posX="7" posY="430" width="1012" height="300">
            <HBox height="170" width="200">
               <!-- subsystem test pass/fail widgets 
                   TestStates:
                       TestInProgress 	- Blue
                       Timeout		- Orange
                       Pass		- Green
                       Fail		- Red
                       Abort		- Yellow
               -->
               <VBox width='185'>
                  <Widget width='175' height='31'  id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                     <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                     <TextBoxConfig>
                        <Font size="22" name="serif" style="bold"></Font>
                     </TextBoxConfig>
                  </Widget>
                  <Widget width='175' height='31'  id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                     <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                     <TextBoxConfig>
                        <Font size="22" name="serif" style="bold"></Font>
                     </TextBoxConfig>
                  </Widget>
                  <Widget width='175' height='31'  id="sound" class="com.bepco.gui.OverallTestPhaseBox" >
                     <DataSource tagname="SoundLevelOverallTest" messagetype="Subscribe"/>
                     <TextBoxConfig>
                        <Font size="22" name="serif" style="bold"></Font>
                     </TextBoxConfig>
                  </Widget>
                  <Widget width='175' height='31'  id="exhaust" class="com.bepco.gui.OverallTestPhaseBox" >
                     <DataSource tagname="ExhaustOverallTest" messagetype="Subscribe"/>
                     <TextBoxConfig>
                        <Font size="22" name="serif" style="bold"></Font>
                     </TextBoxConfig>
                  </Widget>
                  <Widget width='175' height='31'  id="speedo" class="com.bepco.gui.OverallTestPhaseBox" >
                     <DataSource tagname="SpeedoOverallTest" messagetype="Subscribe"/>
                     <TextBoxConfig>
                        <Font size="22" name="serif" style="bold"></Font>
                     </TextBoxConfig>
                  </Widget>

                  

               </VBox>
            </HBox>
            <!-- END OF subsystem test pass/fail widgets ========================================== -->
            <!-- START of Test Failures Box===================================================== -->
            <HBox border="true" height="195" width="520">
               <VBox width="520">
                  <HBox>
                     <Label name="testfailures">
                        <Font size="24" name="sans-serif" style="bold"/>
                     </Label>
                  </HBox>
                  <Widget height="180" width="520" id="testfailures" class="com.bepco.gui.ListBox">
                     <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                     <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings" scrollbar="false">
                        <Font style="bold" name="serif" size="20"/>
                     </ScrollBoxConfig>
                  </Widget>
               </VBox>
            </HBox>
            <!-- END of Test Failures Box ===================================================== -->
		  
            <!-- Wheel Speeds ======================================================================== -->
            <HBox width="290" border="false">
               <VBox width="55">
                  <Widget id="_lf" class="com.bepco.gui.NumberBox" width="80">
                     <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                     <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                     <TextBoxConfig>
                        <Font size="38" name="sans-serif" style="plain"/>
                     </TextBoxConfig>
                  </Widget>
                  <HBox height="100"/>
                  <Widget id="_lr" class="com.bepco.gui.NumberBox" width="80">
                     <DataSource tagname="LRSpeed" messagetype="Read" datarate="10" />
                     <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                     <TextBoxConfig>
                        <Font size="38" name="sans-serif" style="plain"/>
                     </TextBoxConfig>
                  </Widget>
               </VBox>
		  
               <Widget id="axleimage" class="com.bepco.gui.ImagePhaseBox" border="false" width='130'>
                  <DataSource tagname="VehicleTypeImg" messagetype="Subscribe"/>
               </Widget>

               <VBox width="55">
                  <Widget id="_rf" class="com.bepco.gui.NumberBox" width='80'>
                     <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                     <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                     <TextBoxConfig>
                        <Font size="38" name="sans-serif" style="plain"/>
                     </TextBoxConfig>
                  </Widget>
                  <HBox height="100"/>
                  <Widget id="_rr" class="com.bepco.gui.NumberBox" width='80'>
                     <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                     <DataSource tagname="RRSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                     <TextBoxConfig>
                        <Font size="38" name="sans-serif" style="plain"/>
                     </TextBoxConfig>
                  </Widget>
               </VBox>
            </HBox>
         </HBox>
         <!-- END of Wheel Speeds ================================================================ -->
         <!-- START of VIN BOX ============================================================== -->
         <HBox posX='7' posY='700' width='1012' height='68' border="false">
            <!-- VIN -->
            <Label name="vin" border="false" height='68' width='100'>
               <Font size="45" name="sans-serif" style="plain"/>
            </Label>
            <Widget id="_vin" height='68' width="550" class="com.bepco.gui.TextBox">
               <DataSource tagname="VINDisplay" messagetype="Subscribe" />
               <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
                 tagrole="backgroundcolor" />
               <TextBoxConfig>
                  <Font size="45" name="sans-serif" style="plain"/>
               </TextBoxConfig>
            </Widget>
         </HBox>
         <!-- END of VIN Box ============================================================== -->
      </Layout>
   </XmlWidgetPanel>
</RtGuiConfig>
