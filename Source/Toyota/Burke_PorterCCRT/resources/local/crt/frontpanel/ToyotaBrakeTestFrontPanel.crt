<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">
<!-- 
$Revision: 1.3 $
-->

<RtGuiConfig>
    <Metadata author="Burke E. Porter" version="1.0"
                        description="Standard implementation of the Front Panel view."/>

    <XmlWidgetPanel id="FrontPanel">
        <Layout>
            <!-- BEP Address Label -->
            <VBox height="13" width="250" posX="750" posY="5" border="false">
                <Label name="address1" height="13" width="9000" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <VBox height="13" width="250" posX="750" posY="20" border="false">
                <Label name="address2" height="13" width="9000" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <VBox height="13" width="250" posX="750" posY="35" border="false">
                <Label name="phone" height="13" width="9000" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <!-- BEP Header -->
            <VBox height="750" width="1000" posX="0" posY="0" border="false">
                <Widget id="header" class="com.bepco.gui.ImagePhaseBox">
                    <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                </Widget>
            </VBox>

            <!-- Customer Logo -->
            <VBox height="200" width="175" posX="3" posY="75" border="false">
                <HBox height="75" width="175" border="false">
                    <Widget height="75" width="175" id="customerlogo" class="com.bepco.gui.ImagePhaseBox">
                        <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                    </Widget>
                </HBox>
                <HBox height="75" width="175" border="false">
                    <Widget height="75" width="175" id="platformlogo" class="com.bepco.gui.ImagePhaseBox">
                        <DataSource tagname="BodyStyle" messagetype="Subscribe"/>
                    </Widget>
                </HBox>
            </VBox>

            <!-- Wheel speeds -->
            <VBox height="200" width="297" posX="270" posY="70" border="false">
                <HBox height="15"/>
                <!-- Wheel Speeds -->
                <HBox width="200" border="false">
                    <VBox width="60">
                        <HBox>
                            <Label name="lf">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                            <TextBoxConfig convertunits="false">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lfg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30">
                        <DataSource tagname="LFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>

                    <Widget id="_rfg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="rf">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>

                </HBox>
                <HBox height="5"/>
                <HBox width="200">
                    <VBox width="60">
                        <HBox>
                            <Label name="lr">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lr" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LRSpeed" messagetype="Read" datarate="10" />
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lrg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30" >
                        <DataSource tagname="LRForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LRForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>

                    <Widget id="_rrg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RRForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RRForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="rr">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rr" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- LED Panel -->
            <VBox height="200" width="400" posX="590" posY="70" border="false">
                <!-- Inputs from PLC -->
                <HBox height="120">
                    <VBox>
                        <Widget id="powersense" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="plcready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PLCSystemIsReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="vmeready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VMESystemReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="vehiclepresent" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VehiclePresent" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
                    </VBox>

                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="powersense"/>
                        <HBox height="5"/>
                        <Label name="plcready"/>
                        <HBox height="5"/>
                        <Label name="vmeready"/>
                        <HBox height="5"/>
                        <Label name="vehiclepresent"/>
                    </VBox>

                    <!-- SPACER -->
                    <VBox width="40"/>

                    <VBox>
                        <Widget id="driveenable" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="EnableAllRollDrives" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="rollsup" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsUpElevDown" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="rollsdown" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsDownElevUp" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="zerospeed" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="ZerospeedToPLC" messagetype="Subscribe"/>
                        </Widget>
                    </VBox>

                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="driveenable"/>
                        <HBox height="5"/>
                        <Label name="rollsup"/>
                        <HBox height="5"/>
                        <Label name="rollsdown"/>
                        <HBox height="5"/>
                        <Label name="zerospeed"/>
                    </VBox>

                </HBox>

                <!-- Current Cycle Time -->
                <HBox>
                    <Label height="30" width="120" name="cycletime">
                        <Font size="24" name="sans-serif" style="bold"/>
                    </Label>
                    <VBox width="20"/>
                    <Widget id="_cycletime" class="com.bepco.gui.NumberBox" width="60">
                        <DataSource tagname="CycleTime" messagetype="Read" datarate="3" />
                        <TextBoxConfig>
                            <Font size="24" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
            </VBox>

            <!-- Prompt message text box -->
            <Widget id="prompts" class="com.bepco.gui.PromptBox" posX="3" posY="240" width="997" height="60" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts3" class="com.bepco.gui.PromptBox" posX="3" posY="300" width="997" height="60" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>

            <!-- Test Results -->
            <HBox height="310" width="997" posX="3" posY="360" border="true" borderstyle="title" bordertitle="testresults">
                <VBox>
                    <HBox>
                        <!-- Brake Distance -->
                        <HBox height="130" width="300" posX="0" posY="0" border="true" borderstyle="title" bordertitle="brakedistance">
                            <VBox>
                                <Label height="30" width="40" name="lf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="rf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="lr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="rr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox width="30"/>
                            <VBox>
                                <Widget height="30" width="60" id="LFDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LFBrakeDistance" messagetype="Subscribe"/>
                                    <DataSource tagname="LFBrakeDistanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="RFDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RFBrakeDistance" messagetype="Subscribe"/>
                                    <DataSource tagname="RFBrakeDistanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="LRDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LRBrakeDistance" messagetype="Subscribe"/>
                                    <DataSource tagname="LRBrakeDistanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="RRDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RRBrakeDistance" messagetype="Subscribe"/>
                                    <DataSource tagname="RRBrakeDistanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                        </HBox>

                        <!-- Max Brake Force -->
                        <HBox height="130" width="300" posX="0" posY="0" border="true" borderstyle="title" bordertitle="brakeforce">
                            <VBox>
                                <Label height="30" width="40" name="lf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="rf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="lr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="rr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox width="10"/>
                            <VBox>
                                <Widget height="30" width="60" id="LFBrakeForce" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LFForceValue" messagetype="Subscribe"/>
                                    <DataSource tagname="LFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="RFBrakeForce" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RFForceValue" messagetype="Subscribe"/>
                                    <DataSource tagname="RFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="LRBrakeForce" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LRForceValue" messagetype="Subscribe"/>
                                    <DataSource tagname="LRForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="RRBrakeForce" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RRForceValue" messagetype="Subscribe"/>
                                    <DataSource tagname="RRForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                            <VBox width="10"/>
                            <VBox>
                                <Label height="30" width="80" name="front">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <HBox height="30"/>
                                <Label height="30" width="80" name="rear">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox width="10"/>
                            <VBox>
                                <Widget height="30" width="60" id="FrontBrakeBalance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="FrontBalanceValue" messagetype="Subscribe"/>
                                    <DataSource tagname="FrontBalanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <HBox height="30"/>
                                <Widget height="30" width="60" id="RearBrakeBalance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RearBalanceValue" messagetype="Subscribe"/>
                                    <DataSource tagname="RearBalanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                        </HBox>

                        <!-- Park Brake Force -->
                        <HBox height="130" width="300" posX="0" posY="0" border="true" borderstyle="title" bordertitle="parkbrakeforce">
                            <VBox>
                                <Label height="30" width="40" name="lr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Label height="30" width="40" name="rr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <HBox height="30" width="40"/>
                                <Label height="30" width="40" name="total">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox width="50"/>
                            <VBox>
                                <Widget height="30" width="60" id="LRParkBrakeForce" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LRParkBrakeForce" messagetype="Subscribe"/>
                                    <DataSource tagname="LRParkBrakeBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <Widget height="30" width="60" id="RRParkBrakeForce" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RRParkBrakeForce" messagetype="Subscribe"/>
                                    <DataSource tagname="RRParkBrakeBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <HBox height="30" width="40"/>
                                <Widget height="30" width="60" id="TotalParkBrakeForceValue" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="ParkBrakeForce" messagetype="Subscribe"/>
                                    <DataSource tagname="ParkBrakeForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                        </HBox>

                        <!-- Axle Ratio -->
                        <VBox height="130" width="120" posX="0" posY="0">
                            <HBox height="45" border="true" borderstyle="title" bordertitle="axleratio">
                                <VBox>
                                    <Label height="30" width="80" name="axleratio">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </Label>
                                </VBox>
                                <VBox>
                                    <Widget height="30" width="60" id="AxleRatio" class="com.bepco.gui.NumberBox">
                                        <DataSource tagname="AxleRatio" messagetype="Subscribe"/>
                                        <DataSource tagname="AxleRatioBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                        <TextBoxConfig format="{0,number,#.0}">
                                            <Font size="16" name="sans-serif" style="bold"/>
                                        </TextBoxConfig>
                                    </Widget>
                                </VBox>
                            </HBox>
                            <VBox width="120" height="45" border="true" borderstyle="title" bordertitle="tractioncontrol">
                                <HBox height="5"/>
                                <Widget width='140' height='40' id="traction" class="com.bepco.gui.OverallTestPhaseBox" >
                                    <DataSource tagname="BrakeTractionControlTest" messagetype="Subscribe"/>
                                    <TextBoxConfig convertunits="false">
                                        <Font size="18" name="sans-serif" style="plain"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                        </VBox>
                        <VBox>
                            <HBox height="45" border="true" borderstyle="title" bordertitle="foot">
                                <Label height="25" width="40" name="foot">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <Widget height="25" width="60" id="BrakePedalForceValue" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="BrakePedalForce" messagetype="Read" datarate="4"/>
                                    <TextBoxConfig format="{0,number,#}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </HBox>
                            <HBox height="80"/>
                        </VBox>
                    </HBox>
                    <HBox>
                        <!-- Load Cell Values -->
                        <HBox height="60" width="300" posX="0" posY="0" border="true" borderstyle="title" bordertitle="loadcellvalues">
                            <VBox>
                                <Label height="25" width="40" name="lf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <HBox height="10"/>
                                <Label height="25" width="40" name="lr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox>
                                <Widget height="25" width="60" id="LfLoadCellValue" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LFLoadCellValue" messagetype="Read" datarate="10"/>
                                    <TextBoxConfig format="{0,number,#}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <HBox height="10"/>
                                <Widget height="25" width="60" id="LrLoadCellValue" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LRLoadCellValue" messagetype="Read" datarate="10"/>
                                    <TextBoxConfig format="{0,number,#}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                            <VBox width="40"/>
                            <VBox>
                                <Label height="25" width="40" name="rf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <HBox height="10"/>
                                <Label height="25" width="40" name="rr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox>
                                <Widget height="25" width="60" id="RfLoadCellValue" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RFLoadCellValue" messagetype="Read" datarate="10"/>
                                    <TextBoxConfig format="{0,number,#}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <HBox height="10"/>
                                <Widget height="25" width="60" id="RrLoadCellValue" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RRLoadCellValue" messagetype="Read" datarate="10"/>
                                    <TextBoxConfig format="{0,number,#}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                        </HBox>

                        <!-- Brake Distance Values -->
                        <HBox height="60" width="300" posX="0" posY="0" border="true" borderstyle="title" bordertitle="brakedistance">
                            <VBox>
                                <Label height="25" width="40" name="lf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <HBox height="10"/>
                                <Label height="25" width="40" name="lr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox>
                                <Widget height="25" width="80" id="LfDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LFCurrentDistance" messagetype="Read" datarate="5"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <HBox height="10"/>
                                <Widget height="25" width="80" id="LrDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="LRCurrentDistance" messagetype="Read" datarate="5"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                            <VBox width="40"/>
                            <VBox>
                                <Label height="25" width="40" name="rf">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                                <HBox height="10"/>
                                <Label height="25" width="40" name="rr">
                                    <Font size="16" name="sans-serif" style="bold"/>
                                </Label>
                            </VBox>
                            <VBox>
                                <Widget height="25" width="80" id="RfDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RFCurrentDistance" messagetype="Read" datarate="5"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                                <HBox height="10"/>
                                <Widget height="25" width="80" id="RrDistance" class="com.bepco.gui.NumberBox">
                                    <DataSource tagname="RRCurrentDistance" messagetype="Read" datarate="5"/>
                                    <TextBoxConfig format="{0,number,#.0}">
                                        <Font size="16" name="sans-serif" style="bold"/>
                                    </TextBoxConfig>
                                </Widget>
                            </VBox>
                        </HBox>

                        <VBox width="380"/>
                    </HBox>
                </VBox>

            </HBox>

            <!-- Test Failures -->
            <VBox height="160" width="607" posX="3" posY="670" border="true" borderstyle="title" bordertitle="testfailures">
                <Widget height="126" width="598" id="testfailures" class="com.bepco.gui.ListBox">
                    <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                    <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings">
                        <Font style="bold" name="sans-serif" size="14"/>
                    </ScrollBoxConfig>
                </Widget>
            </VBox>

            <!-- Machine Faults -->
            <VBox height="160" width="390" posX="610" posY="670" border="true" borderstyle="title" bordertitle="machinefaults">
                <Widget height="126" width="380" id="machine_faults" class="com.bepco.gui.MachineFaultView">
                    <DataSource tagname="AllFaults" messagetype="Subscribe"/>
                    <ListBoxConfig stringmap="com.bepco.rtc.properties.MachineFaultStrings">
                        <Font style="bold" name="sans-serif" size="14"/>
                    </ListBoxConfig>
                </Widget>
            </VBox>
        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>

