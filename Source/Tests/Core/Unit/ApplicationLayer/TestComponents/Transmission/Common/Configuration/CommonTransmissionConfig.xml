<CVTComponent>
  <Setup>
    <Name>Transmission</Name>
    <Debug>Off</Debug>
    <ProcessPriority>11</ProcessPriority>
    <TestDomain>Foreground</TestDomain>
    <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
    <TagList>
      <SubscribeTags>
        <VIN/>
        <TCMPartNo/>
        <PinionFactor/>
        <Zerospeed/>
        <Transmission/>
        <Abort/>
        <ForegroundTestInProgress/>
        <TestInProgress/>
        <CableConnect/>
        <DriveAxle/>
        <VehiclePresent/>
        <RollsUpElevDown/>
