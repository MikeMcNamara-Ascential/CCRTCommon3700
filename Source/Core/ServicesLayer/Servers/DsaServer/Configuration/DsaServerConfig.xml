            <Setup>
                <Communication>
                    <Debug>Off</Debug>
                    <Name>/dev/LogicalPorts/Dsa</Name>
                    <BufferSize>128</BufferSize>
                    <Timeout>10000</Timeout>
                </Communication>
                <Logging>
                    <Status>Enabled</Status>
                    <ProcessName>DsaComm</ProcessName>
                    <AdditionalLogFile Types="/Communication/DsaComm.log or Disabled">/Communication/DsaComm.log</AdditionalLogFile>
                    <Debug>Off</Debug>
                    <LocalEcho>Disabled</LocalEcho>
                    <Verbose>0x3F</Verbose>
                </Logging>
            </Setup>
        </DsaCommunications>
        <Communication>
            <Type>Server</Type>
            <Debug>Off</Debug>
            <Name>core/DsaServer</Name>
            <Comm>IPC</Comm>
            <Timeout>5000</Timeout>
            <BufferSize>2000</BufferSize>
        </Communication>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>core/DsaServer</ProcessName>
            <AdditionalLogFile Type="/Servers/DsaServer or Disabled">/Servers/DsaServer.log</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
            <Debug>Off</Debug>
        </Logging>
        <TagList>
            <SubscribeTags>
                <VehiclePresent/>
                <RollsDownElevUp/>
                <AllFaults/>
                <Zerospeed/>
                <PowerSense/>
                <PanelEStopPushbuttonDepressed/>
                <LossCompensation/>
                <PLCSystemIsReady/>
