<DriveCurve Description="Base brake drive curve">
   <Components Debug="Off">
      <Airbag>
         <ComponentName>DensoAirbagTC.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>KwpIsoDenso150300AirbagTC.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Airbag/</ConfigPath>
         <Debug>Off</Debug>
      </Airbag>
      <Brake>
         <ComponentName>GenericBaseBrakeTest.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>BaseBrakeTc.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
         <Debug>Off</Debug>
      </Brake>
      <Machine>
         <ComponentName>MachineTC.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>MachineTc.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
         <Debug>Off</Debug>
      </Machine>
   </Components>
   <Test Result="" Debug="Off">
      <!-- Initialize the system -->
      <TestPhase000 Description="Initialize the machine" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Init machine Component" Result="" Timeout="" Component="Machine">
               <Initialize/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase000>
      <TestPhase005 Description="Initialize the brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Init brake Component" Result="" Timeout="" Component="Brake">
               <Initialize/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase005>
      <!-- Perform Speedometer testing -->
      <TestPhase060 Description="Perform speedometer test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Check speedometer on the vehicle" Result="" Timeout="" Component="Machine">
               <Speedometer/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase060>
      <!-- Perform the brake test -->
      <TestPhase100 Description="Perform the brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="run the base brake test" Result="" Timeout="" Component="Brake">
               <BrakeTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase100>
      <TestPhase105 Description="Brake to stop and analyze results" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
               <BrakeToStop/>
            </Objective0>
         </ForegroundObjectives>
         <BackgroundObjectives Result="" Timeout="">
            <Objective0 Description="Analyze brake test data" Result="" Timeout="" Component="Brake">
               <AnalyzeBrakeTest/>
            </Objective0>
         </BackgroundObjectives>
      </TestPhase105>
      <!-- Finishup and set results -->
      <TestPhase200 Description="Set the result for the brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Set the machine test result" Result="" Timeout="" Component="Machine">
               <FinishUp>PerformingFinalTesting</FinishUp>
            </Objective0>
            <Objective1 Description="Perform Airbag Testing" Result="" Timeout="" Component="Airbag">
               <AirbagTest/>
            </Objective1>
            <Objective2 Description="Set the brake test result" Result="" Timeout="" Component="Brake">
               <FinishUp/>
            </Objective2>
         </ForegroundObjectives>
      </TestPhase200>
   </Test>
</DriveCurve>
