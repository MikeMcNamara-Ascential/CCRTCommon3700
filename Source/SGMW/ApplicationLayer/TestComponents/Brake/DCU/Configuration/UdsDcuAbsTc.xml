            <BrakeBurnishStartSpeedRange Units="mph">60 70</BrakeBurnishStartSpeedRange>
            <BrakeToTargetSpeedPrompt>BrakeToTargetSpeed</BrakeToTargetSpeedPrompt>
            <BurnishIterations Description="Number of times to accel and decel for one cycle">11</BurnishIterations>
            <!--Static Brake Burnish Parameters-->
            <BrakeCoolDownBgColor>cyan</BrakeCoolDownBgColor>
            <StaticBrakeBurnishAccelSpeed Units="mph">50</StaticBrakeBurnishAccelSpeed>
            <StaticBrakeBurnishBrakeSpeedRange Units="mph">35 45</StaticBrakeBurnishBrakeSpeedRange>
            <StaticBrakeBurnishCoolDownSpeed Units="mph">50</StaticBrakeBurnishCoolDownSpeed>
            <StaticBrakeBurnishCoolDownTime Units="ms">60000</StaticBrakeBurnishCoolDownTime>
            <StaticBrakeBurnishDisplaySpeedTargetForRear>True</StaticBrakeBurnishDisplaySpeedTargetForRear>
            <StaticBrakeBurnishOperatorSetupTime Units="ms">5000</StaticBrakeBurnishOperatorSetupTime>
            <StaticBrakeBurnishParkBrakeClicks>4</StaticBrakeBurnishParkBrakeClicks>
            <StaticBrakeBurnishTime Units="ms">120000</StaticBrakeBurnishTime>
            <!--Ignition On Startup Time-->
            <IgnitionOnStartupTime>5000</IgnitionOnStartupTime>
            <DisplaySpeedTimeGraph>True</DisplaySpeedTimeGraph>
            <SpeedGraphLowerSeries UnitsX="s" UnitsY="km/h">0 -5,20 15,30 15,50 40,60 40,80 60,90 60,120 90</SpeedGraphLowerSeries>
            <SpeedGraphUpperSeries UnitsX="s" UnitsY="km/h">0 10,20 30,30 30,50 70,60 70,80 100,90 100,120 120</SpeedGraphUpperSeries>
            <!-- Yaw Rate Sensor Parameters -->
            <AlwaysCalibrateGSensor>True</AlwaysCalibrateGSensor>
            <IgnitionOffRpm>0</IgnitionOffRpm>
            <IgnitionOnRpm>400</IgnitionOnRpm>
            <YawRateMax>0.384</YawRateMax>
            <YawRateMin>-0.384</YawRateMin>
        </Parameters>

        <Prompts>
            <AccelerateToTargetSpeed PromptBox="1" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <ApplyBrake PromptBox="2" Priority="0">ApplyBrake</ApplyBrake>
            <ParkBrakeBurnish PromptBox="2" Priority="0">ParkBrakeBurnish</ParkBrakeBurnish>
            <ApplyParkBrakeClicks PromptBox="2" Priority="0">ApplyParkBrakeClicks</ApplyParkBrakeClicks>
            <BrakeBurnish PromptBox="1" Priority="0">BrakeBurnish</BrakeBurnish>
            <PerformBrakeBurnish PromptBox="1" Priority="0">PerformBrakeBurnish</PerformBrakeBurnish>
            <BrakeCoolDown PromptBox="1" Priority="0">BrakeCoolDown</BrakeCoolDown>
            <BrakeModeratelyInGreenBand PromptBox="1" Priority="0">BrakeModeratelyInGreenBand</BrakeModeratelyInGreenBand>
            <BrakeToTargetSpeed PromptBox="2" Priority="0">BrakeToTargetSpeed</BrakeToTargetSpeed>
            <FootOffBrake PromptBox="2" Priority="0">FootOffBrake</FootOffBrake>
            <MaintainSpeed PromptBox="1" Priority="0">MaintainSpeed</MaintainSpeed>
            <ReleaseParkBrake PromptBox="2" Priority="0" Duration="5000">ReleaseParkBrake</ReleaseParkBrake>
            <ShiftToNeutral PromptBox="1" Priority="0">ShiftToNeutral</ShiftToNeutral>
            <ZeroSpeed PromptBox="1" Priority="0">ZeroSpeed</ZeroSpeed>
        </Prompts>

    </Setup>




    <Objectives>

        <AnalyzeEspBrakeTest>
            <TestStep00>AnalyzeBrakeTest</TestStep00>
            <TestStep05>AnalyzeBalance</TestStep05>
            <TestStep10>EvaluateESP</TestStep10>
        </AnalyzeEspBrakeTest>

        <EspBrakeTest>
            <TestStep00>AccelerateToBrakeSpeed</TestStep00>
            <TestStep05>DragTest</TestStep05>
            <TestStep10>AnalyzeDragTest</TestStep10>
            <TestStep15>StopModuleKeepAlive</TestStep15>
            <TestStep25>FlexibleEspValveFiringTest</TestStep25>
            <TestStep30>StartModuleKeepAlive</TestStep30>
            <TestStep35>BrakeTest</TestStep35>
        </EspBrakeTest>

        <FinishUp>
            <TestStep00>DisableForceMeter</TestStep00>
            <TestStep05>StopModuleKeepAlive</TestStep05>
            <TestStep10>AllInletValvesOn</TestStep10>
            <TestStep15>Delay</TestStep15>
            <TestStep20>Delay</TestStep20>
            <TestStep25>AllInletValvesOff</TestStep25>
            <TestStep90>ReadFaults</TestStep90>
            <TestStep99>FinishUp</TestStep99>
        </FinishUp>

        <Setup>
            <TestStep00>Setup</TestStep00>
            <TestStep05>Initialize</TestStep05>
            <TestStep10>EnterDiagnosticMode</TestStep10>
            <TestStep15>DisableSpeedLimit</TestStep15>
            <TestStep90>StartModuleKeepAlive</TestStep90>
        </Setup>

        <WheelSpeedSensorTest>
            <TestStep00>BrakeToStop</TestStep00>
            <TestStep05 AltValue="Rear">TwoMotorWssTest</TestStep05>
            <TestStep10 AltValue="Front">TwoMotorWssTest</TestStep10>
            <TestStep15>BrakeToStop</TestStep15>
        </WheelSpeedSensorTest>

    </Objectives>




    <TestSteps>

        <AccelerateToBrakeSpeed Result="" Timeout="1200000" Description="Accelerate to Brake Test Arm Speed"
            ArmSpeed="50" SpeedTarget="50 60" Prompt1="AccelerateToTargetSpeed"/>

        <AllInletValvesOff Result="" Timeout="1000" Description="All Off" />

        <AllInletValvesOn Result="" Timeout="1000" Description="Open all prime valves" />

        <AnalyzeBalance Result="" Timeout="5000" Description="Base Brake Component Brake Balance Test" 
            FrontSideToSideBalance="8" RearSideToSideBalance="8" 
            BalanceFrontToRearMin="20" BalanceFrontToRearMax="70" 
            Prompt1="" Prompt2=""/>

        <AnalyzeBrakeTest Result="" Timeout="20000" Description="Base Brake Component Brake Test Analysis" 
            FrontMinBrakeForce="222" FrontMaxBrakeForce="600" RearMinBrakeForce="99" RearMaxBrakeForce="400" 
            Prompt1="" Prompt2=""/>

        <AnalyzeDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis" 
            Prompt1="" Prompt2="" FrontMaxDragForce="55" RearMaxDragForce="55"/>

        <BrakeTest Result="" Timeout="40000" Description="Base Brake Component Brake Test"
            StartBrakeSampleSpeed="45" EndBrakeSampleSpeed="5"
            BrakeDomain="0 500" BrakeTarget="250 350"
            Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeModeratelyInGreenBand"/>

        <BrakeToStop Result="" Timeout="120000" Description="Prompt the driver to brake to stop" 
            Prompt1="BrakeToStop" Prompt1Priority="0" SpeedTarget="0 0"/>

        <Delay Result="" Timeout="1000" Description="Delay"/>

        <DisableForceMeter Result="" Timeout="1000" Description="Disable the brake force meter"/>

        <DisableSpeedLimit Result="" Timeout="10000" Description="Disable Speed Limit"/>

        <DragTest Result="" Timeout="40000" Description="Base Brake Component Brake Drag Test" 
            Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="Blank" 
            DragDelay="1000" DragSpeed="48" DragSamples="50"/>

        <EnterDiagnosticMode Result="" Timeout="5000" Description="Enter diagnostic mode" ScanDelay="250"/>

        <EnterDiagModeAtSpeed Result="" Timeout="5000" Description="Enter diagnostic mode at speed" ScanDelay="250"/>

        <EvaluateESP Result="" Timeout="5000" 
            Description="Evaluate ABS pulses to ensure minimum requirements are met"/>

        <FinishUp Result="" Timeout="3000" Description="Brake test finishup"/>

        <FlexibleEspValveFiringTest Result="" Timeout="15000" Description="Sequence the ESP valves"/>

        <Initialize Result="" Timeout="1000" Description="Initialize the BaseBrake portion of the test" 
            Prompt1="Initialize" ZerospeedPrompt="BrakeToStop"/>

        <ReadFaults Result="" Timeout="5000" Description="Read faults from the module" ScanDelay="250"/>

        <Setup Result="" Timeout="500" Description="Set up component for testing"/>

        <StartModuleKeepAlive Result="" Timeout="1000" ScanDelay="250" 
            Description="Start sending tester present message to the module"/>

        <StopModuleKeepAlive Result="" Timeout="1000" ScanDelay="" 
            Description="Stop sending tester present message to the module"/>

        <TwoMotorWssTest Result="" Timeout="30000" ScanDelay="250" 
            Description="Perform wheel speed sensor test on one vehicle axle"/>

    </TestSteps>
</DcuAbs>
