<PlantHostOutboundConfig>
    <!-- PlantHostOutbound config items -->
    <Setup>
        <Debug>Off</Debug>
        <ReportAbortedTestResults>False</ReportAbortedTestResults>
        <Communication>
            <Type>Server</Type>
            <Debug>Off</Debug>
            <Name>core/PlantHostOutbound</Name>
            <Comm>IPC</Comm>
            <Timeout>1000</Timeout>
            <BufferSize>2000</BufferSize>
        </Communication>
        <DataTags>
            <ErrorCodeTest>ErrorCodeTest</ErrorCodeTest>
            <Error>Error</Error>
        </DataTags>
        <Logging>
            <Debug>Off</Debug>
            <ProcessName>core/DcxPho</ProcessName>
            <Status>Enabled</Status>
            <AdditionalLogFile Types="/Server/PlantHostOutbound or Disabled">/Servers/DcxPho.log</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <TagList>
            <SubscribeTags>
                <RollsDownElevUp/>
                <TestResult/>
                <VehiclePresent/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>7</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <PrintForFlaggedFailures>False</PrintForFlaggedFailures>
        <FlaggedFailuresToPrint>
            <MachineMPBOBrakeInterlock/>
        </FlaggedFailuresToPrint>
        <PrintServerCommands>
            <Command1 process="core/DataServer" tag="OverallTest" value="Fail"/>
            <Command2 process="core/DataServer" tag="TestResult" value="TestResultFileName"/>
        </PrintServerCommands>
        <!-- External Host Interface List -->
        <HostInterfaces>
            <!-- ============================================================== -->
            <!-- ALC Interface                                                  -->
            <!-- ============================================================== -->
            <AlcInterface Enabled="1" Process="$(USR_ROOT)/ServicesLayer/Bin/AlcInterface.qxe">
                <Setup>
                    <SendResultsToHost>Yes</SendResultsToHost>
                    <SendTpmResultToHost>No</SendTpmResultToHost>
                    <VinIndex>0</VinIndex>
                    <MaxResponseTime>2000</MaxResponseTime>
                    <MaxAttempts>1</MaxAttempts>
                    <ResultMap>/Configuration/Servers/PFSBaseMap.xml</ResultMap>
                    <PFSDetailMap>/Configuration/Servers/PFSDetailMap.xml</PFSDetailMap>
                    <TestResultConversion>
                        <Pass>P</Pass>
                        <Fail>F</Fail>
                        <Abort>A</Abort>
                        <NotTested>Z</NotTested>
                        <TestInProgress>A</TestInProgress>
                        <Timeout>F</Timeout>
                        <Yes>Y</Yes>
                        <No>N</No>
                    </TestResultConversion>
                    <ComponentNameMapping/>
                    <DataTags>
                        <OverallTest>OverallTest</OverallTest>
                        <MachineNumber>MachineNumber</MachineNumber>
                    </DataTags>
                    <HostCommunication>
                        <Setup>
                            <Communication>
                                <Name>/dev/LogicalPorts/Wcc</Name>
                                <BufferSize>2048</BufferSize>
                                <Timeout>3000</Timeout>
                                <Debug>Off</Debug>
                            </Communication>
                            <Logging>
                                <Debug>Off</Debug>
                                <ProcessName>ALCInterface</ProcessName>
                                <Status>Enabled</Status>
                                <AdditionalLogFile Types="/Server/ALCCommunication.log">/Communication/ALCCommunication.log</AdditionalLogFile>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                            </Logging>
                        </Setup>
                    </HostCommunication>
                    <Communication>
                        <Debug>Off</Debug>
                        <Name>core/AlcInterface</Name>
                        <Type>Server</Type>
                        <Comm>IPC</Comm>
                        <BufferSize>2000</BufferSize>
                        <Timeout>1000</Timeout>
                    </Communication>
                    <Logging>
                        <Status>Enabled</Status>
                        <ProcessName>core/AlcInterface</ProcessName>
                        <AdditionalLogFile>/Servers/AlcInterface.log</AdditionalLogFile>
                        <Debug>Off</Debug>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <ThreadPool>
                        <Debug>Off</Debug>
                        <MinBlockedLimit>1</MinBlockedLimit>
                        <MaxBlockedLimit>3</MaxBlockedLimit>
                        <Increment>1</Increment>
                        <Maximum>5</Maximum>
                    </ThreadPool>
                    <NotificationList>
                        <Setup>
                            <Debug>Off</Debug>
                            <HighWater>3</HighWater>
                            <Increment>1</Increment>
                            <LowWater>1</LowWater>
                            <Maximum>5</Maximum>
                            <StartOnCreate>No</StartOnCreate>
                        </Setup>
                    </NotificationList>
                </Setup>
            </AlcInterface>
            <!-- ============================================================== -->
            <!-- Data Collector Interface                                       -->
            <!-- ============================================================== -->
            <DaqInterface Enabled="0" Process="$(USR_ROOT)/ServicesLayer/Bin/DaqInterface.qxe">
                <Setup>
                    <SendResultsToHost>Yes</SendResultsToHost>
                    <VinIndex>-1</VinIndex>
                    <MachineNumberLength>4</MachineNumberLength>
                    <MeasurementSystem ValidValues="(E)nglish or (M)etric">E</MeasurementSystem>
                    <MaxResponseTime>500</MaxResponseTime>
                    <MaxAttempts>0</MaxAttempts>
                    <ResultMap>/Configuration/Servers/DAQTestResultMap.xml</ResultMap>
                    <LossCompensationResultMap>/Configuration/Servers/DAQLossCompensationMap.xml</LossCompensationResultMap>
                    <MessageID>0x13</MessageID>
                    <TestResultConversion>
                        <Pass>P</Pass>
                        <Fail>F</Fail>
                        <Abort>A</Abort>
                        <NotTested>-</NotTested>
                        <TestInProgress>A</TestInProgress>
                        <Timeout>F</Timeout>
                        <Yes>Y</Yes>
                        <No>N</No>
                    </TestResultConversion>
                    <ComponentNameMapping/>
                    <DataTags>
                        <OverallTest>OverallTest</OverallTest>
                        <MachineNumber>MachineNumber</MachineNumber>
                    </DataTags>
                    <HostCommunication>
                        <Setup>
                            <Communication>
                                <Name>/dev/LogicalPorts/Daq</Name>
                                <BufferSize>2048</BufferSize>
                                <Timeout>500</Timeout>
                                <Debug>Off</Debug>
                            </Communication>
                            <Logging>
                                <Debug>Off</Debug>
                                <ProcessName>DaqInterface</ProcessName>
                                <Status>Enabled</Status>
                                <AdditionalLogFile Types="/Server/DaqInterface.log">/Communication/DAQCommunication.log</AdditionalLogFile>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                            </Logging>
                        </Setup>
                    </HostCommunication>
                    <Communication>
                        <Debug>Off</Debug>
                        <Name>core/DaqInterface</Name>
                        <Type>Server</Type>
                        <Comm>IPC</Comm>
                        <BufferSize>2000</BufferSize>
                        <Timeout>1000</Timeout>
                    </Communication>
                    <Logging>
                        <Status>Enabled</Status>
                        <ProcessName>core/DaqInterface</ProcessName>
                        <AdditionalLogFile>/Servers/DaqInterface.log</AdditionalLogFile>
                        <Debug>Off</Debug>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <ThreadPool>
                        <Debug>Off</Debug>
                        <MinBlockedLimit>1</MinBlockedLimit>
                        <MaxBlockedLimit>3</MaxBlockedLimit>
                        <Increment>1</Increment>
                        <Maximum>5</Maximum>
                    </ThreadPool>
                    <NotificationList>
                        <Setup>
                            <Debug>Off</Debug>
                            <HighWater>3</HighWater>
                            <Increment>1</Increment>
                            <LowWater>1</LowWater>
                            <Maximum>5</Maximum>
                            <StartOnCreate>No</StartOnCreate>
                        </Setup>
                    </NotificationList>
                </Setup>
            </DaqInterface>
        </HostInterfaces>
    </Setup>
</PlantHostOutboundConfig>
