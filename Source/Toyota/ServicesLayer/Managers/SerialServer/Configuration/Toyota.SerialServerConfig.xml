<SerialServerConfig>
   <Verbose>0x01</Verbose>
   <Setup>
      <Demo>0</Demo>
      <MgrPool lowWater="2" hiWater="5" maximum="10" increment="1"/>
      <Logging>
         <ProcessName>mgr/SerialServer</ProcessName>
         <AdditionalLogFile>/Servers/SerialServer.log</AdditionalLogFile>
         <Status>Enabled</Status>
         <LocalEcho>Disabled</LocalEcho>
         <Debug>Off</Debug>
         <Verbose>0x01</Verbose>
      </Logging>
      <LogicalPorts>
		 <PlcToyopuc enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/TcpCommProxy.qxe">
				<Setup>
					<SerialDevice>/dev/socket</SerialDevice>
					<MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
					<IpAddress>192.168.110.76</IpAddress>
					<PortNo>4096</PortNo>
					<TcpType>Client</TcpType>
					<Protocol>
						<Baud>19200</Baud>
						<Parity>None</Parity>
						<DataBits>8</DataBits>
						<StopBits>1</StopBits>
						<Reflection>0</Reflection>
						<ByteGap>0</ByteGap>
						<MssgGap>0</MssgGap>
						<Interrupts>TxRx</Interrupts>
						<FifoSize>1024</FifoSize>
					</Protocol>
					<Logging>
						<ProcessName>logport/PlcToyopuc</ProcessName>
						<AdditionalLogFile>/Servers/PlcToyopuc.log</AdditionalLogFile>
						<Status>Disabled</Status>
						<LocalEcho>Disabled</LocalEcho>
						<Verbose>0x3F</Verbose>
					</Logging>
					<CommLog>
						<ContentType>RAW</ContentType>
						<Setup>
							<Logging>
								<AdditionalLogFile>/Communication/PlcToyopuc_BusComm.log</AdditionalLogFile>
								<Status>Disabled</Status>
								<LocalEcho>Disabled</LocalEcho>
								<Verbose>0x1F</Verbose>
								<Debug>Off</Debug>
							</Logging>
						</Setup>
					</CommLog>
				</Setup>
			</PlcToyopuc>
         <Scanner enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
            <Setup>
                  <SerialDevice>/dev/sl7804/ser1</SerialDevice>
               <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
               <Protocol>
                  <Baud>9600</Baud>
                  <Parity>None</Parity>
                  <DataBits>8</DataBits>
                  <StopBits>1</StopBits>
                  <Reflection>0</Reflection>
                  <ByteGap>0</ByteGap>
                  <MssgGap>0</MssgGap>
                  <Interrupts>Rx</Interrupts>
                  <FifoSize>1024</FifoSize>
               </Protocol>
               <Logging>
                  <ProcessName>logport/Scanner</ProcessName>
                  <AdditionalLogFile>/Servers/ScannerComm.log</AdditionalLogFile>
                  <Status>Enabled</Status>
                  <LocalEcho>Disabled</LocalEcho>
                     <Verbose>0x01</Verbose>
               </Logging>
               <CommLog>
                  <ContentType>RAW</ContentType>
                  <Setup>
                     <Logging>
                        <AdditionalLogFile>/Communication/Scanner_BusComm.log</AdditionalLogFile>
                        <ProcessName>Scanner</ProcessName>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                           <Verbose>0x1F</Verbose>
                        <Debug>Off</Debug>
                     </Logging>
                  </Setup>
               </CommLog>
            </Setup>
         </Scanner>
      </LogicalPorts>
   </Setup>
</SerialServerConfig>
