                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
