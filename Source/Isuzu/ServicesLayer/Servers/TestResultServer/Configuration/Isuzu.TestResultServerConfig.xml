<TestResultServerConfig>
    <Setup>
        <AddForceArray Value="Yes or No">No</AddForceArray>
        <AddSpeedArray Value="Yes or No">No</AddSpeedArray>
        <SpeedArrayPath>/TestResults/Machine/BrakeForceData/Speed.log</SpeedArrayPath>
        <ForceArrayPath>/TestResults/Machine/BrakeForceData/BrakeForce.log</ForceArrayPath>
        <Debug>Off</Debug>
        <IncludeAbortInAllFailures Value="Yes or No">Yes</IncludeAbortInAllFailures>
        <VINLength>17</VINLength>
        <UpdateTestLampStatus Value="Yes or No">No</UpdateTestLampStatus>
        <CreatePassConfirmationFile>True</CreatePassConfirmationFile>
        <Communication>
            <Comm>IPC</Comm>
            <Debug>Off</Debug>
            <Name>core/TestResultServer</Name>
            <BufferSize>2000</BufferSize>
            <Timeout>1000</Timeout>
            <Type>Server</Type>
        </Communication>
        <DataTags>
            <AllFailures>AllFailures</AllFailures>
            <ClearScrollBox>ClearScrollBox</ClearScrollBox>
            <DateFormat>%Y%m%d</DateFormat>
            <DriveCurve>DriveCurve</DriveCurve>
            <DriverNumber>DriverNumber</DriverNumber>
            <Error>Error</Error>
            <ErrorCodeTest>ErrorCodeTest</ErrorCodeTest>
            <KeyPress>KeyPress</KeyPress>
            <OverallTest>OverallTest</OverallTest>
            <StartRetest>StartRetest</StartRetest>
            <StartTest>StartVehicleTest</StartTest>
            <VehicleBuild>VehicleBuild</VehicleBuild>
            <Vin>VIN</Vin>
        </DataTags>
        <Logging>
            <Debug>Off</Debug>
            <AdditionalLogFile>/Servers/TestResultServer.log</AdditionalLogFile>
            <ProcessName>core/TestResultServer</ProcessName>
            <Status>Enabled</Status>
            <LocalEcho>Disabled</LocalEcho>
         <Verbose>0x03</Verbose>
        </Logging>
        <TagList>
            <SubscribeTags>
                <CycleTime/>
                <DriveCurve/>
                <DriverNumber/>
                <KeyPress/>
                <OverallTest/>
                <StartLossCompensation/>
                <StartRetest/>
                <StartVehicleTest/>
                <VehicleBuild/>
                <VIN/>
                <IntermediateOverallResult/>
            </SubscribeTags>
        </TagList>
        <VehicleBuildItems>
            <DriveCurve/>
            <CycleTime/>
        </VehicleBuildItems>
        <TestResults>
            <NumberOfTests>1000</NumberOfTests>
            <PassConfirmationFilePath>/home/CCRT/Rewrite/TestResults/PassConfirmation/</PassConfirmationFilePath>
            <TestResultFile>TestResultIndex</TestResultFile>
            <TestResultPath>/TestResults/Vehicle/</TestResultPath>
        </TestResults>
        <ThreadPool>
            <Debug>Off</Debug>
            <Increment>2</Increment>
            <MaxBlockedLimit>7</MaxBlockedLimit>
            <Maximum>10</Maximum>
            <MinBlockedLimit>2</MinBlockedLimit>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
    </Setup>
</TestResultServerConfig>
