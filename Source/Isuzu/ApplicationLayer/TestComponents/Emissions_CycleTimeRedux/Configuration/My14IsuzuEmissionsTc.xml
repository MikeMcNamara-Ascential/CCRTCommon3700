            <MaximumBarometricPressure Units="kPa" TestSteps="CheckBarometricPressure" Comment="Maximum barometric pressure">120</MaximumBarometricPressure>
            <!-- CASE Learn Parameters -->
            <CaseLearnCompleteValue Comment="Value to indicate CASE Learn has successfully completed" TestSteps="CheckCASELearn">0x80</CaseLearnCompleteValue>
            <CaseLearnInProgressMask Comment="Mask to use to determine if CASE learn is still in progress" TestSteps="CheckCASELearn">0x40</CaseLearnInProgressMask>
            <CaseLearnStartDelay Comment="Amount of time to wait for the module to start the CASE learn process" Units="ms" TestSteps="CheckCASELearn">2000</CaseLearnStartDelay>
