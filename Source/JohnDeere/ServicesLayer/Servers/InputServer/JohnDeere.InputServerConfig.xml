<InputServerConfig>
    <Setup>
        <Debug>Off</Debug>
        <PlantHostInboundName>None</PlantHostInboundName>
        <InputDevices>
            <!-- ******************************************************* -->
            <!-- *                   Handheld Scanner                  * -->
            <!-- ******************************************************* -->
            <LeftHandheld enabled="1" process="$(USR_ROOT)/ServicesLayer/Bin/SymbolScannerMgr.qxe">
                <Setup>
                    <Communication>
                        <Debug>Off</Debug>
                        <Name>core/LeftSymbolScanner</Name>
                        <Type>Server</Type>
                        <Comm>IPC</Comm>
                        <BufferSize>2000</BufferSize>
                        <Timeout>1000</Timeout>
                    </Communication>
                    <Logging>
                        <Status>Enabled</Status>
                        <ProcessName>core/LeftSymbolScanner</ProcessName>
                        <AdditionalLogFile>/Servers/LeftSymbolScanner.log</AdditionalLogFile>
                        <Debug>Off</Debug>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <ThreadPool>
                        <Debug>Off</Debug>
                        <MinBlockedLimit>1</MinBlockedLimit>
                        <MaxBlockedLimit>3</MaxBlockedLimit>
                        <Increment>1</Increment>
                        <Maximum>5</Maximum>
                    </ThreadPool>
                    <NotificationList>
                        <Setup>
                            <Debug>Off</Debug>
                            <HighWater>3</HighWater>
                            <Increment>1</Increment>
                            <LowWater>1</LowWater>
                            <Maximum>5</Maximum>
                            <StartOnCreate>No</StartOnCreate>
                        </Setup>
                    </NotificationList>
                    <ScannerCommunication>
                        <Setup>
                            <Communication>
                                <Debug>Off</Debug>
                                <Name>/dev/LogicalPorts/LeftScanner</Name>
                                <BufferSize>128</BufferSize>
                                <Timeout>10000</Timeout>
                            </Communication>
                            <Logging>
                                <Status>Enabled</Status>
                                <ProcessName>LeftSymbolScanner</ProcessName>
                                <AdditionalLogFile Types="/Servers/SymbolScanner.log or Disabled">/Servers/LeftSymbolScanner.log</AdditionalLogFile>
                                <Debug>Off</Debug>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                            </Logging>
                        </Setup>
                    </ScannerCommunication>
                    <DataDelay>3000</DataDelay>
                    <VinLength>17</VinLength>
                    <DriverNumberLength>7</DriverNumberLength>
                    <MaximumRetries>3</MaximumRetries>
                    <LookForCarriageReturn>Yes</LookForCarriageReturn>
                    <CorrectBadScannerData>No</CorrectBadScannerData>
                    <BadDataIndex>0x01</BadDataIndex>
                    <BadDataIndicator>0x00</BadDataIndicator>
                    <BadDataReplacementValue>0x31</BadDataReplacementValue>
                    <SecondaryDataTag>VCNumber</SecondaryDataTag>
                    <SecondaryDataLength>10</SecondaryDataLength>
                </Setup>
            </LeftHandheld>
        </InputDevices>
        <DataTags>
            <Vin>NextVIN</Vin>
            <VinDisplay>VINDisplay</VinDisplay>
            <DriverNumber>DriverNumber</DriverNumber>
            <ClearKeyPress>ClearKeyPress</ClearKeyPress>
            <InputServerState>InputServerState</InputServerState>
            <DriverNumberDisplay>DriverNumberDisplay</DriverNumberDisplay>
            <VehicleAtBarcodeScanner>VehicleAtBarcodeScanner</VehicleAtBarcodeScanner>
            <VehicleBuildRecordStatus>VehicleBuildRecordStatus</VehicleBuildRecordStatus>
            <RollsDownElevUp>RollsDownElevUp</RollsDownElevUp>
            <CableConnect>CableConnect</CableConnect>
            <VehiclePresent>VehiclePresent</VehiclePresent>
        </DataTags>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>core/InputServer</ProcessName>
            <AdditionalLogFile Types="/Servers/InputServer.log or Disabled">/Servers/InputServer.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbosity>0x1F</Verbosity>
        </Logging>
        <TagList>
            <SubscribeTags>
                <VehicleAtBarcodeScanner/>
                <VehicleBuildRecordStatus/>
                <RollsDownElevUp/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>1</MinBlockedLimit>
            <MaxBlockedLimit>3</MaxBlockedLimit>
            <Increment>1</Increment>
            <Maximum>5</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <Communication>
            <Debug>Off</Debug>
            <Name>core/InputServer</Name>
            <Type>Server</Type>
            <Comm>IPC</Comm>
            <BufferSize>2000</BufferSize>
            <Timeout>1000</Timeout>
        </Communication>
    </Setup>
</InputServerConfig>
