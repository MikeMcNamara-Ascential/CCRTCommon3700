<MachineComponent>
    <Setup>
        <Name>Machine</Name>
        <Debug>Off</Debug>
        <DebugLevel>0</DebugLevel>
        <ProcessPriority>11</ProcessPriority>
        <Communication>
            <Name>component/MachineComponent</Name>
            <Comm>IPC</Comm>
            <Debug>Off</Debug>
            <Type>Server</Type>
            <BufferSize>1024</BufferSize>
            <Timeout>0</Timeout>
        </Communication>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>50</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <Logging>
            <Debug>Off</Debug>
            <MessageTimeout>100</MessageTimeout>
            <AdditionalLogMaxSize>10</AdditionalLogMaxSize>
            <AdditionalLogMaxFiles>5</AdditionalLogMaxFiles>
            <ProcessName>MachineComponent</ProcessName>
            <Status>Enabled</Status>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
            <AdditionalLogFile>/Components/MachineComponent.log</AdditionalLogFile>
        </Logging>
        <TagList>
            <!-- There are no publish tags for the Machine test component -->
            <PublishTags/>
            <SubscribeTags>
                <Abort/>
                <CableConnect/>
                <Clutch/>
                <Declutch/>
                <DriveAxle/>
                <DriverFail/>
                <DriverNumber/>
                <DriverPass/>
                <ForegroundTestInProgress/>
                <KeyPress/>
                <MachineNumber/>
                <MachineType/>
                <ParkingBrakeTestFailed/>
                <ParkingBrakeTestPass/>
                <ParkPawlTestFail/>
                <ParkPawlTestPass/>
                <SoftwareID/>
                <Start40kphTest/>
                <Zerospeed/>
                <ZerospeedToPLC/>
            </SubscribeTags>
        </TagList>

        <DataTags>
            <CableConnect>CableConnect</CableConnect>
            <DriveAxle>DriveAxle</DriveAxle>
            <DriverNumber>DriverNumber</DriverNumber>
            <DriverNumberBGColor>DriverNumberDisplayBGColor</DriverNumberBGColor>
            <DriverNumberMode>DriverNumber</DriverNumberMode>
            <Fail>red</Fail>
            <ForegroundTestInProgress>ForegroundTestInProgress</ForegroundTestInProgress>
            <FourWDSelected>FourWDSelected</FourWDSelected>
            <FourWheelDriveEquipped>FourWDSelected</FourWheelDriveEquipped>
            <HornSignal>Start40kphTest</HornSignal>
            <HydraulicPumpMotor>HydraulicPumptMotor</HydraulicPumpMotor>
            <InputServerState>InputServerState</InputServerState>
            <KeyPress>KeyPress</KeyPress>
            <LFSpeed>LFSpeed</LFSpeed>
            <LRSpeed>LRSpeed</LRSpeed>
            <MachineNumber>MachineNumber</MachineNumber>
            <MachineType>MachineType</MachineType>
            <MachineType3600>3600</MachineType3600>
            <NormalMode>Normal</NormalMode>
            <NoValue>Fail</NoValue>
            <ParkingBrakeTest>ParkingBrakeTest</ParkingBrakeTest>
            <ParkingBrakeTestFail>ParkingBrakeTestFailed</ParkingBrakeTestFail>
            <ParkingBrakeTestFailed>ParkingBrakeTestFailed</ParkingBrakeTestFailed>
            <ParkingBrakeTestPass>ParkingBrakeTestPass</ParkingBrakeTestPass>
            <ParkPawlTest>StartParkingPawlTest</ParkPawlTest>
            <ParkPawlTestFail>ParkingPawlTestFailed</ParkPawlTestFail>
            <ParkPawlTestPass>ParkingPawlTestPassed</ParkPawlTestPass>
            <Pass>green</Pass>
            <Rear>Rear</Rear>
            <RFSpeed>RFSpeed</RFSpeed>
            <RighthandDriveSelected>RighthandDriveSelected</RighthandDriveSelected>
            <RRSpeed>RRSpeed</RRSpeed>
            <ServerStateDriverNumber>DriverNumber</ServerStateDriverNumber>
            <ServerStateNormal>Normal</ServerStateNormal>
            <SoftwareVersion>SoftwareID</SoftwareVersion>
            <SpeedTarget>SpeedTarget</SpeedTarget>
            <Start40kphTest>Start40kphTest</Start40kphTest>
            <Start4WDTestSignalToPLC>Start4WDTestSignalToPLC</Start4WDTestSignalToPLC>
            <TagIndex>TagIndex</TagIndex>
            <TestResultMode>TestResult</TestResultMode>
            <TestResultBox3>SpeedoTestBGColor</TestResultBox3>
            <YesValue>Pass</YesValue>
            <Zerospeed>Zerospeed</Zerospeed>
            <YesButton>DriverPass</YesButton>
            <NoButton>DriverFail</NoButton>
        </DataTags>


        <Parameters>
            <AccelerateToTargetSpeedPrompt>AccelerateToTargetSpeed</AccelerateToTargetSpeedPrompt>
            <BlindSpeedoTest>True</BlindSpeedoTest>
            <BrakeToStopPrompt>BrakeToStop</BrakeToStopPrompt>
            <CurrentDistances>/dev/Icm/Block/PulseCount</CurrentDistances>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <DateFormat>%F</DateFormat>
            <DcxStyleSpeedoTest>False</DcxStyleSpeedoTest>
            <ForcedAccelerateSpeedStep>10</ForcedAccelerateSpeedStep>
            <ForcedAccelerateSpeedStepDelay>500</ForcedAccelerateSpeedStepDelay>
            <ICMName>mgr/ICM</ICMName>
            <KeepTestStatusOnExit>0</KeepTestStatusOnExit>
            <LogTaskStatInfo>Yes</LogTaskStatInfo>
            <MaintainSpeedMaxSpeed>35</MaintainSpeedMaxSpeed>
            <MaintainSpeedMinSpeed>25</MaintainSpeedMinSpeed>
            <MaintainSpeedTime>1000</MaintainSpeedTime>
            <MaxHydraulicBoostPressure>800</MaxHydraulicBoostPressure>
            <MotorLoadingAccelConst>0.0</MotorLoadingAccelConst>
            <MotorLoadingSpeedConst>0.0</MotorLoadingSpeedConst>
            <ParkBrakeApplyForce>250</ParkBrakeApplyForce>
            <ParkBrakeDriverDelay>2000</ParkBrakeDriverDelay>
            <ParkBrakeMaxDistance>20</ParkBrakeMaxDistance>
            <ParkBrakeMinDistance>50</ParkBrakeMinDistance>
            <ParkBrakePrepTime>5000</ParkBrakePrepTime>
            <ParkBrakeSpeedValue>5</ParkBrakeSpeedValue>
            <ParkPawlApplyForce>250</ParkPawlApplyForce>
            <ParkPawlDriverDelay>2000</ParkPawlDriverDelay>
            <ParkPawlMaxDistance>20</ParkPawlMaxDistance>
            <ParkPawlMinDistance>50</ParkPawlMinDistance>
            <ParkPawlPrepTime>5000</ParkPawlPrepTime>
            <ParkPawlSpeedValue>5</ParkPawlSpeedValue>
            <PreForcedAccelerateWait>3000</PreForcedAccelerateWait>
            <ReleaseParkBrakePrompt>ReleaseParkBrake</ReleaseParkBrakePrompt>
            <ResetCommHardware Values="Yes or No">No</ResetCommHardware>
            <ReverseSpeedTarget>5 10</ReverseSpeedTarget>
            <ReverseTestSpeed>5</ReverseTestSpeed>
            <ScanDelayParameter>500</ScanDelayParameter>
            <SetOperatorConsoleTo4WDPrompt>SetOperatorConsoleTo4WD</SetOperatorConsoleTo4WDPrompt>
         <SpeedometerSpeedTarget>21.25 24.37</SpeedometerSpeedTarget>
            <SpeedometerStableTime>3000</SpeedometerStableTime>
         <SpeedometerTestHighLimit>24.37</SpeedometerTestHighLimit>
         <SpeedometerTestLowLimit>21.25</SpeedometerTestLowLimit>
            <SpeedRangeParameter>33 35</SpeedRangeParameter>
            <TargetSpeed40kph>24.85</TargetSpeed40kph>
            <TargetSpeedParameter>30</TargetSpeedParameter>
            <TimeFormat>%H:%M:%S</TimeFormat>
            <UnidirectionalParkBrakeTest>No</UnidirectionalParkBrakeTest>
            <UnidirectionalParkPawlTest>No</UnidirectionalParkPawlTest>
            <UsePlcYesNoButtons>True</UsePlcYesNoButtons>
        </Parameters>

        <FaultList>/Configuration/Components/Common/SampleFaultList.xml</FaultList>

        <Prompts>
            <AccelerateToTargetSpeed PromptBox="1" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <CableConnect PromptBox="1" Priority="0">CableDisconnected</CableConnect>
            <EnterYesOrNo PromptBox="1" Priority="0">EnterYesOrNo</EnterYesOrNo>
            <MaintainSpeed PromptBox="1" Priority="0">MaintainSpeed</MaintainSpeed>
            <NeutralPrompt PromptBox="1" Priority="0">ShiftToNeutral</NeutralPrompt>
            <PassOrFail PromptBox="1" Priority="0">OverallPassOrFail</PassOrFail>
            <RemoveFootFromBrake PromptBox="1" Priority="0">RemoveFootFromBrake</RemoveFootFromBrake>
            <ShiftToReverse PromptBox="1" Priority="0">ApplyBrakeShiftToReverse</ShiftToReverse>
            <SlowDownToTargetSpeed PromptBox="1" Priority="0">SlowDownToTargetSpeed</SlowDownToTargetSpeed>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
        </Prompts>

        <StatusCheckItems>
            <VehiclePresent>1</VehiclePresent>
            <RollsUpElevDown>1</RollsUpElevDown>
        </StatusCheckItems>

        <TestDomain>Foreground</TestDomain>
        <SystemTagsToReset>
            <VINDisplayBGColor>white</VINDisplayBGColor>
            <SpeedoTestBGColor>white</SpeedoTestBGColor>
            <SpeedoTestValue>0</SpeedoTestValue>
            <LeftFrontTpmsCount>0</LeftFrontTpmsCount>
            <LeftFrontTpmsCountBgColor>white</LeftFrontTpmsCountBgColor>
            <LeftRearTpmsCount>0</LeftRearTpmsCount>
            <LeftRearTpmsCountBgColor>white</LeftRearTpmsCountBgColor>
            <RightFrontTpmsCount>0</RightFrontTpmsCount>
            <RightFrontTpmsCountBgColor>white</RightFrontTpmsCountBgColor>
            <RightRearTpmsCount>0</RightRearTpmsCount>
            <RightRearTpmsCountBgColor>white</RightRearTpmsCountBgColor>
        </SystemTagsToReset>
        <TaskMon>
            <Name>MachineTc</Name>
        </TaskMon>
    </Setup>




