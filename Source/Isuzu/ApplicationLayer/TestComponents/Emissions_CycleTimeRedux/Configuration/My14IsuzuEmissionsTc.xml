            <MaximumActualFanSpeed Units="RPM" TestSteps="CheckEngineFan" Comment="Maximum actual fan speed">2000</MaximumActualFanSpeed>
            <MinimumDesiredFanSpeed Units="RPM" TestSteps="CheckEngineFan" Comment="Minimum Desired fan speed">100</MinimumDesiredFanSpeed>
            <MaximumDesiredFanSpeed Units="RPM" TestSteps="CheckEngineFan" Comment="Maximum Desired fan speed">2000</MaximumDesiredFanSpeed>
            <FanSpeedToleranceRPM Units="RPM" TestSteps="CheckEngineFan" Comment="fan speed tolerance to compare actual to desired">100</FanSpeedToleranceRPM>
            <!-- WOT Testing Parameters -->
            <AcceleratorPedalWOTTestMin>98</AcceleratorPedalWOTTestMin>
            <AcceleratorPedalWOTTestMax>200</AcceleratorPedalWOTTestMax>
            <!-- EGR Parameters -->
            <MinimumEgrError Units="%">0</MinimumEgrError>
            <MaximumEgrError Units="%">10</MaximumEgrError>
            <!-- Engine RPM Parameters -->
