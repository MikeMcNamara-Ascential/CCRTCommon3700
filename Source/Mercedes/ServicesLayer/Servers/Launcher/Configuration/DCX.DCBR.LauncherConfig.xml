        <ElectricMotorController Name="ABMotorController.qxe" Path="/ServicesLayer/Bin/" ConfigFile="ABMotorControllerConfig.xml" ConfigPath="/Configuration/Servers/" OrderToLaunch="0113" RegisteredName="core/MotorController" Register="Yes" DemoMode="" ConsoleMode="" AddressValue="" PortValue="" VerboseMode="">Electric Motor Controller</ElectricMotorController>
        <PlantHostOutbound Name="PlantHostOutbound.qxe" Path="/ServicesLayer/Bin/" ConfigFile="PlantHostOutboundConfig.xml" ConfigPath="/Configuration/Servers/" OrderToLaunch="0111" RegisteredName="core/PlantHostOutbound" Register="Yes" DemoMode="Off" ConsoleMode="Off" AddressValue="" PortValue="" VerboseMode="">DC PFS and DataCollector Results</PlantHostOutbound>
    </TasksToLaunch>
    <TasksNotToLaunch>
        <MotorController Name="HydraulicMotorController.qxe" Path="/ServicesLayer/Bin/" ConfigFile="HydraulicMotorControllerConfig.xml" ConfigPath="/Configuration/Servers/" OrderToLaunch="0113" RegisteredName="core/MotorController" Register="Yes" DemoMode="Off" ConsoleMode="Off" AddressValue="" PortValue="" VerboseMode="">Hydraulic Motor Controller</MotorController>
        <SciIsoMuxMgr Name="SciIsoMuxMgr.qxe" Path="/ServicesLayer/Bin/" ConfigFile="SciIsoMuxConfig.xml" ConfigPath="/Configuration/Servers/" OrderToLaunch="0004" RegisteredName="mgr/MuxCtrl" Register="Yes" DemoMode="Off" ConsoleMode="Off" AddressValue="" PortValue="" VerboseMode="">SCI/ISO Multiplexer Board Manager</SciIsoMuxMgr>
        <StaticTesterServer Name="StaticTesterServer.qxe" Path="/ServicesLayer/Bin/" ConfigFile="DCX.DCBR.StaticTesterServerConfig.xml" ConfigPath="/Configuration/Servers/" OrderToLaunch="0114" RegisteredName="core/StaticTesterServer" Register="Yes" DemoMode="Off" ConsoleMode="Off" AddressValue="" PortValue="" VerboseMode="">Static Tester Server</StaticTesterServer>
    </TasksNotToLaunch>
</LauncherConfig>
