            <MinimumEngineCoolantTemperature Units="C" TestSteps="CheckEngineCoolantTemperature,WaitForEngineTemperature" Comment="Minimum operating engine coolant temperature">70</MinimumEngineCoolantTemperature>
            <MaximumEngineCoolantTemperature Units="C" TestSteps="CheckEngineCoolantTemperature,WaitForEngineTemperature" Comment="Maximum operating engine coolant temperature">115</MaximumEngineCoolantTemperature>
            <!-- Engine Oil Temperature Parameters -->
            <EngineOilTemperatureUnits>C</EngineOilTemperatureUnits>
            <MinimumEngineOilTemperature Units="C" TestSteps="CheckEngineOilTemperature" Comment="Minimum operating engine oil temperature">0</MinimumEngineOilTemperature>
            <MaximumEngineOilTemperature Units="C" TestSteps="CheckEngineOilTemperature" Comment="Maximum operating engine oil temperature">210</MaximumEngineOilTemperature>
            <!-- Engine Oil Pressure Parameters -->
            <EngineOilPressureUnits>kPa</EngineOilPressureUnits>
            <MinimumEngineOilPressure Units="kPa" TestSteps="CheckEngineOilPressure" Comment="Minimum operating engine oil pressure">100</MinimumEngineOilPressure>
            <MaximumEngineOilPressure Units="kPa" TestSteps="CheckEngineOilPressure" Comment="Maximum operating engine oil pressure">250</MaximumEngineOilPressure>
            <EngineOilLevelLowCompareValue>True</EngineOilLevelLowCompareValue>
            <EngineOilPressureLowCompareValue>True</EngineOilPressureLowCompareValue>
            <PedalPositionSensorsAgreeCompareValue>False</PedalPositionSensorsAgreeCompareValue>
            <ThrottlePositionSensorsAgreeCompareValue>False</ThrottlePositionSensorsAgreeCompareValue>
