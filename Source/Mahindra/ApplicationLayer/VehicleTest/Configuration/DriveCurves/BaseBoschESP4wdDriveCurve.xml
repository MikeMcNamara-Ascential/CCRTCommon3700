<DriveCurve Description="4WD BIABS brake drive curve">

	<Components Debug="Off">
		<Brake>
			<ComponentName>Bosch8TC.qxe</ComponentName>
			<ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
			<ConfigFile>BoschEspTC.xml</ConfigFile>
			<ConfigPath>/Configuration/Components/Brake/</ConfigPath>
			<Debug>Off</Debug>
		</Brake>
		<Machine>
			<ComponentName>MachineTC.qxe</ComponentName>
			<ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
			<ConfigFile>MachineTc.xml</ConfigFile>
			<ConfigPath>/Configuration/Components/Machine/</ConfigPath>
			<Debug>Off</Debug>
		</Machine>
		<TCase>
			<ComponentName>GenericTcaseTest.qxe</ComponentName>
			<ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
			<ConfigFile>MahindraTcaseTc.xml</ConfigFile>
			<ConfigPath>/Configuration/Components/TransferCase/</ConfigPath>
			<Debug>Off</Debug>
		</TCase>
		<Transmission>
			<ComponentName>ManualTransTC.qxe</ComponentName>
			<ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
			<ConfigFile>ManualTransmissionConfig.xml</ConfigFile>
			<ConfigPath>/Configuration/Components/Transmission/</ConfigPath>
			<Debug>Off</Debug>
		</Transmission>
	</Components>

	<Test Result="" Debug="Off">
		<!-- Initialize the system -->
		<TestPhase000 Description="Initialize the machine" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="Init machine Component" Result="" Timeout="" Component="Machine">
					<InitializeAndSelectDriverSide/>
				</Objective0>
			</ForegroundObjectives>
		</TestPhase000>
		<TestPhase005 Description="Initialize the brake test" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="Init brake Component" Result="" Timeout="" Component="Brake">
					<Setup/>
				</Objective0>
			</ForegroundObjectives>
		</TestPhase005>

		<TestPhase090 Description="Sensor Test" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="Perform the sensor test" Result="" Timeout="" Component="Brake">
					<WheelSpeedSensorTest/>
				</Objective0>
			</ForegroundObjectives>
		</TestPhase090>

		<!-- <TestPhase095 Description="Perform Low Speed Valve Firing Test" Result="" Timeout=""> -->
		<!-- <ForegroundObjectives Result="" Timeout=""> -->
		<!-- <Objective0 Description="Low Speed Valve Fire" Result="" Timeout="" Component="Brake"> -->
		<!-- <LowSpeedValveFiringTest/> -->
		<!-- </Objective0> -->
		<!-- </ForegroundObjectives> -->
		<!-- </TestPhase095>		 -->

		<!-- Perform the transmission testing -->
		<!-- <TestPhase100 Description="Perform the transmission gear test" Result="" Timeout=""> -->
			<!-- <ForegroundObjectives Result="" Timeout=""> -->
				<!-- <Objective0 Description="Run the transmission gear test" Result="" Timeout="" Component="Transmission"> -->
					<!-- <SpeedBasedShiftTest6Gear/> -->
				<!-- </Objective0> -->
			<!-- </ForegroundObjectives> -->
		<!-- </TestPhase100> -->

		<!-- Perform the brake test -->
		<TestPhase200 Description="Perform the brake test" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="run the base brake test" Result="" Timeout="" Component="Brake">
					<BrakeTest/>
				</Objective0>
			</ForegroundObjectives>
		</TestPhase200>

		<TestPhase205 Description="Brake to stop and analyze results" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
					<BrakeToStop/>
				</Objective0>
			</ForegroundObjectives>
			<BackgroundObjectives Result="" Timeout="">
				<Objective0 Description="Analyze brake test data" Result="" Timeout="" Component="Brake">
					<AnalyzeBrakeTest/>
				</Objective0>
			</BackgroundObjectives>
		</TestPhase205>

		<!-- Perform the transmission testing -->
		<!-- <TestPhase207 Description="Perform the transmission gear test" Result="" Timeout=""> -->
			<!-- <ForegroundObjectives Result="" Timeout=""> -->
				<!-- <Objective0 Description="Run the transmission gear test" Result="" Timeout="" Component="Transmission"> -->
					<!-- <SpeedBasedShiftTest6Gear/> -->
				<!-- </Objective0> -->
			<!-- </ForegroundObjectives> -->
		<!-- </TestPhase207> -->


		<!-- <TestPhase210 Description="Engage the machine" Result="" Timeout=""> -->
			<!-- <ForegroundObjectives Result="" Timeout=""> -->
				<!-- <Objective0 Description="Engage the machine" Result="" Timeout="" Component="Machine"> -->
					<!-- <EngageMachine/> -->
				<!-- </Objective0> -->
			<!-- </ForegroundObjectives> -->
		<!-- </TestPhase210> -->

		<!-- Final Low Speed Testing -->
		<TestPhase310 Description="Finishup the transmission testing and run the park brake test" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="Set the transmission result" Result="" Timeout="" Component="Transmission">
					<FinishUp/>
				</Objective0>
				<!-- <Objective1 Description="Perform the park brake test" Result="" Timeout="" Component="Brake"> -->
					<!-- <ParkBrakeTest/> -->
				<!-- </Objective1> -->
			</ForegroundObjectives>
		</TestPhase310>
		<!-- <TestPhase320 Description="4HI t-case test" Result="" Timeout=""> -->
			<!-- <ForegroundObjectives Result="" Timeout=""> -->
				<!-- <Objective0 Description="4-HI T-case test" Result="" Timeout="" Component="TCase"> -->
					<!-- <Tcase4HiTest/> -->
				<!-- </Objective0> -->
			<!-- </ForegroundObjectives> -->
		<!-- </TestPhase320> -->
		<!-- <TestPhase325 Description="Brake to stop and analyze results" Result="" Timeout=""> -->
			<!-- <ForegroundObjectives Result="" Timeout=""> -->
				<!-- <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine"> -->
					<!-- <BrakeToStop/> -->
				<!-- </Objective0> -->
			<!-- </ForegroundObjectives> -->
		<!-- </TestPhase325> -->
		<!-- <TestPhase330 Description="4LO t-case test" Result="" Timeout=""> -->
			<!-- <ForegroundObjectives Result="" Timeout=""> -->
				<!-- <Objective0 Description="4-LOW T-case test" Result="" Timeout="" Component="TCase"> -->
					<!-- <Tcase4LoTest/> -->
				<!-- </Objective0> -->
			<!-- </ForegroundObjectives> -->
		<!-- </TestPhase330> -->

		<!-- Finishup and set results -->
		<TestPhase400 Description="Set the result for the brake test" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="Set the brake test result" Result="" Timeout="" Component="Brake">
					<FinishUp/>
				</Objective0>
			</ForegroundObjectives>
		</TestPhase400>
		<TestPhase500 Description="Disconect Cable" Result="" Timeout="">
			<ForegroundObjectives Result="" Timeout="">
				<Objective0 Description="PromptDriver To Remove Cable" Result="" Timeout="" Component="Machine">
					<DisconnectCable/>
				</Objective0>
			</ForegroundObjectives>
		</TestPhase500>

	</Test>

</DriveCurve>
