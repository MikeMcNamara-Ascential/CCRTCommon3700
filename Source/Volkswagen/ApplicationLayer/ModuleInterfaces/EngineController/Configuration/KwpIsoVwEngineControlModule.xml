<VwEngineControlModule>
    <Setup>
        <ModuleKeepAliveTime>200</ModuleKeepAliveTime>
        <KeepAliveResponseRequired>Yes</KeepAliveResponseRequired>
        <DataByteCountIndex>3</DataByteCountIndex>
        <DataStartIndex>3</DataStartIndex>
        <DataHeaderLength>3</DataHeaderLength>
        <CheckSumLength>1</CheckSumLength>
        <NumberOfRetries>3</NumberOfRetries>
        <ValidResponseOffset>0x40</ValidResponseOffset>
        <SentMessageIdentifierIndex>1</SentMessageIdentifierIndex>
        <NegativeResponseValue>0x7F</NegativeResponseValue>
        <NegativeResponseCodeIndex>2</NegativeResponseCodeIndex>
        <ModuleResponseDelay>100</ModuleResponseDelay>
        <ModuleResponseEndDelay>100</ModuleResponseEndDelay>
        <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
        <DtcData>
            <DtcCountIndex>1</DtcCountIndex>
            <BytesPerDtc>3</BytesPerDtc>
            <DtcStartByte>2</DtcStartByte>
        </DtcData>
        <Communication>
            <Debug>Off</Debug>
            <Name>ISOK</Name>
            <BufferSize>4096</BufferSize>
            <CommSize>1</CommSize>
            <Timeout>10000000</Timeout>
            <Retries>3</Retries>
        </Communication>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>VwEngineModule</ProcessName>
            <AdditionalLogFile>/Communication/VwEngineModule.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
        <NegativeResponseCodes>
            <Code_0x11>Test mode not supported</Code_0x11>
            <Code_0x12>SubFunction Not Supported / Invalid Format</Code_0x12>
            <Code_0x21>Busy, Repeat Request</Code_0x21>
            <Code_0x22>Conditions Not Correct or Request Sequence Error</Code_0x22>
            <Code_0x31>Request data is out of range - e. g. control parameter</Code_0x31>
            <Code_0x33>Requested operation is secured and security access has not been granted</Code_0x33>
            <Code_0x35>Invalid security key</Code_0x35>
            <Code_0x36>Number of attempts has been exceeded</Code_0x36>
            <Code_0x37>Required t ime delay not expired</Code_0x37>
            <Code_0x50>Upload not accepted - the data for the data block identifier and data block index could not be read</Code_0x50>
            <Code_0x78>Request received - response pending</Code_0x78>
            <Code_0x90>Engine is running</Code_0x90>
            <Code_0x91>Engine is not running</Code_0x91>
            <Code_0x92>Vehicle is in motion</Code_0x92>
            <Code_0x93>Vehicle is not in motion</Code_0x93>
            <Code_0x94>Vehicle is in gear</Code_0x94>
            <Code_0x95>Vehicle is not in gear</Code_0x95>
            <Code_0x9A>Sustained loss of programming voltage detected</Code_0x9A>
            <Code_0xA1>Wrong shift lever position</Code_0xA1>
            <Code_0xA5>Actuator tests inhibited</Code_0xA5>
            <Code_0xA9>Actuator tests inhibited. Controller is in limp-in</Code_0xA9>
            <Code_0xAA>Brakes not on</Code_0xAA>
            <Code_0xAB>Shift lever not in park</Code_0xAB>
            <Code_0xB0>Requested DPid is undefined</Code_0xB0>
            <Code_0xB1>Requested DPid is out of permissible range</Code_0xB1>
            <Code_0xB2>Requested DPid area is too large</Code_0xB2>
            <Code_0xB3>Number of data items is too large</Code_0xB3>
            <Code_0xB4>Data for item extends past end of data area</Code_0xB4>
            <Code_0xB6>Data item was not found in the DPid data table</Code_0xB6>
            <Code_0xB7>Requested DPid is not yet reserved/defined</Code_0xB7>
            <Code_0xC0>Security Access Mode seed not previously requested</Code_0xC0>
            <Code_0xD0>No parameter substitution currently active for the requested Pid</Code_0xD0>
            <Code_0xE0>Routine started and completed</Code_0xE0>
            <Code_0xE1>Routine started and in progress</Code_0xE1>
            <Code_0xE2>Routine Pending - Routine request is valid, however, execution will take place at a later time</Code_0xE2>
            <Code_0xE3>Routine stopped</Code_0xE3>
            <Code_0xE4>Routine execution already completed</Code_0xE4>
            <Code_0xE5>Routine execution is pending, thus never started</Code_0xE5>
            <Code_0xE6>Routine still running</Code_0xE6>
            <Code_0xE7>Routine already running - Specified routine is already running</Code_0xE7>
            <Code_0xE8>Routine not running - Specified routine was never requested to enter/start</Code_0xE8>
        </NegativeResponseCodes>
    </Setup>

    <SerialMessages>

        <InitMessage>
            <Byte_00 alias="StartByte"    byteType="Tx" timeOut="500"  value="0x01" baud="5"/>
            <Byte_03 alias="SyncByte"     byteType="Rx" timeOut="5000" value="0x55" baud="10400"/>
            <Byte_04 alias="Keyword1"     byteType="Rx" timeOut="2000" value="0xEF"/>
            <Byte_05 alias="Keyword2"     byteType="Rx" timeOut="2000" value="0x8F"/>
            <Byte_06 alias="InvKeyword"   byteType="Tx" timeOut="28"   value="0x70"/>
            <Byte_07 alias="InvStartByte" byteType="Rx" timeOut="2000" value="0xFE"/>
        </InitMessage>

        <VehicleMessages>
            <ExitDiagnosticMode>
                <TransmitMessage>StopComms</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>StopCommsResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ExitDiagnosticMode>
            <ReadVIN>
                <TransmitMessage>ReadLid</TransmitMessage>
                <TransmitInterpretation>Vin</TransmitInterpretation>
                <ReplyMessage>ReadLidResponse</ReplyMessage>
                <ReplyInterpretation>ModuleVin</ReplyInterpretation>
            </ReadVIN>
        </VehicleMessages>

        <TransmitMessages>
            <ReadLid>0x82,0x10,0xF1,0x21,0x??</ReadLid>
            <StopComms>0x81,0x10,0xF1,0x82</StopComms>
        </TransmitMessages>

        <TransmitInterpretations>
            <Vin>0x51</Vin>
        </TransmitInterpretations>

        <ReplyMessages>
            <ReadLidResponse>
                <Reply_00 lengthType="Variable" ReplyTimeout="500" endGapTime="50">0x??,0xF1,0x??,0x61,0x51,0x??</Reply_00>
                <Reply_10 lengthType="Variable" ReplyTimeout="500" endGapTime="50">0x??,0xF1,0x??,0x??,0x61,0x51,0x??</Reply_10>
                <Reply_02>0x83,0xF1,0x??,0x7F,0x21,0x??,0x??</Reply_02>
            </ReadLidResponse>

            <StopCommsResponse>
                <Reply_00 lengthType="Variable" ReplyTimeout="500" endGapTime="50">0x??,0xF1,0x??,0xC2,0x??</Reply_00>
                <Reply_02>0x83,0xF1,0x??,0x7F,0x81,0x??,0x??</Reply_02>
            </StopCommsResponse>
        </ReplyMessages>

        <ReplyInterpretations>
            <ModuleVin>
                <String>
                    <Substring format="%17s">
                        <chars input_index="4" mask="0xFF" length="17"/>
                    </Substring>
                </String>
            </ModuleVin>
        </ReplyInterpretations>

    </SerialMessages>

</VwEngineControlModule>
