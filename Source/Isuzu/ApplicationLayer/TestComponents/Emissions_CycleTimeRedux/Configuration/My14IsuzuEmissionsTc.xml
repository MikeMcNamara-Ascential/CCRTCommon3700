            <MinimumFuelLevelPrimaryTank Units="%" TestSteps="CheckFuelLevelPrimaryTankLevel" Comment="Minimum operating Fuel Tank Level">0</MinimumFuelLevelPrimaryTank>
            <MaximumFuelLevelPrimaryTank Units="%" TestSteps="CheckFuelLevelPrimaryTankLevel" Comment="Maximum operating Fuel Tank Level">100</MaximumFuelLevelPrimaryTank>
            <!-- Battery Voltage Parameters -->
