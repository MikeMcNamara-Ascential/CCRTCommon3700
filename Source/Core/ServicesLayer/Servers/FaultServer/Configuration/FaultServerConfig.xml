<BepXMLMssg>
   <Setup>
      <Debug>Off</Debug>
      <ProcessPriority>10</ProcessPriority>
      <Communication>
         <Type>Server</Type>
         <Debug>Off</Debug>
         <Name>core/FaultServer</Name>
         <Comm>IPC</Comm>
         <Timeout>1000</Timeout>
         <BufferSize>2000</BufferSize>
      </Communication>
      <DataTags>
         <AllFaultsTag>AllFaults</AllFaultsTag>
      </DataTags>
      <Logging>
         <Status>Enabled</Status>
         <ProcessName>FaultServer</ProcessName>
         <AdditionalLogFile Types="/Servers/FaultServer.log or Disabled">/Servers/FaultServer.log</AdditionalLogFile>
         <Debug>Off</Debug>
         <LocalEcho>Disabled</LocalEcho>
         <Verbose>0x01</Verbose>
      </Logging>
      <FaultLogger>
         <!-- this intentionally looks strange because of the way an ILogger object initializes-->
         <Setup>
            <Logging>
               <Status>Enabled</Status>
               <ProcessName>FaultLogger</ProcessName>
               <!-- note that filename below MUST have a '.' in it !  Also, it will be time/date mangled-->
               <AdditionalLogFile Types="/Faults/FaultLog.log or Disabled">/Faults/FaultLog.log</AdditionalLogFile>
               <Debug>Off</Debug>
               <LocalEcho>Disabled</LocalEcho>
               <!--In order for log to have data, set "Verbose" to 0x09-->
               <Verbose>0x09</Verbose>
            </Logging>
         </Setup>
      </FaultLogger>
      <ThreadPool>
         <Debug>Off</Debug>
         <MinBlockedLimit>2</MinBlockedLimit>
         <MaxBlockedLimit>7</MaxBlockedLimit>
         <Increment>2</Increment>
         <Maximum>10</Maximum>
      </ThreadPool>
      <NotificationList>
         <Setup>
            <Debug>Off</Debug>
            <HighWater>3</HighWater>
            <Increment>1</Increment>
            <LowWater>1</LowWater>
            <Maximum>5</Maximum>
            <StartOnCreate>No</StartOnCreate>
            <ResponseTimeout>2000</ResponseTimeout>
         </Setup>
      </NotificationList>
   </Setup>
</BepXMLMssg>
