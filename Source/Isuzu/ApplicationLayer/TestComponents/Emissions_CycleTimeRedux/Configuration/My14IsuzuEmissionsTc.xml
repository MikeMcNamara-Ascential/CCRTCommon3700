            <MaximumIdleRPM Units="RPM" TestSteps="WaitForEngineRunning" Comment="Maximum idle RPM">1500</MaximumIdleRPM>
            <MinimumIdleRPM Units="RPM" TestSteps="WaitForEngineRunning" Comment="Maximum idle RPM">500</MinimumIdleRPM>
            <MinimumEngineRunningRPM Units="RPM" TestSteps="WaitForEngineRunning" Comment="Minimum engine running RPM">500</MinimumEngineRunningRPM>
            <MinimumEngineSpeed Units="RPM" TestSteps="CheckIdleRPM" Comment="Minimum idle rpm">475</MinimumEngineSpeed>
            <!-- Fuel Trim Parameters -->
            <ShortTermFuelTrimBank1Units>%</ShortTermFuelTrimBank1Units>
            <MinimumShortTermFuelTrimBank1 Units="%" TestSteps="CheckIdleFuelTrim" Comment="min short term fuel trim bank 1">-20</MinimumShortTermFuelTrimBank1>
            <MaximumShortTermFuelTrimBank1 Units="%" TestSteps="CheckIdleFuelTrim" Comment="max short term fuel trim bank 1">20</MaximumShortTermFuelTrimBank1>
            <ShortTermFuelTrimBank2Units>%</ShortTermFuelTrimBank2Units>
            <MinimumShortTermFuelTrimBank2 Units="%" TestSteps="CheckIdleFuelTrim" Comment="min Short term fuel trim bank 2">-20</MinimumShortTermFuelTrimBank2>
            <MaximumShortTermFuelTrimBank2 Units="%" TestSteps="CheckIdleFuelTrim" Comment="max Short term fuel trim bank 2">20</MaximumShortTermFuelTrimBank2>
            <LongTermFuelTrimBank1Units>%</LongTermFuelTrimBank1Units>
            <MinimumLongTermFuelTrimBank1 Units="%" TestSteps="CheckIdleFuelTrim" Comment="min long term fuel trim bank 1">-20</MinimumLongTermFuelTrimBank1>
            <MaximumLongTermFuelTrimBank1 Units="%" TestSteps="CheckIdleFuelTrim" Comment="max long term fuel trim bank 1">20</MaximumLongTermFuelTrimBank1>
            <LongTermFuelTrimBank2Units>%</LongTermFuelTrimBank2Units>
            <MinimumLongTermFuelTrimBank2 Units="%" TestSteps="CheckIdleFuelTrim" Comment="min long term fuel trim bank 2">-20</MinimumLongTermFuelTrimBank2>
            <MaximumLongTermFuelTrimBank2 Units="%" TestSteps="CheckIdleFuelTrim" Comment="max long term fuel trim bank 2">20</MaximumLongTermFuelTrimBank2>
            <!-- Fuel Tank Vapor Pressure Parameters -->
            <FuelTankVaporPressureUnits>Pa</FuelTankVaporPressureUnits>
            <MinimumFuelTankVaporPressure Units="Pa" TestSteps="CheckFuelTankVaporPressure" Comment="Min Fuel Tank Vapor Pressure">-8192.0</MinimumFuelTankVaporPressure>
            <MaximumFuelTankVaporPressure Units="Pa" TestSteps="CheckFuelTankVaporPressure" Comment="Max Fuel Tank Vapor Pressure">0.0</MaximumFuelTankVaporPressure>
            <!-- Knock Sensors Parameters -->
            <KnockSensor1Units>Boolean</KnockSensor1Units>
            <KnockSensor2Units>Boolean</KnockSensor2Units>
            <KnockSensor1CompareValue>True</KnockSensor1CompareValue>
            <KnockSensor2CompareValue>True</KnockSensor2CompareValue>
            <!-- Intake Flow Rational Parameters -->
            <MAFResidualCompareValue>False</MAFResidualCompareValue>
            <MAP1ResidualCompareValue>False</MAP1ResidualCompareValue>
            <MAP2ResidualCompareValue>False</MAP2ResidualCompareValue>
            <!-- Misfire Parameters -->
            <MisfireCatalystFailureUnits>Boolean</MisfireCatalystFailureUnits>
            <MisfireEmissionsFailureUnits>Boolean</MisfireEmissionsFailureUnits>
            <MisfireCatalystFailureCompareValue>False</MisfireCatalystFailureCompareValue>
            <MisfireEmissionsFailureCompareValue>False</MisfireEmissionsFailureCompareValue>
            <!-- Oxygen Sensor Parameters -->
            <OxygenSensorSamples>1000</OxygenSensorSamples>
            <OxygenSensorPeriodTime Units="ms">20</OxygenSensorPeriodTime>
            <OxygenSensor1Bank1Units>V</OxygenSensor1Bank1Units>
            <OxygenSensor1Bank1LBandLimit Units="V" Comment="Oxygen Sensor Low Band Limit">0.400</OxygenSensor1Bank1LBandLimit>
            <OxygenSensor1Bank1OBandLowLimit Units="V" Comment="Oxygen Sensor Open Band Lower Limit">0.425</OxygenSensor1Bank1OBandLowLimit>
            <OxygenSensor1Bank1OBandHighLimit Units="V" Comment="Oxygen Sensor Open Band Upper Limit">0.475</OxygenSensor1Bank1OBandHighLimit>
            <OxygenSensor1Bank1HBandLimit Units="V" Comment="Oxygen Sensor High Band Limit">0.600</OxygenSensor1Bank1HBandLimit>
            <OxygenSensor1Bank1MaxPercentLow Units="%" Comment="Max percentage of Low Band values">80</OxygenSensor1Bank1MaxPercentLow>
            <OxygenSensor1Bank1MaxPercentOpen Units="%" Comment="Max percentage of Open Band values">80</OxygenSensor1Bank1MaxPercentOpen>
            <OxygenSensor1Bank1MaxPercentHigh Units="%" Comment="Max percentage of High Band values">80</OxygenSensor1Bank1MaxPercentHigh>
