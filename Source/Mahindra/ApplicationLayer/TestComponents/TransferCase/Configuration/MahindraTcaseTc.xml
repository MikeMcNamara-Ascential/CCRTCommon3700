<MahindraTcaseTc>
    <Setup>
        <Name>TransferCase</Name>
        <Debug>Off</Debug>
        <DebugLevel>0</DebugLevel>
        <TestDomain>Foreground</TestDomain>
        <ProcessPriority>11</ProcessPriority>
        <Communication>
            <Comm>IPC</Comm>
            <Type>Server</Type>
            <Name>component/MahindraTcase</Name>
            <Debug>Off</Debug>
            <BufferSize>1024</BufferSize>
            <Timeout>0</Timeout>
        </Communication>
        <NamedDataBrokerComm>
            <Comm>IPC</Comm>
            <Type>Client</Type>
            <Name>core/NamedDataBroker</Name>
            <Debug>Off</Debug>
            <Timeout>0</Timeout>
            <BufferSize>1024</BufferSize>
        </NamedDataBrokerComm>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>50</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>MahindraTcase</ProcessName>
            <AdditionalLogFile>/Components/MahindraTcase.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
            <MessageTimeout>100</MessageTimeout>
            <AdditionalLogMaxSize>10</AdditionalLogMaxSize>
            <AdditionalLogMaxFiles>5</AdditionalLogMaxFiles>
        </Logging>
        <TagList>
            <SubscribeTags>
                <Abort/>
                <Clutch/>
                <Declutch/>
                <DriveAxle/>
                <ForegroundTestInProgress/>
                <Zerospeed/>
            </SubscribeTags>
            <PublishTags>
                <OverallPassFail>Pass</OverallPassFail>
            </PublishTags>
        </TagList>
        <DataTags>
            <DriveAxle>DriveAxle</DriveAxle>
            <ForegroundTestInProgress>ForegroundTestInProgress</ForegroundTestInProgress>
            <FourWheelDriveEquipped>FourWheelDriveEquipped</FourWheelDriveEquipped>
            <IcmSpeedArray>/dev/ArraySpeed</IcmSpeedArray>
            <LeftFrontSpeed>LFSpeed</LeftFrontSpeed>
            <LeftRearSpeed>LRSpeed</LeftRearSpeed>
            <LFSpeed>LFSpeed</LFSpeed>
            <LRSpeed>LRSpeed</LRSpeed>
            <ManualTransType>Manual</ManualTransType>
            <PromptBox1>PromptBox1</PromptBox1>
            <PromptBox2>PromptBox2</PromptBox2>
            <Rear>Rear</Rear>
            <RFSpeed>RFSpeed</RFSpeed>
            <RightFrontSpeed>RFSpeed</RightFrontSpeed>
            <RightRearSpeed>RRSpeed</RightRearSpeed>
            <RRSpeed>RRSpeed</RRSpeed>
            <SpeedTarget>SpeedTarget</SpeedTarget>
            <SpeedValue>SpeedValue</SpeedValue>
            <TagIndex>TagIndex</TagIndex>
            <TargetSpeed>SpeedTarget</TargetSpeed>
            <Zerospeed>Zerospeed</Zerospeed>
        </DataTags>

        <Parameters>
            <!-- Test Behavior Parameters -->
            <CheckIf4wdEquipped>False</CheckIf4wdEquipped>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <DeveloperTest>False</DeveloperTest>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <KeepTestStatusOnExit>1</KeepTestStatusOnExit>

            <!-- T-case Shifting Parameters -->
            <MinimumShiftSpeed Units="km/h" ConvertToEnglishUnits="True">0.0</MinimumShiftSpeed>

            <!-- 2-WD Parameters -->
            <CheckShift2WDEngineRunning>Skip</CheckShift2WDEngineRunning>
            <CheckShift2WDKeyPosition>Skip</CheckShift2WDKeyPosition>
            <CheckShift2WDMinimumShiftSpeed Units="km/h" ConvertToEnglishUnits="True">0.0</CheckShift2WDMinimumShiftSpeed>
            <CheckShift2WDThrottlePosition>Skip</CheckShift2WDThrottlePosition>
            <CheckShift2WDTransmissionGear>Skip</CheckShift2WDTransmissionGear>
            <CheckShift2WDVerifyMethod>Prompt</CheckShift2WDVerifyMethod>

            <!-- 4-HI Parameters -->
            <Check4HIAxleBalanceMaxFrontToRearDeltaPercent Units="percent">0.0</Check4HIAxleBalanceMaxFrontToRearDeltaPercent>
            <Check4HIAxleBalanceMaxFrontToRearDelta Units="km/h" ConvertToEnglishUnits="True">5.0</Check4HIAxleBalanceMaxFrontToRearDelta>
            <Check4HIAxleBalanceMaxLeftToRightDelta Units="km/h" ConvertToEnglishUnits="True">1.0</Check4HIAxleBalanceMaxLeftToRightDelta>
            <Check4HIAxleBalanceTargetSpeed Units="km/h" ConvertToEnglishUnits="True">20</Check4HIAxleBalanceTargetSpeed>
            <Check4HIAxleBalanceMaximumSpeed Units="km/h" ConvertToEnglishUnits="True">40</Check4HIAxleBalanceMaximumSpeed>
            <Check4HIAxleBalanceMinimumSpeed Units="km/h" ConvertToEnglishUnits="True">20</Check4HIAxleBalanceMinimumSpeed>
            <Check4HIAxleBalanceOnlyTestFrontRearRatio>False</Check4HIAxleBalanceOnlyTestFrontRearRatio>
            <CheckShift4HIEngineRunning>Skip</CheckShift4HIEngineRunning>
            <CheckShift4HIKeyPosition>Skip</CheckShift4HIKeyPosition>
            <CheckShift4HIMinimumShiftSpeed Units="km/h" ConvertToEnglishUnits="True">0.0</CheckShift4HIMinimumShiftSpeed>
            <CheckShift4HIThrottlePosition>Skip</CheckShift4HIThrottlePosition>
            <CheckShift4HITransmissionGear>Skip</CheckShift4HITransmissionGear>
            <CheckShift4HIVerifyMethod>Prompt</CheckShift4HIVerifyMethod>

            <!-- 4-LO Parameters -->
            <AxleRatioBrakeToStopNotRequired>False</AxleRatioBrakeToStopNotRequired>
            <AxleRatioDirection>Forward</AxleRatioDirection>
            <AxleRatioMinimum Units="percent">97.0</AxleRatioMinimum>
            <AxleRatioMaximum Units="percent">103.0</AxleRatioMaximum>
            <AxleRatioSkipPreconditions>False</AxleRatioSkipPreconditions>
            <CheckShift4LOEngineRunning>Skip</CheckShift4LOEngineRunning>
            <CheckShift4LOKeyPosition>Skip</CheckShift4LOKeyPosition>
            <CheckShift4LOMinimumShiftSpeed Units="km/h" ConvertToEnglishUnits="True">0.0</CheckShift4LOMinimumShiftSpeed>
            <CheckShift4LOThrottlePosition>Skip</CheckShift4LOThrottlePosition>
            <CheckShift4LOTransmissionGear>Skip</CheckShift4LOTransmissionGear>
            <CheckShift4LOVerifyMethod>Prompt</CheckShift4LOVerifyMethod>
            <MaximumAxleRatioAttempts>3</MaximumAxleRatioAttempts>

        </Parameters>

        <Prompts>
            <AccelerateToTargetSpeed PromptBox="2" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <ApplyClutch PromptBox="1" Priority="0">ApplyClutch</ApplyClutch>
            <CheckShift2WDShiftTcase PromptBox="1" Priority="0">ShiftTransferCase</CheckShift2WDShiftTcase>
            <CheckShift4HIShiftTcase PromptBox="1" Priority="0">ShiftTransferCase</CheckShift4HIShiftTcase>
            <CheckShift4LOShiftTcase PromptBox="1" Priority="0">ShiftTransferCase</CheckShift4LOShiftTcase>
            <ShiftToDrive PromptBox="1" Priority="0">ShiftToFirst</ShiftToDrive>
            <SlowDownToTargetSpeed PromptBox="1" Priority="0">SlowDownToTargetSpeed</SlowDownToTargetSpeed>
            <TcaseTesting PromptBox="1" Priority="0">TransferCaseTest</TcaseTesting>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
        </Prompts>

        <FaultList>/Configuration/Components/Common/SampleFaultList.xml</FaultList>
    </Setup>


    <Objectives>
        <Tcase4HiTest>
            <TestStep00>DisengageMachine</TestStep00>
            <TestStep05>CheckShift4HI</TestStep05>
            <TestStep10>Check4HIAxleBalance</TestStep10>
        </Tcase4HiTest>

        <Tcase4LoTest>
            <TestStep00>DisengageMachine</TestStep00>
            <TestStep05>CheckShift4LOW</TestStep05>
            <TestStep10>CheckAxleRatio</TestStep10>
            <TestStep90>CheckShift2WD</TestStep90>
            <TestStep99>FinishUp</TestStep99>
        </Tcase4LoTest>

    </Objectives>


    <TestSteps>

        <Check4HIAxleBalance Result="" Timeout="10000" Description="Check axle balance in 4-HI" ScanDelay="500"
            AbortOnFail="False"/>

        <CheckAxleRatio Result="Not Tested" Timeout="30000" Description="Verify Axle Ratio" ScanDelay="500" 
            SpeedSampleDelay="500" TargetSpeed="5" MinimumSpeed="5" MaximumSpeed="10" 
            RatioSamples="10" SampleTime="500"/>

        <CheckShift2WD Result="Not Tested" Timeout="30000" Description="Test Tcase 2WD" ScanDelay="500" 
            SpeedSampleDelay="500" TcaseMessageDelay="5000" TransmissionMessageDelay="5000" 
            ThrottleMessageDelay="5000" EngineOnOffMessageDelay="5000" KeyOnOffMessageDelay="5000" 
            CommandMessageDelay="5000" 
            TcaseGear="2WD" TargetSpeed="30" MinimumSpeed="0" MaximumSpeed="5"/>

        <CheckShift4HI Result="Not Tested" Timeout="5000" Description="Test Tcase 4HI" ScanDelay="500" 
            SpeedSampleDelay="500" TcaseMessageDelay="10000" TransmissionMessageDelay="5000" 
            ThrottleMessageDelay="5000" EngineOnOffMessageDelay="5000" KeyOnOffMessageDelay="5000" 
            CommandMessageDelay="5000" 
            TcaseGear="4-HI" TargetSpeed="10" MinimumSpeed="0" MaximumSpeed="5"/>

        <CheckShift4LOW Result="Not Tested" Timeout="5000" Description="Test Tcase 4LO" ScanDelay="500" 
            SpeedSampleDelay="500" TcaseMessageDelay="10000" TransmissionMessageDelay="5000" 
            ThrottleMessageDelay="5000" EngineOnOffMessageDelay="5000" KeyOnOffMessageDelay="5000" 
            CommandMessageDelay="5000" 
            TcaseGear="4-LOW" TargetSpeed="0" MinimumSpeed="0" MaximumSpeed="5"/>

        <DisengageMachine Result="" Timeout="3000" Description="Disengage machine for t-case testing"/>

        <FinishUp Result="Not Tested" Timeout="500" Description="Finish Tcase testing"/>

    </TestSteps>
</MahindraTcaseTc>
