<KwpIsuzuSpeedControl>

    <Setup>
        <Debug>Off</Debug>
        <Name>SpeedControl</Name>
        <TestDomain>Foreground</TestDomain>
        <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
        <Communication>
            <Debug>Off</Debug>
            <Type>Server</Type>
            <Comm>IPC</Comm>
            <Name>component/IsuzuSpeedControl</Name>
            <BufferSize>1024</BufferSize>
            <Timeout>2000</Timeout>
        </Communication>
        <TagList>
            <SubscribeTags>
                <Abort/>
                <CableConnect/>
                <Zerospeed/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>component/IsuzuSpeedControl</ProcessName>
            <AdditionalLogFile Types="/Components/NGC4KeywordEmissions or Disable">/Components/IsuzuSpeedControl.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>

        <!-- Test Component Data Tags -->
        <DataTags>
            <!-- Module Message Tags -->
            <ReadBrakeSwitch>ReadCruiseCutoutHistory</ReadBrakeSwitch>
            <ReadCancelSwitch>ReadCruiseStatus</ReadCancelSwitch>
            <ReadResumeButton>ReadCruiseStatus</ReadResumeButton>
            <ReadSpeedControlOff>ReadCruiseStatus</ReadSpeedControlOff>
            <ReadSpeedControlOn>ReadCruiseStatus</ReadSpeedControlOn>
            <ReadSetButton>ReadCruiseStatus</ReadSetButton>
            <ThrottleClosedVoltageMessage>ReadAcceleratorPedalSensor1</ThrottleClosedVoltageMessage>

            <!-- System Data Tags -->
            <BroadcastSpeedControlType>SpeedControl</BroadcastSpeedControlType>
            <SpeedControl>SpeedControl</SpeedControl>

            <!-- Speed Control Types -->
            <NoSpeedControl>NotEquipped</NoSpeedControl>

        </DataTags>

        <!-- Test Component Parameters -->
        <Parameters>
            <!-- Test Component Behavior Parameters -->
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <DelayModuleInitialization>No</DelayModuleInitialization>
            <DelayBeforeBrakeTap>30000</DelayBeforeBrakeTap>
            <DeveloperTest>False</DeveloperTest>
            <ICMName>mgr/ICM</ICMName>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <KeepTestStatusOnExit>True</KeepTestStatusOnExit>
            <LoadStaticTestResults>False</LoadStaticTestResults>
            <MarkSpeedDuringStableCheck>True</MarkSpeedDuringStableCheck>
            <NoModuleComms 
                TestSteps="CheckOnEnable,CheckSetEngagement,CheckBrakeCutOut,CheckResumeEngagement,CheckCancelCutOut,CheckOffDisable" 
                Comment="Flag used to determine if data should be read from the module">False</NoModuleComms>
            <SkipOnTestResult TestSteps="CheckSetEngagement"
                Comment="Flag to determine if the On step should be ignored">False</SkipOnTestResult>

            <!-- Module Parameters -->
            <ConfigFile>/Configuration/Components/Emissions/IsuzuEngineControllerModule.xml</ConfigFile>

            <!-- Diagnostic Mode Parameters -->
            <AlwaysEnterDiagnosticMode TestSteps="EnterDiagnosticMode"
                Comment="Enter diagnostic mode if module does not need to be tested">False</AlwaysEnterDiagnosticMode>

            <!-- Speed Control State Parameters -->
            <SpeedControlBrakeMaskNotAnyBitsSet TestSteps="CheckBrakeCutOut"
                Comment="Mask requires no bits set to indicate brake cutout">True</SpeedControlBrakeMaskNotAnyBitsSet>
            <SpeedControlBrakeMask TestSteps="CheckBrakeCutOut"
                Comment="Mask to apply to hr data to determine if the speed control system cutout for brake tap">0x00FF</SpeedControlBrakeMask>
            <SpeedControlModeCheckDelay Units="ms" 
                TestSteps="CheckOnEnable,CheckSetEngagement,CheckBrakeCutOut,CheckResumeEngagement,CheckCancelCutOut"
                Comment="Time to wait between checks of the speed control state">50</SpeedControlModeCheckDelay>
            <SpeedControlOffMask TestSteps="CheckOffDisable"
                Comment="Mask to apply to the data to determine if the speed control system is off">0x0000</SpeedControlOffMask>
            <SpeedControlOnMask TestSteps="CheckOnEnable"
                Comment="Mask to apply to the data to determine if the speed control system is on">0x0001</SpeedControlOnMask>
            <SpeedControlResumeMask TestSteps="CheckResumeEngagement"
                Comment="Mask to apply to the data to determine if the speed control system is resumed">0x0004</SpeedControlResumeMask>
            <SpeedControlSetMask TestSteps="CheckSetEngagement"
                Comment="Mask to apply to the data to determine if the speed control system is set">0x0002</SpeedControlSetMask>

            <!-- Speed control testing parameters -->
            <CheckForClosedThrottle TestSteps="CheckSetEngagement,CheckResumeEngagement"
                Comment="Flag to determine if the test should check for closed throttle">True</CheckForClosedThrottle>
            <ClosedThrottleVoltage Units="%" TestSteps="CheckSetEngagement,CheckResumeEngagement"
                Comment="Maximum closed throttle percent">20.0</ClosedThrottleVoltage>
            <DeltaSpeedCheckDelay Units="ms" TestSteps="CheckBrakeCutOut,CheckCancelCutOut"
                Comment="Amount of time to wait between checks for speed delta achieved">500</DeltaSpeedCheckDelay>
            <SpeedControlDeltaSpeed Units="mph" TestSteps="CheckBrakeCutOut,CheckCancelCutOut"
                Comment="Speed delta to make sure the speed control has disengaged">5</SpeedControlDeltaSpeed>
            <SpeedControlMaxSpeed Units="mph" TestSteps="CheckSetEngagement"
                Comment="Maximum speed for speed control test">75</SpeedControlMaxSpeed>
            <SpeedControlMinSpeed Units="mph" TestSteps="CheckSetEngagement"
                Comment="Minimum speed for speed control test">65</SpeedControlMinSpeed>
            <SpeedIncreaseSamples TestSteps="CheckResumeEngagement"
                Comment="Number of consecutive increasing speed samples to conclude speed control has re-engaged">20</SpeedIncreaseSamples>
            <SpeedRangeCheckDelay Units="ms" TestSteps="CheckSetEngagement"
                Comment="Time delay between checks for vehicle speed in range">500</SpeedRangeCheckDelay>
            <StableSpeedMaxVariation Units="mph" TestSteps="CheckSetEngagement"
                Comment="Upper limit of speed variation from set speed">5</StableSpeedMaxVariation>
            <StableSpeedMinVariation Units="mph" TestSteps="CheckSetEngagement"
                Comment="Lower limit of speed variation from set speed">5</StableSpeedMinVariation>
            <StableSpeedVariation Units="mph" TestSteps="CheckResumeEngagement"
                Comment="Allowable variation between set speed and current speed">5</StableSpeedVariation>
            <StableSpeedPoints TestSteps="CheckSetEngagement"
                Comment="Number of samples within the acceptable speed range to determine if vehicle speed is stable">20</StableSpeedPoints>
            <StableSpeedSampleDelay Units="ms" TestSteps="CheckSetEngagement"
                Comment="Amount of time to wait between checks for stable vehicle speed">250</StableSpeedSampleDelay>
            <UseModuleSpeed TestSteps="CheckSetEngagement,CheckBrakeCutOut,CheckResumeEngagement,CheckCancelCutOut"
                Comment="Flag to determine if vehicle speed should be used from the module">True</UseModuleSpeed>

            <!-- Valid Speed Control Types -->
            <ValidSpeedControlTypes>
                <Type00>Cruise</Type00>
            </ValidSpeedControlTypes>

        </Parameters>

        <!-- Test Component Prompts -->
        <Prompts>
            <CancelPrompt PromptBox="1" Priority="0" TestSteps="CheckCancelCutOut">SpeedControlCancel</CancelPrompt>
            <CheckStableSpeed PromptBox="1" Priority="0" TestSteps="CheckSetEngagement">CheckForStableSpeed</CheckStableSpeed>
            <PressFailPrompt PromptBox="2" Priority="0" 
                TestSteps="CheckBrakeCutOut,CheckResumeEngagement,CheckCancelCutOut">SpeedControlPressFail</PressFailPrompt>
            <PressResumePrompt PromptBox="1" Priority="0" 
                TestSteps="CheckResumeEngagement">SpeedControlResume</PressResumePrompt>
            <RemoveFootPrompt PromptBox="2" Priority="0" TestSteps="CheckSetEngagement">RemoveFootFromAccelerator</RemoveFootPrompt>
            <SpeedControlOff PromptBox="2" Priority="0" TestSteps="CheckOffDisable">SpeedControlOff</SpeedControlOff>
            <SpeedControlOn PromptBox="1" Priority="0" TestSteps="CheckOnEnable">SpeedControlOn</SpeedControlOn>
            <SetPrompt PromptBox="1" Priority="0" TestSteps="CheckSetEngagement">SpeedControlSet</SetPrompt>
            <TapBrakePrompt PromptBox="1" Priority="0" TestSteps="CheckBrakeCutOut">SpeedControlTapBrakes</TapBrakePrompt>
            <AccelerateToTargetSpeed PromptBox="1" Priority="0" TestSteps="CheckSetEngagement">AccelerateToTargetSpeedInD6</AccelerateToTargetSpeed>
            <DelayBeforeTapPrompt PromptBox="1" Priority="0" TestSteps="CheckBrakeCutOut">DelayBeforeTapPrompt</DelayBeforeTapPrompt>
        </Prompts>

        <!-- Fault Data -->
        <IgnoreFaults/>
        <FaultList>Configuration/Components/Emissions/EmissionsFaults.xml</FaultList>

    </Setup>

    <!-- Testing Objectives -->
    <Objectives>
        <CruiseOn>
            <TestStep00>Setup</TestStep00>
            <TestStep05>CheckOnEnable</TestStep05>
        </CruiseOn>

        <CruiseSet>
            <TestStep00>CheckSetEngagement</TestStep00>
        </CruiseSet>

        <SpeedControlTest>
            <TestStep00>CheckBrakeCutOut</TestStep00>
            <TestStep05>CheckResumeEngagement</TestStep05>
            <TestStep15>CheckOffDisable</TestStep15>
            <TestStep20>FinishUp</TestStep20>
        </SpeedControlTest>

    </Objectives>

    <!-- Test Component Test Steps -->
    <TestSteps>
        <CheckBrakeCutOut Result="" Timeout="20000" Description="Verify cruise cuts out when the brake pedal is tapped"/>
        <CheckOffDisable Result="" Timeout="15000" Description="Verify the Off switch and functionality"/>
        <CheckOnEnable Result="" Timeout="15000" Description="Verify the On switch and functionality"/>
        <CheckResumeEngagement Result="" Timeout="25000" Description="Verify the Resume button and functionality" ScanDelay="100"/>
        <CheckSetEngagement Result="" Timeout="60000" Description="Verify the Set button and functionality" ScanDelay="150"/>
        <FinishUp Result="" Timeout="3000" Description="Finish testing and update results in the module"/>
        <Setup Result="" Timeout="10000" Description="Set up component for testing"/>
    </TestSteps>

</KwpIsuzuSpeedControl>
