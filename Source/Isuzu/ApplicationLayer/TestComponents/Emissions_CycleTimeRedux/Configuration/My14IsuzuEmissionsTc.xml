            <MaximumManifoldAbsolutePressure Units="kPa" TestSteps="CheckManifoldAbsolutePressureAtIdle" Comment="Maximum operating ManifoldAbsolutePressure">50</MaximumManifoldAbsolutePressure>
            <!-- MassAirFlow Parameters -->
