<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">
<!-- 
$Revision: 1.3 $
-->

<RtGuiConfig>
    <Metadata author="Burke E. Porter" version="1.0"
        description="Standard implementation of the Front Panel view."/>

    <XmlWidgetPanel id="FrontPanel">
        <Layout>
            <!-- BEP Address Label -->
            <VBox height="13" width="250" posX="750" posY="5" border="false">
                <Label name="address1" height="13" width="9000" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <VBox height="13" width="250" posX="750" posY="20" border="false">
                <Label name="address2" height="13" width="9000" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <VBox height="13" width="250" posX="750" posY="35" border="false">
                <Label name="phone" height="13" width="9000" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <!-- BEP Header -->
            <VBox height="750" width="1000" posX="0" posY="0" border="false">
                <Widget id="header" class="com.bepco.gui.ImagePhaseBox">
                    <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                </Widget>
            </VBox>
            <!-- VIN Display -->
            <HBox height="38" width="450" posX="20" posY="65" border="false">
                <!-- spacer -->
                <Label name="vin">
                    <Font size="18" name="sans-serif" style="plain"/>
                </Label>
                <!-- spacer -->
                <VBox width="40"/>
                <Widget id="_vinDisplay" width="250" class="com.bepco.gui.TextBox">
                    <DataSource tagname="VINDisplay" messagetype="Subscribe"/>
                    <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe" tagrole="backgroundcolor" />
                    <TextBoxConfig>
                        <Font size="18" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
            </HBox>
            <!-- Broadcast info, column 1-->
            <HBox height="60" width="175" posX="3" posY="100" border="false">
                <HBox height="130" posX="0" posY="0" border="false">
                    <!-- Left Pane Widget VBox-->
                    <VBox width="40">
                        <HBox height="2"/>
                        <Label name="bodystyle"/>
                        <HBox height="2"/>
                        <Label name="brake"/>
                        <HBox height="2"/>
                        <Label name="driveaxle"/>
                    </VBox>
                    <!-- spacer -->
                    <VBox width="10"/>
                    <VBox>
                        <HBox height="2"/>
                        <Widget id="_bodystyle" width="130" class="com.bepco.gui.TextBox">
                            <DataSource tagname="VehicleType" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="2"/>
                        <Widget id="_brake" width="130" class="com.bepco.gui.TextBox">
                            <DataSource tagname="BrakeType" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="2"/>
                        <Widget id="_driveaxle" width="130" class="com.bepco.gui.TextBox">
                            <DataSource tagname="DriveAxle" messagetype="Subscribe"/>
                        </Widget>
                    </VBox>
                </HBox>
            </HBox>

            <!-- LED Panel -->
            <VBox height="130" width="400" posX="590" posY="60" border="false">
                <!-- Inputs from PLC -->
                <HBox height="130">
                    <VBox>
                        <Widget id="powersense" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="plcready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PLCSystemIsReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="vmeready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VMESystemReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="vehiclepresent" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VehiclePresent" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="cableconnect" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="CableConnect" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                    </VBox>

                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="powersense"/>
                        <HBox height="5"/>
                        <Label name="plcready"/>
                        <HBox height="5"/>
                        <Label name="vmeready"/>
                        <HBox height="5"/>
                        <Label name="vehiclepresent"/>
                        <HBox height="5"/>
                        <Label name="cableconnect"/>
                    </VBox>

                    <!-- SPACER -->
                    <VBox width="40"/>

                    <VBox>
                        <Widget id="driveenable" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="EnableAllRollDrives" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="rollsup" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsUpElevDown" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="rollsdown" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsDownElevUp" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="zerospeed" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="ZerospeedToPLC" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="teststatuswidget" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="TestInProgress" messagetype="Subscribe"/>
                        </Widget>

                    </VBox>

                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="driveenable"/>
                        <HBox height="5"/>
                        <Label name="rollsup"/>
                        <HBox height="5"/>
                        <Label name="rollsdown"/>
                        <HBox height="5"/>
                        <Label name="zerospeed"/>
                        <HBox height="5"/>
                        <Label name="teststatuswidget"/>
                    </VBox>

                </HBox>
            </VBox>
            <!-- test subsystems pass/fail widgets -->
            <HBox height="40" width='1000' posX="5" posY="189" border="false">
                <Widget width='83' height='40'  id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='83' height='40'  id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                </Widget>
            </HBox>
            <!-- Row 2 of 4: Prompt message text box -->
            <Widget id="prompts" class="com.bepco.gui.PromptBox" posX="3" posY="230" width="997" height="60" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts3" class="com.bepco.gui.PromptBox" posX="3" posY="290" width="997" height="60" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>

            <!-- Row 3 of 4 -->
            <!-- Wheel speeds -->
            <VBox height="200" width="297" posX="3" posY="350" border="true" borderstyle="title" bordertitle="speed">
                <HBox height="15"/>
                <!-- Wheel Speeds -->
                <HBox width="200" border="false">
                    <VBox width="60">
                        <HBox>
                            <Label name="lf">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="lfcolor" convertunits="false">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig convertunits="false">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lfg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30">
                        <DataSource tagname="LFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>

                    <Widget id="_rfg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="rf">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="rfcolor">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>

                </HBox>
                <HBox height="5"/>
                <HBox width="200">
                    <VBox width="60">
                        <HBox>
                            <Label name="lr">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lr" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LRSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="lrcolor">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lrg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30" >
                        <DataSource tagname="LRForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LRForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>

                    <Widget id="_rrg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RRForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RRForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="rr">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rr" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="rrcolor">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- drag, brake, reduction, recovery -->
            <VBox width="350" height="200" posX="300" posY="350" border="true" borderstyle="title" bordertitle="brake">
                <HBox height="8"/>
                <HBox height="10">
                    <Label height="30" width="80" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="drag">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="brake">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="red">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="rec">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="80" name="lf">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="60" id="LFDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="80" name="rf">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>

                    <Widget height="30" width="60" id="RFDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFBrake" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="80" name="lr">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="60" id="LRDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LRDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="LRDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LRForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LRForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="LRForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LRABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LRABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="LRABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LRABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LRABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="LRABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="80" name="rr">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>

                    <Widget height="30" width="60" id="RRDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RRDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="RRDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RRForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RRForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="RRForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RRReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RRABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="RRABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RRABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RRABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="RRABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
            </VBox>

            <!-- Balance  -->
            <VBox width="180" height="200" posX="650" posY="350" border="true" borderstyle="title" bordertitle="balance">
                <HBox height="20"/>
                <!--HBox height="30">
                            <Label height="30" width="120" name="balance">
                                <Font size="16" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox-->
                <HBox height="30">
                    <Label height="30" width="100" name="front">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="FrontBalance" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="FrontBalanceValue" messagetype="Subscribe"/>
                        <DataSource tagname="FrontBalanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="20"/>
                <HBox height="30">
                    <Label height="30" width="100" name="rear">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="RearBalance" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RearBalanceValue" messagetype="Subscribe"/>
                        <DataSource tagname="RearBalanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="20"/>
                <HBox height="30">
                    <Label height="30" width="100" name="f/r">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="FRBalance" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="FrontToRearBalanceValue" messagetype="Subscribe"/>
                        <DataSource tagname="FrontToRearBalanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
            </VBox>

            <!-- Park Brake  -->
            <VBox width="180" height="200" posX="830" posY="350" border="true" borderstyle="title" bordertitle="parkbrake">
                <HBox height="30"/>
                <HBox height="30">
                    <Label height="30" width="100" name="lr">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="lrParkBrake" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LRParkBrakeForce" messagetype="Subscribe"/>
                        <DataSource tagname="LRParkBrakeBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30"/>
                <HBox height="30">
                    <Label height="30" width="100" name="rr">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="rrParkBrake" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RRParkBrakeForce" messagetype="Subscribe"/>
                        <DataSource tagname="RRParkBrakeBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
            </VBox>

            <!-- Row 4 of 4 -->
            <!-- Test Failures -->
            <VBox height="160" width="607" posX="3" posY="550" border="true" borderstyle="title" bordertitle="testfailures">
                <!--HBox>
                    <Label name="testfailures" width="334" height="20">
                        <Font size="14" name="sans-serif" style="bold"/>
                    </Label>
                </HBox-->
                <Widget height="126" width="598" id="testfailures" class="com.bepco.gui.ListBox">
                    <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                    <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings">
                        <Font style="bold" name="sans-serif" size="14"/>
                    </ScrollBoxConfig>
                </Widget>
            </VBox>

            <!-- Machine Faults -->
            <VBox height="160" width="390" posX="610" posY="550" border="true" borderstyle="title" bordertitle="machinefaults">
                <!--HBox>
                    <Label name="machinefaults" width="334" height="20">
                        <Font size="14" name="sans-serif" style="bold"/>
                    </Label>
                </HBox-->
                <Widget height="126" width="380" id="machine_faults" class="com.bepco.gui.MachineFaultView">
                    <DataSource tagname="AllFaults" messagetype="Subscribe"/>
                    <ListBoxConfig stringmap="com.bepco.rtc.properties.MachineFaultStrings">
                        <Font style="bold" name="sans-serif" size="14"/>
                    </ListBoxConfig>
                </Widget>
            </VBox>
        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>

