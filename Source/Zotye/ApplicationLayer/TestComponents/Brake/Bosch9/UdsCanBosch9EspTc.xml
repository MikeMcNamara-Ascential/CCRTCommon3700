    <Objectives>

        <AnalyzeBrakeTest>
            <TestStep00>AnalyzeBrakeTest</TestStep00>
            <TestStep05>AnalyzeBalance</TestStep05>
            <TestStep10>EvaluateESP</TestStep10>
        </AnalyzeBrakeTest>

        <BrakeTest>
            <TestStep00>AccelerateToBrakeSpeed</TestStep00>
            <TestStep05>DragTest</TestStep05>
            <TestStep10>AnalyzeDragTest</TestStep10>
            <TestStep15>BrakeSwitchOffTest</TestStep15>
            <TestStep20>StopModuleKeepAlive</TestStep20>
            <TestStep25>FlexibleEspValveFiringTest</TestStep25>
            <TestStep30>StartModuleKeepAlive</TestStep30>
            <TestStep35>BrakeTest</TestStep35>
            <TestStep40>BrakeSwitchOnTest</TestStep40>
        </BrakeTest>

        <FinishUp>
            <TestStep00>DisableForceMeter</TestStep00>
            <TestStep05>StopModuleKeepAlive</TestStep05>
            <TestStep10>ReadFaults</TestStep10>
            <TestStep20>EnableSpeedLimit</TestStep20>
            <TestStep25>EnableValveRelayShutdown</TestStep25>
            <TestStep99>FinishUp</TestStep99>
        </FinishUp>

        <ParkBrakeTest>
            <TestStep00>AccelerateToParkBrakeSpeed</TestStep00>
            <TestStep01>DynamicParkBrakeTest</TestStep01>
            <TestStep02>AnalyzeDynamicParkBrake</TestStep02>
        </ParkBrakeTest>

        <Setup>
            <TestStep00>Setup</TestStep00>
            <TestStep05>Initialize</TestStep05>
            <TestStep10>EnterDiagnosticMode</TestStep10>
            <TestStep20>CheckEvacAndFill</TestStep20>
            <TestStep25>ClearFaults</TestStep25>
            <TestStep30>ReadFaults</TestStep30>
            <TestStep35>DisableSpeedLimit</TestStep35>
            <TestStep40>DisableValveRelayShutdown</TestStep40>
            <TestStep45>InitializeEolStatus</TestStep45>
            <TestStep90>StartModuleKeepAlive</TestStep90>
        </Setup>

        <WheelSpeedSensorTest>
            <TestStep00>BrakeToStop</TestStep00>
            <TestStep05 AltValue="Rear">TwoMotorWssTest</TestStep05>
            <TestStep10 AltValue="Front">TwoMotorWssTest</TestStep10>
            <TestStep15>BrakeToStop</TestStep15>
        </WheelSpeedSensorTest>

    </Objectives>



    <TestSteps>

        <AccelerateToBrakeSpeed Result="" Timeout="1200000" Description="Accelerate to Brake Test Arm Speed"
            ArmSpeed="50" SpeedTarget="50 60" Prompt1="AccelerateToTargetSpeed"/>

        <AccelerateToParkBrakeSpeed Result="" Timeout="90000" 
            Description="Accelerate to Dynamic Park Brake Speed" 
            Prompt1="AccelerateToTargetSpeed" 
            SpeedTarget="18 25" SpeedDomain="0 100" SpeedActive="1" SpeedInactive="0"/>

        <AnalyzeBalance Result="" Timeout="5000" Description="Base Brake Component Brake Balance Test" 
            FrontSideToSideBalance="8" RearSideToSideBalance="8" 
            BalanceFrontToRearMin="20" BalanceFrontToRearMax="70" Prompt1="" Prompt2=""/>

        <AnalyzeBrakeTest Result="" Timeout="20000" Description="Base Brake Component Brake Test Analysis" 
            FrontMinBrakeForce="222" FrontMaxBrakeForce="600" 
            RearMinBrakeForce="99" RearMaxBrakeForce="400" Prompt1="" Prompt2=""/>

        <AnalyzeDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis" 
            Prompt1="" Prompt2="" FrontMaxDragForce="55" RearMaxDragForce="55"/>

        <AnalyzeDynamicParkBrake Result="" Timeout="10000" Description="Analyze Dynamic Park Brake forces"/>

        <BrakeSwitchOffTest Result="" Timeout="500" ScanDelay="100" 
            Description="Verify brake switch indicates off when foot off pedal"
            PostDelayTime="0"/>

        <BrakeSwitchOnTest Result="" Timeout="500" ScanDelay="100"
            Description="Verify brake switch indicates on when foot on pedal"
            PostDelayTime="0"/>

        <BrakeTest Result="" Timeout="40000" Description="Base Brake Component Brake Test"
            StartBrakeSampleSpeed="45" EndBrakeSampleSpeed="25"
            BrakeDomain="0 500" BrakeTarget="250 350"
            Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeModeratelyInGreenBand"/>

        <BrakeToStop Result="" Timeout="120000" Description="Prompt the driver to brake to stop" 
            Prompt1="BrakeToStop" Prompt1Priority="0" SpeedTarget="0 0"/>

        <CheckEvacAndFill Result="" Timeout="10000" Description="Check the status of the evac/fill procedure"/>

        <ClearFaults Result="" Timeout="5000" Description="Clear faults from the module" ScanDelay="250"/>

        <DisableForceMeter Result="" Timeout="1000" Description="Disable the brake force meter"/>

        <DisableSpeedLimit Result="" Timeout="10000" Description="Disable Speed Limit"/>

        <DisableValveRelayShutdown Result="" Timeout="10000" Description="Disable Valve Relay Shutdown"/>

        <DragTest Result="" Timeout="40000" Description="Base Brake Component Brake Drag Test" 
            Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="Blank" 
            DragDelay="2000" DragSpeed="48" DragSamples="50"/>

        <DynamicParkBrakeTest Result="" Timeout="90000" 
            Description="Dynamic Park Brake Test" 
            RollerDirection="Forward" Prompt1="ShiftToNeutral" Prompt2="ApplyParkBrake"/>

        <EnableSpeedLimit Result="" Timeout="10000" Description="Enable Speed Limit"/>

        <EnableValveRelayShutdown Result="" Timeout="500" Description="Re-enable valve relay shutdown"/>

        <EnterDiagnosticMode Result="" Timeout="5000" Description="Enter diagnostic mode" ScanDelay="250"/>

        <EvaluateESP Result="" Timeout="5000" Description="Evaluate ABS pulses to ensure minimum requirements are met"/>

        <FinishUp Result="" Timeout="3000" Description="Brake test finishup"/>

        <FlexibleEspValveFiringTest Result="" Timeout="15000" Description="Sequence the ESP valves"/>

        <Initialize Result="" Timeout="1000" 
            Description="Initialize the BaseBrake portion of the test" 
            Prompt1="Initialize" ZerospeedPrompt="BrakeToStop"/>

        <InitializeEolStatus Result="" Timeout="500" Description="Set EOL Status to test not complete"/>

        <ReadFaults Result="" Timeout="5000" Description="Read faults from the module" ScanDelay="250"/>

        <Setup Result="" Timeout="500" Description="Set up component for testing"/>

