<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
  First stab at writing a config file for the GUI panels.
  Config for specific XMLWidgetPanels is under the
  $Revision: 1.1 $
-->

<RtGuiConfig>
    <Metadata author="Burke Porter, Inc" version="1.0"
              description="Standard implementation of the Driver Monitor view."/>
    <XmlWidgetPanel id="DriverMonitor">
        <Layout>
            <!-- row 1 of three -->
            <!-- Trafficlight (test drive status) ================================================= -->
            <!-- Traffic Light
                Traffic Light States:
                    NoVIN = OFF
                    TestReady = GREEN
                    ProcessingVIN = YELLOW
                    ReadVIN = RED
            -->
            <HBox posX='7' posY='1' height='280' width='175'>
                <VBox width='175'>
                    <HBox>
                        <Label name="vinread" border="false">
                            <Font size="20" name="serif" style="bold"/>
                        </Label>
                    </HBox>
                    <HBox>
                        <Widget id="trafficlight" class="com.bepco.gui.ImagePhaseBox"
                                  height="125" screensaver="true">
                            <DataSource tagname="VINReadStatus" messagetype="Subscribe"/>
                        </Widget>
                    </HBox>
        

                    <HBox height='10'/>

                    <HBox height='20'>
                        <VBox>
                            <HBox>
                                <Label name="front">
                                    <Font size="30" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <HBox height='7'/>
                            <HBox>
                                <Label name="rear">
                                    <Font size="30" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                        </VBox>
                        <VBox width="15"/>
                        <VBox>
                            <Widget id="_lf" class="com.bepco.gui.NumberBox" width="60">
                                <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                                <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                <TextBoxConfig>
                                    <Font size="30" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                            <HBox height='7'/>
                            <Widget id="_rr" class="com.bepco.gui.NumberBox" width='60'>
                                <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                                <DataSource tagname="RRSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                <TextBoxConfig>
                                    <Font size="30" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>
            <!-- END OF Trafficlight ========================================== -->
            <!-- START OF Three radial gauges ================================= -->
            <HBox posX="175" posY="0" width="600" height="270">
                <!-- space -->
                <!--VBox width="50"/-->
                <!-- Speedometer gauge -->
                <Widget id="speed" height="300" width="300" class="com.bepco.gui.RadialGauge">
                    <DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
                    <DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
                    <DataSource tagname="SpeedActive" tagrole="enabled" messagetype="Subscribe"/>
                    <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
                        <Font size="32" name="sans-serif" style="plain"/>
                    </RadialGaugeConfig>
                </Widget>
                <VBox width="20"/>
                <!-- Brake force gauge -->
                <VBox>
                    <Widget id="brakeforce" height="230" width="230" class="com.bepco.gui.RadialGauge">
                        <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10"/>
                        <DataSource tagname="BrakeTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <DataSource tagname="BrakeActive" messagetype="Subscribe" tagrole="enabled"/>
                        <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="450" targetlow="0" targethigh="0" bgcolor="red">
                            <Font size="30" name="sans-serif" style="plain"/>
                        </RadialGaugeConfig>
                    </Widget>
                    <HBox>
                        <Label name="requestedGear">
                            <Font size="32" name="sans-serif" style="bold"/>
                        </Label>
                        <VBox width="5"/>
                        <Widget id="_reqTransGear" class="com.bepco.gui.NumberBox" width='80'>
                            <DataSource tagname="RequestedGear" messagetype="Read" datarate="10" />
                            <DataSource tagname="TPSActive" messagetype="Subscribe" tagrole="enabled"/>
                            <TextBoxConfig>
                                <Font size="32" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                    </HBox>
                </VBox>
            </HBox>
            <!-- TPS - Blade angle -->
            <Widget id="blade" height="230" width="240" class="com.bepco.gui.RadialGauge" posX="770" posY="0">
                <DataSource tagname="TPSValue" messagetype="Read" datarate="20"/>
                <DataSource tagname="TPSTarget" tagrole="targetrange" messagetype="Subscribe"/>
                <DataSource tagname="TPSActive" messagetype="Subscribe" tagrole="enabled"/>
                <RadialGaugeConfig placement="southwest" startangle="270" stopangle="360" domainlow="0" domainhigh="35" targetlow="15" targethigh="23" bgcolor="red">
                    <Font size="20" name="sans-serif" style="plain"/>
                </RadialGaugeConfig>
            </Widget>
            <VBox height="40" width="240" posX="780" posY="230">
                <HBox>
                    <VBox>
                        <Label name="currentGear">
                            <Font size="32" name="sans-serif" style="bold"/>
                        </Label>
                    </VBox>
                        <VBox width='5'/>
                    <VBox>
                        <Widget id="_transGear" class="com.bepco.gui.NumberBox" width='80'>
                            <DataSource tagname="CurrentGear" messagetype="Read" datarate="10" />
                            <DataSource tagname="TPSActive" messagetype="Subscribe" tagrole="enabled"/>
                            <TextBoxConfig>
                                <Font size="32" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                    </HBox>
                </VBox>
            <!-- END OF Three radial gauges =================================== -->
            <!-- START OF Driver Prompt Boxes ================================= -->
            <Widget id="prompts1" class="com.bepco.gui.PromptBox" posX="7" posY="275" width="1005" height="90" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe" />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts2" class="com.bepco.gui.PromptBox" posX="7" posY="370" width="1005" height="90" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe" />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <!-- END OF Driver Prompt Boxes ================================= -->
            <!-- Row 2 of 3 -->
            <HBox border="false" posX="7" posY="430" width="1012" height="300">
                <HBox height="170" width="200">
                    <!-- subsystem test pass/fail widgets 
                        TestStates:
                            TestInProgress 	- Blue
                            Timeout		- Orange
                            Pass		- Green
                            Fail		- Red
                            Abort		- Yellow
                    -->
                    <VBox width='185'>
                        <Widget width='175' height='31' id="emiss" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="EmissionsOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="xfer" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TransferCaseOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="cruise" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SpeedControlOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="skim" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SKIMOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="airbag" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="AirbagOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
                <HBox>
                    <VBox width='185'>
                        <Widget width='175' height='31'  id="tpm" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TPMOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="steering" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SASOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="epb" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="EpbOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="parkAssist" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="ParkAssistOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="throttlecontrol" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="ETCOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="ocm" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="OCMOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='175' height='31'  id="rfhm" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="RFHMOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="22" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
                <!-- END OF subsystem test pass/fail widgets ========================================== -->
                <!-- START of Test Failures Box===================================================== -->
                <HBox border="true" height="195" width="620">
                    <VBox width="620">
                        <HBox>
                            <Label name="testfailures">
                                <Font size="24" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget height="180" width="615" id="testfailures" class="com.bepco.gui.ListBox">
                            <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                            <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings" scrollbar="false">
                                <Font style="bold" name="serif" size="22"/>
                            </ScrollBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
            </HBox>
            <!-- END of Test Failures Box ===================================================== -->
		  
            <!-- START of VIN BOX ============================================================== -->
            <HBox posX='7' posY='700' width='1012' height='68' border="false">
                <!-- VIN -->
                <Label name="vin" border="false" height='68' width='100'>
                    <Font size="45" name="sans-serif" style="plain"/>
                </Label>
                <Widget id="_vin" height='68' width="550" class="com.bepco.gui.TextBox" screensaver="true">
                    <DataSource tagname="VINDisplay" messagetype="Subscribe" />
                    <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
                              tagrole="backgroundcolor" />
                    <TextBoxConfig>
                        <Font size="45" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
                <!-- DRIVER ID -->
                <Label name="driverid" border="false" height='68' width='160'>
                    <Font size="45" name="sans-serif" style="plain"/>
                </Label>
                <Widget id="_driverid" height='68' width="200" class="com.bepco.gui.TextBox" screensaver="true">
                    <DataSource tagname="DriverNumberDisplay" messagetype="Subscribe"/>
                    <DataSource tagname="DriverNumberDisplayBGColor" messagetype="Subscribe"
                              tagrole="backgroundcolor" />
                    <TextBoxConfig>
                        <Font size="45" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
            </HBox>
            <!-- START of Driver ID ============================================================ -->
            <!-- END of Driver ID ============================================================== -->
        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>

