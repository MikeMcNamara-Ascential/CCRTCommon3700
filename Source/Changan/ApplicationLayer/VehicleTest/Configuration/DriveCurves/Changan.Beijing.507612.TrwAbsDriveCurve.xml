<DriveCurve Description="Base brake drive curve">
   <Components Debug="Off">
      <Brake>
         <ComponentName>TrwAbsTc.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>UdsTrwAbsTc.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
         <Debug>Off</Debug>
      </Brake>
      <Machine>
         <ComponentName>MachineTC.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>MachineTc.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
         <Debug>Off</Debug>
      </Machine>
      <ElectronicParkBrake>
         <ComponentName>ElectronicParkBrakeTC.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>ElectronicParkBrakeTc.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/ElectronicParkBrake/</ConfigPath>
         <Debug>Off</Debug>
      </ElectronicParkBrake>
      <SoundLevel>
         <ComponentName>ChanganSoundLevelTC.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
         <ConfigFile>SoundLevelComponent.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/SoundLevel</ConfigPath>
         <Debug>Off</Debug>
      </SoundLevel>
      <SpeedControl>
         <ComponentName>GenericSpeedControl.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
         <ConfigFile>SpeedControlTc.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/SpeedControl</ConfigPath>
         <Debug>Off</Debug>
      </SpeedControl>
      <Speedometer>
         <ComponentName>MachineTC.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>MachineTc_Speedometer.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
         <Debug>Off</Debug>
      </Speedometer>
   </Components>
   <Test Result="" Debug="Off">
      <!-- Initialize the system -->
      <TestPhase000 Description="Initialize the machine" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Init machine Component" Result="" Timeout="" Component="Machine">
               <Initialize/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase000>
      <TestPhase001 Description="Connect the cable" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Machine">
               <ConnectCable/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase001>
      <TestPhase005 Description="Initialize the brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Init brake Component" Result="" Timeout="" Component="Brake">
               <Initialize/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase005>
      <!-- Perform Reverse testing -->
      <TestPhase050 Description="Perform reverse driving test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Check reverse driving gear on the vehicle" Result="" Timeout="" Component="Machine">
               <Reverse/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase050>
      <TestPhase055 Description="Check Reverse Lamps" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Check reverse lamps on the vehicle" Result="" Timeout="" Component="Machine">
               <DriverQuestion>CheckReverseLamps</DriverQuestion>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase055>
      <!--Perform Idle Horn Test-->
      <TestPhase065 Description="Start monitoring sound level" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Start monitoring sound level" Result="" Timeout="" Component="SoundLevel">
               <StartSoundTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase065>
      <TestPhase066 Description="Read idle sound level" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Read idle sound level" Result="" Timeout="" Component="SoundLevel">
               <IdleHornTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase066>
      <!-- Perform the 40kph Speedo test -->
      <TestPhase070 Description="40kph Speedo Test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="40kph Speedo Test" Result="" Timeout="" Component="Speedometer">
               <Speedometer/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase070>
      <!-- Perform the AccelerateToSpeed test -->
      <TestPhase080 Description="Acceleration Test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Acceleration Test" Result="" Timeout="" Component="Machine">
               <AccelerateToSpeed/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase080>
      <!--Perform Running Horn Test-->
      <TestPhase085 Description="Read running sound level" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Read running sound level" Result="" Timeout="" Component="SoundLevel">
               <RunningHornTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase085>
      <!-- Speed Control Testing -->
      <TestPhase090 Description="Speed Control Test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Speed Control Test" Result="" Timeout="" Component="SpeedControl">
               <SpeedControlTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase090>
      <!-- Perform the brake test -->
      <TestPhase100 Description="Perform the brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="run the base brake test" Result="" Timeout="" Component="Brake">
               <BrakeTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase100>
      <TestPhase105 Description="Brake to stop and analyze results" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
               <BrakeToStop/>
            </Objective0>
         </ForegroundObjectives>
         <BackgroundObjectives Result="" Timeout="">
            <Objective0 Description="Analyze brake test data" Result="" Timeout="" Component="Brake">
               <AnalyzeBrakeTest/>
            </Objective0>
         </BackgroundObjectives>
      </TestPhase105>
      <TestPhase130 Description="Perform Electronic Park Brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Perform Electronic Park Brake test" Result="" Timeout="" Component="ElectronicParkBrake">
               <ParkBrakeTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase130>
      <TestPhase140 Description="Stop the sound monitor thread" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Stop the sound monitor thread" Result="" Timeout="" Component="SoundLevel">
               <StopSoundTest/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase140>
      <TestPhase145 Description="" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective3 Description="Perform finish-up" Result="" Timeout="" Component="SoundLevel">
               <FinishUp>PerformingFinishUp</FinishUp>
            </Objective3>
         </ForegroundObjectives>
      </TestPhase145>
      <!-- Perform operator buyoff checks -->
      <TestPhase150 Description="Check vehicle Lamps" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Check lamps on the vehicle" Result="" Timeout="" Component="Machine">
               <MultiDriverQuestion>LampCheck</MultiDriverQuestion>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase150>
      <!-- Finishup and set results -->
      <TestPhase200 Description="Set the result for the brake test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Set the brake test result" Result="" Timeout="" Component="Brake">
               <FinishUp/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase200>
   </Test>
</DriveCurve>
