<SideSlipMonitor>

    <Setup>

        <Debug>Off</Debug>

        <Communication>
           <Comm>IPC</Comm>
           <Debug>Off</Debug>
           <Name>core/SideSlipMonitor</Name>
           <BufferSize>4000</BufferSize>
           <Timeout>2000</Timeout>
           <Type>Server</Type>
        </Communication>

        <DataTags>
            <SideSlipIn>VehiclePresentSideSlipIn</SideSlipIn>
            <SideSlipOut>VehiclePresentSideSlipOut</SideSlipOut>
        </DataTags>

        <Logging>
           <Status>Enabled</Status>
           <ProcessName>core/SideSlipMonitor</ProcessName>
           <AdditionalLogFile>/Servers/SideSlipMonitor.log</AdditionalLogFile>
           <LocalEcho>Disabled</LocalEcho>
           <Verbose>0x1F</Verbose>
           <Debug>Off</Debug>
        </Logging>

        <TagList>
           <SubscribeTags>
               <VehiclePresentSideSlipIn/>
               <VehiclePresentSideSlipOut/>
           </SubscribeTags>
        </TagList>

        <ThreadPool>
           <Debug>Off</Debug>
           <Increment>2</Increment>
           <MaxBlockedLimit>21</MaxBlockedLimit>
           <Maximum>30</Maximum>
           <MinBlockedLimit>2</MinBlockedLimit>
        </ThreadPool>

        <NotificationList>
           <Setup>
              <Debug>Off</Debug>
              <HighWater>3</HighWater>
              <Increment>1</Increment>
              <LowWater>1</LowWater>
              <Maximum>5</Maximum>
              <StartOnCreate>No</StartOnCreate>
              <ResponseTimeout>2000</ResponseTimeout>
           </Setup>
        </NotificationList>

        <Parameters>
            <AxleInterval>10000</AxleInterval>
            <AxleTimeLimit>5000</AxleTimeLimit>
            <SideSlipConversionFactor>0.01</SideSlipConversionFactor>
            <SideSlipMonitorInterval>100</SideSlipMonitorInterval>
        </Parameters>

    </Setup>

</SideSlipMonitor>
