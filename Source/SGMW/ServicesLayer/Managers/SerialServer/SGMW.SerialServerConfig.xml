<SerialServerConfig>
    <Verbose>0x1F</Verbose>
    <Setup>
        <Demo>0</Demo>
        <MgrPool lowWater="2" hiWater="5" maximum="10" increment="1"/>
        <Logging>
            <ProcessName>mgr/SerialServer</ProcessName>
            <AdditionalLogFile>/Servers/SerialServer.log</AdditionalLogFile>
            <Status>Enabled</Status>
            <LocalEcho>Disabled</LocalEcho>
            <Debug>Off</Debug>
            <Verbose>0x1F</Verbose>
        </Logging>
        <LogicalPorts>

            <MQS enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/TcpCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/socket</SerialDevice>
                    <MgrPool lowWater="2" hiWater="45" maximum="50" increment="2" priority="35"/>
                    <IpAddress>10.18.243.77</IpAddress>
                    <PortNo>8041</PortNo>
                    <TcpType>Client</TcpType>
                    <Protocol>
                        <Baud>19200</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>TxRx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/MQS</ProcessName>
                        <AdditionalLogFile>/Communication/Mqs.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>MQS</ProcessName>
                                <AdditionalLogFile>/Communication/MqsComm.log</AdditionalLogFile>
                                <Status>Enabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </MQS>

            <GryphonCCan enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/GryphonCANCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/socket</SerialDevice>
                    <MgrPool lowWater="2" hiWater="45" maximum="50" increment="2" priority="35"/>
                    <Protocol>
                        <Baud>19200</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>TxRx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/GryphonCAN</ProcessName>
                        <AdditionalLogFile>/Communication/GryphonCAN.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>CAN</ProcessName>
                                <AdditionalLogFile>/Communication/GryphonCANComm.log</AdditionalLogFile>
                                <Status>Enabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                    <Login>
                        <IPAddress>192.168.1.20</IPAddress>
                        <Port>7000</Port>
                        <UserID>gryphon</UserID>
                        <Password>gryphon</Password>
                    </Login>
                    <Alias>/home/CCRT/Rewrite/GryphonCCan</Alias>
                    <NodePairs>
                        <ABS Outgoing="0x7DF" Incoming="0x728"/>
                    </NodePairs>
                    <NodePairSetup>
                        <Range1 FirstRequestID="0x7DF" FirstResponseID="0x728" NumberOfPairs="1"/>
                    </NodePairSetup>
                </Setup>
            </GryphonCCan>

            <ISOK enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/IsoCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/sl7804/ser2</SerialDevice>
                    <MgrPool lowWater="7" hiWater="7" maximum="7" increment="1" priority="23"/>
                    <DefaultReplyTimeout units="milliseconds">5000</DefaultReplyTimeout>
                    <Protocol>
                        <Baud>9600</Baud>
                        <Parity>Even</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>1</Reflection>
                        <ByteGap>5</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>Rx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/ISOK</ProcessName>
                        <AdditionalLogFile>/Servers/ISOKComm.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>ISOK_Comm</ProcessName>
                                <AdditionalLogFile>/Communication/ISO_BusComm.log</AdditionalLogFile>
                                <Status>Enabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </ISOK>


            <LeftScanner enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
                <Setup>
                    <SerialDevice>/dev/sl7804/ser3</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="23"/>
                    <Protocol>
                        <Baud>9600</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>Rx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/LeftScanner</ProcessName>
                        <AdditionalLogFile>LeftScannerComm.log</AdditionalLogFile>
                        <Status>Enabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x01</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>LeftScanner_Comm</ProcessName>
                                <AdditionalLogFile>LeftScanner_BusComm.log</AdditionalLogFile>
                                <Status>Disabled</Status>
