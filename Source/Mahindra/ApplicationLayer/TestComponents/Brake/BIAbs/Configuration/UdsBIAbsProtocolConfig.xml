<WabcoAbsUdsProtocol>
    <Setup>
        <!-- Module Interface parameters -->
        <CommunicationProtocol>CANKeywordProtocol2000</CommunicationProtocol>
        <IndividualWheelSensorRead>1</IndividualWheelSensorRead>
        <WheelSpeedSensors>
            <Wheel_0>LFWheelspeedSensor</Wheel_0>
            <Wheel_1>RFWheelspeedSensor</Wheel_1>
            <Wheel_2>LRWheelspeedSensor</Wheel_2>
            <Wheel_3>RRWheelspeedSensor</Wheel_3>
            <Wheel_4>LTWheelspeedSensor</Wheel_4>
            <Wheel_5>RTWheelspeedSensor</Wheel_5>
        </WheelSpeedSensors>

        <!-- Protocol filter behavior settings -->
        <AutomaticallyEnterDiagnosticMode>True</AutomaticallyEnterDiagnosticMode>
        <NumberOfRetries>3</NumberOfRetries>
        <ResponsePendingReads>3</ResponsePendingReads>

        <!-- Module specific Settings -->
        <ModuleRequestID>0x7E4</ModuleRequestID>
        <ModuleResponseDelay>250</ModuleResponseDelay>
        <ModuleResponseEndDelay>30</ModuleResponseEndDelay>
        <ModuleKeepAliveTime>250</ModuleKeepAliveTime>
        <KeepAliveResponseRequired>Yes</KeepAliveResponseRequired>
        <UDSReadFaults>1</UDSReadFaults>
        <DTCData>
            <DTCCountIndex>-1</DTCCountIndex>
            <BytesPerDTC>4</BytesPerDTC>
            <FirstDTCByteIndex>3</FirstDTCByteIndex>
            <NumberOfFaultRegisters>0</NumberOfFaultRegisters>
        </DTCData>
        <SecurityUnlockType>BIAbs</SecurityUnlockType>

        <!-- Message Settings -->
        <CheckSumLength>1</CheckSumLength>
        <DataByteCountIndex>3</DataByteCountIndex>
        <DataHeaderLength>2</DataHeaderLength>
        <DataStartIndex>6</DataStartIndex>
        <NegativeResponseCodeIndex>2</NegativeResponseCodeIndex>
        <NegativeResponseValue>0x7F</NegativeResponseValue>
        <SentMessageIdentifierIndex>0</SentMessageIdentifierIndex>
        <ValidateChecksum>False</ValidateChecksum>
        <ValidResponseOffset>0x40</ValidResponseOffset>

        <NegativeResponseCodes>
            <Code_0x10>General Reject</Code_0x10>
            <Code_0x11>Service Not Supported</Code_0x11>
            <Code_0x12>Sub-Function Not Supported</Code_0x12>
            <Code_0x13>Incorrect Message Length / Invalid Format</Code_0x13>
            <Code_0x21>ECU Busy, Repeat Request</Code_0x21>
            <Code_0x22>Conditions Not Correct</Code_0x22>
            <Code_0x24>Request Sequence Error</Code_0x24>
            <Code_0x31>Request out Of Range</Code_0x31>
            <Code_0x33>Security Access Denied</Code_0x33>
            <Code_0x35>Invalid Security Key</Code_0x35>
            <Code_0x36>Exceeded Number of Attempts</Code_0x36>
            <Code_0x37>Required Time Delay Not Expired</Code_0x37>
            <Code_0x70>Upload/Download Not Accepted</Code_0x70>
            <Code_0x71>Transfer Data Suspended</Code_0x71>
            <Code_0x72>NVRAM Write Error Failure</Code_0x72>
            <Code_0x73>Wrong Block Sequence Counter</Code_0x73>
            <Code_0x78>Response Pending</Code_0x78>
            <Code_0x7E>Sub-Function Not Supported in Active Session</Code_0x7E>
            <Code_0x7F>Service Not Supported in Active Session</Code_0x7F>
            <Code_0x81>RPM Too High</Code_0x81>
            <Code_0x82>RPM Too Low</Code_0x82>
            <Code_0x83>Engine Is Running</Code_0x83>
            <Code_0x84>Engine Is NOt Running</Code_0x84>
            <Code_0x85>EngineRun Time Too Low</Code_0x85>
            <Code_0x86>Temperature Too High</Code_0x86>
            <Code_0x87>Temperature Too Low</Code_0x87>
            <Code_0x88>Vehicle Speed Too High</Code_0x88>
            <Code_0x89>Vehicle Speed Too Low</Code_0x89>
            <Code_0x8A>Throttle Pedal Too High</Code_0x8A>
            <Code_0x8B>Throttle Pedal Too low</Code_0x8B>
            <Code_0x8C>Transmission in Neutral</Code_0x8C>
            <Code_0x8D>Transmission in Gear</Code_0x8D>
            <Code_0x8F>Brake Switch Not Closed</Code_0x8F>
            <Code_0x90>Shift Lever Not In Park</Code_0x90>
            <Code_0x91>Torque Converter Clutch Locked</Code_0x91>
            <Code_0x92>Voltage Too High</Code_0x92>
            <Code_0x93>Voltage Too Low</Code_0x93>
            <EnterDiagnosticMode>0x7F</EnterDiagnosticMode>
            <ResponsePending>0x78</ResponsePending>
            <ModuleBusy>0x21</ModuleBusy>
            <EnterDiagnosticModeMessageTag>EnterDiagMode</EnterDiagnosticModeMessageTag>
        </NegativeResponseCodes>

        <Communication>
            <Debug>Off</Debug>
            <Name>/home/CCRT/Rewrite/GryphonCCan</Name>
            <BufferSize>4096</BufferSize>
            <CommSize>1</CommSize>
            <Timeout>10000000</Timeout>
            <Retries>3</Retries>
        </Communication>

        <Logging>
            <Status>Enabled</Status>
            <ProcessName>UdsBIAbsProtocol</ProcessName>
            <AdditionalLogFile>/Communication/UdsBIAbsProtocol.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
        
        

