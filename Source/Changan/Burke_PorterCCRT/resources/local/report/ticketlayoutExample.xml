<?xml version="1.0"?>
<!DOCTYPE RtReportConfig SYSTEM "resource:///com/bepco/rtc/report/rtreportconfig.dtd">
 
 <RtReportConfig>
	<ReportLayout>
	  <Title>CCRT Vehicle Test Result Report</Title>
	  <TestIdBlock>
		<Column>
		  <ServerTag tagname="VIN" label="VIN"/>
			<Timestamp/>
			<TestResultDetail tagname="MachineDriverNumber" childtagname="DriverNumber" label="Driver"/>
		</Column>
	  </TestIdBlock>	

	  <HorizontalBar/>

 	  <BuildDataBlock label="Build Data">
		<Column>
		  <ServerTag tagname="Axle" label="Axle"/>
		  <ServerTag tagname="BuildDate" label="Date"/>
		  <ServerTag tagname="BuildTime" label="Time"/>
		</Column>
	  </BuildDataBlock>

	  <HorizontalBar/>

		<BrakeResultsBlock>	
    <Column>
		</Column>
		</BrakeResultsBlock>
		
 	  <TestResultsBlock>
		<Column>
		  <TestProcess showdetail="failures" tagname="EmissionsOverallTest" label="Emissions"/>
		  <TestProcess showdetail="failures" tagname="AirbagOverallTest" label="Airbag"/>
		  <TestProcess showdetail="failures" tagname="BrakeOverallTest" label="Brake"/>
		  <TestProcess showdetail="failures" tagname="SpeedControlOverallTest" label="Speed Control"/>
		  <TestProcess showdetail="failures" tagname="TransmissionOverallTest" label="Transmission"/>
		  <TestProcess showdetail="all" tagname="SKIMOverallTest" label="SKIM"/>
		  <TestProcess showdetail="all" tagname="CruiseOverallTest" label="Cruise"/>
		  <TestProcess showdetail="all" tagname="ClusterOverallTest" label="Cluster"/>
		</Column>
	  </TestResultsBlock>

	</ReportLayout>
  

 </RtReportConfig>
 
 
