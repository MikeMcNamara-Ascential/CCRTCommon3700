<DataServerconfig>
    <DataServer>
        <Setup>
            <Debug>Off</Debug>
            <NdbCommandTags>
                <CommandTest/>
                <LossCompensation/>
            </NdbCommandTags>
            <NdbWriteTags>
                <JogWheelbaseLong/>
                <JogWheelbaseShort/>
            </NdbWriteTags>
            <Communication>
                <Type>Server</Type>
                <Address>localhost</Address>
                <Comm>TCP/IP</Comm>
                <Size>5000</Size>
                <Timeout>1000</Timeout>
                <FrameStart>BepXmlMssg</FrameStart>
                <FrameEnd>/BepXmlMssg</FrameEnd>
                <Port>10000</Port>
                <Debug>Off</Debug>
                <Backlog>10</Backlog>
            </Communication>
            <Logging>
                <Status>Disabled</Status>
                <ProcessName>DataServer</ProcessName>
                <AdditionalLogFile Types="/Servers/DataServer.log or Disabled">/Servers/DataServer.log</AdditionalLogFile>
                <Debug>Off</Debug>
                <LocalEcho>Disabled</LocalEcho>
                <Verbose>0x00</Verbose>
            </Logging>
            <NotificationList>
                <Setup>
                    <Debug>Off</Debug>
                    <HighWater>3</HighWater>
                    <Increment>1</Increment>
                    <LowWater>1</LowWater>
                    <Maximum>5</Maximum>
                    <StartOnCreate>No</StartOnCreate>
                    <ResponseTimeout>2000</ResponseTimeout>
                </Setup>
            </NotificationList>
            <ThreadPool>
                <Debug>Off</Debug>
                <MinBlockedLimit>10</MinBlockedLimit>
                <MaxBlockedLimit>20</MaxBlockedLimit>
                <Increment>1</Increment>
                <Maximum>500</Maximum>
            </ThreadPool>
        </Setup>
    </DataServer>
    <SubscriptionManager>
        <Setup>
            <Debug>Off</Debug>
            <Communication>
                <Comm>IPC</Comm>
                <Type>Server</Type>
                <Name>core/DataServer</Name>
                <BufferSize>1024</BufferSize>
                <Timeout>1000</Timeout>
                <Debug>Off</Debug>
            </Communication>
            <Logging>
                <Status>Disabled</Status>
                <ProcessName>SubscriptionManager</ProcessName>
                <AdditionalLogFile Types="/Servers/SubscriptionManager.log or Disabled">/Servers/SubscriptionManager.log</AdditionalLogFile>
                <Debug>Off</Debug>
                <LocalEcho>Disabled</LocalEcho>
                <Verbose>0x01</Verbose>
            </Logging>
            <NotificationList>
                <Setup>
                    <Debug>Off</Debug>
                    <HighWater>3</HighWater>
                    <Increment>1</Increment>
                    <LowWater>1</LowWater>
                    <Maximum>5</Maximum>
                    <StartOnCreate>No</StartOnCreate>
                    <ResponseTimeout>2000</ResponseTimeout>
                </Setup>
            </NotificationList>
            <ThreadPool>
                <Debug>Off</Debug>
                <MinBlockedLimit>10</MinBlockedLimit>
                <MaxBlockedLimit>20</MaxBlockedLimit>
                <Increment>1</Increment>
                <Maximum>50</Maximum>
            </ThreadPool>
        </Setup>
    </SubscriptionManager>
</DataServerconfig>
