<BrakeTC>
    <Setup>
        <Name>Brake</Name>
        <Debug>Off</Debug>
        <DebugLevel>0</DebugLevel>
        <ProcessPriority>11</ProcessPriority>
        <TestDomain>Foreground</TestDomain>
        <Communication>
            <Comm>IPC</Comm>
            <Type>Server</Type>
            <Name>component/BaseBrake</Name>
            <Debug>Off</Debug>
            <BufferSize>1024</BufferSize>
            <Timeout>0</Timeout>
        </Communication>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>50</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
            </Setup>
        </NotificationList>
        <Logging>
            <Debug>Off</Debug>
            <MessageTimeout>100</MessageTimeout>
            <AdditionalLogMaxSize>10</AdditionalLogMaxSize>
            <AdditionalLogMaxFiles>5</AdditionalLogMaxFiles>
            <Status>Enable</Status>
            <ProcessName>BaseBrake</ProcessName>
            <AdditionalLogFile>/Components/BaseBrake</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <TagList>
            <!-- There are no publish tags for the base brake test component -->
            <PublishTags/>
            <SubscribeTags>
                <Abort/>
                <Zerospeed/>
            </SubscribeTags>
        </TagList>
        <!-- ============================================================================================== -->
        <DataTags>
            <AbsBuildOk>AbsBuildOk</AbsBuildOk>
            <AbsDumpOk>AbsDumpOk</AbsDumpOk>

            <LfBrakeDisplayTag>LFForceValue</LfBrakeDisplayTag>
            <LfCurrentForce>LFLoadCellValueRaw</LfCurrentForce>
            <LfDragDisplayTag>LFForceValue</LfDragDisplayTag>
            <LFSpeed>LFSpeed</LFSpeed>

            <LrBrakeDisplayTag>LRForceValue</LrBrakeDisplayTag>
            <LrCurrentForce>LRLoadCellValueRaw</LrCurrentForce>
            <LrDragDisplayTag>LRForceValue</LrDragDisplayTag>
            <LRSpeed>LRSpeed</LRSpeed>

            <RfBrakeDisplayTag>RFForceValue</RfBrakeDisplayTag>
            <RfCurrentForce>RFLoadCellValueRaw</RfCurrentForce>
            <RfDragDisplayTag>RFForceValue</RfDragDisplayTag>
            <RFSpeed>RFSpeed</RFSpeed>

            <RrBrakeDisplayTag>RRForceValue</RrBrakeDisplayTag>
            <RrCurrentForce>RRLoadCellValueRaw</RrCurrentForce>
            <RrDragDisplayTag>RRForceValue</RrDragDisplayTag>
            <RRSpeed>RRSpeed</RRSpeed>

            <VariableDataBalanceResultTag>VariableDataBalanceResult</VariableDataBalanceResultTag>
            <VariableDataBalanceValueTag>VariableDataBalanceValue</VariableDataBalanceValueTag>
            <VariableDataReadyTag>VariableDataReady</VariableDataReadyTag>
            <VariableDataSumResultTag>VariableDataTestResult</VariableDataSumResultTag>
            <VariableDataSumValueTag>VariableDataTestValue</VariableDataSumValueTag>
            <VariableDataTypeTag>VariableDataType</VariableDataTypeTag>

        </DataTags>
        <!-- ============================================================================================== -->
        <Parameters>
            <!-- Testing Behavior Parameters -->
            <DisplayBrakeMeterUntilZeroSpeed>True</DisplayBrakeMeterUntilZeroSpeed>
            <IgnoreMachineConditions>True</IgnoreMachineConditions>
            <KeepTestStatusOnExit>True</KeepTestStatusOnExit>
            <OperatorReactionTime Units="ms">3000</OperatorReactionTime>
            <SamplesAboveLimitToStartAverage>10</SamplesAboveLimitToStartAverage>
            <TestCompleteCheckDelay Units="ms">250</TestCompleteCheckDelay>
            <TestHeadStatusBitDelay Units="ms">500</TestHeadStatusBitDelay>
            <TestInProgressColor>yellow</TestInProgressColor>
            <VariableDataprocessingDelay Units="ms">500</VariableDataprocessingDelay>

            <!-- ICM Data Parameters -->
            <CurrentDistances>/dev/Icm/Block/PulseCount</CurrentDistances>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <ICMName>mgr/ICM</ICMName>

            <!-- Machine Parameters -->
            <LoadCellReadingDelay Units="ms">100</LoadCellReadingDelay>
            <MotorReactionTime Units="ms">1000</MotorReactionTime>
            <PulsesPerRevolution>1250</PulsesPerRevolution>
            <RollerDiameter Units="inches">19.5275</RollerDiameter>

            <!-- ABS Test Parameters -->
            <AbsBuildDelay Units="ms">500</AbsBuildDelay>
            <AbsBuildMaxPercent Units="percent">1.50</AbsBuildMaxPercent>
            <AbsBuildMinPercent Units="percent">0.60</AbsBuildMinPercent>
            <MaxAbsBuildComparePercent Units="percent">1.50</MaxAbsBuildComparePercent>
            <MinAbsBuildComparePercent Units="percent">0.80</MinAbsBuildComparePercent>
            <AbsDumpMaxLimit Units="N" ConvertToEnglishUnits="False">30</AbsDumpMaxLimit>
            <AbsMonitorDelay Units="ms">100</AbsMonitorDelay>
            <MaxAbsDumpPercent Units="percent">1.50</MaxAbsDumpPercent>
            <MinAbsDumpPercent Units="percent">0.80</MinAbsDumpPercent>

            <!-- Brake Test Parameters -->
            <NumberOfBrakeSamples>20</NumberOfBrakeSamples>
            <FrontAxleBrakeForceSpeedLf Units="km/h" ConvertToEnglishUnits="True">2.5</FrontAxleBrakeForceSpeedLf>
            <FrontAxleBrakeForceSpeedRf Units="km/h" ConvertToEnglishUnits="True">2.5</FrontAxleBrakeForceSpeedRf>
            <FrontAxleBrakeForceSpeedLr Units="km/h" ConvertToEnglishUnits="True">0.0</FrontAxleBrakeForceSpeedLr>
            <FrontAxleBrakeForceSpeedRr Units="km/h" ConvertToEnglishUnits="True">0.0</FrontAxleBrakeForceSpeedRr>
            <RearAxleBrakeForceSpeedLf Units="km/h" ConvertToEnglishUnits="True">0.0</RearAxleBrakeForceSpeedLf>
            <RearAxleBrakeForceSpeedRf Units="km/h" ConvertToEnglishUnits="True">0.0</RearAxleBrakeForceSpeedRf>
            <RearAxleBrakeForceSpeedLr Units="km/h" ConvertToEnglishUnits="True">2.5</RearAxleBrakeForceSpeedLr>
            <RearAxleBrakeForceSpeedRr Units="km/h" ConvertToEnglishUnits="True">2.5</RearAxleBrakeForceSpeedRr>
            <FrontBrakeLimit Units="N" ConvertToEnglishUnits="False">200</FrontBrakeLimit>
            <FrontBrakeDiffLimit Units="N" ConvertToEnglishUnits="False">20</FrontBrakeDiffLimit>
            <RearBrakeLimit Units="N" ConvertToEnglishUnits="False">150</RearBrakeLimit>
            <RearBrakeDiffLimit Units="N" ConvertToEnglishUnits="False">15</RearBrakeDiffLimit>
    
            <!-- Drag Test Parameters -->
            <FrontDragDiffLimit Units="N" ConvertToEnglishUnits="False">10.0</FrontDragDiffLimit>
            <RearDragDiffLimit Units="N" ConvertToEnglishUnits="False">10.0</RearDragDiffLimit>
            <FrontDragLimit Units="N" ConvertToEnglishUnits="False">50.0</FrontDragLimit>
            <RearDragLimit Units="N" ConvertToEnglishUnits="False">50.0</RearDragLimit>
            <LfDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">2.5</LfDragTestSpeed>
            <RfDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">2.5</RfDragTestSpeed>
            <LrDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">2.5</LrDragTestSpeed>
            <RrDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">2.5</RrDragTestSpeed>
            <NumberOfDragSamples>50</NumberOfDragSamples>

            <!-- Park Brake Test Parameters -->
            <ParkBrakeAxleBrakeForceSpeedLf Units="km/h" ConvertToEnglishUnits="True">0.0</ParkBrakeAxleBrakeForceSpeedLf>
            <ParkBrakeAxleBrakeForceSpeedRf Units="km/h" ConvertToEnglishUnits="True">0.0</ParkBrakeAxleBrakeForceSpeedRf>
            <ParkBrakeAxleBrakeForceSpeedLr Units="km/h" ConvertToEnglishUnits="True">2.5</ParkBrakeAxleBrakeForceSpeedLr>
            <ParkBrakeAxleBrakeForceSpeedRr Units="km/h" ConvertToEnglishUnits="True">2.5</ParkBrakeAxleBrakeForceSpeedRr>
            <ParkBrakeBrakeLimit Units="N" ConvertToEnglishUnits="False">150</ParkBrakeBrakeLimit>
            <ParkBrakeBrakeDiffLimit Units="N" ConvertToEnglishUnits="False">15</ParkBrakeBrakeDiffLimit>

            <!-- Wheel Speed Sensor Test Paramerters -->
            <LfSpeedSensorCheckSpeed Units ="km/h" ConvertToEnglishUnits="True">3.0</LfSpeedSensorCheckSpeed>
            <RfSpeedSensorCheckSpeed Units ="km/h" ConvertToEnglishUnits="True">4.0</RfSpeedSensorCheckSpeed>
            <LrSpeedSensorCheckSpeed Units ="km/h" ConvertToEnglishUnits="True">5.0</LrSpeedSensorCheckSpeed>
            <RrSpeedSensorCheckSpeed Units ="km/h" ConvertToEnglishUnits="True">6.0</RrSpeedSensorCheckSpeed>
            <SetWheelspeedTolerance Units="percent">5.0</SetWheelspeedTolerance>

            <!-- Mazda Test Head Test Steps -->
            <MazdaTestHeadTestSteps>
                <BrakeSwitchTest StartTag="RunBrakeSwitchTest" TestCompleteTag="BrakeSwitchTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <DiagClr StartTag="RunDiagclrTest" TestCompleteTag="DiagclrTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <FcChk StartTag="RunFcchkTest" TestCompleteTag="FcchkTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <LfAbsTest StartTag="RunLfAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <LrAbsTest StartTag="RunLrAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <RfAbsTest StartTag="RunRfAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <RrAbsTest StartTag="RunRrAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <WheelSpeedSensorTest StartTag="RunWheelSpeedSensorTest" TestCompleteTag="WheelSpeedSensorTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
            </MazdaTestHeadTestSteps>

        </Parameters>
        <Prompts>
            <ApplyBrake PromptBox="1" Priority="0" Duration="3000">ApplyBrake</ApplyBrake>
            <ApplyParkBrake PromptBox="2" Priority="0" Duration="3000">ApplyParkBrake</ApplyParkBrake>
            <NeutralPrompt PromptBox="1" Priority="0" Duration="3000">ShiftToNeutral</NeutralPrompt>
            <ReleaseParkBrake PromptBox="2" Priority="0" Duration="3000">ReleaseParkBrake</ReleaseParkBrake>
            <RemoveFootFromBrake PromptBox="2" Priority="0" Duration="3000">RemoveFootFromBrake</RemoveFootFromBrake>
        </Prompts>
        <!-- ============================================================================================== -->
        <SystemTagsToReset>
            <AxleRatio>0</AxleRatio>
            <AxleRatioBGColor>white</AxleRatioBGColor>
            <BrakeActive>0</BrakeActive>
            <FrontBalanceBGColor>white</FrontBalanceBGColor>
            <FrontBalanceValue>0</FrontBalanceValue>
            <FrontToRearBalanceBGColor>white</FrontToRearBalanceBGColor>
            <FrontToRearBalanceValue>0</FrontToRearBalanceValue>
            <LFBrakeDistance>0</LFBrakeDistance>
            <LFBrakeDistanceBGColor>white</LFBrakeDistanceBGColor>
            <LFDragBGColor>white</LFDragBGColor>
            <LFDragValue>0</LFDragValue>
            <LFForceBGColor>white</LFForceBGColor>
            <LFForceDomain>0 500</LFForceDomain>
            <LFForceTarget>200 400</LFForceTarget>
            <LFForceValue>0</LFForceValue>
            <LRBrakeDistance>0</LRBrakeDistance>
            <LRBrakeDistanceBGColor>white</LRBrakeDistanceBGColor>
            <LRDragBGColor>white</LRDragBGColor>
            <LRDragValue>0</LRDragValue>
            <LRForceBGColor>white</LRForceBGColor>
            <LRForceDomain>0 500</LRForceDomain>
            <LRForceTarget>200 400</LRForceTarget>
            <LRForceValue>0</LRForceValue>
            <LRParkBrakeBGColor>white</LRParkBrakeBGColor>
            <LRParkBrakeForce>0</LRParkBrakeForce>
            <ParkBrakeForce>0</ParkBrakeForce>
            <ParkBrakeForceBGColor>white</ParkBrakeForceBGColor>
            <RearBalanceBGColor>white</RearBalanceBGColor>
            <RearBalanceValue>0</RearBalanceValue>
            <RFBrakeDistance>0</RFBrakeDistance>
            <RFBrakeDistanceBGColor>white</RFBrakeDistanceBGColor>
            <RFDragBGColor>white</RFDragBGColor>
            <RFDragValue>0</RFDragValue>
            <RFForceBGColor>white</RFForceBGColor>
            <RFForceDomain>0 500</RFForceDomain>
            <RFForceTarget>200 400</RFForceTarget>
            <RFForceValue>0</RFForceValue>
            <RRBrakeDistance>0</RRBrakeDistance>
            <RRBrakeDistanceBGColor>white</RRBrakeDistanceBGColor>
            <RRDragBGColor>white</RRDragBGColor>
            <RRDragValue>0</RRDragValue>
            <RRForceBGColor>white</RRForceBGColor>
            <RRForceDomain>0 500</RRForceDomain>
            <RRForceTarget>200 400</RRForceTarget>
            <RRForceValue>0</RRForceValue>
            <RRParkBrakeBGColor>white</RRParkBrakeBGColor>
            <RRParkBrakeForce>0</RRParkBrakeForce>
            <TractionControlBgColor>white</TractionControlBgColor>
        </SystemTagsToReset>
    </Setup>
    <!-- ============================================================================================== -->
    <Objectives>

        <AbsTests>
            <TestStep00>SpeedSensorCheck</TestStep00>
            <TestStep05>StartBrakeSwitchTest</TestStep05>
            <TestStep10>StopBrakeSwitchTest</TestStep10>
        </AbsTests>

        <BrakeTesting>
            <TestStep00>MazdaDragTest</TestStep00>
            <TestStep05>MazdaFrontBrakeForce</TestStep05>
            <TestStep10>AbsLfTest</TestStep10>
            <TestStep15>AbsRfTest</TestStep15>
            <TestStep20>MazdaParkBrakeForce</TestStep20>
            <TestStep25>MazdaRearBrakeForce</TestStep25>
            <TestStep30>AbsLrTest</TestStep30>
            <TestStep35>AbsRrTest</TestStep35>
            <TestStep99>BrakeTestComplete</TestStep99>
        </BrakeTesting>

        <DiagnosticClearRoutine>
            <TestStep00>ClearDiagnosticRoutine</TestStep00>
        </DiagnosticClearRoutine>

        <FaultCheckRoutine>
            <TestStep00>FaultCheckRoutine</TestStep00>
        </FaultCheckRoutine>

        <Setup>
            <TestStep00>Initialize</TestStep00>
        </Setup>
    </Objectives>

    <!-- ============================================================================================== -->
    <TestSteps>
        <AbsLfTest Result="" Timeout="10000" SecondaryTimeout="2000" Description="LF ABS Valve Test"/>
        <AbsLrTest Result="" Timeout="10000" SecondaryTimeout="2000" Description="LR ABS Valve Test"/>
        <AbsRfTest Result="" Timeout="10000" SecondaryTimeout="2000" Description="RF ABS Valve Test"/>
        <AbsRrTest Result="" Timeout="10000" SecondaryTimeout="2000" Description="RR ABS Valve Test"/>
        <BrakeTestComplete Result="" Timeout="5000" Description="Run the process for completing the brake test"/>
        <ClearDiagnosticRoutine Result="" Timeout="10000" Description="Clear diagnostic routine"
            TestHeadTestName="DiagClr"/>
        <FaultCheckRoutine Result="" Timeout="10000" Description="Fault Check Routine"
            TestHeadTestName="FcChk"/>
        <Initialize Result="" Timeout="10000" Description="Initialize for the BaseBrake test."
            Prompt1="Initialize" ZerospeedPrompt="BrakeToStop" Prompt1Priority="0"/>
        <MazdaDragTest  Result="" Timeout="30000" Description="Check the drag on the rollers" ScanDelay="100"/>
        <MazdaFrontBrakeForce Result="" Timeout="10000" Description="Analyze the brake force for the front axle"/>
        <MazdaParkBrakeForce Result="" Timeout="10000" Description="Analyze the park brake force for the rear axle"/>
        <MazdaRearBrakeForce Result="" Timeout="10000" Description="Analyze the brake force for the rear axle"/>
        <SpeedSensorCheck Result="" Timeout="10000" Description="Wheel speed sensor test" ScanDelay="500"
            TestHeadTestName="WheelSpeedSensorTest"/> 
        <StartBrakeSwitchTest Result="" Timeout="20000" Description="Brake switch test" 
            TestHeadTestName="BrakeSwitchTest"/>
        <StopBrakeSwitchTest Result="" Timeout="20000" Description="Brake switch test" 
            TestHeadTestName="BrakeSwitchTest"/>
    </TestSteps>
</BrakeTC>
