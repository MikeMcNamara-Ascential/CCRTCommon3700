<ElectricMotorController>
   <Setup>
      <Debug>Off</Debug>
      <ProcessPriority>12</ProcessPriority>
      <ClutchOnZeroSpeed>No</ClutchOnZeroSpeed>
      <ThreadPool>
         <Debug>Off</Debug>
         <MinBlockedLimit>2</MinBlockedLimit>
         <MaxBlockedLimit>4</MaxBlockedLimit>
         <Increment>1</Increment>
         <Maximum>10</Maximum>
      </ThreadPool>
      <NotificationList>
         <Setup>
            <Debug>Off</Debug>
            <HighWater>3</HighWater>
            <Increment>1</Increment>
            <LowWater>1</LowWater>
            <Maximum>5</Maximum>
            <StartOnCreate>No</StartOnCreate>
         </Setup>
      </NotificationList>
      <Communication>
         <Comm>IPC</Comm>
         <Type>Server</Type>
         <Name>core/MotorController</Name>
         <Debug>Off</Debug>
         <Timeout>0</Timeout>
         <BufferSize>1024</BufferSize>
      </Communication>
      <TagList>
         <SubscribeTags>
            <SimulatorSwitchStatus/>
            <LossCompensationSwitchStatusToPLC/>
            <ZerospeedToPLC/>
            <Clutch/>
            <Declutch/>
            <Boost/>
            <RollsUpElevDown/>
            <RollsDownElevUp/>
            <DriveAxle/>
            <VehiclePresent/>
            <LFRollMotorDriveCommFault/>
            <RFRollMotorDriveCommFault/>
