#brakeforce.constants
#contains constants from brakeforce.properties

panel.brakeforce.background=white
panel.brakeforce.foreground=black
panel.brakeforce.chartarea.background=black
panel.brakeforce.chartarea.foreground=0 50 0
panel.brakeforce.labels.border.color=black
panel.brakeforce.labels.background=white
panel.brakeforce.labels.foreground=102 102 153
panel.brakeforce.xaxis.visible=true
panel.brakeforce.xaxis.color=0 50 0
panel.brakeforce.yaxis.visible=true
