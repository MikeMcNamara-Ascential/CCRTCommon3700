<DriveCurve Description="Drive Curve For The Roadster Test">
    <Components Debug="Off">
        <Machine>
            <ComponentName>MachineTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>MachineComponent.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
            <Debug>Off</Debug>
        </Machine>
        <SpeedControl>
            <ComponentName>GenericSpeedControl.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>SpeedControlConfig.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/SpeedControl/</ConfigPath>
            <Debug>Off</Debug>
        </SpeedControl>
    </Components>
    <Test Result="Overall Test result (Pass, Fail, Abort, ...)" Debug="Off">
        <TestPhase000 Description="Validate the driver numbrer" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Prompt the driver to input the driver number" Result="" Timeout="" Component="Machine">
                    <Initialize>DisableTractionControl</Initialize>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>
        <!-- Speed Control Test -->
      <TestPhase500 Description="Prompt speed control test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display speed control test phase" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>SpeedControlTestPhase</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase500>
      <TestPhase510 Description="Shift to Drive" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Shift to Drive to continue testing" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>ShiftToDrive</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase510>
      <TestPhase520 Description="Perform the speed control test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Perform speed control test" Result="" Timeout="" Component="SpeedControl">
                    <SpeedControlTest/>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase520>
      <TestPhase530 Description="Prompt speed control test complete" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Display speed control test phase complete" Result="" Timeout="" Component="Machine">
                    <PromptDriverAlways>SpeedControlTestPhaseComplete</PromptDriverAlways>
                </Objective0>
            </ForegroundObjectives>
      </TestPhase530>
      
      <!-- Finish up processing -->
      <TestPhase999 Description="Finishup" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective1 Result="" Description="Perform module finish-up" Timeout="" Component="Machine">
                    <FinishUp>PerformingFinishUp</FinishUp>
                </Objective1>
                <Objective2 Result="" Description="Perform SpeedControl finish-up" Timeout="" Component="SpeedControl">
                   <FinishUp/>
                </Objective2>
            </ForegroundObjectives>
      </TestPhase999>
    </Test>
</DriveCurve>
