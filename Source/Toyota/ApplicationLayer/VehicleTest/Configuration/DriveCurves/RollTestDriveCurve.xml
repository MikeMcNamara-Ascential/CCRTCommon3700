<DriveCurve Description="Toyota Roll Test drive curve">

    <Components Debug="Off">
        <Machine>
            <ComponentName>ToyotaMachineTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
            <ConfigFile>MachineTC.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine</ConfigPath>
        </Machine>
    </Components>

    <Test Result="Not Tested" Debug="Off">
        <TestPhase000 Description="Setup the system for testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Setup machine" Result="" Timeout="" Component="Machine">
                    <Initialize/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>

        <TestPhase010 Description="Prompt operator to accelerate to high speed" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Prompt operator to accelerate to speed" Result="" Timeout="" Component="Machine">
                    <AccelerateToSpeed>80</AccelerateToSpeed>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase010>

        <TestPhase020 Description="Speedometer Validation" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Validate the speedometer is adjusted correctly" Result="" Timeout="" Component="Machine">
                    <Speedometer/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase020>

        <TestPhase030 Description="Brake to stop at the end of the cycle" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
                    <ReverseTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase030>
        

        <TestPhase040 Description="Brake to stop at the end of the cycle" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Brake to stop" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase040>
    </Test>

</DriveCurve>
