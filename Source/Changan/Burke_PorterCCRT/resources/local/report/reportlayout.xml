<?xml version="1.0"?>
<!DOCTYPE RtReportConfig SYSTEM "resource:///com/bepco/rtc/report/rtreportconfig.dtd">

 <RtReportConfig>
	<ReportLayout>
	  <Title>CCRT Vehicle Test Result Report</Title>
	  <TestIdBlock>
		<Column>
		  <ServerTag tagname="VIN" label="VIN"/>
			<Timestamp/>
			<TestResultDetail tagname="MachineDriverNumber" childtagname="DriverNumber" label="Driver"/>
		</Column>
	  </TestIdBlock>	

	  <HorizontalBar/>

 	  <BuildDataBlock label="Build Data">
		<Column>
		</Column>
	  </BuildDataBlock>

	  <HorizontalBar/>

 	  <TestResultsBlock>
		<Column>
		  <TestProcess showfailures="true" tagname="BrakeOverallTest" label="Brake"/>
		</Column>
	  </TestResultsBlock>

	</ReportLayout>
  

 </RtReportConfig>



