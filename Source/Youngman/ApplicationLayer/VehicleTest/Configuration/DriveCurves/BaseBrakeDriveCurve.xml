<DriveCurve Description="Drive Curve For The Base Brake Test">
    <Components Debug="Off">
        <Brake>
            <ComponentName>GenericBaseBrakeTest.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>BaseBrakeTc.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
            <Debug>Off</Debug>
        </Brake>
        <Machine>
            <ComponentName>MachineTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>MachineTC.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
            <Debug>Off</Debug>
        </Machine>
        <SoundLevel>
            <ComponentName>SoundLevelTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
         <ConfigFile>SoundLevelComponentHY114.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/SoundLevel</ConfigPath>
            <Debug>Off</Debug>
        </SoundLevel>
    </Components>
    <Test Result="Overall Test result (Pass, Fail, Abort, ...)" Debug="Off">
        <TestPhase10 Description="Validate the driver numbrer" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Prompt the driver to input the driver number" Result="" Timeout="" Component="Machine">
                    <InitializeNoCableConnect/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase10>
        <TestPhase20 Description="Initialize the test components" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Init Base Brake Component" Result="" Timeout="" Component="Brake">
                    <Initialize/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase20>
        <TestPhase50 Description="40Kph Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="40KPH test" Result="" Timeout="" Component="Machine">
                    <Speedometer/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase50>
        <TestPhase55 Description="Run The Base Brake" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Brake">
                    <BrakeTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase55>
        <TestPhase60 Description="Brake to stop" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Machine">
                    <BrakeToStop/>
                </Objective0>
            </ForegroundObjectives>
            <BackgroundObjectives Result="" Timeout="">
                <Objective0 Description="Analyze the brake test results" Result="" Timeout="" Component="Brake">
                    <AnalyzeBrakeTest/>
                </Objective0>
            </BackgroundObjectives>
        </TestPhase60>
        <!--TestPhase80 Description="Perform Park Brake Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Perform park brake test" Result="" Timeout="" Component="Machine">
                    <ParkBrake/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase80-->
      <TestPhase70 Description="Reverse Test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Reverse test" Result="" Timeout="" Component="Machine">
               <Reverse/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase70>
      <TestPhase75 Description="Brake to stop" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Machine">
               <BrakeToStop/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase75>
        <TestPhase85 Description="Run the horn test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Run the horn test" Result="" Timeout="" Component="SoundLevel">
                    <SoundPressureLevelTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase85>
        <TestPhase90 Description="" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="" Result="" Timeout="" Component="Brake">
                    <FinishUp/>
                </Objective0>
                <Objective1 Result="" Description="Perform module finish-up" Timeout="" Component="Machine">
                    <FinishUp>PerformingFinishUp</FinishUp>
                </Objective1>
                <Objective2 Result="" Description="Sound level finishup" Timeout="" Component="SoundLevel">
                    <FinishUp/>
                </Objective2>
            </ForegroundObjectives>
        </TestPhase90>
    </Test>
</DriveCurve>
