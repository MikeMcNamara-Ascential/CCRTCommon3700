            <FrontToRearBalanceValue>FrontToRearBalanceValue</FrontToRearBalanceValue>
            <LeftFrontDragBGColor>LFDragBGColor</LeftFrontDragBGColor>
            <LeftFrontDragValue>LFDragValue</LeftFrontDragValue>
            <LeftFrontForce>LFForce</LeftFrontForce>
            <LeftFrontForceBGColor>LFForceBGColor</LeftFrontForceBGColor>
            <LeftFrontForceValue>LFForceValue</LeftFrontForceValue>
            <LeftFrontSpeed>LFSpeed</LeftFrontSpeed>
            <LeftRearDragBGColor>LRDragBGColor</LeftRearDragBGColor>
            <LeftRearDragValue>LRDragValue</LeftRearDragValue>
            <LeftRearForce>LRForce</LeftRearForce>
            <LeftRearForceBGColor>LRForceBGColor</LeftRearForceBGColor>
            <LeftRearForceValue>LRForceValue</LeftRearForceValue>
            <LeftRearSpeed>LRSpeed</LeftRearSpeed>
            <LFBrakeDistanceTag>LFBrakeDistance</LFBrakeDistanceTag>
            <LFBrakeDistanceColorTag>LFBrakeDistanceBGColor</LFBrakeDistanceColorTag>
            <LFCurrentForce>LFLoadCellValueRaw</LFCurrentForce>
            <LFMaxBrakeForceColorTag>LFForceBGColor</LFMaxBrakeForceColorTag>
            <LFMaxBrakeForceTag>LFForceValue</LFMaxBrakeForceTag>
            <LFSpeed>LFSpeed</LFSpeed>
            <LRBrakeDistanceTag>LRBrakeDistance</LRBrakeDistanceTag>
            <LRBrakeDistanceColorTag>LRBrakeDistanceBGColor</LRBrakeDistanceColorTag>
            <LRCurrentForce>LRLoadCellValueRaw</LRCurrentForce>
            <LRMaxBrakeForceColorTag>LRForceBGColor</LRMaxBrakeForceColorTag>
            <LRMaxBrakeForceTag>LRForceValue</LRMaxBrakeForceTag>
            <LRParkBrakeForceColorTag>LRParkBrakeBGColor</LRParkBrakeForceColorTag>
            <LRParkBrakeForceTag>LRParkBrakeForce</LRParkBrakeForceTag>
            <LRSpeed>LRSpeed</LRSpeed>
            <MachineType>MachineType</MachineType>
            <MachineType3600>3600</MachineType3600>
            <ParkBrakeForceTag>ParkBrakeForce</ParkBrakeForceTag>
            <ParkBrakeForceBgColorTag>ParkBrakeForceBGColor</ParkBrakeForceBgColorTag>
            <Rear>Rear</Rear>
            <RearBalanceBGColor>RearBalanceBGColor</RearBalanceBGColor>
            <RearBalanceTest>RearBalanceTest</RearBalanceTest>
            <RearBalanceValue>RearBalanceValue</RearBalanceValue>
            <RetainersUp>RollsUpElevDown</RetainersUp>
            <RFBrakeDistanceTag>RFBrakeDistance</RFBrakeDistanceTag>
            <RFBrakeDistanceColorTag>RFBrakeDistanceBGColor</RFBrakeDistanceColorTag>
            <RFCurrentForce>RFLoadCellValueRaw</RFCurrentForce>
            <RFMaxBrakeForceColorTag>RFForceBGColor</RFMaxBrakeForceColorTag>
            <RFMaxBrakeForceTag>RFForceValue</RFMaxBrakeForceTag>
            <RFSpeed>RFSpeed</RFSpeed>
            <RightFrontDragBGColor>RFDragBGColor</RightFrontDragBGColor>
            <RightFrontDragValue>RFDragValue</RightFrontDragValue>
            <RightFrontForce>RFForce</RightFrontForce>
            <RightFrontForceBGColor>RFForceBGColor</RightFrontForceBGColor>
            <RightFrontForceValue>RFForceValue</RightFrontForceValue>
            <RightFrontSpeed>RFSpeed</RightFrontSpeed>
            <RightRearDragBGColor>RRDragBGColor</RightRearDragBGColor>
            <RightRearDragValue>RRDragValue</RightRearDragValue>
            <RightRearForce>RRForce</RightRearForce>
            <RightRearForceBGColor>RRForceBGColor</RightRearForceBGColor>
            <RightRearForceValue>RRForceValue</RightRearForceValue>
            <RightRearSpeed>RRSpeed</RightRearSpeed>
            <RRBrakeDistanceTag>RRBrakeDistance</RRBrakeDistanceTag>
            <RRBrakeDistanceColorTag>RRBrakeDistanceBGColor</RRBrakeDistanceColorTag>
            <RRCurrentForce>RRLoadCellValueRaw</RRCurrentForce>
            <RRMaxBrakeForceColorTag>RRForceBGColor</RRMaxBrakeForceColorTag>
            <RRMaxBrakeForceTag>RRForceValue</RRMaxBrakeForceTag>
            <RRParkBrakeForceColorTag>RRParkBrakeBGColor</RRParkBrakeForceColorTag>
            <RRParkBrakeForceTag>RRParkBrakeForce</RRParkBrakeForceTag>
            <RRSpeed>RRSpeed</RRSpeed>
            <SpeedTarget>SpeedTarget</SpeedTarget>
            <TagIndex>TagIndex</TagIndex>
            <TractionControlFromPlc>TractionControlSelected</TractionControlFromPlc>
            <TractionControlBgColor>TractionControlBgColor</TractionControlBgColor>
            <VehiclePresent>VehiclePresent</VehiclePresent>
            <Zerospeed>ZerospeedToPLC</Zerospeed>
        </DataTags>
        <!-- ============================================================================================== -->
        <Parameters>
            <!-- ICM Data Parameters -->
            <CurrentDistances>/dev/Icm/Block/PulseCount</CurrentDistances>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <ICMName>mgr/ICM</ICMName>

            <!-- Brake Testing Parameters -->
            <BaseBrakeSampleCount>100</BaseBrakeSampleCount>
            <FrontToRearBalanceUseFront>1</FrontToRearBalanceUseFront>
            <IncludeDragInBrakeForce>1</IncludeDragInBrakeForce>
            <MinimumStartForce Units="lbf">50.0</MinimumStartForce>
            <StartSamplingAtMinimumForce>1</StartSamplingAtMinimumForce>

            <!-- Brake Stopping Distance Parameters -->
            <BrakeStopdistanceStartSpeed Units="mph">34.0</BrakeStopdistanceStartSpeed>
            <ConversionFactorFromMiles Description="Conversion factor to convert from miles to meters">1609.344</ConversionFactorFromMiles>

            <!-- Max Brake Force Parameters -->
            <ApplyBrakePedalWaitTime Units="ms">500</ApplyBrakePedalWaitTime>
            <BrakeForceConversionFactor Description="Conversion factor for converting lbf to kgf">0.4535924</BrakeForceConversionFactor>
            <FrontMaxBrakeStablizationTime Units="ms">1000</FrontMaxBrakeStablizationTime>
            <RearMaxBrakeStablizationTime Units="ms">2000</RearMaxBrakeStablizationTime>

            <!-- Park Brake Force Parameters -->
            <ApplyParkBrakeWaitTime Units="ms">2500</ApplyParkBrakeWaitTime>

            <!-- Testing Behavior Parameters -->
            <DisplayBrakeMeterUntilZeroSpeed>1</DisplayBrakeMeterUntilZeroSpeed>
            <IgnoreMachineConditions>1</IgnoreMachineConditions>
            <KeepTestStatusOnExit>1</KeepTestStatusOnExit>
            <TestInProgressColor>yellow</TestInProgressColor>

            <!-- SpeedSensorCheck Parameter -->
            <FLSpeedSensorCheck Units ="mph" Notes="Equals 3kph">1.86</FLSpeedSensorCheck>
            <FRSpeedSensorCheck Units ="mph" Notes="Equals 4kph">2.49</FRSpeedSensorCheck>
            <RLSpeedSensorCheck Units ="mph" Notes="Equals 5kph">3.11</RLSpeedSensorCheck>
            <RRSpeedSensorCheck Units ="mph" Notes="Equals 6kph">3.73</RRSpeedSensorCheck>
            <WheelspeedSensorCheckAccelTimeout Units="ms">5000</WheelspeedSensorCheckAccelTimeout>
             <WheelSpeedAccelerateRange Units="percent">5.0</WheelSpeedAccelerateRange>

             <!--MazdaDragTest Parameters -->
             <WheelspeedDragTestAccelTimeout Units="ms">15000</WheelspeedDragTestAccelTimeout>
            <FLSpeedBaseDrag Units ="mph" Notes="Equals 2.5kph">1.55</FLSpeedBaseDrag>
            <FRSpeedBaseDrag Units ="mph" Notes="Equals 2.5kph">1.55</FRSpeedBaseDrag>
            <RLSpeedBaseDrag Units ="mph" Notes="Equals 2.5kph">1.55</RLSpeedBaseDrag>
            <RRSpeedBaseDrag Units ="mph" Notes="Equals 2.5kph">1.55</RRSpeedBaseDrag>
            <NumberFrontSamples>10</NumberFrontSamples>
            <FrontSampleRate Units ="ms">350</FrontSampleRate>          
            <DisplayBrakeTargetSpeeds>0</DisplayBrakeTargetSpeeds>
            <FrontAxleMinDrag>0.0</FrontAxleMinDrag>
            <FrontAxleMaxDrag>50.0</FrontAxleMaxDrag>
            <FrontAxleMinDragDiff>0.0</FrontAxleMinDragDiff>
            <FrontAxleMaxDragDiff>10.0</FrontAxleMaxDragDiff>            
            <RearAxleMinDrag>0.0</RearAxleMinDrag>
            <RearAxleMaxDrag>50.0</RearAxleMaxDrag>
            <RearAxleMinDragDiff>0.0</RearAxleMinDragDiff>
            <RearAxleMaxDragDiff>10.0</RearAxleMaxDragDiff>

             <!--Mazda Front Force Parameters -->
            <WheelspeedFrontForceTestAccelTimeout Units="ms">15000</WheelspeedFrontForceTestAccelTimeout>
            <FLSpeedFrontForce Units ="mph" Notes="Equals 2.5kph">1.55</FLSpeedFrontForce>
            <FRSpeedFrontForce Units ="mph" Notes="Equals 2.5kph">1.55</FRSpeedFrontForce>
            <RLSpeedFrontForce Units ="mph" Notes="Equals 2.5kph">0.0</RLSpeedFrontForce>
            <RRSpeedFrontForce Units ="mph" Notes="Equals 2.5kph">0.0</RRSpeedFrontForce>
            <FrontAxleMinBrake Units="N">0.0</FrontAxleMinBrake>
            <FrontAxleMaxBrake Units="N">50.0</FrontAxleMaxBrake>          
            <FrontAxleMinBrakeDiff Units="N">0.0</FrontAxleMinBrakeDiff>
            <FrontAxleMaxBrakeDiff Units="N">10.0</FrontAxleMaxBrakeDiff>

            <!--Mazda Rear Force Parameters -->
            <WheelspeedRearForceTestAccelTimeout Units="ms">15000</WheelspeedRearForceTestAccelTimeout>
            <FLSpeedRearForce Units ="mph" Notes="Equals 2.5kph">0.0</FLSpeedRearForce>
            <FRSpeedRearForce Units ="mph" Notes="Equals 2.5kph">0.0</FRSpeedRearForce>
            <RLSpeedRearForce Units ="mph" Notes="Equals 2.5kph">1.55</RLSpeedRearForce>
            <RRSpeedRearForce Units ="mph" Notes="Equals 2.5kph">1.55</RRSpeedRearForce>
            <NumberRearSamples Units="N">10</NumberRearSamples>
            <RearSampleRate Units ="ms">350</RearSampleRate>
            
            <!--Mazda Park Brake Force Parameters -->
            <WheelspeedParkBrakeForceTestAccelTimeout Units="ms">15000</WheelspeedParkBrakeForceTestAccelTimeout>
            <FLSpeedParkBrakeForce Units ="mph" Notes="Equals 2.5kph">0.0</FLSpeedParkBrakeForce>
            <FRSpeedParkBrakeForce Units ="mph" Notes="Equals 2.5kph">0.0</FRSpeedParkBrakeForce>
            <RLSpeedParkBrakeForce Units ="mph" Notes="Equals 2.5kph">1.55</RLSpeedParkBrakeForce>
            <RRSpeedParkBrakeForce Units ="mph" Notes="Equals 2.5kph">1.55</RRSpeedParkBrakeForce>
            <NumberParkBrakeSamples Units="N">10</NumberParkBrakeSamples>
            <ParkBrakeSampleRate Units ="ms">350</ParkBrakeSampleRate>             
            
            <!-- Machine Parameters -->
            <RollerDiameter Units="inches">19.5275</RollerDiameter>
            <PulsesPerRevolution>1250</PulsesPerRevolution>
            <LoadCellReadingDelay Units="ms">100</LoadCellReadingDelay>
            <SetWheelspeedTolerance Units="percent">5.0</SetWheelspeedTolerance>

            <RearAxleMass Units="??">345.0</RearAxleMass>
            <FrontAxleMass Units="??">345.0</FrontAxleMass>
            
            <!-- Dev speed tests -->
            <BrakeDistanceTestStartMeasureSpeed>5.0</BrakeDistanceTestStartMeasureSpeed>
            <TravelDistance>0.1</TravelDistance>
            <TravelDistanceTimeout>60000</TravelDistanceTimeout>
            <TravelDistancePollRate>500</TravelDistancePollRate>
            <InchesPerMile>63360</InchesPerMile>
            
            
            
        </Parameters>
        <Prompts>
            <AccelerateToTargetSpeed PromptBox="2" Priority="0" Duration="5000">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <ApplyBrake PromptBox="1" Priority="0" Duration="3000">ApplyBrake</ApplyBrake>
            <ApplyParkBrake PromptBox="1" Priority="0" Duration="3000">ApplyParkBrake</ApplyParkBrake>
            <EnableTractionControl PromptBox="1" Priority="0" Duration="3000">EnableTractionControl</EnableTractionControl>
            <NeutralPrompt PromptBox="1" Priority="0" Duration="3000">ShiftToNeutral</NeutralPrompt>
            <RemoveFootFromBrake PromptBox="2" Priority="0" Duration="3000">RemoveFootFromBrake</RemoveFootFromBrake>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
            <ShiftToDrive PromptBox="1" Priority="0">ShiftToDrive</ShiftToDrive>
        </Prompts>
        <!-- ============================================================================================== -->
        <SystemTagsToReset>
            <AxleRatio>0</AxleRatio>
            <AxleRatioBGColor>white</AxleRatioBGColor>
            <BrakeActive>0</BrakeActive>
            <FrontBalanceBGColor>white</FrontBalanceBGColor>
            <FrontBalanceValue>0</FrontBalanceValue>
            <FrontToRearBalanceBGColor>white</FrontToRearBalanceBGColor>
            <FrontToRearBalanceValue>0</FrontToRearBalanceValue>
            <LFBrakeDistance>0</LFBrakeDistance>
            <LFBrakeDistanceBGColor>white</LFBrakeDistanceBGColor>
            <LFDragBGColor>white</LFDragBGColor>
            <LFDragValue>0</LFDragValue>
            <LFForceBGColor>white</LFForceBGColor>
            <LFForceDomain>0 500</LFForceDomain>
            <LFForceTarget>200 400</LFForceTarget>
            <LFForceValue>0</LFForceValue>
            <LRBrakeDistance>0</LRBrakeDistance>
            <LRBrakeDistanceBGColor>white</LRBrakeDistanceBGColor>
            <LRDragBGColor>white</LRDragBGColor>
            <LRDragValue>0</LRDragValue>
            <LRForceBGColor>white</LRForceBGColor>
            <LRForceDomain>0 500</LRForceDomain>
            <LRForceTarget>200 400</LRForceTarget>
            <LRForceValue>0</LRForceValue>
            <LRParkBrakeBGColor>white</LRParkBrakeBGColor>
            <LRParkBrakeForce>0</LRParkBrakeForce>
            <ParkBrakeForce>0</ParkBrakeForce>
            <ParkBrakeForceBGColor>white</ParkBrakeForceBGColor>
            <RearBalanceBGColor>white</RearBalanceBGColor>
            <RearBalanceValue>0</RearBalanceValue>
            <RFBrakeDistance>0</RFBrakeDistance>
            <RFBrakeDistanceBGColor>white</RFBrakeDistanceBGColor>
            <RFDragBGColor>white</RFDragBGColor>
            <RFDragValue>0</RFDragValue>
            <RFForceBGColor>white</RFForceBGColor>
            <RFForceDomain>0 500</RFForceDomain>
            <RFForceTarget>200 400</RFForceTarget>
            <RFForceValue>0</RFForceValue>
            <RRBrakeDistance>0</RRBrakeDistance>
            <RRBrakeDistanceBGColor>white</RRBrakeDistanceBGColor>
            <RRDragBGColor>white</RRDragBGColor>
            <RRDragValue>0</RRDragValue>
            <RRForceBGColor>white</RRForceBGColor>
            <RRForceDomain>0 500</RRForceDomain>
            <RRForceTarget>200 400</RRForceTarget>
            <RRForceValue>0</RRForceValue>
            <RRParkBrakeBGColor>white</RRParkBrakeBGColor>
            <RRParkBrakeForce>0</RRParkBrakeForce>
            <TractionControlBgColor>white</TractionControlBgColor>
        </SystemTagsToReset>
    </Setup>
    <!-- ============================================================================================== -->
    <Objectives>

        <Setup>
            <TestStep00>Initialize</TestStep00>
        </Setup>

        <SpeedCheck>
            <TestStep00>SpeedSensorCheck</TestStep00>
        </SpeedCheck>
    












        <DragTest>
            <TestStep00>MazdaDragTest</TestStep00>
            <TestStep05>AnalyzeMazdaDragTest</TestStep05>
        </DragTest>
        
        <MazdaFrontBrakeForce>
            <TestStep00 AltValue="Front">MazdaMaxBrakeForce</TestStep00>
            <TestStep05 AltValue="Front">AnalyzeMazdaBrakeForce</TestStep05>
        </MazdaFrontBrakeForce>
        
        <MazdaRearBrakeForce>
            <TestStep00 AltValue="Rear">MazdaMaxBrakeForce</TestStep00>
            <TestStep05 AltValue="Rear">AnalyzeMazdaBrakeForce</TestStep05>
        </MazdaRearBrakeForce>        
        
        <MazdaRearParkBrakeForce>
            <TestStep00>MazdaParkBrakeForce</TestStep00>
            <TestStep05>AnalyzeMazdaParkBrakeForce</TestStep05>
        </MazdaRearParkBrakeForce>        
        
        <BrakeToStop>
           <TestStep00>BrakeToStop</TestStep00>
        </BrakeToStop>
        <BrakeDistanceTest>
            <TestStep00>DistanceValidationTest</TestStep00>
        </BrakeDistanceTest>
        <FinishUp>
            <TestStep00>FinishUp</TestStep00>
        </FinishUp>
        
    </Objectives>

    <!-- ============================================================================================== -->
    <TestSteps>
        <Initialize Result="" Timeout="10000" Description="Initialize for the BaseBrake test."
            Prompt1="Initialize" ZerospeedPrompt="BrakeToStop" Prompt1Priority="0"/>










        <AccelerateRollers Result="" Timeout="60000" Description="Accelerate rollers to stopping distance speed"/>
        <AnalyzeDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis" FrontMaxDragForce="10.0" RearMaxDragForce="10.0" Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="">Perform Vehicle Drag Test Analysis</AnalyzeDragTest>
        <BrakeDistanceTest Result="" Timeout="65000" Description="Test the distance">Test the distance</BrakeDistanceTest>
        <DistanceValidationTest Result="" Timeout="65000" Description="Test the distance">Test the distance</DistanceValidationTest>
        <AnalyzeMazdaDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis" FrontMaxDragForce="10.0" RearMaxDragForce="10.0" Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="">Perform Vehicle Drag Test Analysis</AnalyzeMazdaDragTest>
        <AnalyzeMazdaFrontBrakeForce Result="" Timeout="1000" Description="Analyze the brake force for the front axle" Prompt1="ApplyBrake" Prompt2=""/>
        <AnalyzeMazdaRearBrakeForce Result="" Timeout="1000" Description="Analyze the brake force for the front axle" Prompt1="ApplyBrake" Prompt2=""/>
        <AnalyzeMazdaParkBrakeForce Result="" Timeout="1000" Description="Analyze the park brake force for the rear axle" Prompt1="ApplyParkBrake" Prompt2=""/>
        <MazdaFrontBrakeForce Result="" Timeout="1000" Description="Analyze the brake force for the front axle" Prompt1="ApplyBrake" Prompt2="" WeightBrakeForce="45.0" BrakeForceDiff="30.0"/>
        <MazdaRearBrakeForce Result="" Timeout="1000" Description="Analyze the brake force for the front axle" Prompt1="ApplyBrake" Prompt2="" WeightBrakeForce="8.0" BrakeForceDiff="30.0"/>
        <MazdaParkBrakeForce Result="" Timeout="1000" Description="Analyze the park brake force for the rear axle" Prompt1="ApplyParkBrake" Prompt2="" WeightBrakeForce="10.0" BrakeForceDiff="30.0"/>
        
        <AccelerateRollers Result="" Timeout="60000" Description="Accelerate rollers to stopping distance speed"/>
        <BrakeTest Result="" Timeout="40000" Description="Base Brake Component Brake Test"
            StartBrakeSampleSpeed="55" EndBrakeSampleSpeed="10"
            BrakeDomain="0 500" BrakeTarget="250 350"
            Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeToStop"/>

        <BrakeStoppingDistanceTest Result="" Timeout="30000" Description="Measure brake stopping distance" ScanDelay="250"/>

        <BrakeToStop Result="" Timeout="1200000" Description="Brake The Vehicle To A Stop"
            Prompt1="BrakeToStop"/>
        <FinishUp Result="" Timeout="35000" Description="Finish Up" Prompt1="" ScanDelay="250"/>

        <MazdaDragTest  Result="" Timeout="30000" Description="Check the drag on the rollers" ScanDelay="100" DragSpeed="6.0" DragDelay="1000" DragSamples="100" />


        <MaxBrakeForceMeasurement Result="" Timeout="30000" Description="Verify vehicle is producing required brake force" ScanDelay="100"/>

        <ParkBrakeForceMeasurement Result="" Timeout="15000" Description="Verify park brake is adjusted properly" ScanDelay="100"/>

        <PreShiftCheckout Result="" Timeout="10000" Description="Verify rollers spin"/>

        <TractionControlTest Result="" Timeout="10000" Description="Check Traction Control System" ScanDelay="500"/>
        <SpeedSensorCheck Result="" Timeout="10000" Description="Wheelspeed sensor test" ScanDelay="500"/> 
    </TestSteps>
</BrakeTC>
