<ManualTransmissionConfig>
    <Setup>
        <Debug>Off</Debug>
        <Name>Transmission</Name>
        <TestDomain>Foreground</TestDomain>
        <Parameters>
            <KeepTestStatusOnExit>False</KeepTestStatusOnExit>
            <ICMName>mgr/ICM</ICMName>
            <DeveloperTest>False</DeveloperTest>
            <UsePlcResultButtons>True</UsePlcResultButtons>

            <!-- Parameters for Checking Reverse Gear Operation -->
            <ReverseSpeedMinimum ConvertToEnglishUnits="True" Units="km/h">4.0</ReverseSpeedMinimum>
            <ReverseSpeedMaximum ConvertToEnglishUnits="True" Units="km/h">10.0</ReverseSpeedMaximum>

            <DriveCurveParameters>
                <Segment000>
                    <Prompt1 Value1="Drive" Value2=" ">ShiftToGearAndAccelerate</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">15</TargetSpeed>
                    <EndTime Units="Seconds">3.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment000>

                <Segment005>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">16</TargetSpeed>
                    <EndTime Units="Seconds">5.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment005>

                <Segment010>
                    <Prompt1 Value1="M2" Value2="">ShiftToGearAndAccelerate</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">17</TargetSpeed>
                    <EndTime Units="Seconds">6.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment010>

                <Segment015>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">20</TargetSpeed>
                    <EndTime Units="Seconds">8.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment015>

                <Segment020>
                    <Prompt1 Value1="M3" Value2="">ShiftToGearAndAccelerate</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">22</TargetSpeed>
                    <EndTime Units="Seconds">9.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment020>

                <Segment025>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">40</TargetSpeed>
                    <EndTime Units="Seconds">11</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment025>

                <Segment030>
                    <Prompt1 Value1="M4" Value2="">ShiftToGearAndAccelerate</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">41</TargetSpeed>
                    <EndTime Units="Seconds">13</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment030>

                <Segment035>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">50</TargetSpeed>
                    <EndTime Units="Seconds">15</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment035>

                <Segment040>
                    <Prompt1 Value1="M5" Value2="">ShiftToGearAndAccelerate</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">52</TargetSpeed>
                    <EndTime Units="Seconds">17.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment040>

                <Segment045>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">60</TargetSpeed>
                    <EndTime Units="Seconds">20.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment045>

                <Segment050>
                    <Prompt1 Value1="M4" Value2="Gear">ShiftToGearAndReleaseThrottle</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <PromptSpeedHigh Value1="" Value2="">SpeedHigh</PromptSpeedHigh>
                    <PromptSpeedLow Value1="" Value2="">SpeedLow</PromptSpeedLow>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">20</TargetSpeed>
                    <EndTime Units="Seconds">22.2</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment050>

                <Segment055>
                    <Prompt1 Value1="" Value2="">AccelerateAtWOT</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">80</TargetSpeed>
                    <EndTime Units="Seconds">31.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment055>

                <Segment060>
                    <Prompt1 Value1="Drive" Value2="">ShiftToGearAndAccelerate</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">82</TargetSpeed>
                    <EndTime Units="Seconds">35.2</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment060>

                <Segment065>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">120</TargetSpeed>
                    <EndTime Units="Seconds">40.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment065>

                <Segment070>
                    <Prompt1 Value1="" Value2="">MaintainSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">120</TargetSpeed>
                    <EndTime Units="Seconds">45.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment070>

                <Segment075>
                    <Prompt1 Value1="M5" Value2="Gear">ShiftToGearAndReleaseThrottle</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <PromptSpeedHigh Value1="" Value2="">SpeedHigh</PromptSpeedHigh>
                    <PromptSpeedLow Value1="" Value2="">SpeedLow</PromptSpeedLow>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">115</TargetSpeed>
                    <EndTime Units="Seconds">50.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment075>

                <Segment080>
                    <Prompt1 Value1="M4" Value2="Gear">ShiftToGearAndReleaseThrottle</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <PromptSpeedHigh Value1="" Value2="">SpeedHigh</PromptSpeedHigh>
                    <PromptSpeedLow Value1="" Value2="">SpeedLow</PromptSpeedLow>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">110</TargetSpeed>
                    <EndTime Units="Seconds">51.2</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment080>

                <Segment085>
                    <Prompt1 Value1="M3" Value2="Gear">ShiftToGearAndReleaseThrottle</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <PromptSpeedHigh Value1="" Value2="">SpeedHigh</PromptSpeedHigh>
                    <PromptSpeedLow Value1="" Value2="">SpeedLow</PromptSpeedLow>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">90</TargetSpeed>
                    <EndTime Units="Seconds">55.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment085>

                <Segment090>
                    <Prompt1 Value1="Drive" Value2="Gear">ShiftToGearAndReleaseThrottle</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <PromptSpeedHigh Value1="" Value2="">SpeedHigh</PromptSpeedHigh>
                    <PromptSpeedLow Value1="" Value2="">SpeedLow</PromptSpeedLow>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">80</TargetSpeed>
                    <EndTime Units="Seconds">60.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment090>

                <Segment100>
                    <Prompt1 Value1="" Value2="">MaintainSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">80</TargetSpeed>
                    <EndTime Units="Seconds">65.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment100>

                <Segment105>
                    <Prompt1 Value1="" Value2="">ApplyBrake</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed>40</TargetSpeed>
                    <EndTime Units="Seconds">72.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment105>

                <Segment110>
                    <Prompt1 Value1="M2" Value2="Gear">ShiftToGearAndReleaseThrottle</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <PromptSpeedHigh Value1="" Value2="">SpeedHigh</PromptSpeedHigh>
                    <PromptSpeedLow Value1="" Value2="">SpeedLow</PromptSpeedLow>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">20</TargetSpeed>
                    <EndTime Units="Seconds">75.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment037>

                <Segment111>
                    <Prompt1 Value1="" Value2="">ApplyBrake</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed>0</TargetSpeed>
                    <EndTime Units="Seconds">82.0</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment111>

            </DriveCurveParameters>
        </Parameters>
        <Prompts>

            <ShiftToGear PromptBox="1" Priority="0">ShiftToGear</ShiftToGear>
            <ShiftToDrive PromptBox="1" Priority="0">ShiftToDrive</ShiftToDrive>
            <ShiftToReverse PromptBox="1" Priority="0">ShiftToReverse</ShiftToReverse>
            <ShiftToGearAndAccelerate PromptBox="1" Priority="0">ShiftToGearAndAccelerate</ShiftToGearAndAccelerate>
            <ShiftToGearAndPressBrake PromptBox="1" Priority="0">ShiftToGearAndPressBrake</ShiftToGearAndPressBrake>
            <CoastDownToTargetSpeed PromptBox="1" Priority="0">CoastDownToTargetSpeed</CoastDownToTargetSpeed>
            <MaintainSpeed PromptBox="1" Priority="0">MaintainSpeed</MaintainSpeed>
            <ShiftToGearAndReleaseThrottle PromptBox="1" Priority="0">ShiftToGearAndReleaseThrottle</ShiftToGearAndReleaseThrottle>
            <AccelerateToTargetSpeed PromptBox="2" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <AccelerateAtWOT PromptBox="1" Priority="0">AccelerateAtWOT</AccelerateAtWOT>
            <DecreaseThrottle PromptBox="2" Priority="0">DecreaseThrottle</DecreaseThrottle>
            <IncreaseThrottle PromptBox="2" Priority="0">IncreaseThrottle</IncreaseThrottle>
            <ReleaseThrottle PromptBox="2" Priority="0">ReleaseThrottle</ReleaseThrottle>
            <ApplyBrake PromptBox="2" Priority="0">ApplyBrake</ApplyBrake>
            <FootOffBrake PromptBox="2" Priority="0">FootOffBrake</FootOffBrake>
            <TransmissionShiftPointX PromptBox="2" Priority="0">TransmissionShiftPointX</TransmissionShiftPointX>
            <SpeedHigh PromptBox="2" Priority="0">SpeedHigh</SpeedHigh>
            <SpeedLow PromptBox="2" Priority="0">SpeedLow</SpeedLow>
            <CableConnect PromptBox="1" Priority="0">ConnectCable</CableConnect>
            <PressPassWhenComplete PromptBox="2" Priority="0">PressPassWhenComplete</PressPassWhenComplete>
            <RemoveFootFromAccelerator PromptBox="1" Priority="0">RemoveFootFromAccelerator</RemoveFootFromAccelerator>
            <SlowDownToTargetSpeed PromptBox="1" Priority="0">SlowDownToTargetSpeed</SlowDownToTargetSpeed>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
        </Prompts>
        <SystemTagsToReset/>
        <FaultList>/Configuration/Components/Transmission/TransmissionFaultList.xml</FaultList>
        <IgnoreFaults/>
        <Communication>
            <Debug>Off</Debug>
            <Type>Server</Type>
            <Comm>IPC</Comm>
            <Name>component/Transmission</Name>
            <BufferSize>1024</BufferSize>
            <Timeout>2000</Timeout>
        </Communication>
        <TagList>
            <SubscribeTags>
                <Abort/>
                <CableConnect/>
                <DriveAxle/>
                <ForegroundTestInProgress/>
                <TCMPartNo/>
                <Transmission/>
                <VIN/>
                <Zerospeed/>
                <ZerospeedToPLC/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
            </Setup>
        </NotificationList>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>ManualTransmission</ProcessName>
            <AdditionalLogFile Types="/Components/ManualTransmission.log or Disabled">/Components/ManualTransmission.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
            <MessageTimeout>100</MessageTimeout>
            <AdditionalLogMaxSize>10</AdditionalLogMaxSize>
            <AdditionalLogMaxFiles>5</AdditionalLogMaxFiles>
        </Logging>
        <NamedDataBrokerComm>
            <Comm>IPC</Comm>
            <Type>Client</Type>
            <Name>core/NamedDataBroker</Name>
            <Debug>Off</Debug>
            <Timeout>0</Timeout>
            <BufferSize>1024</BufferSize>
        </NamedDataBrokerComm>
        <DataTags>
            <Abort>Abort</Abort>
            <BoostMode>Boost</BoostMode>
            <DriveAxle>DriveAxle</DriveAxle>
            <FailButton>NoPB</FailButton>
            <FourWheelDriveEquipped>FourWheelDrive</FourWheelDriveEquipped>
            <LFSpeed>LFSpeed</LFSpeed>
            <LRSpeed>LRSpeed</LRSpeed>
            <MotorMode>MotorMode</MotorMode>
            <OverallTest>TransmissionOverallTest</OverallTest>
            <PassButton>YesPB</PassButton>
            <Rear>Rear</Rear>
            <RFSpeed>RFSpeed</RFSpeed>
            <RRSpeed>RRSpeed</RRSpeed>
            <SpeedActive>SpeedActive</SpeedActive>
            <SpeedTarget>SpeedTarget</SpeedTarget>
            <SpeedValue>SpeedValue</SpeedValue>
            <Zerospeed>ZerospeedToPLC</Zerospeed>
        </DataTags>
    </Setup>
    <Objectives>
        <FollowDriveCurve>
            <TestStep00>FollowDriveCurve</TestStep00>
            <TestStep10>BrakeToStop</TestStep10>
        </FollowDriveCurve>
        <ReverseTesting>
            <TestStep00>AccelerateInReverse</TestStep00>
            <TestStep10>BrakeToStop</TestStep10>
        </ReverseTesting>
        <FinishUp>
            <TestStep00>FinishUp</TestStep00>
        </FinishUp>
    </Objectives>
    <TestSteps>
        <AccelerateInReverse Result="" Timeout="30000" Description="Validate Reverse gear functionality" ScanDelay="250"/>
        <FollowDriveCurve Result="" Timeout="90000" Description="Prompt and display target speeds for desired drive curve"
            Prompt1="ShiftToGearAndAccelerate" Prompt1Value1="Drive" Prompt1Value2=" "
            SpeedTarget="0 5" ScanDelay="90"/>
        <BrakeToStop Description="Prompt the driver to brake to stop" Result="" Timeout="120000" Prompt1="BrakeToStop" Prompt1Priority="0" SpeedTarget="0 0"/>
        <FinishUp Result="Not Tested" Timeout="500" Description="Finish testing sequence"/>
    </TestSteps>
</ManualTransmissionConfig>
