<MimamoriTc>

    <Setup>

        <Debug>Off</Debug>
        <Name>Mimamori</Name>
        <TestDomain>Foreground</TestDomain>

        <!-- ===== Test Component Data Tags ===== -->
        <DataTags>
            <!-- Message Tags -->
            <ReadModuleFaults>ReadFaults</ReadModuleFaults>
        </DataTags>


        <!-- ===== Test Parameters =====  -->
        <Parameters>
            <!-- Test component behavior parameters -->
            <AlwaysEnterDiagnosticMode>False</AlwaysEnterDiagnosticMode>
            <DelayModuleInitialization>False</DelayModuleInitialization>
            <ICMName>mgr/ICM</ICMName>
            <KeepTestStatusOnExit>True</KeepTestStatusOnExit>
            <LoadStaticTestResults>False</LoadStaticTestResults>
            <ConfigFile>/Configuration/Components/VehicleConfig/MimamoriModule.xml</ConfigFile>

			<ClearHistoryDelay>4000</ClearHistoryDelay>

            <!-- DTC Parameters -->
            <AbortIfDTCPresent>False</AbortIfDTCPresent>
            <AlwaysClearFaults>False</AlwaysClearFaults>
            <AlwaysReadFaults>False</AlwaysReadFaults>
            <ClearFaultsDelay>100</ClearFaultsDelay>

            <!-- Module Info Parameters -->
            <ModuleDataItems/>

            <!-- Part number parameters -->
            <PartNumberPositionComparison/>
            <PartNumbersToCheck/>
            <ValidPartNumbers/>
        </Parameters>


        <!-- ===== Test Component Logging ===== -->
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>component/Mimamori</ProcessName>
            <AdditionalLogFile Types="/Components/Mimamori or Disable">/Components/Mimamori.Log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>


        <!-- ===== Test Component Prompts ===== -->
        <Prompts>
            <CableConnect PromptBox="1" Priority="0">ConnectMimamoriCable</CableConnect>
        </Prompts>


        <Communication>
            <Debug>Off</Debug>
            <Type>Server</Type>
            <Comm>IPC</Comm>
            <Name>component/Mimamori</Name>
            <BufferSize>1024</BufferSize>
            <Timeout>2000</Timeout>
        </Communication>

        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>

        <StatusCheckItems>
            <!--
            <MimamoriCableConnect>1</MimamoriCableConnect>
            <RollsUpElevDown>1</RollsUpElevDown>
            -->
        </StatusCheckItems>

        <SystemTagsToReset/>

        <TagList>
            <SubscribeTags>
                <Abort/>
                <!--MimamoriCableConnect/-->
                <MimamoriCableConnect/>
            </SubscribeTags>
        </TagList>

        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>

        <FaultList>/Configuration/Components/VehicleConfig/MimamoriFaults.xml</FaultList>
        <IgnoreFaults/>
    </Setup>

    <Objectives>
        <MimamoriTest>
            <TestStep00>Setup</TestStep00>
            <TestStep05>EnterDiagnosticMode</TestStep05>
			<TestStep10>ReadFaults</TestStep10>
			<TestStep15>CheckTotalMileage</TestStep15>
            <TestStep20>CheckFuelEconomy</TestStep20>
            <TestStep25>CheckDataRecordMemory</TestStep25>
            <TestStep30>CheckEdrData</TestStep30>
            <TestStep35>ClearFaults</TestStep35>
            <TestStep40>ReadFaults</TestStep40>
        </MimamoriTest>
        <ReadMimamoriData>
            <TestStep00>ClearHistory</TestStep00>
            <TestStep03>EnterDiagnosticMode</TestStep03>
            <TestStep05>CheckTotalMileage</TestStep05>
            <TestStep10>CheckFuelEconomy</TestStep10>
            <TestStep15>CheckDataRecordMemory</TestStep15>
            <TestStep20>CheckEdrData</TestStep20>
        </ReadMimamoriData>
        <FinishUp>
            <!--TestStep05>LockModule</TestStep05-->
            <TestStep10>FinishUp</TestStep10>
        </FinishUp>
    </Objectives>



    <TestSteps>
        <CheckDataRecordMemory Result="" Timeout="2000" Description="Read module's data record and memory" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <CheckFuelEconomy Result="" Timeout="2000" Description="Read module's Fuel Economy" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <CheckEdrData Result="" Timeout="2000" Description="Read module's EDR data" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <CheckTotalMileage Result="" Timeout="2000" Description="Read module's total mileage" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <ClearFaults Result="" Timeout="100" Description="Clear faults from the module" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <ClearHistory Result="" Timeout="5000" Description="Clear module history" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <EnterDiagnosticMode Result="" Timeout="1000" Description="Establish comms with Mimamori Module" ScanDelay="500" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <FinishUp Result="" Timeout="100" Description="Finish up Mimamori Testing" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <LockModule Result="" Timeout="2000" Description="Lock the Module" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <ReadFaults Result="" Timeout="100" Description="Read faults from Mimamori Module" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
        <Setup Result="" Timeout="100" Description="Setup test component for testing" Prompt1="ReadMimamoriData" Prompt2="Blank"/>
    </TestSteps>

</MimamoriTc>
