            <AbsMonitorDelay Units="ms">100</AbsMonitorDelay>
            <MaxAbsDumpPercent Units="percent">2.5</MaxAbsDumpPercent>
            <MinAbsDumpPercent Units="percent">0.3</MinAbsDumpPercent>

            <!-- Brake Test Parameters -->
            <DefaultFrontAxleWeight Units="N" ConvertToEnglishUnits="False">8143</DefaultFrontAxleWeight>
            <DefaultRearAxleWeight Units="N" ConvertToEnglishUnits="False">5155</DefaultRearAxleWeight>
            <NumberOfBrakeSamples>10</NumberOfBrakeSamples>
            <FrontAxleBrakeForceSpeedLf Units="km/h" ConvertToEnglishUnits="True">2.5</FrontAxleBrakeForceSpeedLf>
            <FrontAxleBrakeForceSpeedRf Units="km/h" ConvertToEnglishUnits="True">2.5</FrontAxleBrakeForceSpeedRf>
            <FrontAxleBrakeForceSpeedLr Units="km/h" ConvertToEnglishUnits="True">2.5</FrontAxleBrakeForceSpeedLr>
            <FrontAxleBrakeForceSpeedRr Units="km/h" ConvertToEnglishUnits="True">2.5</FrontAxleBrakeForceSpeedRr>
            <RearAxleBrakeForceSpeedLf Units="km/h" ConvertToEnglishUnits="True">2.5</RearAxleBrakeForceSpeedLf>
            <RearAxleBrakeForceSpeedRf Units="km/h" ConvertToEnglishUnits="True">2.5</RearAxleBrakeForceSpeedRf>
            <RearAxleBrakeForceSpeedLr Units="km/h" ConvertToEnglishUnits="True">2.5</RearAxleBrakeForceSpeedLr>
            <RearAxleBrakeForceSpeedRr Units="km/h" ConvertToEnglishUnits="True">2.5</RearAxleBrakeForceSpeedRr>
            <FrontBrakeLimit Units="% of front axle weight" ConvertToEnglishUnits="False">0.30</FrontBrakeLimit>
            <FrontBrakeDiffLimit Units="% of front axle weight" ConvertToEnglishUnits="False">0.08</FrontBrakeDiffLimit>
            <RearBrakeLimit Units="% of rear axle weight" ConvertToEnglishUnits="False">0.10</RearBrakeLimit>
            <RearBrakeDiffLimit Units="% of rear axle weight" ConvertToEnglishUnits="False">0.08</RearBrakeDiffLimit>
            <TotalBrakeLimit Units="% of total axle weight" ConvertToEnglishUnits="False">0.25</TotalBrakeLimit>
            <UseAxleWeightsForTotalBrakeForceResult>True</UseAxleWeightsForTotalBrakeForceResult>
    
            <!-- Drag Test Parameters -->
            <DisableMotorsAfterDragTest>False</DisableMotorsAfterDragTest>
            <FrontDragDiffLimit Units="N" ConvertToEnglishUnits="False">500.0</FrontDragDiffLimit>
            <RearDragDiffLimit Units="N" ConvertToEnglishUnits="False">500.0</RearDragDiffLimit>
            <FrontDragLimit Units="N" ConvertToEnglishUnits="False">490.0</FrontDragLimit>
            <RearDragLimit Units="N" ConvertToEnglishUnits="False">490.0</RearDragLimit>
            <LfDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">4.5</LfDragTestSpeed>
            <RfDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">5.5</RfDragTestSpeed>
            <LrDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">2.5</LrDragTestSpeed>
            <RrDragTestSpeed Units="km/h" ConvertToEnglishUnits="True">3.5</RrDragTestSpeed>
            <NumberOfDragSamples>5</NumberOfDragSamples>

            <!-- Park Brake Test Parameters -->
            <ParkBrakeAxleBrakeForceSpeedLf Units="km/h" ConvertToEnglishUnits="True">2.5</ParkBrakeAxleBrakeForceSpeedLf>
            <ParkBrakeAxleBrakeForceSpeedRf Units="km/h" ConvertToEnglishUnits="True">2.5</ParkBrakeAxleBrakeForceSpeedRf>
            <ParkBrakeAxleBrakeForceSpeedLr Units="km/h" ConvertToEnglishUnits="True">2.5</ParkBrakeAxleBrakeForceSpeedLr>
            <ParkBrakeAxleBrakeForceSpeedRr Units="km/h" ConvertToEnglishUnits="True">2.5</ParkBrakeAxleBrakeForceSpeedRr>
            <ParkBrakeBrakeLimit Units="% of total axle weight" ConvertToEnglishUnits="False">0.08</ParkBrakeBrakeLimit>
            <ParkBrakeBrakeDiffLimit Units="% of total axle weight" ConvertToEnglishUnits="False">0.5</ParkBrakeBrakeDiffLimit>

            <!-- Wheel Speed Sensor Test Paramerters -->
            <LfSpeedSensorCheckSpeed Units="km/h" ConvertToEnglishUnits="True">4.5</LfSpeedSensorCheckSpeed>
            <RfSpeedSensorCheckSpeed Units="km/h" ConvertToEnglishUnits="True">5.5</RfSpeedSensorCheckSpeed>
            <LrSpeedSensorCheckSpeed Units="km/h" ConvertToEnglishUnits="True">2.5</LrSpeedSensorCheckSpeed>
            <RrSpeedSensorCheckSpeed Units="km/h" ConvertToEnglishUnits="True">3.5</RrSpeedSensorCheckSpeed>
            <SetWheelspeedTolerance Units="percent">5</SetWheelspeedTolerance>
            <SpeedSensorTestTime Units="ms">100</SpeedSensorTestTime>

            <!-- Mazda Test Head Test Steps -->
            <MazdaTestHeadTestSteps>
                <BrakeSwitchTest StartTag="RunBrakeSwitchTest" TestCompleteTag="BrakeSwitchTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <DiagClr StartTag="RunDiagclrTest" TestCompleteTag="DiagclrTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <FcChk StartTag="RunFcchkTest" TestCompleteTag="FcchkTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <LfAbsTest StartTag="RunLfAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <LrAbsTest StartTag="RunLrAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <RfAbsTest StartTag="RunRfAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <RrAbsTest StartTag="RunRrAbsTest" TestCompleteTag="CurrentWheelAbsTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
                <WheelSpeedSensorTest StartTag="RunWheelSpeedSensorTest" TestCompleteTag="WheelSpeedSensorTestComplete" TestResultTag="CurrentTestStepResultFromTestHead"/>
            </MazdaTestHeadTestSteps>

        </Parameters>
        <Prompts>
            <AbsValveFiring PromptBox="1" Priority="0">AbsValveFiring</AbsValveFiring>
            <ApplyBrake PromptBox="1" Priority="0" Duration="1800">ApplyBrake</ApplyBrake>
            <ApplyParkBrake PromptBox="1" Priority="0" Duration="1400">ApplyParkBrake</ApplyParkBrake>
            <BrakeForceTesting PromptBox="2" Priority="0">BrakeForceTesting</BrakeForceTesting>
            <ClearDiagnostics PromptBox="1" Priority="0">ClearDiagnostics</ClearDiagnostics>
            <DragForceTest PromptBox="1" Priority="0">DragForceTesting</DragForceTest>
            <NeutralPrompt PromptBox="1" Priority="0" Duration="50">ShiftToNeutral</NeutralPrompt>
            <ReleaseParkBrake PromptBox="2" Priority="0" Duration="900">ReleaseParkBrake</ReleaseParkBrake>
            <RemoveFootFromBrake PromptBox="2" Priority="0" Duration="700">RemoveFootFromBrake</RemoveFootFromBrake>
            <SpeedSensorCheck PromptBox="1" Priority="0">SpeedSensorCheck</SpeedSensorCheck>
            <VehicleFaultCheck PromptBox="1" Priority="0">CheckingVehicle</VehicleFaultCheck>
        </Prompts>
