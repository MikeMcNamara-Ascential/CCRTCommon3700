<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
First stab at writing a config file for the GUI panels.
Config for specific XMLWidgetPanels is under the
$Revision: 10718 $
-->

<RtGuiConfig> 
	<Metadata author="Burke Porter, Inc" version="1.0"
						description="Standard implementation of the Driver Monitor view."/>
	<XmlWidgetPanel id="DriverMonitor">
		<Layout bgcolor="white">
			<!-- Top Row -->
			<VBox posX="10" posY="0" width="1000" height="180">
				<!-- START OF Driver Prompt Boxes ================================= -->
				<Widget id="prompts1" class="com.bepco.gui.PromptBox" width="1005" height="90" border="true">
					<DataSource tagname="PromptBox1" messagetype="Subscribe" />
					<DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
					<TextBoxConfig>
						<Font size="48" name="sans-serif" style="plain"/>
					</TextBoxConfig>  
				</Widget>
				<Widget id="prompts2" class="com.bepco.gui.PromptBox" width="1005" height="90" border="true">
					<DataSource tagname="PromptBox2" messagetype="Subscribe" />
					<DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
					<TextBoxConfig>
						<Font size="48" name="sans-serif" style="plain"/>
					</TextBoxConfig>  
				</Widget>
				<!-- END OF Driver Prompt Boxes ================================= -->
			</VBox>
			<!-- END OF Three radial gauges =================================== -->

			<!-- Bottom Row -->
			<HBox border="true" posX="7" posY="190" width="1012" height="500">
				<!-- Speed graph -->
				<Widget id="speedgraph" height="510" width="800" posX="7" posY="210" class="com.bepco.gui.GraphWidget">
					<DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
					<DataSource tagname="StartTest" tagrole="starttest" messagetype="Subscribe"/>
                                        <DataSource tagname="GraphLowerSeries" tagrole="lowerSeries" messagetype="Subscribe"/>
                                        <DataSource tagname="GraphUpperSeries" tagrole="upperSeries" messagetype="Subscribe"/>
					<GraphWidgetConfig graphtitle="Time vs. Speed" 
														 domainlow="0.0" domainhigh="300.0" domainnumticks="5" domainlabel="Time (seconds)" 
														 rangelow="0.0" rangehigh="140.0" rangenumticks="14" rangelabel="Speed"
														 bgcolor="blue" plotcolor="white" linecolor="black" textcolor="orange">
						<Font size="35" name="sans-serif" style="plain"/>
						<TitleFont size="10" name="sans-serif" style="bold"/>
					</GraphWidgetConfig>  
				</Widget>
				<!-- Speedometer gauge -->
				<Widget id="speed" height="180" width="180" class="com.bepco.gui.RadialGauge">
					<DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
					<DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
					<RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
						<Font size="15" name="sans-serif" style="plain"/>
					</RadialGaugeConfig>
				</Widget>
			</HBox>
		</Layout>
	</XmlWidgetPanel>
</RtGuiConfig>

