<AllisonTransmission>
    <Setup>
        <!-- Module Communication Parameters -->
        <AutomaticallyEnterDiagnosticMode>Yes</AutomaticallyEnterDiagnosticMode>
        <CheckSumLength>1</CheckSumLength>
        <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
        <DataByteCountIndex>3</DataByteCountIndex>
        <DataHeaderLength>4</DataHeaderLength>
        <DataStartIndex>8</DataStartIndex>
        <EnterDiagnosticModeMessageTag>EnterDiagnosticMode</EnterDiagnosticModeMessageTag>
      <AutomaticallyEnterDiagnosticMode>No</AutomaticallyEnterDiagnosticMode>
        <ModuleRequestID>0x18DA03F1</ModuleRequestID>
        <ModuleResponseDelay>500</ModuleResponseDelay>
        <ModuleResponseEndDelay>0</ModuleResponseEndDelay>
        <NegativeResponseCodeIndex>2</NegativeResponseCodeIndex>
        <NegativeResponseValue>0x7F</NegativeResponseValue>
        <NumberOfRetries>3</NumberOfRetries>
        <ResponsePendingReads>10</ResponsePendingReads>
        <SentMessageIdentifierIndex>0</SentMessageIdentifierIndex>
        <ValidResponseOffset>0x40</ValidResponseOffset>

        <!-- Keep Alive Parameters -->
        <KeepAlivePriority>10</KeepAlivePriority>
        <ModuleKeepAliveTime Units="ms">1000</ModuleKeepAliveTime>
        <KeepAliveResponseRequired>Yes</KeepAliveResponseRequired>

        <!-- DTC Data -->
        <DtcData>
            <DtcCountIndex>1</DtcCountIndex>
            <BytesPerDtc>4</BytesPerDtc>
            <DtcStartByte>1</DtcStartByte>
        </DtcData>
        <LimpInMonitorDelay Units="ms">500</LimpInMonitorDelay>
        <ModuleFaultsDetectedPrompt>TcmFaultsDetected</ModuleFaultsDetectedPrompt>

        <!-- Gear Monitor Parameters -->
        <GearMonitorDelay Units="ms">500</GearMonitorDelay>
        <GearStringRepresentation>
            <First>1</First>
            <Second>2</Second>
            <Third>3</Third>
            <Fourth>4</Fourth>
            <Fifth>5</Fifth>
            <Sixth>6</Sixth>
            <Reverse>R</Reverse>
        <Neutral>N</Neutral>
            <Park>P</Park>
        </GearStringRepresentation>
        

        <NegativeResponseCodes>
            <Code_0x10>General Reject</Code_0x10>
            <Code_0x11>Service Not Supported</Code_0x11>
            <Code_0x12>SubFunction Not Supported / Invalid Format</Code_0x12>
            <Code_0x21>Busy / Repeat Request</Code_0x21>
            <Code_0x22>Conditions Not Correct or Request Sequence Error</Code_0x22>
            <Code_0x23>Routine Not Complete</Code_0x23>
            <Code_0x31>Request Out Of Range</Code_0x31>
            <Code_0x33>Security Access Denied / Security Access Requested</Code_0x33>
            <Code_0x35>Invalid Key</Code_0x35>
            <Code_0x36>Exceed Number Of Attempts</Code_0x36>
            <Code_0x37>Required Time Delay Not Expired</Code_0x37>
            <Code_0x40>Download Not Accepted</Code_0x40>
            <Code_0x50>Upload Not Accepted</Code_0x50>
            <Code_0x71>Transfer Suspended</Code_0x71>
            <Code_0x78>Request Correctly Received / Response Pending</Code_0x78>
            <Code_0x80>Service Not Supported In Active Diagnostic Session</Code_0x80>
            <Code_0x9A>Data Decompression Failed</Code_0x9A>
            <Code_0x9B>Dta Decryption Failed</Code_0x9B>
            <Code_0xA0>ECU Not Responding</Code_0xA0>
            <Code_0xA1>ECU Address Unknown</Code_0xA1>
            <EnterDiagnosticMode>0x80</EnterDiagnosticMode>
            <ResponsePending>0x78</ResponsePending>
            <ModuleBusy>0x21</ModuleBusy>
        </NegativeResponseCodes>
        <Communication>
            <Debug>Off</Debug>
            <Name>/home/CCRT/Rewrite/GryphonJ1939</Name>
            <BufferSize>4096</BufferSize>
            <CommSize>1</CommSize>
            <Timeout>10000000</Timeout>
            <Retries>3</Retries>
        </Communication>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>TransmissionModule</ProcessName>
            <AdditionalLogFile>/Communication/AllisonTransmissionModule.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
    </Setup>
    <SerialMessages>
        <VehicleMessages>
		
			<EnterDiagnosticMode>
				<TransmitMessage>EnterDiagnosticMode</TransmitMessage>
				<TransmitInterpretation/>
				<ReplyMessage>EnterDiagnosticMode</ReplyMessage>
				<ReplyInterpretation/>
			</EnterDiagnosticMode>
			
			<ExitDiagnosticMode>
				<TransmitMessage>ExitDiagnosticMode</TransmitMessage>
				<TransmitInterpretation/>
				<ReplyMessage>ExitDiagnosticMode</ReplyMessage>
				<ReplyInterpretation/>
			</ExitDiagnosticMode>
		
            <ModuleKeepAlive>
                <TransmitMessage>TesterPresent</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>TesterPresent</ReplyMessage>
                <ReplyInterpretation/>
            </ModuleKeepAlive>
		 
            <LockModule>
                <TransmitMessage>WriteDid</TransmitMessage>
                <TransmitInterpretation>MecClear</TransmitInterpretation>
                <ReplyMessage>WriteDid</ReplyMessage>
                <ReplyInterpretation/>
            </LockModule>

            <ReadCurrentGear>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>CommandedTransmissionGear</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>CommandedTransmissionGear</ReplyInterpretation>
            </ReadCurrentGear>

            <ReadFaultCount>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>DtcCount</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>DtcCount</ReplyInterpretation>
            </ReadFaultCount>

            <ReadPartNumber>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>PartNumber</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>EndModelPartNumber</ReplyInterpretation>
            </ReadPartNumber>

            <SoftwareModule02PartNo>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>SoftwareModule02PartNo</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>EndModelPartNumber</ReplyInterpretation>
            </SoftwareModule02PartNo>

            <SoftwareModule03PartNo>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>SoftwareModule03PartNo</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>EndModelPartNumber</ReplyInterpretation>
            </SoftwareModule03PartNo>

            <SoftwareModule04PartNo>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>SoftwareModule04PartNo</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>EndModelPartNumber</ReplyInterpretation>
            </SoftwareModule04PartNo>

            <SoftwareModule01PartNo>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>SoftwareModule01PartNo</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>EndModelPartNumber</ReplyInterpretation>
            </SoftwareModule01PartNo>

            <ReadTccSlipError>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>TccSlipError</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>TccSlipError</ReplyInterpretation>
            </ReadTccSlipError>

            <ReadVIN>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>Vin</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>Vin</ReplyInterpretation>
            </ReadVIN>

            <ClearFaults>
                <TransmitMessage>ClearFaults</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ClearFaults</ReplyMessage>
                <ReplyInterpretation>FaultsCleared</ReplyInterpretation>
            </ClearFaults>

            <IsModuleLocked>
                <TransmitMessage>ReadDid</TransmitMessage>
                <TransmitInterpretation>MecValue</TransmitInterpretation>
                <ReplyMessage>ReadDidResponse</ReplyMessage>
                <ReplyInterpretation>IsModuleLocked</ReplyInterpretation>
            </IsModuleLocked>

            <ReadFaults>
                <TransmitMessage>ReadFaults</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ReadFaults</ReplyMessage>
                <ReplyInterpretation/>
            </ReadFaults>

            <ReadShiftLeverPosition IsBusBroadcastMessage="True">
                <ResponseFailureRetryCount>7</ResponseFailureRetryCount>
                <ResponsePendingReads>3</ResponsePendingReads>
                <TransmitMessage/>
                <TransmitInterpretation/>
                <ReplyMessage>ReadShiftLeverPosition</ReplyMessage>
                <ReplyInterpretation>InterpShiftLeverPosition</ReplyInterpretation>
             </ReadShiftLeverPosition>

			<UnlockModuleSecurity>
				<TransmitMessage>UnlockModuleSecurity</TransmitMessage>
				<TransmitInterpretation></TransmitInterpretation>
				<ReplyMessage>UnlockModuleSecurity</ReplyMessage>
				<ReplyInterpretation></ReplyInterpretation>
			</UnlockModuleSecurity>
			
			<!--ReadSecuritySeed>
				<TransmitMessage>ReadSecuritySeed</TransmitMessage>
				<TransmitInterpretation/>
				<ReplyMessage>ReadSecuritySeed</ReplyMessage>
				<ReplyInterpretation>ReadSecuritySeed</ReplyInterpretation>
			</ReadSecuritySeed-->
			
		</VehicleMessages>

        <!-- Message Formats -->
        <TransmitMessages>
			<EnterDiagnosticMode>0x10,0x03</EnterDiagnosticMode>
			<ExitDiagnosticMode>0x10,0x01</ExitDiagnosticMode>
            <TesterPresent>0x3E,0x00</TesterPresent>
			<UnlockModuleSecurity>0x27,0x02,0xBB,0xBB</UnlockModuleSecurity>
			<ReadSecuritySeed>0x27,0x01</ReadSecuritySeed>
            <ReadDid>0x1A,0x??</ReadDid>
            <ReadPid>0x22,0x??,0x??</ReadPid>
            <WriteDid>0x2F,0x??,0x??,0x??,0x??,0x??,0x??</WriteDid>
            <WriteDid4>0x2F,0x??,0x??,0x??</WriteDid4>
            <ClearFaults>0x14,0xFF,0xFF,0xFF</ClearFaults>
            <ReadFaults>0x19,0x02,0x0D</ReadFaults>
        </TransmitMessages>

        <!-- PIDs / DIDs -->
        <TransmitInterpretations>
            <CommandedTransmissionGear>0x19,0x9A</CommandedTransmissionGear>
            <DtcCount>0x00,0x01</DtcCount>
            <MecClear>0xA0,0x00</MecClear>
            <MecValue>0xA0</MecValue>
            <PartNumber>0x00,0x11</PartNumber>
            <ShiftLeverPosition>0x19,0x4F</ShiftLeverPosition>
            <TccSlipError>0x1A,0x26</TccSlipError>
			<TECL>0x05,0x19,0x03,0x00,0x01,0xFF</TECL>
			<EndTECL>0x05,0x19,0x00</EndTECL>
			<TECLearned>0x12,0xF0</TECLearned>
            <Vin>0x90</Vin>
            <SoftwareModule02PartNo>0x00,0x12</SoftwareModule02PartNo>
            <SoftwareModule03PartNo>0x00,0x13</SoftwareModule03PartNo>
            <SoftwareModule04PartNo>0x00,0x14</SoftwareModule04PartNo>
            <SoftwareModule01PartNo>0x00,0x11</SoftwareModule01PartNo>
        </TransmitInterpretations>

        <!-- Response Filters -->
        <ReplyMessages>
			<EnterDiagnosticMode>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x50,0x03,0x??</Reply_00>
                <Reply_01>0x7F,0x10,0x??</Reply_01>
				<Reply_02 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x??,0x50,0x03,0x??</Reply_02>
				<Reply_03 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x??,0x7F,0x10,0x??</Reply_03>
            </EnterDiagnosticMode>
			
			<ExitDiagnosticMode>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x50,0x01,0x??</Reply_00>
                <Reply_01>0x7F,0x10,0x??</Reply_01>
				<Reply_02 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x??,0x50,0x01,0x??</Reply_02>
				<Reply_03 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x??,0x7F,0x10,0x??</Reply_03>
            </ExitDiagnosticMode>
			
			<UnlockModuleSecurity>
				<Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="50">0x67,0x02,0x??</Reply_00>
				<Reply_01 lengthType="Variable" ReplyTimeout="200" endGapTime="50">0x7F,0x27,0x??</Reply_01>
				<Reply_02>0x67,0x02,0x??,0x??</Reply_02>
			</UnlockModuleSecurity>
			
			<ReadSecuritySeed>
				<Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="50">0x67,0x01,0x??,0x??</Reply_00>
				<Reply_01 lengthType="Variable" ReplyTimeout="200" endGapTime="50">0x7F,0x27,0x??</Reply_01>
			</ReadSecuritySeed>
			
			<TesterPresent>
				<Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="50">0x6E,0x??</Reply_00>
				<Reply_01 lengthType="Variable" ReplyTimeout="200" endGapTime="50">0x7F,0x3E,0x??</Reply_01>
			</TesterPresent>
			
            <ReadDidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x5A,0x??</Reply_0>
                <Reply_1>0x7F,0x1A,0x??</Reply_1>
            </ReadDidResponse>

            <ReadFaultsResponse>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0xE9</Reply_00>
                <Reply_02>0x7F,0xA9,0x??</Reply_02>
            </ReadFaultsResponse>
			
			<ReadPidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x62,0x??</Reply_0>
                <Reply_1>0x7F,0x22,0x??</Reply_1>
            </ReadPidResponse>

            <ReadShiftLeverPosition>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x18,0xF0,0x05,0x03,0x??,0x??,0x??,0x??,0x??,0x??,0x??,0x??</Reply_00>
                <Reply_01>0x??,0x??,0x??,0x??,0x18,0xF0,0x05,0x03,0x??,0x??,0x??,0x??,0x??,0x??,0x??,0x??</Reply_01>
            </ReadShiftLeverPosition>

            <WriteDid>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x6F,0x??</Reply_0>
                <Reply_1>0x7F,0x2F,0x??</Reply_1>
            </WriteDid>

            <ReadFaults>
               <Reply_00>0x??,0x??,0x??,0x??,0x18,0xDA,0xF1,0x03,0x7F,0x??,0x??</Reply_00>
               <Reply_01 lengthType="Variable" ReplyTimeout="100" endGapTime="150">0x??,0x??,0x??,0x??,0x18,0xDA,0xF1,0x03,0x59,0x02,0x19,0x??,0x??,0x??</Reply_01>
               <Reply_02>0x??,0x??,0x??,0x??,0x18,0xDA,0xF1,0x03,0x59,0x02,0xFF</Reply_02>
            </ReadFaults>

            <ClearFaults>
               <Reply_00>0x54</Reply_00>
               <!--Added response to temporarily bypass the clear faults response due to module not responding to command-->
			   <Reply_01 lengthType="Variable" ReplyTimeout="100" endGapTime="150">0x??</Reply_01>
               <!--This is the negative response message-->
               <Reply_02>0x??,0x??,0x??,0x??,0x18,0xDA,0xF1,0x03,0x7F,0x??,0x??</Reply_02>
            </ClearFaults>

        </ReplyMessages>

        <!-- Data Conversions -->
        <ReplyInterpretations>
            <CommandedTransmissionGear>
                <String>
                    <Substring>
                        <Chars input_index="3" mask="0x0F" length="1">
                            <StringSubstitute04 condition="equals" compare="0x06" replace="6"/>
                            <StringSubstitute05 condition="equals" compare="0x05" replace="5"/>
                            <StringSubstitute06 condition="equals" compare="0x04" replace="4"/>
                            <StringSubstitute07 condition="equals" compare="0x03" replace="3"/>
                            <StringSubstitute08 condition="equals" compare="0x02" replace="2"/>
                            <StringSubstitute09 condition="equals" compare="0x01" replace="1"/>
                        </Chars>
                    </Substring>
                </String>
            </CommandedTransmissionGear>

            <DtcCount>
                <Integer type="unsigned" bits="8" scale="1" offset="0">
                    <Byte1 input_index="3" mask="0x7F" output_index="0"/>
                </Integer>
            </DtcCount>

            <EndModelPartNumber>
                <String>
                    <Substring format="%08d">
                        <Integer type="unsigned" scale="1" offset="0">
                            <Byte1 input_index="2" mask="0xFF" output_index="3"/>
                            <Byte2 input_index="3" mask="0xFF" output_index="2"/>
                            <Byte3 input_index="4" mask="0xFF" output_index="1"/>
                            <Byte4 input_index="5" mask="0xFF" output_index="0"/>
                        </Integer>
                    </Substring>
                </String>
            </EndModelPartNumber>

            <FaultsDetected>
                <Boolean>
                    <Byte0 input_index="1" mask="0xFF" compare="0x00"/>
                </Boolean>
            </FaultsDetected>
			
            <InterpShiftLeverPosition>
			    <Integer type="unsigned" bits="8" scale="1" offset="0">
                    <Byte0 input_index="8" mask="0xFF" output_index="0"/>
			    </Integer>
            </InterpShiftLeverPosition>

            <TccSlipError>
                <Float scale="0.125" offset="0">
                    <Integer type="unsigned" scale="1" offset="0">
                        <Byte1 input_index="3" mask="0xFF" output_index="1"/>
                        <Byte2 input_index="4" mask="0xFF" output_index="0"/>
                    </Integer>
                </Float>
            </TccSlipError>

            <Vin>
                <String>
                    <Substring format="%17s">
                        <chars input_index="2" mask="0xFF" length="17"/>
                    </Substring>
                </String>
            </Vin>

			<!--Boolean>
                   <Byte01 input_index="0" mask="0xFF" compare="0x54"/> 
                </Boolean-->
			
            <FaultsCleared>
                <Boolean>
                   <Byte01 input_index="0" mask="0x00" compare="0x00"/> 
                </Boolean>
            </FaultsCleared>

            <IsModuleLocked>
                <Boolean>
                    <Byte01 input_index="2" mask="0xFF" compare="0x00"/>
                </Boolean>
            </IsModuleLocked>
			
			<PreTECL>
                <Boolean>
                    <!--Byte0 input_index="3" mask="0x0D" compare="0x0C"/-->
					<Byte0 input_index="0" mask="0xFF" compare="0x00"/>
                </Boolean>
            </PreTECL>
			<TECLearned>
                <Boolean>
                    <!--Byte0 input_index="3" mask="0x0D" compare="0x0C"/-->
					<Byte0 input_index="3" mask="0x08" compare="0x08"/>
                </Boolean>
            </TECLearned>

        </ReplyInterpretations>
    </SerialMessages>
</AllisonTransmission>
