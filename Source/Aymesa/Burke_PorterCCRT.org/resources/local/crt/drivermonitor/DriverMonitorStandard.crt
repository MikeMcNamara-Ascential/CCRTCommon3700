<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
  First stab at writing a config file for the GUI panels.
  Config for specific XMLWidgetPanels is under the
  $Revision: 1.1 $
-->

<RtGuiConfig> 
  <Metadata author="Burke Porter, Inc" version="1.0"
	description="Standard implementation of the Driver Monitor view."/>
  <XmlWidgetPanel id="DriverMonitor">
  <Layout>
            <!-- test subsystems pass/fail widgets -->
            <HBox height="40" width='1000' posX="10" posY="442" border="false">
                <Widget width='80' height='40'  id="emiss" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="EmissionsOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="cruise" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="SpeedControlOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="xfer" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TransferCaseOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="axle" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="AxleOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="skim" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="SKIMOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="airbag" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="AirbagOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="radio" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="RadioOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="etc" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="ETCOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='80' height='40'  id="ocs" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="OcsOverallTest" messagetype="Subscribe"/>
                </Widget>
                <!--Widget width='80' height='40'  id="tpm" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TPMOverallTest" messagetype="Subscribe"/>
                </Widget-->
                <Widget width='120' height='40'  id="machine" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="OverallTest" messagetype="Subscribe"/>
                </Widget>
            </HBox>

<!-- row 1 of three -->
<!-- Trafficlight (test drive status) ================================================= -->
<!-- Traffic Light
	Traffic Light States:
		NoVIN = OFF
		TestReady = GREEN
		ProcessingVIN = YELLOW
		ReadVIN = RED
-->
	<HBox posX='7' posY='30' height='200' width='175'>	
		<VBox width='175'>  
		  <HBox>
			<Label name="vinread" border="false">
			  <Font size="30" name="serif" style="bold"/>
			</Label>
		  </HBox>
		  <HBox>
			<Widget id="trafficlight" class="com.bepco.gui.ImagePhaseBox" 
			  height="147">
			  <DataSource tagname="VINReadStatus" messagetype="Subscribe"/>
			</Widget> 
		  </HBox>
		</VBox>
	</HBox>
<!-- END OF Trafficlight ========================================== -->	
<!-- START OF Three radial gauges ================================= -->
	  <HBox posX="210" posY="0" width="800" height="270">
		<!-- space -->
		<VBox width="10"/>
<!-- TPS - Blade angle -->
		<VBox>
		  <Widget id="blade" height="200" width="200" class="com.bepco.gui.RadialGauge">
			<DataSource tagname="TPSValue" messagetype="Read" datarate="10"/>
			<DataSource tagname="TPSTarget" tagrole="targetrange" messagetype="Subscribe"/>
			<DataSource tagname="TPSActive" messagetype="Subscribe" tagrole="enabled"/>
			<RadialGaugeConfig placement="southwest" startangle="270" stopangle="360" domainlow="0" domainhigh="50" targetlow="10" targethigh="20" >
			  <Font size="30" name="sans-serif" style="plain"/>
			</RadialGaugeConfig>  
		  </Widget>
		</VBox>
<!-- Speedometer gauge -->
		<Widget id="speed" height="300" width="300" class="com.bepco.gui.RadialGauge">
		  <DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
		  <DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
		  <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
			<Font size="30" name="sans-serif" style="plain"/>
		  </RadialGaugeConfig>
		</Widget>
<!-- Brake force gauge -->
		<Widget id="brakeforce" height="300" width="300" class="com.bepco.gui.RadialGauge">
		  <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10"/>
		  <DataSource tagname="BrakeTarget" tagrole="targetrange" messagetype="Subscribe"/>
		  <DataSource tagname="BrakeActive" messagetype="Subscribe" tagrole="enabled"/>
		  <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="600" targetlow="0" targethigh="0" >  
			<Font size="30" name="sans-serif" style="plain"/>
		  </RadialGaugeConfig>  
		</Widget>
	  </HBox>
<!-- END OF Three radial gauges =================================== -->
<!-- START OF Driver Prompt Boxes ================================= -->
	  <Widget id="prompts1" class="com.bepco.gui.PromptBox" posX="7" posY="268" width="1005" height="90" border="true">
		<DataSource tagname="PromptBox1" messagetype="Subscribe" />
		<DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
		<TextBoxConfig>
		  <Font size="48" name="sans-serif" style="plain"/>
		</TextBoxConfig>  
	  </Widget>
	  <Widget id="prompts2" class="com.bepco.gui.PromptBox" posX="7" posY="350" width="1005" height="90" border="true">
		<DataSource tagname="PromptBox2" messagetype="Subscribe" />
	    <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
		<TextBoxConfig>
		  <Font size="48" name="sans-serif" style="plain"/>
		</TextBoxConfig>  
	  </Widget>
<!-- END OF Driver Prompt Boxes ================================= -->
<!-- Row 2 of 3 -->
	  <HBox border="false" posX="7" posY="445" width="1012" height="300">
<!-- END OF subsystem test pass/fail widgets ========================================== -->
<!-- START of Test Failures Box===================================================== -->
		<HBox border="true" height="195" width="660">
		  <VBox width="660">
			<HBox>
			  <Label name="testfailures">
				<Font size="24" name="sans-serif" style="bold"/>
			  </Label>
			</HBox>
			<Widget height="180" width="660" id="testfailures" class="com.bepco.gui.ListBox">
			  <DataSource tagname="AllFailures" messagetype="Subscribe"/>
			  <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings" scrollbar="false">
				<Font style="bold" name="serif" size="20"/>
			  </ScrollBoxConfig>
			</Widget>
		  </VBox>
		</HBox>		  
<!-- END of Test Failures Box ===================================================== -->
          <!-- Tire Pressure  -->
		<HBox width="120" height="212" border="true">            
		<VBox width="120" border="false">
		<!--HBox height="30">
                    <Label height="30" width="120" name="tirepressure">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </HBox-->
		<HBox height="20"/>
                <Widget width='80' height='40'  id="tpm" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TPMOverallTest" messagetype="Subscribe"/>
                </Widget>
			  <!--Widget id="_driverid" height='68' width="200" class="com.bepco.gui.TextBox">
				<DataSource tagname="DriverNumberDisplay" messagetype="Subscribe"/>
				<DataSource tagname="DriverNumberDisplayBGColor" messagetype="Subscribe"
				  tagrole="backgroundcolor" />
				<TextBoxConfig>
				  <Font size="45" name="sans-serif" style="plain"/>
				</TextBoxConfig> 
			  </Widget-->

		<HBox height="10"/>
                <HBox height="30">
                    <Label height="30" width="50" name="lf">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="LFTirePressure" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFTirePressureValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFTirePressureBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="50" name="rf">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="RFTirePressure" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFTirePressureValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFTirePressureBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="50" name="lr">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="LRTirePressure" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LRTirePressureValue" messagetype="Subscribe"/>
                        <DataSource tagname="LRTirePressureBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="50" name="rr">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="50" id="RRTirePressure" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RRTirePressureValue" messagetype="Subscribe"/>
                        <DataSource tagname="RRTirePressureBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
		<HBox height="20"/>
            </VBox>
	</HBox>		  
<!-- Wheel Speeds ======================================================================== -->
		<HBox width="290" border="false">
			<VBox width="10"/>		  
			<VBox width="55">
			<Widget id="_lf" class="com.bepco.gui.NumberBox" width="80">
			  <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
			  <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
			  <TextBoxConfig>
				<Font size="38" name="sans-serif" style="plain"/>
			  </TextBoxConfig>  
			</Widget>
			<HBox height="100"/>
			<Widget id="_lr" class="com.bepco.gui.NumberBox" width="80">
			  <DataSource tagname="LRSpeed" messagetype="Read" datarate="10" />
			  <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
			  <TextBoxConfig>
				<Font size="38" name="sans-serif" style="plain"/>
			  </TextBoxConfig>  
			</Widget>
		  </VBox>
		  
		<VBox width="20"/>
		  <!--Widget id="axleimage" class="com.bepco.gui.ImagePhaseBox" border="false" width='130'>
			<DataSource tagname="VehicleTypeImg" messagetype="Subscribe"/>
		  </Widget-->
		  
		  <VBox width="55">
			<Widget id="_rf" class="com.bepco.gui.NumberBox" width='80'>
			  <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
			  <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
			  <TextBoxConfig>
				<Font size="38" name="sans-serif" style="plain"/>
			  </TextBoxConfig>  
			</Widget>
			<HBox height="100"/>
			<Widget id="_rr" class="com.bepco.gui.NumberBox" width='80'>
			  <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
			  <DataSource tagname="RRSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
			  <TextBoxConfig>
				<Font size="38" name="sans-serif" style="plain"/>
			  </TextBoxConfig>  
			</Widget>
		  </VBox>
		</HBox>
	</HBox>
<!-- END of Wheel Speeds ================================================================ -->
<!-- START of VIN BOX ============================================================== -->
	  <HBox posX='7' posY='700' width='1012' height='68' border="false">
		<!-- VIN -->
		  <Label name="vin" border="false" height='68' width='100'>
			<Font size="45" name="sans-serif" style="plain"/>
		  </Label>
		  <Widget id="_vin" height='68' width="550" class="com.bepco.gui.TextBox">
			<DataSource tagname="VINDisplay" messagetype="Subscribe" />
			<DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
			  tagrole="backgroundcolor" />
			<TextBoxConfig>
			  <Font size="45" name="sans-serif" style="plain"/>
			</TextBoxConfig>  
		  </Widget>
<!-- START of Driver ID ============================================================ -->
			  <Label name="driverid" border="false" height='68' width='160'>
				<Font size="45" name="sans-serif" style="plain"/>
			  </Label>	
			  <Widget id="_driverid" height='68' width="200" class="com.bepco.gui.TextBox">
				<DataSource tagname="DriverNumberDisplay" messagetype="Subscribe"/>
				<DataSource tagname="DriverNumberDisplayBGColor" messagetype="Subscribe"
				  tagrole="backgroundcolor" />
				<TextBoxConfig>
				  <Font size="45" name="sans-serif" style="plain"/>
				</TextBoxConfig> 
			  </Widget>
	  </HBox>  
<!-- END of Driver ID ============================================================== -->
	</Layout>
  </XmlWidgetPanel>
</RtGuiConfig>