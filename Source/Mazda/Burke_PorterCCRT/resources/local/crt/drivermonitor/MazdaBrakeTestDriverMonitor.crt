<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
  First stab at writing a config file for the GUI panels.
  Config for specific XMLWidgetPanels is under the
  $Revision: 1.1 $
-->

<RtGuiConfig>
    <Metadata author="Burke Porter, Inc" version="1.0"
      description="Standard implementation of the Driver Monitor view."/>
    <XmlWidgetPanel id="DriverMonitor">
        <Layout>

            <!-- START OF Driver Prompt Boxes ================================= -->
            <Widget id="prompts" class="com.bepco.gui.PromptBox" posX="3" posY="270" width="1005" height="100" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts3" class="com.bepco.gui.PromptBox" posX="3" posY="370" width="1005" height="100" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <!-- END OF Driver Prompt Boxes ================================= -->

            <!-- Roller Data -->
            <HBox height="270" width="1005" posX="3" posY="0" border="false" borderstyle="title" bordertitle="speed">

                <!-- Wheel Speeds -->
                <VBox height="200" width="300" posX="0" posY="70" border="false">
                    <!-- Wheel Speeds -->
                    <HBox width="200" border="false">
                        <VBox width="60">
                            <HBox>
                                <Label name="lf">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="speed">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_lf" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                                <TextBoxConfig convertunits="false" format="{0,number,#.0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                        <VBox width="40"/>
                        <VBox width="60">
                            <HBox>
                                <Label name="rf">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="speed">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_rf" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                                <TextBoxConfig format="{0,number,#.0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>

                    </HBox>
                    <HBox width="200">
                        <VBox width="60">
                            <HBox>
                                <Label name="lr">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="speed">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_lr" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="LRSpeed" messagetype="Read" datarate="10" />
                                <TextBoxConfig format="{0,number,#.0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                        <VBox width="40"/>
                        <VBox width="60">
                            <HBox>
                                <Label name="rr">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="speed">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_rr" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                                <TextBoxConfig format="{0,number,#.0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox width="20"/>

                <!-- Brake Apply Transducers -->
                <VBox height="200" width="260" posX="310" posY="70">
                    <HBox>
                        <Label name="brakepedalforce">
                            <Font size="20" name="sans-serif" style="bold"/>
                        </Label>
                        <Widget id="_pedalforce" class="com.bepco.gui.NumberBox" width="80">
                            <DataSource tagname="BrakePedalForceTransducer" messagetype="Read" datarate="10" />
                            <TextBoxConfig convertunits="false" format="{0,number,#}">
                                <Font size="20" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                    </HBox>
                    <Widget id="brakePedal" class="com.bepco.gui.HorizontalBarGraph" height="30" width="250">
                        <DataSource tagname="BrakePedalForceTransducer" messagetype="Read" datarate="10" />
                        <BarGraphConfig domainhigh="1112" domainlow="0" targethigh="147" targetlow="177" />
                    </Widget>
                    <HBox height="40"/>
                    <HBox>
                        <Label name="pbHandleForce" width="145">
                            <Font size="20" name="sans-serif" style="bold"/>
                        </Label>
                        <Widget id="_handleforce" class="com.bepco.gui.NumberBox" width="80">
                            <DataSource tagname="PbHandleForceTransducer" messagetype="Read" datarate="10" />
                            <TextBoxConfig convertunits="false" format="{0,number,#}">
                                <Font size="20" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                    </HBox>
                    <Widget id="parkBrakeHandle" class="com.bepco.gui.HorizontalBarGraph" height="30" width="250">
                        <DataSource tagname="PbHandleForceTransducer" messagetype="Read" datarate="10" />
                        <BarGraphConfig domainhigh="667" domainlow="0" targethigh="147" targetlow="177" />
                    </Widget>
                </VBox>

                <VBox width="20"/>

                <!-- Load Cell Reading -->
                <VBox height="200" width="360" posX="455" posY="535" border="false" borderstyle="title" bordertitle="loadcellvalues">
                    <HBox width="200" border="false">
                        <VBox width="60">
                            <HBox>
                                <Label name="lf">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="force">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_lfforce" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="LFLoadCellValue" messagetype="Read" datarate="10" />
                                <TextBoxConfig convertunits="false" format="{0,number,#}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                        <VBox width="40"/>
                        <VBox width="60">
                            <HBox>
                                <Label name="rf">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="force">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_rfforce" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="RFLoadCellValue" messagetype="Read" datarate="10" />
                                <TextBoxConfig format="{0,number,0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                    </HBox>

                    <HBox width="200" border="false">
                        <VBox width="60">
                            <HBox>
                                <Label name="lr">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="force">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_lrforce" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="LRLoadCellValue" messagetype="Read" datarate="10" />
                                <TextBoxConfig convertunits="false" format="{0,number,0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                        <VBox width="40"/>
                        <VBox width="60">
                            <HBox>
                                <Label name="rr">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                                <VBox width="10"/>
                                <Label name="force">
                                    <Font size="28" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_rrforce" class="com.bepco.gui.NumberBox" width="140">
                                <DataSource tagname="RRLoadCellValue" messagetype="Read" datarate="10" />
                                <TextBoxConfig format="{0,number,0}">
                                    <Font size="52" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Test Failures -->
            <VBox height="280" width="607" posX="3" posY="470" border="true" borderstyle="title" bordertitle="testfailures">
                <Widget height="250" width="598" id="testfailures" class="com.bepco.gui.ListBox">
                    <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                    <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings">
                        <Font style="bold" name="sans-serif" size="32"/>
                    </ScrollBoxConfig>
                </Widget>
            </VBox>

            <!-- Vehicle Data -->
            <HBox posX="620" posY="470" height="130" width="390" border="false">
                <VBox>
                    <Label name="aon">
                        <Font size="28" name="sans-serif" style="bold"/>
                    </Label>
                    <Label name="frontaxleweight">
                        <Font size="28" name="sans-serif" style="bold"/>
                    </Label>
                    <Label name="rearaxleweight">
                        <Font size="28" name="sans-serif" style="bold"/>
                    </Label>
                </VBox>
                <VBox width="10"/>
                <VBox>
                    <Widget id="_aon" class="com.bepco.gui.TextBox" screensaver="true">
                        <DataSource tagname="Aon" messagetype="Subscribe" />
                        <TextBoxConfig>
                            <Font size="28" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget id="_frontweight" class="com.bepco.gui.NumberBox" width="140">
                        <DataSource tagname="VehicleFrontAxleWeight" messagetype="Subscribe"/>
                        <TextBoxConfig format="{0,number,0}">
                            <Font size="28" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget id="rearweight" class="com.bepco.gui.NumberBox" width="140">
                        <DataSource tagname="VehicleRearAxleWeight" messagetype="Subscribe"/>
                        <TextBoxConfig format="{0,number,0}">
                            <Font size="28" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                </VBox>
            </HBox>

        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>
