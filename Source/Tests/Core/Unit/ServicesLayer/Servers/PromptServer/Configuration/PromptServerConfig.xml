<BepXMLMssg>
   <Setup>
      <Debug>Off</Debug>
      <NumberOfPromptBoxes>2</NumberOfPromptBoxes>
      <MaximumPriority>2</MaximumPriority>
      <Communication>
         <Type>Server</Type>
         <Debug>Off</Debug>
         <Name>core/PromptServer</Name>
         <Comm>IPC</Comm>
         <Timeout>1000</Timeout>
         <BufferSize>2000</BufferSize>
      </Communication>
      <Logging>
         <Status>Disabled</Status>
         <ProcessName>PromptServer</ProcessName>
         <AdditionalLogFile Types="/Servers/PromptServer.log or Disabled">/Servers/PromptServer.log</AdditionalLogFile>
         <Debug>Off</Debug>
         <LocalEcho>Disabled</LocalEcho>
         <Verbose>0x01</Verbose>
      </Logging>
      <TagList>
         <PublishTags>
            <PromptBox1>Blank</PromptBox1>
            <PromptBox2>Blank</PromptBox2>
            <PromptBox1BGColor>White</PromptBox1BGColor>
            <PromptBox2BGColor>White</PromptBox2BGColor>
         </PublishTags>
      </TagList>
      <ThreadPool>
         <Debug>Off</Debug>
         <MinBlockedLimit>2</MinBlockedLimit>
         <MaxBlockedLimit>7</MaxBlockedLimit>
         <Increment>2</Increment>
         <Maximum>10</Maximum>
      </ThreadPool>
      <NotificationList>
         <Setup>
        	<Logging>
        		<Debug>Off</Debug>
        		<Status>Enabled</Status>
        		<ProcessName>PromptNotify</ProcessName>
        		<AdditionalLogFile>/Servers/PromptServer.log</AdditionalLogFile>
        		<LocalEcho>Enabled</LocalEcho>
        		<Verbose>0x1F</Verbose>
        	</Logging>
            <Debug>Off</Debug>
            <HighWater>3</HighWater>
            <Increment>1</Increment>
            <LowWater>1</LowWater>
            <Maximum>5</Maximum>
            <StartOnCreate>No</StartOnCreate>
            <ResponseTimeout>2000</ResponseTimeout>
         </Setup>
      </NotificationList>
   </Setup>
</BepXMLMssg>
