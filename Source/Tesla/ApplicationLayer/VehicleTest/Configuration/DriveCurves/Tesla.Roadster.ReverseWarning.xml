<DriveCurve Description="Drive Curve For The Roadster Test">
    <Components Debug="Off">
        <DriveTrain>
            <ComponentName>TeslaDrivetrainTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>DrivetrainTC.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Drivetrain/</ConfigPath>
            <Debug>Off</Debug>
        </DriveTrain>
        <Machine>
            <ComponentName>MachineTC.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
            <ConfigFile>MachineComponent.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
            <Debug>Off</Debug>
        </Machine>
    </Components>
    <Test Result="Overall Test result (Pass, Fail, Abort, ...)" Debug="Off">
        <TestPhase000 Description="Validate the driver numbrer" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Prompt the driver to input the driver number" Result="" Timeout="" Component="Machine">
                    <Initialize>DisableTractionControl</Initialize>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase000>
        
      <!-- Reverse Warning -->
      <TestPhase300 Description="Prompt reverse warning test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Display reverse warning test phase" Result="" Timeout="" Component="Machine">
               <PromptDriverAlways>ReverseWarningTestPhase</PromptDriverAlways>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase300>
      <TestPhase310 Description="Shift to Drive" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Shift to Drive to continue testing" Result="" Timeout="" Component="Machine">
               <PromptDriverAlways>ShiftToDrive</PromptDriverAlways>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase310>
      <TestPhase320 Description="Perofrm reverse warning" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Perform reverse warning test" Result="" Timeout="" Component="DriveTrain">
               <Reverse/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase320>
      <TestPhase330 Description="Brake to stop" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Machine">
               <BrakeToStop/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase330>
      <TestPhase340 Description="Prompt reverse warning test complete" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Display drive profile test phase complete" Result="" Timeout="" Component="Machine">
               <PromptDriverAlways>ReverseWarningTestPhaseComplete</PromptDriverAlways>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase340>
      <!-- Finish up processing -->
      <TestPhase999 Description="Finishup" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
             <Objective1 Result="" Description="Perform module finish-up" Timeout="" Component="Machine">
                 <FinishUp>PerformingFinishUp</FinishUp>
             </Objective1>
             <Objective2 Result="" Description="Perform DriveTrain finish-up" Timeout="" Component="DriveTrain">
                <FinishUp/>
             </Objective2>
         </ForegroundObjectives>
      </TestPhase999>
    </Test>
</DriveCurve>
