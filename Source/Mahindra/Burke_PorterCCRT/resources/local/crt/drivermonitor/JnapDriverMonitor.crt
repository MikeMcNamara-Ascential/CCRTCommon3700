<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">

<!-- 
  First stab at writing a config file for the GUI panels.
  Config for specific XMLWidgetPanels is under the
  $Revision: 1.1 $
-->

<RtGuiConfig>
    <Metadata author="Burke Porter, Inc" version="1.0"
              description="Standard implementation of the Driver Monitor view."/>
    <XmlWidgetPanel id="DriverMonitor">
        <Layout>
            <!-- row 1 of three -->
            <!-- Trafficlight (test drive status) ================================================= -->
            <!-- Traffic Light
                Traffic Light States:
                    NoVIN = OFF
                    TestReady = GREEN
                    ProcessingVIN = YELLOW
                    ReadVIN = RED
            -->
            <HBox posX='7' posY='1' height='300' width='175'>
                <VBox width='175'>
                    <HBox>
                        <Label name="vinread" border="false">
                            <Font size="30" name="serif" style="bold"/>
                        </Label>
                    </HBox>
                    <HBox>
                        <Widget id="trafficlight" class="com.bepco.gui.ImagePhaseBox"
                                  height="137" screensaver="true">
                            <DataSource tagname="VINReadStatus" messagetype="Subscribe"/>
                        </Widget>
                    </HBox>
                    <!-- Front and Rear Wheel Speeds -->
                    <HBox height='100'>
                        <!-- spacing -->
                        <VBox width='5'/>
                        <!-- Front Wheel speed and labels -->
                        <VBox>
                            <HBox>
                                <Label name="front">
                                    <Font size="18" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_lf" class="com.bepco.gui.NumberBox" width="80">
                                <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                                <DataSource tagname="LFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                <TextBoxConfig>
                                    <Font size="36" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                        <!-- spacing -->
                        <VBox width='5'/>
                        <!-- Rear Wheel speed and labels -->
                        <VBox width="55">
                            <HBox>
                                <Label name="rear">
                                    <Font size="18" name="sans-serif" style="bold"/>
                                </Label>
                            </HBox>
                            <Widget id="_rr" class="com.bepco.gui.NumberBox" width='80'>
                                <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                                <DataSource tagname="RRSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                                <TextBoxConfig>
                                    <Font size="36" name="sans-serif" style="plain"/>
                                </TextBoxConfig>
                            </Widget>
                        </VBox>
                        <!-- spacing -->
                        <VBox width='5'/>
                    </HBox>
                </VBox>
            </HBox>
            <!-- END OF Trafficlight ========================================== -->
            <!-- START OF Three radial gauges ================================= -->
            <HBox posX="160" posY="0" width="840" height="270">
                <!-- space -->
                <VBox width="0"/>
                <!-- Speedometer gauge -->
                <Widget id="speed" height="300" width="300" class="com.bepco.gui.RadialGauge">
                    <DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
                    <DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
                    <DataSource tagname="SpeedActive" tagrole="enabled" messagetype="Subscribe"/>
                    <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
                        <Font size="30" name="sans-serif" style="plain"/>
                    </RadialGaugeConfig>
                </Widget>
                <!-- Brake force gauge -->
                <Widget id="brakeforce" height="300" width="300" class="com.bepco.gui.RadialGauge">
                    <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10"/>
                    <DataSource tagname="BrakeTarget" tagrole="targetrange" messagetype="Subscribe"/>
                    <DataSource tagname="BrakeActive" messagetype="Subscribe" tagrole="enabled"/>
                    <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="450" targetlow="0" targethigh="0" >
                        <Font size="30" name="sans-serif" style="plain"/>
                    </RadialGaugeConfig>
                </Widget>
                <!-- TPS - Blade angle -->
                <VBox>
                    <Widget id="blade" height="220" width="240" class="com.bepco.gui.RadialGauge">
                        <DataSource tagname="TPSValue" messagetype="Read" datarate="20"/>
                        <DataSource tagname="TPSTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <DataSource tagname="TPSActive" messagetype="Subscribe" tagrole="enabled"/>
                        <RadialGaugeConfig placement="southwest" startangle="270" stopangle="360" domainlow="0" domainhigh="1" targetlow=".1" targethigh=".25" >
                            <Font size="30" name="sans-serif" style="plain"/>
                        </RadialGaugeConfig>
                    </Widget>
                </VBox>
            </HBox>
            <!-- END OF Three radial gauges =================================== -->
            <!-- START OF Driver Prompt Boxes ================================= -->
            <Widget id="prompts1" class="com.bepco.gui.PromptBox" posX="7" posY="275" width="1005" height="90" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe" />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts2" class="com.bepco.gui.PromptBox" posX="7" posY="370" width="1005" height="90" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe" />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="48" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <!-- END OF Driver Prompt Boxes ================================= -->
            <!-- Row 2 of 3 -->
            <HBox border="false" posX="7" posY="410" width="1012" height="300">
                <HBox height="170" width="200">
                    <!-- subsystem test pass/fail widgets 
                        TestStates:
                            TestInProgress 	- Blue
                            Timeout		- Orange
                            Pass		- Green
                            Fail		- Red
                            Abort		- Yellow
                    -->
                    <VBox width='125'>
                        <Widget width='115' height='25' id="emiss" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="EmissionsOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="transfercase" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TransferCaseOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="cruise" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SpeedControlOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="daytimerunninglamps" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="DaytimeRunningLampsOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="airbag" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="AirbagOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
                <HBox>
                    <VBox width='125'>
                        <Widget width='115' height='25'  id="tpm" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TPMOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="axle" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="AxleOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="steering" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SASOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="parkAssist" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="ParkAssistOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="throttlecontrol" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="ETCOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="smartbeam" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SmartbeamOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="radio" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="RadioOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                    <VBox width='125'>
                        <Widget width='115' height='25'  id="faultreader" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="ModuleFaultReaderOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="skim" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SKIMOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="gateway" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="TipmOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="camera" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="CameraOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="suspension" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="SuspensionOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="cluster" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="ClusterOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="18" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                        <Widget width='115' height='25'  id="adaptivecruise" class="com.bepco.gui.OverallTestPhaseBox" >
                            <DataSource tagname="AdaptiveCruiseControlOverallTest" messagetype="Subscribe"/>
                            <TextBoxConfig>
                                <Font size="14" name="serif" style="bold"></Font>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
                <!-- END OF subsystem test pass/fail widgets ========================================== -->
            </HBox>
            <HBox border="false" posX="380" posY="430" width="640" height="300">
                <!-- START of Test Failures Box===================================================== -->
                <HBox border="true" height="195" width="620">
                    <VBox width="620">
                        <HBox>
                            <Label name="testfailures">
                                <Font size="24" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget height="180" width="615" id="testfailures" class="com.bepco.gui.ListBox">
                            <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                            <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings" scrollbar="false">
                                <Font style="bold" name="serif" size="22"/>
                            </ScrollBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
            </HBox>
            <!-- END of Test Failures Box ===================================================== -->
		  
            <!-- START of VIN BOX ============================================================== -->
            <VBox posX='7' posY='650' width='650' height='118' border="false">
                <!-- DRIVER ID -->
                <HBox>
                    <Label name="driverid" border="false" height='68' width='140'>
                        <Font size="45" name="sans-serif" style="plain"/>
                    </Label>
                    <Widget id="_driverid" height='68' width="200" class="com.bepco.gui.TextBox" screensaver="true">
                        <DataSource tagname="DriverNumberDisplay" messagetype="Subscribe"/>
                        <DataSource tagname="DriverNumberDisplayBGColor" messagetype="Subscribe"
                                  tagrole="backgroundcolor" />
                        <TextBoxConfig>
                            <Font size="45" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                    <VBox width="330"/>
                </HBox>
                <!-- VIN -->
                <HBox>
                    <Label name="vin" border="false" height='68' width='100'>
                        <Font size="45" name="sans-serif" style="plain"/>
                    </Label>
                    <Widget id="_vin" height='68' width="550" class="com.bepco.gui.TextBox" screensaver="true">
                        <DataSource tagname="VINDisplay" messagetype="Subscribe" />
                        <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
                                  tagrole="backgroundcolor" />
                        <TextBoxConfig>
                            <Font size="45" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
            </VBox>

            <!-- Valid VIN and PFS Status ===================================================== -->
            <HBox posX="660" posY="700" width="355" height="68" border="false">
                <Label name="vin">
                    <Font size="32" name="sans-serif" style="plain"/>
                </Label>
                <VBox width="10"/>
                <Widget id="vinLed" class="com.bepco.gui.ImagePhaseBox" height="30" screensaver="true">
                    <DataSource tagname="VINReadStatus" messagetype="Subscribe"/>
                </Widget>
                <VBox width="30"/>
                <Label name="pfsstatus">
                    <Font size="32" name="sans-serif" style="plain"/>
                </Label>
                <VBox width="10"/>
                <Widget id="pfsBlock" class="com.bepco.gui.ImagePhaseBox" height="30" screensaver="true">
                    <DataSource tagname="PfsBlocked" messagetype="Subscribe"/>
                </Widget>
                <VBox width="30"/>
                <Label name="vp">
                    <Font size="32" name="sans-serif" style="plain"/>
                </Label>
                <VBox width="10"/>
                <Widget id="vehiclepresent" class="com.bepco.gui.ImagePhaseBox" height="30" screensaver="true">
                    <DataSource tagname="VehiclePresent" messagetype="Subscribe"/>
                </Widget>
            </HBox>
        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>

