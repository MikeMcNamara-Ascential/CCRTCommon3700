        <TaskMon>
            <Name>BaseBrakeTc</Name>
        </TaskMon>
    </Setup>
    <Objectives>
        <Initialize>
            <TestStep1>Initialize</TestStep1>
        </Initialize>
        <DragTest>
            <TestStep1>DragTest</TestStep1>
            <TestStep2>AnalyzeDragTest</TestStep2>
        </DragTest>
        <BeginBrakeTest>
            <TestStep1>StartBaseBrakeTest</TestStep1>
        </BeginBrakeTest>
        <EndBrakeTest>
            <TestStep1>StopBaseBrakeTest</TestStep1>
            <TestStep2>AnalyzeBrakeTest</TestStep2>
            <TestStep3>AnalyzeBalance</TestStep3>
        </EndBrakeTest>
        <BeginAbsValveFiring>
            <TestStep1>StartAbsValveFiring</TestStep1>
        </BeginAbsValveFiring>
        <EndAbsValveFiring>
            <TestStep1>StopAbsValveFiring</TestStep1>
            <TestStep2>EvaluateABS</TestStep2>
        </EndAbsValveFiring>
        <BeginParkBrakeTest>
            <TestStep1>StartParkBrakeTest</TestStep1>
        </BeginParkBrakeTest>
        <EndParkBrakeTest>
            <TestStep1>StopParkBrakeTest</TestStep1>
        </EndParkBrakeTest>
        <BeginTractionControlTest>
            <TestStep1>StartTractionControlTest</TestStep1>
        </BeginTractionControlTest>
        <EndTractionControlTest>
            <TestStep1>StopTractionControlTest</TestStep1>
        </EndTractionControlTest>
        <BeginMaxBrakeTest>
            <TestStep1>StartMaxBrakeForceTest</TestStep1>
        </BeginMaxBrakeTest>
        <EndMaxBrakeTest>
            <TestStep1>StopMaxBrakeForceTest</TestStep1>
        </EndMaxBrakeTest>


        <FinishUp>
            <TestStep1>FinishUp</TestStep1>
        </FinishUp>
    </Objectives>
    <TestSteps>
        <Initialize Result="" Timeout="10000" Description="Initialize for the BaseBrake test." Prompt1="Initialize" ZerospeedPrompt="BrakeToStop">Initialize the system for a new brake test</Initialize>
        <DragTest Result="" Timeout="40000" Description="Base Brake Component Brake Drag Test" Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="Blank" DragDelay="10" DragSpeed="70" DragSamples="50">Perform Vehicle Drag Test</DragTest>
        <AnalyzeDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis" Prompt1="" Prompt2="" FrontMaxDragForce="500" RearMaxDragForce="500">Perform Vehicle Drag Test Analysis</AnalyzeDragTest>
        <BrakeTest Result="" Timeout="40000" Description="Base Brake Component Brake Test" StartBrakeSampleSpeed="25" EndBrakeSampleSpeed="10" BrakeDomain="0 500" BrakeTarget="250 350" Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeModeratelyInGreenBand">Perform Vehicle BaseBrake Test</BrakeTest>
        <AnalyzeBrakeTest Result="" Timeout="20000" Description="Base Brake Component Brake Test Analysis" FrontMinBrakeForce="222" RearMinBrakeForce="99" FrontMaxBrakeForce="600" RearMaxBrakeForce="400" Prompt1="" Prompt2="">Perform Vehicle BaseBrake Test Analysis</AnalyzeBrakeTest>
        <AnalyzeBalance Result="" Timeout="5000" Description="Base Brake Component Brake Balance Test" FrontSideToSideBalance="50" RearSideToSideBalance="50" TandemSideToSideBalance="20" BalanceFrontToRearMin="0" BalanceFrontToRearMax="500" BalanceTandemToRearMin="40" BalanceTandemToRearMax="60" Prompt1="" Prompt2="">Perform Vehicle Brake Balance Test</AnalyzeBalance>
        <StartAbsValveFiring Result="" Timeout="1000"  Description="Start the valve firing sequence"/> 
        <StopAbsValveFiring Result="" Timeout="1000"  Description="Stop the valve firing sequence"/> 
        <EvaluateABS Result="" Timeout="10000" Description="Evaluate the ABS valve firing results"/>
        <StartBaseBrakeTest Result="" Timeout="500" Description="Start sampling the forces for the base brake test"/>
        <StopBaseBrakeTest Result="" Timeout="500" Description="Stop the base brake test"/>
        <StartParkBrakeTest Result="" Timeout="500" Description="Start sampling the forces for the park brake test"/>
        <StopParkBrakeTest Result="" Timeout="500" Description="Stop the park brake test and find the max force for each wheel"/>
        <StartTractionControlTest Result="" Timeout="500" Description="Start sampling the forces for the traction control test"/>
        <StopTractionControlTest Result="" Timeout="500" Description="Stop the traction controltest"/>
        <StartMaxBrakeForceTest Result="" Timeout="500" Description="Start sampling the forces for the max brake test"/>
        <StopMaxBrakeForceTest Result="" Timeout="500" Description="Stop the max brake force test"/>

        <AccelerateToBrakeSpeed Result="" Timeout="1200000" Description="Accelerate to Brake Test Arm Speed" SpeedTarget="40 50" ArmSpeed="40" Prompt1="AccelerateToTargetSpeed">Accelerate to brake test speed</AccelerateToBrakeSpeed>
        <Coast Result="" Timeout="70000" Description="Base Brake Component Coast" Prompt1="CoastDownToTargetSpeed" Prompt2="Blank" SpeedTarget="23 33" CoastEndSpeed="33">Perform Vehicle Coast</Coast>
        <CoastToStop Result="" Timeout="70000" Description="Base Brake Component Coast" Prompt1="CoastDownToTargetSpeed" Prompt2="Blank" SpeedTarget="23 33" CoastEndSpeed="33">Perform Vehicle Coast</CoastToStop>
        <BrakeToStop Result="" Timeout="1200000" Description="Brake The Vehicle To A Stop" Prompt1="BrakeToStop">Brake the vehicle to a stop</BrakeToStop>
        <FinishUp Result="" Timeout="30000" Description="Brake test finishup" Prompt1="" Prompt2="">Perform finishup to complete test</FinishUp>
        <DisableForceMeter Result="" Timeout="30000" Description="Disable The Brake Force Meter">Disable the brake force meter</DisableForceMeter>
        <TireChunkingTest Result="" Timeout="30000" Description="Check for excessive brake force">Check for excessive brake force</TireChunkingTest>
        <ExcessiveBrakeForceCheck Result="" Timeout="30000" Description="Check for excessive brake force">Check for excessive brake force</ExcessiveBrakeForceCheck>
        <AccelerateToTestSpeed Result="" Timeout="10000" Description="Accelerate to test speed" TargetSpeedParameter="TargetSpeedParameter" SpeedRangeParameter="SpeedRangeParameter" ScanDelayParameter="ScanDelayParameter" Prompt1Value1="32"/>
        <EnableMotorLoading Description="Apply a load to the drive axle of the vehicle" Result="" Timeout="2000"/>
        <DisableMotorLoading Description="Disable the loading of the drive axle of the vehicle" Result="" Timeout="2000"/>
        <MaintainSpeedForTime Result = "" Description="Prompt the operator to accelerate to and maintain speed" Timeout="30000"/>
        <ReadMemoryStatistics Result = "" Description="Read the current memory statistics" Timeout="10000"/>
    </TestSteps>
</GMBrake>
