      <TestStep90>StopShiftLeverMonitor</TestStep90>

    </StopShiftLeverMonitorMonitor>

    <FinishUp>

      <TestStep00>EnterDiagnosticMode</TestStep00>

      <TestStep95>StopFaultLimpInMonitor</TestStep95>

      <TestStep96>ClearDiagnosticTellTale</TestStep96>

      <!-- <TestStep97>ClearOverallStatus</TestStep97> -->

      <TestStep98>FinishUp</TestStep98>

    </FinishUp>

    <ReadFaults>

      <TestStep40>EnterDiagnosticMode</TestStep40>

      <TestStep50>ReadFaults</TestStep50>

    </ReadFaults>

    <ClearFaults>

      <TestStep40>EnterDiagnosticMode</TestStep40>

      <TestStep50>ClearFaults</TestStep50>

    </ClearFaults>

    <Testing>

      <TestStep00>EnterDiagnosticMode</TestStep00>

      <!-- <TestStep05>ResetTestStatus</TestStep05> -->

      <TestStep10>ClearFaults</TestStep10>

      <TestStep15>CheckLimpInStatus</TestStep15>

      <TestStep20>StartModuleKeepAlive</TestStep20>

      <!-- <TestStep00>CheckPartNumber</TestStep00> -->

      <TestStep22>ControllerLearningCheck</TestStep22>

      <TestStep23>CollectTraceData</TestStep23>

      <!-- <TestStep20>CheckVIN</TestStep20> -->

      <TestStep25>ReadFaults</TestStep25>

      <TestStep30>CheckAutostickEquipped</TestStep30>

      <TestStep35>StopModuleKeepAlive</TestStep35>

      <TestStep40>StartShiftLeverMonitor</TestStep40>

      <TestStep45>StartFaultLimpInMonitor</TestStep45>

      <TestStep50>NeutralGateTest</TestStep50>

      <TestStep60>AccelerateInReverse</TestStep60>

      <TestStep65>StartRatioMonitor</TestStep65>

      <TestStep70>StartLockUpMonitor</TestStep70>

      <TestStep75>StopRatioMonitor</TestStep75>

      <TestStep80>StopLockUpMonitor</TestStep80>

      <TestStep90>StopShiftLeverMonitor</TestStep90>

      <TestStep95>StopFaultLimpInMonitor</TestStep95>

      <!-- <TestStep96>ClearDiagnosticTellTale</TestStep96> -->

      <!-- <TestStep97>ClearOverallStatus</TestStep97> -->

      <TestStep98>FinishUp</TestStep98>

    </Testing>

  </Objectives>

  <TestSteps>

    <EnterDiagnosticMode Result="Not Tested" Timeout="10000" Description="Establish communication with the transmission module" ScanDelay="250"/>

    <ResetTestStatus Result="Not Tested" Timeout="1000" Description="Reset the EOL status bytes in the module" ScanDelay="250"/>

    <CheckLimpInStatus Result="Not Tested" Timeout="1000" Description="Verify Transmission is not in Limp-In" ScanDelay="250"/>

    <ClearFaults Result="" Timeout="10000" Description="Clear the current faults in the module" ScanDelay="250"/>

    <CheckPartNumber Result="Not Tested" Timeout="500" Description="Verify TCM part number" ScanDelay="250"/>

    <ControllerLearningCheck Result="Not Tested" Timeout="500" Description="Verify the Controller learning by ensuring valid PRNDL Display value" ScanDelay="250"/>

    <CollectTraceData Result="Not Tested" Timeout="500" Description="Collect Trace Information from TCM" ScanDelay="250"/>

    <CheckVIN Result="Not Tested" Timeout="1000" Description="Verify the module VIN matches broadcast" ScanDelay="250"/>

    <CheckAutostickEquipped Result="Not Tested" Timeout="1000" Description="Verify autostick configuration matches broadcast" ScanDelay="250"/>

    <ReadFaults Result="Not Tested" Timeout="500" Description="Read faults from the TCM" ScanDelay="250"/>

    <NeutralGateTest Result="Not Tested" Timeout="20000" Description="Test the shift lever neutral gate" ScanDelay="250"/>

    <AccelerateInReverse Result="Not Tested" Timeout="30000" Description="Accelerate In Reverse To Test Speed" ScanDelay="250"/>

    <ElectronicRangeSelect Result="Not Tested" Timeout="30000" Description="Verify Electronic Range Select operates properly" ScanDelay="250" SecondaryTimeoutTime="10000"/>

    <CheckAutostickOperationAtSpeed Result="Not Tested" Timeout="30000" Description="Verify proper operation of autostick at speed" ScanDelay="250" SecondaryTimeoutTime="10000"/>

    <ClearDiagnosticTellTale Result="Not Tested" Timeout="1000" Description="Clear diagnostic information" ScanDelay="250"/>

    <ClearOverallStatus Result="Not Tested" Timeout="1000" Description="Clear the EOL test status in the module" ScanDelay="250"/>

    <FinishUp Result="Not Tested" Timeout="60000" Description="Finish Test" ScanDelay="250"/>

    <!-- Monitors -->

    <StartShiftLeverMonitor Result="Not Tested" Timeout="1000" Description="Start the shift lever monitor" ScanDelay="250"/>

    <StopShiftLeverMonitor Result="Not Tested" Timeout="20000" Description="Stop the shift lever monitor" ScanDelay="200"/>

    <StartFaultLimpInMonitor Result="Not Tested" Timeout="1000" Description="Start the Fault monitor and Limp-In monitor" ScanDelay="250"/>

    <StopFaultLimpInMonitor Result="Not Tested" Timeout="1000" Description="Stop the fault and limp-in monitor" ScanDelay="250"/>

    <StartLockUpMonitor Result="Not Tested" Timeout="1000" Description="Start the Torque Converter Lockup monitor" ScanDelay="250"/>

    <StopLockUpMonitor Result="Not Tested" Timeout="15000" Description="Stop the torque converter lockup monitor" SpeedRange="70 75" ScanDelay="250"/>

    <StartRatioMonitor Result="Not Tested" Timeout="1000" Description="Start the transmission ratio monitor" ScanDelay="250"/>

    <StopRatioMonitor Result="Not Tested" Timeout="15000" Description="Stop the transmission ratio monitor" ScanDelay="250"/>

    <!-- Utility Test Steps -->

    <StartModuleKeepAlive Result="Not Tested" Timeout="500" Description="Start sending tester present messages to the module" ScanDelay="250"/>

    <StopModuleKeepAlive Result="Not Tested" Timeout="500" Description="Stop sending tester present messages to the module" ScanDelay="250"/>

    <WaitForEngineOffIgnitionOff Result="Not Tested" Timeout="1000" ScanDelay="1"/>
  </TestSteps>

</CVTComponent>

