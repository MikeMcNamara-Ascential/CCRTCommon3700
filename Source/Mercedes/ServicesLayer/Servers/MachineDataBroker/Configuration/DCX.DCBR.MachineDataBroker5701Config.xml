    <Setup>
      <Debug>Off</Debug>
      <DataFile Description="This is the file where persistent data is stored">/TestResults/Machine/LossCompensationTimeDate.dat</DataFile>
      <CycleTimeUpdateRate Description="Delay in mS between updates, 0 disables the feature">500</CycleTimeUpdateRate>
      <EncoderDataUpdateRate Units="ms">100</EncoderDataUpdateRate>
      <CustId Description="This is the customer identifier Code">Mercedes</CustId>
      <CustBld Description="This is the build date code string yymmddrr">10111201</CustBld>
	  <UseConfigMachineNumber>No</UseConfigMachineNumber>
      <IcmDataFiles>
          <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
          <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
          <CurrentDistances>/dev/Icm/Block/PulseCount</CurrentDistances>
          <ForceArray>/dev/ArrayForce</ForceArray>
          <SpeedArray>/dev/ArraySpeed</SpeedArray>
          <DistanceArray>/dev/ArrayDistance</DistanceArray>
      </IcmDataFiles>
      <ThreadPool>
         <Debug>Off</Debug>
         <MinBlockedLimit>2</MinBlockedLimit>
         <MaxBlockedLimit>4</MaxBlockedLimit>
         <Increment>2</Increment>
         <Maximum>50</Maximum>
      </ThreadPool>
      <NotificationList>
         <Setup>
            <Debug>Off</Debug>
            <HighWater>3</HighWater>
            <Increment>1</Increment>
            <LowWater>1</LowWater>
            <Maximum>5</Maximum>
            <StartOnCreate>No</StartOnCreate>
            <ResponseTimeout>2000</ResponseTimeout>
         </Setup>
      </NotificationList>
