<DriveCurve Description="Drive Curve For The Base Brake Test">
   <Components Debug="Off">
      <Brake>
         <ComponentName>BaseBrake.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>BaseBrake.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Brake/</ConfigPath>
         <Debug>On</Debug>
      </Brake>
      <Machine>
         <ComponentName>MachineComponent.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>MachineComponent.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Machine/</ConfigPath>
         <Debug>Off</Debug>
      </Machine>
      <Transmission>
         <ComponentName>TransmissionComponent.qxe</ComponentName>
         <ComponentPath>/ApplicationLayer/Bin/</ComponentPath>
         <ConfigFile>TransmissionComponent.xml</ConfigFile>
         <ConfigPath>/Configuration/Components/Transmission/</ConfigPath>
         <Debug>Off</Debug>
      </Transmission>
   </Components>
   <Test Result="Overall Test result (Pass, Fail, Abort, ...)" Debug="Off">
      <TestPhase10 Description="Validate the driver numbrer" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Prompt the driver to input the driver number" Result="" Timeout="20000" Component="Machine">
               <Initialize/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase10>
      <TestPhase20 Description="Initialize the Base Brake Test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Init Base Brake Component" Result="" Timeout="" Component="Brake">
               <Initialize/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase20>
      <TestPhase30 Description="Perform a vehicle reverse test" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Perform a vehicle reverse test" Result="" Timeout="" Component="Transmission">
               <Reverse/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase30>
      <TestPhase40 Description="" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Prompt the driver to brake to stop" Result="" Timeout="" Component="Machine">
               <BrakeToStop/>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase40>
      <TestPhase50 Description="Run The Base Brake" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Brake">
               <BrakeTest/>
            </Objective0>
         </ForegroundObjectives>
         <BackgroundObjectives Result="" Timeout="">
            <Objective0 Description="Prompt to check the speedometer" Result="" Timeout="0" Component="Machine">
               <PromptDriver>SpeedometerWorks</PromptDriver>
            </Objective0>
         </BackgroundObjectives>
      </TestPhase50>
      <TestPhase60 Description="Brake to stop" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Machine">
               <BrakeToStop/>
            </Objective0>
         </ForegroundObjectives>
         <BackgroundObjectives Result="" Timeout="">
            <Objective0 Description="Analyze the brake test results" Result="" Timeout="" Component="Brake">
               <AnalyzeBrakeTest/>
            </Objective0>
         </BackgroundObjectives>
      </TestPhase60>
      <TestPhase70 Description="" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="" Result="" Timeout="" Component="Brake">
               <FinishUp/>
            </Objective0>
            <Objective1 Result="" Description="Perform module finish-up" Timeout="" Component="Transmission">
               <FinishUp/>
            </Objective1>
            <Objective2 Result="" Description="Perform module finish-up" Timeout="" Component="Machine">
               <FinishUp>PerformingFinishUp</FinishUp>
            </Objective2>
         </ForegroundObjectives>
      </TestPhase70>
      <TestPhase80 Description="" Result="" Timeout="">
         <ForegroundObjectives Result="" Timeout="">
            <Objective0 Description="Prompt the driver for the overall pass fail of the vehicle" Result="" Timeout="10000" Component="Machine">
               <DriverQuestion>DriverPassFail</DriverQuestion>
            </Objective0>
         </ForegroundObjectives>
      </TestPhase80>
   </Test>
</DriveCurve>
