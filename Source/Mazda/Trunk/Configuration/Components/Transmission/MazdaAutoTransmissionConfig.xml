                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">46</TargetSpeed>
                    <EndTime Units="Seconds">13.8</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment023>

                <Segment032>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">65</TargetSpeed>
                    <EndTime Units="Seconds">19.2</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment032>

                <Segment035>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">66</TargetSpeed>
                    <EndTime Units="Seconds">21</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment035>

                <Segment037>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">70</TargetSpeed>
                    <EndTime Units="Seconds">22.2</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment037>

                <Segment039>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">72</TargetSpeed>
                    <EndTime Units="Seconds">23.4</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment039>

                <Segment042>
                    <Prompt1 Value1="" Value2="">AccelerateToTargetSpeed</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
                    <TargetSpeed ConvertToEnglishUnits="True" Units="km/h">75</TargetSpeed>
                    <EndTime Units="Seconds">25.2</EndTime>
                    <SpeedTolerance Units="%">10</SpeedTolerance>
                </Segment042>

                <Segment044>
                    <Prompt1 Value1="" Value2="">AccelerateAtWOT</Prompt1>
                    <Prompt2 Value1="" Value2=""></Prompt2>
