<PlantHostInbound>
    <Setup>
        <Debug>Off</Debug>
        <InputServer>core/InputServer</InputServer>
        <Broadcast>
            <Data>
                <MessageDescriptionLength>50</MessageDescriptionLength>
                <TestDataSectionLength>17</TestDataSectionLength>
                <PartNumberSectionLength>60</PartNumberSectionLength>
                <TestCodeSectionLength>28</TestCodeSectionLength>
                <WccTimeIndex>157</WccTimeIndex>
                <WccTimeLength>4</WccTimeLength>
                <WccDateIndex>162</WccDateIndex>
                <WccDateLength>6</WccDateLength>
                <WccChecksumIndex>168</WccChecksumIndex>
            </Data>
            <BroadcastCommunication>
                <Setup>
                    <Communication>
                        <Name>/dev/LogicalPorts/Wcc</Name>
                        <BufferSize>2000</BufferSize>
                        <Timeout>3000</Timeout>
                        <Debug>Off</Debug>
                    </Communication>
                    <Logging>
                        <ProcessName>BroadcastCommunication</ProcessName>
                        <Status>Enabled</Status>
                        <AdditionalLogFile Types="/Servers/BroadCastCommunication.log or Disabled">/Servers/BroadCastCommunication.log</AdditionalLogFile>
                        <Debug>Off</Debug>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <MaxAttempts>3</MaxAttempts>
                    <MaxResponseTime>3000</MaxResponseTime>
                    <MessageDelay>100</MessageDelay>
                </Setup>
            </BroadcastCommunication>
            <RequestHandlerConfig>
                <Setup>
                    <Communication>
                        <Name>/dev/LogicalPorts/Wcc</Name>
                        <BufferSize>2000</BufferSize>
                        <Timeout>5000</Timeout>
                        <Debug>Off</Debug>
                    </Communication>
                    <Logging>
                        <Debug>Off</Debug>
                        <ProcessName>Blank</ProcessName>
                        <Status>Disable</Status>
                        <AdditionalLogFile Types="/Server/RequestHandler.log or Disabled">Disabled</AdditionalLogFile>
                        <LocalEcho>Disable</LocalEcho>
                        <Verbose>0x00</Verbose>
                    </Logging>
                    <WccRequests>
                        <CommunicationCheck>0</CommunicationCheck>
                    </WccRequests>
                    <RequestResponses>
                        <CommunicationCheck>R1</CommunicationCheck>
                    </RequestResponses>
                    <MaxAttempts>3</MaxAttempts>
                    <MessageDelay>25</MessageDelay>
                    <MaxRequestLength>5</MaxRequestLength>
                </Setup>
            </RequestHandlerConfig>
        </Broadcast>
        <Communication>
            <Type>Server</Type>
            <Debug>Off</Debug>
            <Name>core/PlantHostInbound</Name>
            <Comm>IPC</Comm>
            <Timeout>1000</Timeout>
            <BufferSize>2000</BufferSize>
        </Communication>
        <DataTags>
            <VehicleBuild>NextVehicleBuild</VehicleBuild>
            <BuildRecord>BuildRecord</BuildRecord>
            <Vin>VIN</Vin>
            <NextVIN>NextVIN</NextVIN>
            <VINDisplay>VINDisplay</VINDisplay>
            <VINReadStatus>VINReadStatus</VINReadStatus>
            <InputServerState>InputServerState</InputServerState>
            <VehiclePresent>VehiclePresent</VehiclePresent>
            <RollsDownElevUp>RollsDownElevUp</RollsDownElevUp>
            <VehicleBuildRecordStatus>VehicleBuildRecordStatus</VehicleBuildRecordStatus>
            <WheelbasePositionTag>WheelbasePositionInchesX10</WheelbasePositionTag>
            <VehicleType>VehicleType</VehicleType>
            <PlanthostOutboundName>core/PlantHostOutbound</PlanthostOutboundName>
            <AllWheelDriveEquipped>
                <AWD>Yes</AWD>
            </AllWheelDriveEquipped>
            <FourWheelDriveEquipped>
                <Undefined>No</Undefined>
                <NotEquipped>No</NotEquipped>
                <AWD>No</AWD>
            </FourWheelDriveEquipped>
            <SecondarySelectionDataTag>ZTSCode</SecondarySelectionDataTag>
            <SecondarySelectionData SelectedCharacterType = "SpecifiedCharacters">
                <ZTSCodeIndex01>0</ZTSCodeIndex01>
                <ZTSCodeIndex06>5</ZTSCodeIndex06>
                <ZTSCodeIndex07>6</ZTSCodeIndex07>
                <ZTSCodeIndex14>13</ZTSCodeIndex14>
                <ZTSCodeIndex15>14</ZTSCodeIndex15>
            </SecondarySelectionData>
        </DataTags>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>core/PlantHostInbound</ProcessName>
            <AdditionalLogFile Type="/Servers/PlantHostInbound.log or Disabled">/Servers/PlantHostInbound.log</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
            <Debug>Off</Debug>
        </Logging>
        <TagList>
            <SubscribeTags>
                <VehiclePresent/>
                <RollsDownElevUp/>
                <NextVIN/>
                <FrontAxleTestSelected/>
                <ZTSCode/>
            </SubscribeTags>
            <PublishTags>
                <VehicleBuildRecordStatus/>
                <BuildRecord/>
                <StopCurrentTest>0</StopCurrentTest>
            </PublishTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>7</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
            </Setup>
        </NotificationList>
        <InvalidateBuildRecordOnRead>False</InvalidateBuildRecordOnRead>
        <VehicleBuildFilePath>/Configuration/VehicleTest/BuildRecords/</VehicleBuildFilePath>
        <VehicleBuildRecordSource Type="File, Broadcast, None">File</VehicleBuildRecordSource>
        <VINIntermittentCharacterSelection Type="Zero based Index">
            <SelectedChar00>3</SelectedChar00>
            <SelectedChar01>7</SelectedChar01>
        </VINIntermittentCharacterSelection>
        <WheelbaseConfigFile>/Configuration/Servers/WheelbaseConfig.xml</WheelbaseConfigFile>
    </Setup>
    <VehicleConvert/>
</PlantHostInbound>
