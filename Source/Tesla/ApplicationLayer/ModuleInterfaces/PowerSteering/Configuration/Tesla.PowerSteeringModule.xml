            <Reply_02>0x7F,0x31,0x??</Reply_02>
         </TuneStatus>
         <ReadVIN>
            <Reply_01 lengthType="Variable">0x62,0xF1,0x90,0x??</Reply_01>
            <Reply_02>0x7F,0x22,0x??</Reply_02>
         </ReadVIN>
         <ReadPartNumber>
            <Reply_01 lengthType="Variable">0x62,0xF1,0x87,0x??</Reply_01>
            <Reply_02>0x7F,0x22,0x??</Reply_02>
         </ReadPartNumber>
         <TesterPresent>
            <Reply_01 lengthType="Variable">0x7E,0x00</Reply_01>
            <Reply_02>0x7F,0x3E,0x??</Reply_02>
         </TesterPresent>
      </ReplyMessages>
      <ReplyInterpretations>
         <ReadByID>
            <Boolean>
               <Byte1 input_index="3" mask="0xFF" compare="0x00"/>
            </Boolean>
         </ReadByID>
         <ReadTraceData>
            <String>
               <Substring format="%4s">
                  <Chars input_index="3" mask="0xFF" length="4"/>
               </Substring>
            </String>
         </ReadTraceData>
         <ReadVIN>
            <String>
               <Substring format="%17s">
                  <Chars input_index="3" mask="0xFF" length="17"/>
               </Substring>
            </String>
         </ReadVIN>
         <ReadPartNumber>
            <String>
               <Substring format="%12s">
                  <Chars input_index="3" mask="0xFF" length="12"/>
               </Substring>
            </String>
         </ReadPartNumber>
         <VINStatus>
            <String>
               <Substring>
                  <Chars input_index="5" mask="0xFF" length="1">
                     <StringSubstitute00 condition="equals" compare="0x00" replace="VINLearned"/>
                     <StringSubstitute01 condition="equals" compare="0x01" replace="VINAlreadyLearned"/>
                     <StringSubstitute02 condition="equals" compare="0x02" replace="VINMismatch"/>
                     <StringSubstitute03 condition="equals" compare="0x03" replace="BadVINReceived"/>
                     <StringSubstitute04 condition="equals" compare="0x04" replace="Timeout"/>
                     <StringSubstitute05 condition="equals" compare="0x05" replace="WriteError"/>
                     <StringSubstitute06 condition="equals" compare="0xFE" replace="UnknownError"/>
                  </Chars>
               </Substring>
            </String>
         </VINStatus>
         <TuneStatus>
            <String>
               <Substring>
                  <Chars input_index="5" mask="0xFF" length="1">
                     <StringSubstitute00 condition="equals" compare="0x00" replace="TuneLearned"/>
                     <StringSubstitute01 condition="not equal" compare="0x00" replace="TuneNotLearned"/>
                  </Chars>
               </Substring>
            </String>
         </TuneStatus>
      </ReplyInterpretations>
   </SerialMessages>
</DelphiAirbagModule>
