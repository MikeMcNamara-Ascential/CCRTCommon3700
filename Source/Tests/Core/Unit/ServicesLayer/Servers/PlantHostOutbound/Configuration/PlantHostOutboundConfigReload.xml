<PlantHostOutboundConfig>
    <!-- PlantHostOutbound config items -->
    <Setup>
        <Debug>Off</Debug>
        <ReportAbortedTestResults>False</ReportAbortedTestResults>
        <Communication>
            <Type>Server</Type>
            <Debug>Off</Debug>
            <Name>core/PlantHostOutbound</Name>
            <Comm>IPC</Comm>
            <Timeout>1000</Timeout>
            <BufferSize>2000</BufferSize>
        </Communication>
    <DataTags/>
        <Logging>
            <Debug>Off</Debug>
            <ProcessName>PlantHostOutbound</ProcessName>
            <Status>Disabled</Status>
            <AdditionalLogFile Types="/Server/PlantHostOutbound or Disabled">/Servers/PlantHostOutbound.log</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x1F</Verbose>
        </Logging>
        <TagList>
            <SubscribeTags>
                <RollsDownElevUp/>
                <TestResult/>
                <VehiclePresent/>
            </SubscribeTags>
        </TagList>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>7</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>10</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <HighWater>3</HighWater>
                <Increment>1</Increment>
                <LowWater>1</LowWater>
                <Maximum>5</Maximum>
                <StartOnCreate>No</StartOnCreate>
                <ResponseTimeout>2000</ResponseTimeout>
            </Setup>
        </NotificationList>
        <!-- External Host Interface List -->
        <DoNotLoadHostInterfaces>
            <!-- ============================================================== -->
            <!-- Sample Interface                                                  -->
            <!-- ============================================================== -->
            <SampleInterface Enabled="0" Process="$(USR_ROOT)/ServicesLayer/Bin/HostInterface.qxe">
                <Setup>
                    <SendResultsToHost>Yes</SendResultsToHost>
                    <VinIndex>18</VinIndex>
                    <MaxResponseTime>20000</MaxResponseTime>
                    <MaxAttempts>3</MaxAttempts>
                    <ResultMap>/Configuration/Servers/SampleResultMap.xml</ResultMap>
                    <MessageID>0x13</MessageID>
                    <TestResultConversion>
                        <Pass>P</Pass>
                        <Fail>F</Fail>
                        <Abort>A</Abort>
                        <NotTested>Z</NotTested>
                        <TestInProgress>A</TestInProgress>
                        <Timeout>F</Timeout>
                    </TestResultConversion>
                    <ComponentNameMapping/>
                    <DataTags>
                        <OverallTest>OverallTest</OverallTest>
                        <MachineNumber>MachineNumber</MachineNumber>
                    </DataTags>
                    <HostCommunication>
                        <Setup>
                            <Communication>
                                <Name>/dev/LogicalPorts/Wcc</Name>
                                <BufferSize>2048</BufferSize>
                                <Timeout>3000</Timeout>
                                <Debug>Off</Debug>
                            </Communication>
                            <Logging>
                                <Debug>Off</Debug>
                                <ProcessName>SampleInterface</ProcessName>
                                <Status>Enabled</Status>
                                <AdditionalLogFile Types="/Server/PFSCommunication.log">/Servers/SampleInterfaceCommunication.log</AdditionalLogFile>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1F</Verbose>
                            </Logging>
                        </Setup>
                    </HostCommunication>
                    <Communication>
                        <Debug>Off</Debug>
                        <Name>core/SampleInterface</Name>
                        <Type>Server</Type>
                        <Comm>IPC</Comm>
                        <BufferSize>2000</BufferSize>
                        <Timeout>1000</Timeout>
                    </Communication>
                    <Logging>
                        <Status>Enabled</Status>
                        <ProcessName>core/SampleInterface</ProcessName>
                        <AdditionalLogFile>/Servers/SampleInterface.log</AdditionalLogFile>
                        <Debug>Off</Debug>
                        <LocalEcho>Enabled</LocalEcho>
                        <Verbose>0x1F</Verbose>
                    </Logging>
                    <ThreadPool>
                        <Debug>Off</Debug>
                        <MinBlockedLimit>1</MinBlockedLimit>
                        <MaxBlockedLimit>3</MaxBlockedLimit>
                        <Increment>1</Increment>
                        <Maximum>5</Maximum>
                    </ThreadPool>
                    <NotificationList>
                        <Setup>
                            <Debug>Off</Debug>
                            <HighWater>3</HighWater>
                            <Increment>1</Increment>
                            <LowWater>1</LowWater>
                            <Maximum>5</Maximum>
                            <StartOnCreate>No</StartOnCreate>
                        </Setup>
                    </NotificationList>
                </Setup>
            </SampleInterface>
        </DoNotLoadHostInterfaces>
    </Setup>
</PlantHostOutboundConfig>
