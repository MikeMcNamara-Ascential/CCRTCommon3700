            <LeftTandemDragValue>LTDragValue</LeftTandemDragValue>
            <LeftTandemForce>LTForce</LeftTandemForce>
            <LeftTandemForceBGColor>LTForceBGColor</LeftTandemForceBGColor>
            <LeftTandemForceValue>LTForceValue</LeftTandemForceValue>
            <LeftTandemSpeed>LTSpeed</LeftTandemSpeed>
