<SystemScreenSaverConfig>
   <Setup>
      <Debug>Off</Debug>
      <Logging>
         <Status>Enabled</Status>
         <ProcessName>core/SystemScreenSaver</ProcessName>
         <AdditionalLogFile Types="/Servers/SystemScreenSaver.log">/Servers/SystemScreenSaver.log</AdditionalLogFile>
         <LocalEcho>Disabled</LocalEcho>
         <Verbose>0x1F</Verbose>
         <Debug>Off</Debug>
      </Logging>
      <ThreadPool>
         <Debug>Off</Debug>
         <MinBlockedLimit>2</MinBlockedLimit>
         <MaxBlockedLimit>4</MaxBlockedLimit>
         <Increment>2</Increment>
         <Maximum>50</Maximum>
      </ThreadPool>
      <NotificationList>
         <Setup>
            <Debug>Off</Debug>
            <HighWater>3</HighWater>
            <Increment>1</Increment>
            <LowWater>1</LowWater>
            <Maximum>5</Maximum>
            <StartOnCreate>No</StartOnCreate>
         </Setup>
      </NotificationList>
      <Communication>
         <Comm>IPC</Comm>
         <Type>Server</Type>
         <Name>core/SystemScreenSaver</Name>
         <Debug>Off</Debug>
         <Timeout>5000</Timeout>
         <BufferSize>1024</BufferSize>
      </Communication>
      <DataTags>
         <Rollskup>RollsUp</Rollskup>
      </DataTags>
      <TagList>
         <SubscribeTags>
            <!-- note that we also use these as trigger tags -->
            <RollsDownElevUp>
               <Value0>NormalScreen</Value0>
               <Default>NoAction</Default>
            </RollsDownElevUp>
         </SubscribeTags>
         <PublishTags>
            <VideoMode/>
         </PublishTags>
      </TagList>
      <Control>
         <Actions>
            <NormalScreen>
               <Message>NormalVideo</Message>
               <ScreenStatus>Normal</ScreenStatus>
            </NormalScreen>
         </Actions>
         <Timer>
            <!-- times are in seconds -->
            <ModeSwitch>
               <ModeSwitchTime>60</ModeSwitchTime>
               <AcceptableDelta>120</AcceptableDelta>
               <Modes>
                  <!-- this selects the ACTION to do, base on the largest accumulated Mode time -->
                  <Normal>InvertedScreen</Normal>
                  <Inverted>NormalScreen</Inverted>
               </Modes>
            </ModeSwitch>
            <!-- not yet implemented -->
            <Blanking>
               <BlankingTime>1000</BlankingTime>
            </Blanking>
         </Timer>
      </Control>
      <VideoControl>
         <!-- at present, software only supports a single serial and a single IPC control channel -->
         <PanasonicSerialControl>
            <Active>True</Active>
            <CommunicationType>Serial</CommunicationType>
            <Setup>
               <Communication>
                  <Name>MonitorControl</Name>
                  <BufferSize>2048</BufferSize>
                  <Timeout>3000</Timeout>
                  <Debug>Off</Debug>
               </Communication>
               <Logging>
                  <Debug>Off</Debug>
                  <ProcessName>MonitorControl</ProcessName>
                  <Status>Enabled</Status>
                  <AdditionalLogFile Types="/Server/MonitorCommunication or Disabled">/Servers/MonitorCommunication</AdditionalLogFile>
                  <LocalEcho>Disabled</LocalEcho>
                  <Verbose>0x1F</Verbose>
               </Logging>
            </Setup>
            <TransmitMessages>
               <NormalVideo>0x02,0x53,0x53,0x43,0x3a,0x4d,0x4f,0x44,0x30,0x03,0x02,0x41,0x56,0x4c,0x3a,0x30,0x30,0x03</NormalVideo>
               <InvertedVideo>0x02,0x53,0x53,0x43,0x3a,0x4d,0x4f,0x44,0x33,0x03,0x02,0x41,0x56,0x4c,0x3a,0x30,0x30,0x03</InvertedVideo>
               <!-- not yet implemented -->
               <BlankVideo>0x42,0x6c,0x61,0x6E,0x6B,0x0D,0x0A</BlankVideo>
               <UnblankVideo>0x00</UnblankVideo>
            </TransmitMessages>
         </PanasonicSerialControl>
         <IpcControl>
            <Active>False</Active>
            <CommunicationType>IPC</CommunicationType>
            <TransmitMessages>
               <NormalVideo>
                  <VideoMode>Normal</VideoMode>
               </NormalVideo>
               <InvertedVideo>
                  <VideoMode>Inverted</VideoMode>
               </InvertedVideo>
               <BlankScreen>
                  <VideoMode>Blank</VideoMode>
               </BlankScreen>
            </TransmitMessages>
         </IpcControl>
      </VideoControl>
   </Setup>
</SystemScreenSaverConfig>
