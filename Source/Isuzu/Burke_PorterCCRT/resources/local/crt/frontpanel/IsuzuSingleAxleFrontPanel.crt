<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">
<!-- 
  $Revision: 1.1 $
-->

<RtGuiConfig>
    <Metadata author="Burke Porter, Inc" version="1.0"
      description="Ford India Specific implementation of the Front Panel view."/>
  

    <XmlWidgetPanel id="FrontPanel">
        <Layout>
            <!-- BEP Address Label -->
            <VBox height="13" width="250" posX="750" posY="5" border="false">
                <Label name="address1" height="13" width="900" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <VBox height="13" width="250" posX="750" posY="20" border="false">
                <Label name="address2" height="13" width="900" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <VBox height="13" width="250" posX="750" posY="35" border="false">
                <Label name="phone" height="13" width="900" border="false">
                    <Font size="14" name="sans-serif" style="bold"/>
                </Label>
            </VBox>
            <!-- BEP Header -->
            <VBox height="750" width="1000" posX="0" posY="0" border="false">
                <Widget id="header" class="com.bepco.gui.ImagePhaseBox">
                    <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                </Widget>
            </VBox>
            <!-- VIN Display -->
            <HBox height="38" width="450" posX="25" posY="60" border="false">
                <!-- spacer -->
                <Label name="vin">
                    <Font size="18" name="sans-serif" style="plain"/>
                </Label>
                <!-- spacer -->
                <VBox width="20"/>
                <Widget id="_vinDisplay" width="250" class="com.bepco.gui.TextBox">
                    <DataSource tagname="VINDisplay" messagetype="Subscribe"/>
                    <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
                      tagrole="backgroundcolor" />
                    <TextBoxConfig>
                        <Font size="18" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
            </HBox>
      
            <HBox height="75" width="115" posX="5" posY="100" border="false">
                <Widget height="75" width="115" id="logo" class="com.bepco.gui.ImagePhaseBox">
                    <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                </Widget>
            </HBox>

            <!-- LED Panel -->
            <VBox height="130" width="450" posX="420" posY="60" border="false">
                <!-- Inputs from PLC -->
                <HBox height="130">
                    <VBox>
                        <Widget id="powersense" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="plcready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PLCSystemIsReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="vmeready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VMESystemReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="vehiclepresent" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VehiclePresent" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="cableconnect" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="CableConnect" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
                    </VBox>
          
                    <!-- SPACER -->
                    <VBox width="20"/>
          

                    <VBox>
                        <Label name="powersense"/>
                        <HBox height="5"/>
                        <Label name="plcready"/>
                        <HBox height="5"/>
                        <Label name="vmeready"/>
                        <HBox height="5"/>
                        <Label name="vehiclepresent"/>
                        <HBox height="5"/>
                        <Label name="cableconnect"/>
                    </VBox>
          
                    <!-- SPACER -->
                    <VBox width="40"/>
                    <VBox>
                        <Widget id="driveenable" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="AllRollDrivesEnabled" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="rollsup" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsUpElevDown" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="rollsdown" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsDownElevUp" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="zerospeed" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="ZerospeedToPLC" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
            

                        <Widget id="teststatuswidget" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="TestInProgress" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
                    </VBox>
          
                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="driveenable"/>
                        <HBox height="5"/>
                        <Label name="rollsup"/>
                        <HBox height="5"/>
                        <Label name="rollsdown"/>
                        <HBox height="5"/>
                        <Label name="zerospeed"/>
                        <HBox height="5"/>
                        <Label name="teststatuswidget"/>
                    </VBox>
          
                    <!-- SPACER -->
                    <VBox width="40"/>
                    <VBox>
                        <Widget id="rackfault" class="com.bepco.gui.ImagePhaseBox" screensaver="false">
                            <DataSource tagname="PLCRackFault" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
                        <Widget id="rearwd" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RearWheelDriveToPLC" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
                        <Widget id="allwd" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="AllWheelDrive" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>
                    </VBox>
          
                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="rackfault"/>
                        <HBox height="5"/>
                        <Label name="rearwd"/>
                        <HBox height="5"/>
                        <Label name="allwd"/>
                    </VBox>
          
                    <!-- SPACER -->
                    <VBox width="40"/>
                </HBox>
            </VBox>
      
            <!-- Test Drive Status traffic light indicator
              NoVIN = OFF
              TestReady = GREEN
              ProcessingVIN = YELLOW
              ReadVIN = RED
              -->
            <VBox height="110" width="100" posX="900" posY="70" border="false" borderstyle="title" bordertitle="vinread">
                <Widget id="trafficlight" class="com.bepco.gui.ImagePhaseBox"
                  width="50" height="110">
                    <DataSource tagname="VINReadStatus" messagetype="Subscribe"/>
                </Widget>
            </VBox>
            <!-- Row 1 of 4  -->


            <!-- Vehicle Build Info ========================================================== -->
            <HBox posX="1000" posY="0" width="200" height="200" border="true" borderstyle="title" bordertitle="vehiclebuild">
                <VBox>
                    <Label name="cruise"/>
                    <HBox height="5"/>
                    <Label name="brake"/>
                    <HBox height="5"/>
                    <Label name="abspartno"/>
                    <HBox height="5"/>
                    <Label name="pcmpartno"/>
                    <HBox height="5"/>
                    <Label name="tcmpartno"/>
                    <HBox height="5"/>
                    <Label name="wheelbase"/>
                </VBox>
                <VBox width="30"/>
                <VBox>
                    <Widget id="_cruiseType" width="75" class="com.bepco.gui.TextBox">
                        <DataSource tagname="SpeedControl" messagetype="Subscribe"/>
                        <DataSource tagname="SpeedControlBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    </Widget>
                    <HBox height="5"/>
                    <Widget id="_brakeType" width="75" class="com.bepco.gui.TextBox">
                        <DataSource tagname="BrakeType" messagetype="Subscribe"/>
                        <DataSource tagname="BrakeTypeBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    </Widget>
                    <HBox height="5"/>
                    <Widget id="_brakePartNo" width="75" class="com.bepco.gui.TextBox">
                        <DataSource tagname="ABSPartNo" messagetype="Subscribe"/>
                        <DataSource tagname="ABSPartNumberBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    </Widget>
                    <HBox height="5"/>
                    <Widget id="_emissionsPartNo" width="75" class="com.bepco.gui.TextBox">
                        <DataSource tagname="PCMPartNo" messagetype="Subscribe"/>
                        <DataSource tagname="PCMPartNoBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    </Widget>
                    <HBox height="5"/>
                    <Widget id="_transmissionPartNo" width="75" class="com.bepco.gui.TextBox">
                        <DataSource tagname="TCMPartNo" messagetype="Subscribe"/>
                        <DataSource tagname="TCMPartNoBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    </Widget>
                    <HBox height="5"/>
                    <Widget id="_wheelbasePosition" width="75" class="com.bepco.gui.TextBox">
                        <DataSource tagname="WheelbasePositionInchesX10" messagetype="Subscribe"/>
                    </Widget>
                </VBox>
            </HBox>

            <VBox posX="1010" posY="210" width="260" height="500">
                <!-- Speedometer gauge -->
                <Widget id="speed" height="250" width="250" class="com.bepco.gui.RadialGauge">
                    <DataSource tagname="SpeedValue" messagetype="Read" datarate="10"/>
                    <DataSource tagname="SpeedTarget" tagrole="targetrange" messagetype="Subscribe"/>
                    <DataSource tagname="SpeedActive" messagetype="Subscribe" tagrole="enabled"/>
                    <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="100" targetlow="40" targethigh="60" scale="true" >
                        <Font size="30" name="sans-serif" style="plain"/>
                    </RadialGaugeConfig>
                </Widget>
                <!-- Brake force gauge -->
                <Widget id="brakeforce" height="210" width="210" class="com.bepco.gui.RadialGauge">
                    <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10"/>
                    <DataSource tagname="BrakeTarget" tagrole="targetrange" messagetype="Subscribe"/>
                    <DataSource tagname="BrakeActive" messagetype="Subscribe" tagrole="enabled"/>
                    <RadialGaugeConfig placement="center" startangle="135" stopangle="405" domainlow="0" domainhigh="1500" targetlow="0" targethigh="0" >
                        <Font size="30" name="sans-serif" style="plain"/>
                    </RadialGaugeConfig>
                </Widget>
                <Widget id="_brakeForce" class="com.bepco.gui.NumberBox">
                    <DataSource tagname="BrakeForceValue" messagetype="Read" datarate="10" />
                    <DataSource tagname="RFSpeedBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    <TextBoxConfig>
                        <Font size="28" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
            </VBox>

            <!-- test subsystems pass/fail widgets -->
            <HBox height="40" width='1000' posX="5" posY="189" border="false">
                <!-- Spacer -->
                <HBox height="20"/>

                <!-- Test Result Boxes  -->
                <Widget width='250' height='40' id="engine" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="EmissionsOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='250' height='40' id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='250' height='40' id="trans" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TransmissionOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='245' height='40' id="cruise" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="SpeedControlOverallTest" messagetype="Subscribe"/>
                </Widget>

            </HBox>
      
            <!-- Row 2 of 4: Prompt message text box -->
            <Widget id="prompts" class="com.bepco.gui.PromptBox" posX="3" posY="230" width="997" height="60" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts3" class="com.bepco.gui.PromptBox" posX="3" posY="290" width="997" height="60" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
      
            <!-- Row 3 of 4 -->
            <!-- Wheel speeds -->
            <VBox height="200" width="247" posX="3" posY="350" border="true" borderstyle="title" bordertitle="speed">
                <HBox height="15"/>
                <!-- Wheel Speeds -->
                <HBox width="200" border="false">
                    <VBox width="60">
                        <HBox>
                            <Label name="left">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                            <TextBoxConfig convertunits="false">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lfg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30">
                        <DataSource tagname="LFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>
          

                    <Widget id="_rfg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="right">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                </HBox>
                <HBox height="5"/>
                <HBox width="200">
                    <VBox width="155">
                    </VBox>
                </HBox>
            </VBox>
            <!-- drag, brake, reduction, recovery -->
            <VBox width="380" height="200" posX="250" posY="350" border="true" borderstyle="title" bordertitle="brake">
                <HBox height="8"/>
                <HBox height="10">
                    <Label height="30" width="40" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="drag">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="brake">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="parkbrake">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="red">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="rec">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="40" name="left">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="60" id="LFDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LfPbForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LeftFrontParkBrakeForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="LeftFrontParkBrakeForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="40" name="right">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
          

                    <Widget height="30" width="60" id="RFDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFBrake" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RfPbForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RightFrontParkBrakeForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="RightFrontParkBrakeForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="60">
                </HBox>
            </VBox>
      
            <!-- Balance  -->
            <VBox width="130" height="200" posX="630" posY="350" border="true" borderstyle="title" bordertitle="balance">
                <HBox height="20"/>
                <HBox height="30">
                    <Widget height="30" width="50" id="FrontBalance" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="FrontBalanceValue" messagetype="Subscribe"/>
                        <DataSource tagname="FrontBalanceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="60">
                </HBox>
            </VBox>

            <!-- Vehicle Data -->
            <HBox width="240" height="200" posX="760" posY="350" border="true" borderstyle="title" bordertitle="vehicledata">
                <VBox>
                    <Label height="30" width="100" name="enginetemp">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </VBox>
                <VBox width="20"/>
                <VBox>
                    <Widget height="30" width="50" id="EngineTemp" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="EngineOperatingTemp" messagetype="Subscribe"/>
                        <TextBoxConfig format="{0,number,#}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </VBox>
            </HBox>
      
      
            <!-- Row 4 of 4 -->
            <!-- Test Failures -->
            <VBox height="160" width="557" posX="3" posY="550" border="true" borderstyle="title" bordertitle="testfailures">
                <Widget height="126" width="598" id="testfailures" class="com.bepco.gui.ListBox">
                    <DataSource tagname="AllFailures" messagetype="Subscribe"/>
                    <ScrollBoxConfig stringmap="com.bepco.rtc.properties.TestFailureStrings">
                        <Font style="bold" name="sans-serif" size="14"/>
                    </ScrollBoxConfig>
                </Widget>
            </VBox>
      
            <!-- Machine Faults -->
            <VBox height="160" width="440" posX="560" posY="550" border="true" borderstyle="title" bordertitle="machinefaults">
                <Widget height="126" width="380" id="machine_faults" class="com.bepco.gui.MachineFaultView">
                    <DataSource tagname="AllFaults" messagetype="Subscribe"/>
                    <ListBoxConfig stringmap="com.bepco.rtc.properties.MachineFaultStrings">
                        <Font style="bold" name="sans-serif" size="14"/>
                    </ListBoxConfig>
                </Widget>
            </VBox>
        </Layout>
    </XmlWidgetPanel>
</RtGuiConfig>
