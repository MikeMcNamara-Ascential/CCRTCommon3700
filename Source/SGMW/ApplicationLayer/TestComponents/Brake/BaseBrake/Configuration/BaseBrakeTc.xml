            <TestResultBox3BGColor>white</TestResultBox3BGColor>
        </SystemTagsToReset>
        <TaskMon>
            <Name>BaseBrakeTc</Name>
        </TaskMon>
    </Setup>



    <Objectives>
        <AnalyzeBrakeTest>
            <TestStep2>AnalyzeBrakeTest</TestStep2>
            <TestStep3>AnalyzeBalance</TestStep3>
        </AnalyzeBrakeTest>

        <AccelerateToSpeed>
            <TestStep00>DisplaySpeedTimeGraph</TestStep00>
            <TestStep05>AccelerateToBrakeSpeed</TestStep05>
        </AccelerateToSpeed>

        <BrakeTest>
            <TestStep03>AccelerateToBrakeSpeed</TestStep03>
            <TestStep05>DragTest</TestStep05>
            <TestStep10>AnalyzeDragTest</TestStep10>
            <TestStep15>BrakeTest</TestStep15>
        </BrakeTest>

        <BrakeToStop>
            <TestStep1>BrakeToStop</TestStep1>
        </BrakeToStop>

        <FinishUp>
            <TestStep0>DisableForceMeter</TestStep0>
            <TestStep1>FinishUp</TestStep1>
        </FinishUp>

        <Initialize>
            <TestStep1>Initialize</TestStep1>
        </Initialize>

        <ParkBrakeTest>
            <TestStep00>EngageMachine</TestStep00>
            <TestStep05>AccelerateToParkBrakeSpeed</TestStep05>
            <TestStep10>DynamicParkBrakeTest</TestStep10>
            <TestStep15>AnalyzeDynamicParkBrake</TestStep15>
            <TestStep20>BrakeToStop</TestStep20>
            <TestStep25>DisableForceMeter</TestStep25>
        </ParkBrakeTest>

    </Objectives>
    <TestSteps>

        <AccelerateToBrakeSpeed Result="" Timeout="1200000" Description="Accelerate to Brake Test Arm Speed"
            SpeedTarget="48 55" ArmSpeed="40" Prompt1="AccelerateToTargetSpeed"/>

        <AccelerateToParkBrakeSpeed Result="" Timeout="120000" Description="Accelerate to Park Brake Speed"
            Prompt1="ShiftToDrive" Prompt2="AccelerateToTargetSpeed"
            SpeedDomain="0 100" SpeedActive="1" SpeedInactive="0" SpeedTarget="9 13"/>

        <AnalyzeBalance Result="" Timeout="5000" Description="Base Brake Component Brake Balance Test"
            FrontSideToSideBalance="8" RearSideToSideBalance="8" TandemSideToSideBalance="20"
            BalanceFrontToRearMin="60" BalanceFrontToRearMax="90"
            BalanceTandemToRearMin="40" BalanceTandemToRearMax="60" Prompt1="" Prompt2=""/>

        <AnalyzeBrakeTest Result="" Timeout="20000" Description="Base Brake Component Brake Test Analysis"
            FrontMinBrakeForce="150" FrontMaxBrakeForce="600"
            RearMinBrakeForce="40" RearMaxBrakeForce="400"
            Prompt1="" Prompt2=""/>

        <AnalyzeDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis"
            Prompt1="" Prompt2="" FrontMaxDragForce="55" RearMaxDragForce="55"/>

        <AnalyzeDynamicParkBrake Result="" Timeout="1000" Description="Validate park brake forces"/>

        <BrakeTest Result="" Timeout="40000" Description="Base Brake Component Brake Test"
            StartBrakeSampleSpeed="45" EndBrakeSampleSpeed="10"
            BrakeDomain="0 500" BrakeTarget="150 250"
            Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeModeratelyInGreenBand"/>

        <BrakeToStop Result="" Timeout="1200000" Description="Brake The Vehicle To A Stop" Prompt1="BrakeToStop"/>

        <DisableForceMeter Result="" Timeout="30000" Description="Disable The Brake Force Meter"/>

        <DragTest Result="" Timeout="40000" Description="Base Brake Component Brake Drag Test"
            Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="Blank"
            DragDelay="1000" DragSpeed="48" DragSamples="50"/>

        <DynamicParkBrakeTest Result="" Timeout="60000" Description="Perform park brake test"
            Prompt1="ShiftToNeutral" Prompt2="ApplyParkBrake"/>

        <EngageMachine Result="" Description="Engage the machine, clutches, boost, etc." Timeout="30000"/>

        <FinishUp Result="" Timeout="30000" Description="Brake test finishup" Prompt1="" Prompt2=""/>

        <Initialize Result="" Timeout="10000" Description="Initialize for the BaseBrake test."
            Prompt1="Initialize" ZerospeedPrompt="BrakeToStop"/>

        <DisplaySpeedTimeGraph Result="" Timeout="5000" Description="Display Speed Time Graph" ScanDelay="250"/>

        <RemoveSpeedTimeGraph Result="" Timeout="5000" Description="Remove Speed Time Graph" ScanDelay="250"/>

        <!--  Unused Test Steps
                <Coast Result="" Timeout="70000" Description="Base Brake Component Coast" Prompt1="CoastDownToTargetSpeed" Prompt2="Blank" SpeedTarget="23 33" CoastEndSpeed="33">Perform Vehicle Coast</Coast>
                <CoastToStop Result="" Timeout="70000" Description="Base Brake Component Coast" Prompt1="CoastDownToTargetSpeed" Prompt2="Blank" SpeedTarget="23 33" CoastEndSpeed="33">Perform Vehicle Coast</CoastToStop>
                <TireChunkingTest Result="" Timeout="30000" Description="Check for excessive brake force">Check for excessive brake force</TireChunkingTest>
                <ExcessiveBrakeForceCheck Result="" Timeout="30000" Description="Check for excessive brake force">Check for excessive brake force</ExcessiveBrakeForceCheck>
                <AccelerateToTestSpeed Result="" Timeout="10000" Description="Accelerate to test speed" TargetSpeedParameter="TargetSpeedParameter" SpeedRangeParameter="SpeedRangeParameter" ScanDelayParameter="ScanDelayParameter" Prompt1Value1="32"/>
                <EnableMotorLoading Description="Apply a load to the drive axle of the vehicle" Result="" Timeout="2000"/>
                <DisableMotorLoading Description="Disable the loading of the drive axle of the vehicle" Result="" Timeout="2000"/>
                <MaintainSpeedForTime Result = "" Description="Prompt the operator to accelerate to and maintain speed" Timeout="30000"/>
                <ReadMemoryStatistics Result = "" Description="Read the current memory statistics" Timeout="10000"/>
        -->
    </TestSteps>
</BaseBrake>
