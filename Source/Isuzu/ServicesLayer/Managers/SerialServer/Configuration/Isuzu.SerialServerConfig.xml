                        <EngineController Outgoing="0x7E0" Incoming="0x7E8" UudtResponse="0x5E8"/>
                        <Transmission Outgoing="0x7E2" Incoming="0x7EA" UudtResponse="0x5EA"/>
                        <PIM Outgoing="0x244" Incoming="0x644"/>
                        <ClearFaults Outgoing="0x101" Incoming="0x7E8"/>
