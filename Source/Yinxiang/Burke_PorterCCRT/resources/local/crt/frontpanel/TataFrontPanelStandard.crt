<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">
<!-- 
$Revision: 1.3 $
-->

<RtGuiConfig>
    <Metadata author="Burke E. Porter" version="1.0"
                        description="Standard implementation of the Front Panel view."/>

    <XmlWidgetPanel id="FrontPanel">
        <Layout>
            <!-- BEP Address Label -->
            <VBox height="45" width="250" posX="750" posY="5" border="false">
                <HBox height="13" width="250">
                    <Label name="address1" height="15" width="250" border="false">
                        <Font size="14" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox height="13" width="250" border="false">
                    <Label name="address2" height="15" width="250" border="false">
                        <Font size="14" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox height="13" width="250" border="false">
                    <Label name="phone" height="15" width="250" border="false">
                        <Font size="14" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
            </VBox>
            <!-- BEP Header -->
            <VBox height="715" width="1000" posX="0" posY="0" border="false">
                <Widget id="header" class="com.bepco.gui.ImagePhaseBox">
                    <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                </Widget>
            </VBox>
            
            
            <!-- Test counter -->
            <HBox height="40" width="350" posX="10" posY="72" border="true">
                <Label name="numberOfTests">
                    <Font size="18" name="sans-serif" style="bold"/>
                </Label>
                <VBox width="88"/>
                <Widget id="_numberOfTests" class="com.bepco.gui.TextBox">
                    <DataSource tagname="TestsSinceLossCompensation" messagetype="Subscribe"/>
                    <TextBoxConfig>
                        <Font size="18" name="sans-serif" style="plain"/>
                    </TextBoxConfig>
                </Widget>
            </HBox>
            <!-- LED Panel -->
            <VBox height="130" width="400" posX="590" posY="60" border="false">
                <!-- Inputs from PLC -->
                <HBox height="130">
                    <VBox>
                        <Widget id="powersense" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PowerSense" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="plcready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="PLCSystemIsReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="vmeready" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VMESystemReady" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="vehiclepresent" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="VehiclePresent" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="cableconnect" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="CableConnect" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                    </VBox>

                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="powersense"/>
                        <HBox height="5"/>
                        <Label name="plcready"/>
                        <HBox height="5"/>
                        <Label name="vmeready"/>
                        <HBox height="5"/>
                        <Label name="vehiclepresent"/>
                        <HBox height="5"/>
                        <Label name="cableconnect"/>
                    </VBox>

                    <!-- SPACER -->
                    <VBox width="40"/>

                    <VBox>
                        <Widget id="driveenable" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="EnableAllRollDrives" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="rollsup" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsUpElevDown" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="rollsdown" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="RollsDownElevUp" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="zerospeed" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="ZerospeedToPLC" messagetype="Subscribe"/>
                        </Widget>
                        <HBox height="5"/>

                        <Widget id="teststatuswidget" class="com.bepco.gui.ImagePhaseBox">
                            <DataSource tagname="TestInProgress" messagetype="Subscribe"/>
                        </Widget>

                    </VBox>

                    <!-- SPACER -->
                    <VBox width="20"/>

                    <VBox>
                        <Label name="driveenable"/>
                        <HBox height="5"/>
                        <Label name="rollsup"/>
                        <HBox height="5"/>
                        <Label name="rollsdown"/>
                        <HBox height="5"/>
                        <Label name="zerospeed"/>
                        <HBox height="5"/>
                        <Label name="teststatuswidget"/>
                    </VBox>

                </HBox>
            </VBox>
            
            <!-- VC and VIN Display -->
            <VBox height="80" width="270" posX="5" posY="120" border="false">
                <HBox>
                    <VBox width="10"/>
                    <Label name="vc">
                        <Font size="18" name="sans-serif" style="plain"/>
                    </Label>
                    <!-- spacer -->
                    <VBox width="20"/>
                    <Widget id="_vcDisplay" width="250" class="com.bepco.gui.TextBox">
                        <DataSource tagname="VCNumber" messagetype="Subscribe"/>
                        <TextBoxConfig>
                            <Font size="18" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox>
                    <VBox width="10"/>
                    <Label name="vin">
                        <Font size="18" name="sans-serif" style="plain"/>
                    </Label>
                    <!-- spacer -->
                    <VBox width="20"/>
                    <Widget id="_vinDisplay" width="250" class="com.bepco.gui.TextBox">
                        <DataSource tagname="VINDisplay" messagetype="Subscribe"/>
                        <DataSource tagname="VINDisplayBGColor" messagetype="Subscribe"
                            tagrole="backgroundcolor" />
                        <TextBoxConfig>
                            <Font size="18" name="sans-serif" style="plain"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
            </VBox>

            <!-- test subsystems pass/fail widgets -->
            <HBox height="40" width='500' posX="5" posY="189" border="false">
                <Widget width='120' height='40'  id="cruise" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="SpeedControlOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='120' height='40'  id="brake" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="BrakeOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='120' height='40'  id="sound" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="SoundLevelOverallTest" messagetype="Subscribe"/>
                </Widget>
                <Widget width='120' height='40'  id="tirepressuremonitor" class="com.bepco.gui.OverallTestPhaseBox" >
                    <DataSource tagname="TpmsOverallTest" messagetype="Subscribe"/>
                </Widget>
            </HBox>
			
            <!-- Row 2 of 4: Prompt message text box -->
            <Widget id="prompts" class="com.bepco.gui.PromptBox" posX="3" posY="230" width="997" height="60" border="true">
                <DataSource tagname="PromptBox1" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox1BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>
            <Widget id="prompts3" class="com.bepco.gui.PromptBox" posX="3" posY="290" width="997" height="60" border="true">
                <DataSource tagname="PromptBox2" messagetype="Subscribe"  />
                <DataSource tagname="PromptBox2BGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                <TextBoxConfig>
                    <Font size="24" name="sans-serif" style="plain"/>
                </TextBoxConfig>
            </Widget>

            <!-- Row 3 of 4 -->
            <!-- Wheel speeds -->
            <VBox height="200" width="297" posX="3" posY="350" border="true" borderstyle="title" bordertitle="speed">
                <HBox height="15"/>
                <!-- Wheel Speeds -->
                <HBox width="200" border="false">
                    <VBox width="60">
                        <HBox>
                            <Label name="lf">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LFSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="lfcolor" convertunits="false">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig convertunits="false">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lfg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30">
                        <DataSource tagname="LFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>

                    <Widget id="_rfg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RFForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RFForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="rf">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rf" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RFSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="rfcolor">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>

                </HBox>
                <HBox height="5"/>
                <HBox width="200">
                    <VBox width="60">
                        <HBox>
                            <Label name="lr">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_lr" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="LRSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="lrcolor">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                    <VBox width="10"/>
                    <Widget id="_lrg" class="com.bepco.gui.VerticalBarGraph" height="70" width="30" >
                        <DataSource tagname="LRForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="LRForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="5"/>

                    <Widget id="_rrg" class="com.bepco.gui.VerticalBarGraph" width="30" height="70" >
                        <DataSource tagname="RRForce" messagetype="Read" datarate="10" />
                        <DataSource tagname="RRForceTarget" tagrole="targetrange" messagetype="Subscribe"/>
                        <BarGraphConfig domainhigh="600" domainlow="0" targethigh="66" targetlow="66" />
                    </Widget>
                    <VBox width="10"/>
                    <VBox width="60">
                        <HBox>
                            <Label name="rr">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                        <Widget id="_rr" class="com.bepco.gui.NumberBox" width="50">
                            <DataSource tagname="RRSpeed" messagetype="Read" datarate="10" />
                            <!--TextBoxConfig bgcolor="rrcolor">
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig-->
                            <TextBoxConfig>
                                <Font size="24" name="sans-serif" style="plain"/>
                            </TextBoxConfig>
                        </Widget>
                        <HBox>
                            <Label name="speed">
                                <Font size="14" name="sans-serif" style="bold"/>
                            </Label>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Speedometer Results -->
            <VBox height="100" width="130" posX="3" posY="550" border="true" borderstyle="title" bordertitle="speedo">
                <Widget height="60" width="60" id="SpeedoResult" class="com.bepco.gui.NumberBox">
                    <DataSource tagname="SpeedoTestValue" messagetype="Subscribe"/>
                    <DataSource tagname="SpeedoTestBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    <TextBoxConfig format="{0,number,#.0}">
                        <Font size="24" name="sans-serif" style="bold"/>
                    </TextBoxConfig>
                </Widget>
            </VBox>

            <!-- Sound Level Results -->
            <VBox height="100" width="130" posX="3" posY="650" border="true" borderstyle="title" bordertitle="sound">
                <Widget height="60" width="60" id="SoundResult" class="com.bepco.gui.NumberBox">
                    <DataSource tagname="SoundLevelValue" messagetype="Subscribe"/>
                    <DataSource tagname="SoundLevelBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                    <TextBoxConfig format="{0,number,#.0}">
                        <Font size="24" name="sans-serif" style="bold"/>
                    </TextBoxConfig>
                </Widget>
            </VBox>

            <!-- Sound Level Results -->
            <VBox height="200" width="170" posX="130" posY="550" border="true" borderstyle="title" bordertitle="tirepressuremonitor">
                <HBox height="10">
                    <Label height="30" width="140" name="framecount">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox>
                    <VBox>
                        <Label height="30" width="40" name="lf">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </Label>
                        <Label height="30" width="40" name="rf">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </Label>
                        <Label height="30" width="40" name="lr">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </Label>
                        <Label height="30" width="40" name="rr">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </Label>
                    </VBox>
                    <VBox width="30"/>
                    <VBox>
                        <Widget height="30" width="40" id="lfTpmsCount" class="com.bepco.gui.NumberBox">
                            <DataSource tagname="LeftFrontTpmsCount" messagetype="Subscribe"/>
                            <DataSource tagname="LeftFrontTpmsCountBgColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig format="{0,number,#.0}">
                                <Font size="16" name="sans-serif" style="bold"/>
                            </TextBoxConfig>
                        </Widget>
                        <Widget height="30" width="40" id="rfTpmsCount" class="com.bepco.gui.NumberBox">
                            <DataSource tagname="RightFrontTpmsCount" messagetype="Subscribe"/>
                            <DataSource tagname="RightFrontTpmsCountBgColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig format="{0,number,#.0}">
                                <Font size="16" name="sans-serif" style="bold"/>
                            </TextBoxConfig>
                        </Widget>
                        <Widget height="30" width="40" id="lrTpmsCount" class="com.bepco.gui.NumberBox">
                            <DataSource tagname="LeftRearTpmsCount" messagetype="Subscribe"/>
                            <DataSource tagname="LeftRearTpmsCountBgColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig format="{0,number,#.0}">
                                <Font size="16" name="sans-serif" style="bold"/>
                            </TextBoxConfig>
                        </Widget>
                        <Widget height="30" width="40" id="rrTpmsCount" class="com.bepco.gui.NumberBox">
                            <DataSource tagname="RightRearTpmsCount" messagetype="Subscribe"/>
                            <DataSource tagname="RightRearTpmsCountBgColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                            <TextBoxConfig format="{0,number,#.0}">
                                <Font size="16" name="sans-serif" style="bold"/>
                            </TextBoxConfig>
                        </Widget>
                    </VBox>
                </HBox>
            </VBox>

            <!-- drag, brake, reduction, recovery -->
            <VBox width="490" height="230" posX="300" posY="350" border="true" borderstyle="title" bordertitle="brake">
                <HBox height="8"/>
                <HBox height="10">
                    <Label height="30" width="40" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="120" name="abs">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="120" name="esp">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox height="10">
                    <Label height="30" width="40" name="blank">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="drag">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="brake">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="red">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="rec">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="red">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="rec">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Label height="30" width="60" name="wss">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="40" name="lf">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>
                    <Widget height="30" width="60" id="LFDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFForce" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LFABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="LFABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LFEspReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LeftFrontESPReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="LeftFrontESPReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LfESPBuildValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LeftFrontESPBuildValue" messagetype="Subscribe"/>
                        <DataSource tagname="LeftFrontESPBuildBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="LfWssValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="LeftFrontWssValue" messagetype="Subscribe"/>
                        <DataSource tagname="LeftFrontWssValueBgColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                </HBox>
                <HBox height="30">
                    <Label height="30" width="40" name="rf">
                        <Font size="16" name="sans-serif" style="bold"/>
                    </Label>

                    <Widget height="30" width="60" id="RFDrag" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFDragValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFDragBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFBrake" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFForceValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFForceBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFABSReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFABSReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFABSReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RFABSRecoveryValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RFABSRecoveryValue" messagetype="Subscribe"/>
                        <DataSource tagname="RFABSRecoveryBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RfEspReductionValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RightFrontESPReductionValue" messagetype="Subscribe"/>
                        <DataSource tagname="RightFrontESPReductionBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RfESPBuildValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RightFrontESPBuildValue" messagetype="Subscribe"/>
                        <DataSource tagname="RightFrontESPBuildBGColor" messagetype="Subscribe" tagrole="backgroundcolor"/>
                        <TextBoxConfig format="{0,number,#.0}">
                            <Font size="16" name="sans-serif" style="bold"/>
                        </TextBoxConfig>
                    </Widget>
                    <Widget height="30" width="60" id="RfWssValue" class="com.bepco.gui.NumberBox">
                        <DataSource tagname="RightFrontWssValue" messagetype="Subscribe"/>
