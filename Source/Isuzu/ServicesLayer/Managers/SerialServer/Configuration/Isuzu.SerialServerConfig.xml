							<Status>Enabled</Status>
							<LocalEcho>Disabled</LocalEcho>
							<Verbose>0xFF</Verbose>
							<Debug>Off</Debug>
						 </Logging>
					  </Setup>
				   </CommLog>
				   <Login>
					  <IPAddress>192.168.1.1</IPAddress>
					  <Port>7000</Port>
					  <UserID>gryphon</UserID>
					  <Password>gryphon</Password>
				   </Login>
				   <Alias>/home/CCRT/Rewrite/GryphonJ1939</Alias>
				   <NodePairs>
					  <Emissions Outgoing="0x18DA00F1" Incoming="0x18DAF100" UudtResponse="0x18DAF100"/>
					  <PIM Outgoing="0x18DA8CF1" Incoming="0x18DAF18C" UudtResponse="0x18DAF18C"/>
					  <ABS Outgoing="0x18DA0BF1" Incoming="0x18DAF10B" UudtResponse="0x18DAF10B"/>
					  <Transmission Outgoing="0x18DA03F1" Incoming="0x18DAF103" UudtResponse="0x18DAF103"/>
				   </NodePairs>
				   <NodePairSetup>
					  <Range1 FirstRequestID="0x18DA00F1" FirstResponseID="0x18DAF100" Offset="0x00000008" NumberOfPairs="1"/>
					  <Range2 FirstRequestID="0x18DA8CF1" FirstResponseID="0x18DAF18C" Offset="0x00000008" NumberOfPairs="1"/>
					  <Range3 FirstRequestID="0x18DA0BF1" FirstResponseID="0x18DAF10B" Offset="0x00000008" NumberOfPairs="1"/>
					  <Range4 FirstRequestID="0x18DA03F1" FirstResponseID="0x18DAF103" Offset="0x00000008" NumberOfPairs="1"/>
				   </NodePairSetup>
				   <!--BroadcastMessageIDs>
					  <WheelSpeeds Incoming="0x18FEBF0B"/>
					  <ShiftLeverPosition Incoming="0x18F00503"/>
				   </BroadcastMessageIDs-->
				</Setup>
			</GryphonJ1939>
