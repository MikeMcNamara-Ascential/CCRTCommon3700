<?xml version="1.0"?>
<!DOCTYPE RtGuiConfig SYSTEM "resource:///com/bepco/rtc/crt/rtguiconfig.dtd">
<!-- 
  $Revision$
-->

<RtGuiConfig> 
  <Metadata author="Burke Porter, Inc" version="1.0"
	description="Standard implementation of the Front Panel view."/>

  <XmlWidgetPanel id="AboutServer">
	<Layout>
			<VBox height="300" width='600' posX="0" posY="0" border="true">
		  <HBox height="100">
				<Label name="serverid" width="250">
						<Font size="24" name="sans-serif" style="bold"/>
				</Label>	
				 <Widget id="serveridtag" class="com.bepco.gui.TextBox" width="400">
					<DataSource tagname="ServerID" messagetype="Subscribe" />
					<TextBoxConfig>
						<Font size="24" name="sans-serif" style="plain"/>
					</TextBoxConfig>
				
				 </Widget>
         </HBox>
			</VBox>

    </Layout>
  </XmlWidgetPanel>
</RtGuiConfig>

