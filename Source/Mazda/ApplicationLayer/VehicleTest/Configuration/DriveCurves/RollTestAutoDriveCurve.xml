                <Objective0 Description="Rain / Light sensor operator verification" Result="" Timeout="" Component="Machine">
                    <RainLightSensorVerification/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase015>

<!--
        <TestPhase020 Description="Perform forward gear / speed prompting" Result="" Timeout="">
