        </AccelerateToSpeed>

        <BrakeToStop>
            <TestStep0>BrakeToStop</TestStep0>
            <TestStep1>EngageMachine</TestStep1>
        </BrakeToStop>

        <ConnectCable>
            <TestStep1>Initialize</TestStep1>
            <TestStep2>MachineReady</TestStep2>
            <TestStep3>ConnectCable</TestStep3>
        </ConnectCable>

        <EngageMachine>
            <TestStep1>EngageMachine</TestStep1>
        </EngageMachine>

        <Initialize>
            <TestStep1>Initialize</TestStep1>
            <TestStep2>MachineReady</TestStep2>
        </Initialize>

        <MultiDriverQuestion>
            <TestStep1>MultiDriverQuestion</TestStep1>
        </MultiDriverQuestion>

        <Speedometer>
            <TestStep1>Speedometer</TestStep1>
        </Speedometer>

