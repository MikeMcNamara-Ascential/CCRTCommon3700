<SampleSpeedControlConfig>
  <Setup>
    <Name>SpeedControl</Name>
    <Debug>Off</Debug>
    <DebugLevel>0</DebugLevel>
    <ProcessPriority>11</ProcessPriority>
    <Communication>
      <Comm>IPC</Comm>
      <Type>Server</Type>
      <Name>component/SpeedControl</Name>
      <Debug>Off</Debug>
      <BufferSize>1024</BufferSize>
      <Timeout>2000</Timeout>
    </Communication>
    <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
    <ThreadPool>
      <Debug>Off</Debug>
      <MinBlockedLimit>2</MinBlockedLimit>
      <MaxBlockedLimit>4</MaxBlockedLimit>
      <Increment>2</Increment>
      <Maximum>50</Maximum>
    </ThreadPool>
    <NotificationList>
      <Setup>
        <Debug>Off</Debug>
        <StartOnCreate>Off</StartOnCreate>
        <LowWater>1</LowWater>
        <HighWater>3</HighWater>
        <Maximum>5</Maximum>
        <Increment>1</Increment>
        <ResponseTimeout>2000</ResponseTimeout>
      </Setup>
    </NotificationList>
    <Logging>
      <Debug>Off</Debug>
      <MessageTimeout>100</MessageTimeout>
      <AdditionalLogMaxSize>10</AdditionalLogMaxSize>
      <AdditionalLogMaxFiles>5</AdditionalLogMaxFiles>
      <Status>Enabled</Status>
      <ProcessName>SpeedControl</ProcessName>
      <AdditionalLogFile>/Components/SpeedControl.log</AdditionalLogFile>
      <LocalEcho>Disabled</LocalEcho>
      <Verbose>0x01</Verbose>
    </Logging>
    <TagList>
      <SubscribeTags>
        <Abort/>
        <DriveAxle/>
        <Zerospeed/>
        <CableConnect/>
      </SubscribeTags>
    </TagList>
    <DataTags>
      <Abort>Abort</Abort>
      <BroadcastSpeedControlType>SpeedControl</BroadcastSpeedControlType>
      <DriveAxle>DriveAxle</DriveAxle>
      <EmissionsOverallTestTag>EmissionsOverallTest</EmissionsOverallTestTag>
      <FourWheelDriveEquipped>FourWheelDriveEquipped</FourWheelDriveEquipped>
      <LeftFrontSpeed>LFSpeed</LeftFrontSpeed>
      <LeftRearSpeed>LRSpeed</LeftRearSpeed>
      <LFSpeed>LFSpeed</LFSpeed>
      <LRSpeed>LRSpeed</LRSpeed>
      <NoSpeedControl>NotEquipped</NoSpeedControl>
      <ReadBrakeSwitch>ReadCruiseMode</ReadBrakeSwitch>
      <ReadCancelSwitch>ReadCruiseMode</ReadCancelSwitch>
      <ReadClutchPedal>ReadCruiseMode</ReadClutchPedal>
      <ReadResumeButton>ReadCruiseMode</ReadResumeButton>
      <ReadSetButton>ReadCruiseMode</ReadSetButton>
      <ReadSpeedControlOff>ReadCruiseMode</ReadSpeedControlOff>
      <ReadSpeedControlOn>ReadCruiseMode</ReadSpeedControlOn>
      <ReadSpeedLimit>ReadSpeedLimit</ReadSpeedLimit>
      <Rear>Rear</Rear>
      <RFSpeed>RFSpeed</RFSpeed>
      <RightFrontSpeed>RFSpeed</RightFrontSpeed>
      <RightRearSpeed>RRSpeed</RightRearSpeed>
      <RRSpeed>RRSpeed</RRSpeed>
      <SpeedControl>SpeedControl</SpeedControl>
      <SpeedRange>SpeedRange</SpeedRange>
      <SpeedTarget>SpeedTarget</SpeedTarget>
      <ThrottleClosedVoltageMessage>ReadThrottleAtoD</ThrottleClosedVoltageMessage>
      <ThrottleClosedVoltageMessage5.7L>ReadThrottleAtoD5.7</ThrottleClosedVoltageMessage5.7L>
    </DataTags>
    <Parameters>
      <CheckForClosedThrottle>0</CheckForClosedThrottle>
      <CheckSpeedAgainstLimit>1</CheckSpeedAgainstLimit>
      <ClosedThrottleVoltage>0.95</ClosedThrottleVoltage>
      <ClosedThrottleVoltage5.7L>0.99</ClosedThrottleVoltage5.7L>
      <ConfigFile>/Configuration/Components/Emissions/SampleEngineControlModule.xml</ConfigFile>
      <DelayModuleInitialization>Yes</DelayModuleInitialization>
      <DeltaSpeedCheckDelay>150</DeltaSpeedCheckDelay>
      <DeveloperTest>0</DeveloperTest>
      <ICMName>mgr/ICM</ICMName>
      <KeepTestStatusOnExit>1</KeepTestStatusOnExit>
      <MinimumSpeedOverLimit>2.0</MinimumSpeedOverLimit>
      <NoModuleComms>0</NoModuleComms>
      <ReadSpeedLimitFromModule>1</ReadSpeedLimitFromModule>
      <SecurityUnlockAttempts>2</SecurityUnlockAttempts>
      <SkipOnTestResult>0</SkipOnTestResult>
      <SpeedControlBrakeMask>0200</SpeedControlBrakeMask>
      <SpeedControlCancelMask>0020</SpeedControlCancelMask>
      <SpeedControlClutchMask>2000</SpeedControlClutchMask>
      <SpeedControlDeltaSpeed>3.0</SpeedControlDeltaSpeed>
      <SpeedControlMaxSpeed>70</SpeedControlMaxSpeed>
      <SpeedControlMinSpeed>50</SpeedControlMinSpeed>
      <SpeedControlModeCheckDelay>200</SpeedControlModeCheckDelay>
      <SpeedControlOffMask>0000</SpeedControlOffMask>
      <SpeedControlOnMask>0200</SpeedControlOnMask>
      <SpeedControlResumeMask>0600</SpeedControlResumeMask>
      <SpeedControlSetMask>0600</SpeedControlSetMask>
      <SpeedControlStatusByte>0x9E01</SpeedControlStatusByte>
      <SpeedControlTestResultBit>4</SpeedControlTestResultBit>
      <SpeedIncreaseSamples>5</SpeedIncreaseSamples>
      <SpeedLimiterEngageDelay>500</SpeedLimiterEngageDelay>
      <SpeedLimiterRange>50 60</SpeedLimiterRange>
      <SpeedLimiterSpeedLimit>50.0</SpeedLimiterSpeedLimit>
      <SpeedRangeCheckDelay>500</SpeedRangeCheckDelay>
      <StableSpeedMaxVariation>3.0</StableSpeedMaxVariation>
      <StableSpeedMinVariation>3.0</StableSpeedMinVariation>
      <StableSpeedPoints>5</StableSpeedPoints>
      <StableSpeedSampleDelay>500</StableSpeedSampleDelay>
      <StableSpeedVariation>2.0</StableSpeedVariation>
      <TapSpeedChangeMinSpeedChange>3.0</TapSpeedChangeMinSpeedChange>
      <UseModuleSpeed>0</UseModuleSpeed>
      <ValidSpeedControlTypes>
        <Type00>ETC</Type00>
      </ValidSpeedControlTypes>
    </Parameters>
    <Prompts>
      <AccelerateToTargetSpeed PromptBox="1" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
      <AccelToSpeedLimiter PromptBox="1" Priority="0">SpeedControlAccelToSpeedLimiter</AccelToSpeedLimiter>
      <CableConnect PromptBox="1" Priority="0">ConnectCable</CableConnect>
      <CancelPrompt PromptBox="1" Priority="0">SpeedControlCancel</CancelPrompt>
      <CheckStableSpeed PromptBox="1" Priority="0">CheckForStableSpeed</CheckStableSpeed>
      <DisengageSpeedLimiter PromptBox="1" Priority="0">SpeedControlDisengageSpeedLimiter</DisengageSpeedLimiter>
      <EngageSpeedLimiter PromptBox="1" Priority="0">SpeedControlEngageSpeedLimiter</EngageSpeedLimiter>
      <EngineRunning PromptBox="1" Priority="0">StartVehicle</EngineRunning>
      <IgnitionOn PromptBox="1" Priority="0">KeyOn</IgnitionOn>
      <MaintainSpeed PromptBox="1" PromptPriority="0">MaintainSpeed</MaintainSpeed>
      <PressClutchPrompt PromptBox="1" Priority="0">SpeedControlClutch</PressClutchPrompt>
      <PressFailPrompt PromptBox="2" Priority="0">SpeedControlPressFail</PressFailPrompt>
      <PressResumePrompt PromptBox="1" Priority="0">SpeedControlResume</PressResumePrompt>
      <PressTapDownButton PromptBox="1" Priority="0">SpeedControlTapDown</PressTapDownButton>
      <PressTapUpButton PromptBox="1" Priority="0">SpeedControlTapUp</PressTapUpButton>
      <RemoveFootPrompt PromptBox="2" Priority="0">RemoveFootFromAccelerator</RemoveFootPrompt>
      <SetPrompt PromptBox="1" Priority="0">SpeedControlSet</SetPrompt>
      <SpeedControlOff PromptBox="2" Priority="0">SpeedControlOff</SpeedControlOff>
      <SpeedControlOn PromptBox="2" Priority="0">SpeedControlOn</SpeedControlOn>
      <TapBrakePrompt PromptBox="1" Priority="0">SpeedControlTapBrakes</TapBrakePrompt>
      <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
    </Prompts>
    <FaultList>/Configuration/Components/Common/SampleFaultList.xml</FaultList>
    <TestDomain>Foreground</TestDomain>
  </Setup>
  <Objectives>
    <CheckOnEnable>
      <TestStep00>CheckOnEnable</TestStep00>
    </CheckOnEnable>
    <CheckOffDisable>
      <TestStep00>CheckOffDisable</TestStep00>
    </CheckOffDisable>
    <CheckBrakeCutOut>
      <TestStep00>CheckBrakeCutOut</TestStep00>
    </CheckBrakeCutOut>
    <CheckCancelCutOut>
      <TestStep00>CheckCancelCutOut</TestStep00>
    </CheckCancelCutOut>
    <CheckClutchCutOut>
      <TestStep00>CheckClutchCutOut</TestStep00>
    </CheckClutchCutOut>
    <CheckResumeEngagement>
      <TestStep00>CheckResumeEngagement</TestStep00>
    </CheckResumeEngagement>
    <CheckSetEngagement>
      <TestStep00>CheckSetEngagement</TestStep00>
    </CheckSetEngagement>
    <CheckTapUpAccel>
      <TestStep00>CheckTapUpAccel</TestStep00>
    </CheckTapUpAccel>
    <CheckTapDownDecel>
      <TestStep00>CheckTapDownDecel</TestStep00>
    </CheckTapDownDecel>
    <CheckSpeedLimiter>
      <TestStep00>CheckSpeedLimiter</TestStep00>
    </CheckSpeedLimiter>
    <DeterminePreviousPass>
      <TestStep00>DeterminePreviousPass</TestStep00>
    </DeterminePreviousPass>
    <UpdateModuleResult>
      <TestStep00>UpdateModuleResult</TestStep00>
    </UpdateModuleResult>
    <Setup>
      <TestStep00>Setup</TestStep00>
    </Setup>
    <FinishUp>
      <TestStep00>FinishUp</TestStep00>
    </FinishUp>
    <EnterDiagnosticMode>
      <TestStep00>EnterDiagnosticMode</TestStep00>
    </EnterDiagnosticMode>
    <StartModuleKeepAlive>
      <TestStep00>StartModuleKeepAlive</TestStep00>
    </StartModuleKeepAlive>
    <StopModuleKeepAlive>
      <TestStep00>StopModuleKeepAlive</TestStep00>
    </StopModuleKeepAlive>
  </Objectives>
  <TestSteps>
    <CheckOnEnable Result="" Timeout="15000" Description="Verify the On switch and functionality"/>
    <CheckOffDisable Result="" Timeout="15000" Description="Verify the Off switch and functionality"/>
    <CheckBrakeCutOut Result="" Timeout="10000" Description="Verify cruise cuts out when the brake pedal is tapped"/>
    <CheckCancelCutOut Result="" Timeout="10000" Description="Verify the cruise cuts out when the Cancel switch is pressed"/>
    <CheckClutchCutOut Result="" Timeout="10000" Description="Verify the cruise cuts out when the clutch pedal is tapped"/>
    <CheckResumeEngagement Result="" Timeout="25000" Description="Verify the Resume button and functionality" ScanDelay="100"/>
    <CheckSetEngagement Result="" Timeout="60000" Description="Verify the Set button and functionality" ScanDelay="150"/>
    <CheckTapUpAccel Result="" Timeout="60000" Description="Verify the vehicle accelerates when the up button is pressed" ScanDelay="250"/>
    <CheckTapDownDecel Result="" Timeout="60000" Description="Verify the vehicle decelerates when the down button is pressed" ScanDelay="250"/>
    <CheckSpeedLimiter Result="" Timeout="60000" Description="Check the speed limiter" ScanDelay="250"/>
    <DeterminePreviousPass Result="" Timeout="1000" Description="Determine if emissions testing has previously passed"/>
    <UpdateModuleResult Result="" Timeout="1000" Description="Update Speed Control test status in the module"/>
    <Setup Result="" Timeout="10000" Description="Set up component for testing"/>
    <FinishUp Result="" Timeout="3000" Description="Finish testing and update results in the module"/>
    <EnterDiagnosticMode Result="" Timeout="10000" Description="Enter diagnostic mode"/>
    <StartModuleKeepAlive Result="" Timeout="1000" Description="Start sending tester present message to the module" ScanDelay="250"/>
    <StopModuleKeepAlive Result="" Timeout="1000" Description="Stop sending tester present message to the module" ScanDelay="250"/>
  </TestSteps>
</SampleSpeedControlConfig>
