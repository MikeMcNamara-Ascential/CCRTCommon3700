            <TestStep02>Initialize</TestStep02>
            <TestStep03>InitWinCcrtInterface</TestStep03>
            <TestStep05>EnterDiagnosticMode</TestStep05>
            <TestStep06>RequestCoding</TestStep06>
            <TestStep07>SendCoding</TestStep07>
            <TestStep08>StartEolSession</TestStep08>
            <!-- TestStep09>ReadEcuId</TestStep09 -->
            <TestStep15>ReadFaults</TestStep15>
            <TestStep20>ClearFaults</TestStep20>
            <TestStep25>StartModuleKeepAlive</TestStep25>
        </Setup>
        <BrakeTest>
            <TestStep00>DisplaySpeedTimeGraph</TestStep00>
            <TestStep01>AccelerateToBrakeSpeed</TestStep01>
            <TestStep04>RemoveSpeedTimeGraph</TestStep04>
            <TestStep10>DragTest</TestStep10>
            <TestStep15>AnalyzeDragTest</TestStep15>
            <TestStep20>BrakeSwitchOffTest</TestStep20>
            <TestStep25>RunPumpMotor</TestStep25>
            <TestStep30>BrakeTest</TestStep30>
            <TestStep35>StopModuleKeepAlive</TestStep35>
            <TestStep40>BrakeSwitchOnTest</TestStep40>
            <TestStep45>ValveFiringTest</TestStep45>
            <TestStep60>StartModuleKeepAlive</TestStep60>
        </BrakeTest>     
        <AnalyzeBrakeTest>
            <TestStep00>AnalyzeBrakeTest</TestStep00>
            <TestStep05>AnalyzeBalance</TestStep05>
            <TestStep10>EvaluateABS</TestStep10>
        </AnalyzeBrakeTest>
        <FinishUp>
            <!-- TestStep00>DisableForceMeter</TestStep00 -->
            <!-- TestStep05>StopModuleKeepAlive</TestStep05 -->
            <TestStep10>ReadFaults</TestStep10>
            <!-- TestStep15>ExitDiagnosticMode</TestStep15 -->
            <TestStep16>CloseWinCcrtInterface</TestStep16>
            <!-- TestStep20>FinishUp</TestStep20 -->
        </FinishUp>

        <LowSpeedTesting>
            <TestStep00>BrakeToStop</TestStep00>
            <TestStep10>LowSpeedSensorTest</TestStep10>
            <TestStep15>BrakeToStop</TestStep15>
        </LowSpeedTesting>
        <ParkBrakeTest>
            <TestStep00>AccelerateToParkBrakeSpeed</TestStep00>
            <TestStep05>DynamicParkBrakeTest</TestStep05>
            <TestStep10>AnalyzeDynamicParkBrake</TestStep10>
            <TestStep15>BrakeToStop</TestStep15>
        </ParkBrakeTest>
    </Objectives>

    <TestSteps>
        <IsCableConnected  Result="Not Tested" Timeout="300000" Description="Accelerate to the brake test speed"/>
        <AccelerateToBrakeSpeed Result="Not Tested" Timeout="300000" Description="Accelerate to the brake test speed"
            SpeedTarget="60 70" ArmSpeed="60" Prompt1="AccelerateToTargetSpeed"/>
        <AccelerateToParkBrakeSpeed Result="" Timeout="90000" Description="Accelerate to Dynamic Park Brake Speed" 
            Prompt1="AccelerateToTargetSpeed" SpeedTarget="18 25" SpeedDomain="0 100" SpeedActive="1" SpeedInactive="0"/>
        <AnalyzeBalance Result="Not Tested" Timeout="100" Description="Analyze brake force balance"
            FrontSideToSideBalance="10" RearSideToSideBalance="10" BalanceFrontToRearMin="50" BalanceFrontToRearMax="90"/>
        <AnalyzeBrakeTest Result="" Timeout="20000" Description="Base Brake Component Brake Test Analysis" 
            FrontMinBrakeForce="224.8089" FrontMaxBrakeForce="675" RearMinBrakeForce="56.20224" RearMaxBrakeForce="340" 
            Prompt1="" Prompt2=""/>
        <AnalyzeDragTest Result="Not Tested" Timeout="500" Description="Analyze drag force data"
            FrontMaxDragForce="56" RearMaxDragForce="45"/>
        <AnalyzeDynamicParkBrake Result="" Timeout="10000" Description="Analyze Dynamic Park Brake forces"/>
        <BrakeSwitchOffTest Result="Not Tested" Timeout="3000" Description="Verify the brake switch is in the off position"
            ScanDelay="100"/>
        <BrakeSwitchOnTest Result="Not Tested" Timeout="3000" Description="Verify the brake switch is in the on position"
            ScanDelay="100"/>
        <BrakeTest Result="Not Tested" Timeout="10000" Description="Perform the base brake test"
            Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeModeratelyInGreenBand"
            StartBrakeSampleSpeed="55" EndBrakeSampleSpeed="45" BrakeDomain="0 500" BrakeTarget="300 500"/>
        <BrakeToStop Result="Not Tested" Timeout="120000" Description="Bring the vehicle to zero speed"
            Prompt1="BrakeToStop"/>
        <ClearFaults Result="Not Tested" Timeout="100" Description="Clear faults from the module"/>
        <CloseWinCcrtInterface Result="Not Tested" Timeout="500" Description="Have WinCcrt initiate a closing with its connected device"/>
        <DisableForceMeter Result="" Timeout="30000" Description="Disable The Brake Force Meter"/>
        <DragTest Result="Not Tested" Timeout="30000" Description="Measure vehicle drag forces"
            Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="RemoveFootFromAccelerator"
            DragSpeed="58" DragDelay="1000" DragSamples="50"/>
        <DumpAndIsolateAllWheels Result="Not Tested" Timeout="1000" Description="Dump pressure at all wheels"/>
        <DynamicParkBrakeTest Result="" Timeout="90000" Description="Dynamic Park Brake Test" 
            RollerDirection="Forward" Prompt1="ShiftToNeutral" Prompt2="ApplyParkBrake"/>
        <EnterDiagnosticMode Result="Not Tested" Timeout="500" Description="Place the module into diagnostic mode"/>
        <ExitDiagnosticMode Result="Not Tested" Timeout="500" Description="Exit the current diagnostic session"/>
        <EvaluateABS Result="Not Tested" Timeout="100" Description="Analyze the ABS valve firing data"/>
        <FinishUp Result="" Timeout="100" Description="Set overall ABS test result"/>
        <Initialize Result="" Timeout="10000" Description="Initialize for the BaseBrake test." 
            Prompt1="Initialize" ZerospeedPrompt="BrakeToStop"/>
        <LowSpeedSensorTest Result="Not Tested" Timeout="100" Description="Validate wheel speed sensors"/>
        <ReadEcuId Result="Not Tested" Timeout="500" Description="Read the ECUs ID"/>
        <ReadFaults Result="Not Tested" Timeout="500" Description="Read all faults from the ABS module"/>
        <RequestCoding Result="Not Tested" Timeout="500" Description="Request Coding 2 from module" ScanDelay="250"/>
        <RunPumpMotor Result="Not Tested" Timeout="500" Description="Run the ABS pump motor"/>
        <Setup Result="" Timeout="500" Description="Set up component for testing"/>
        <SendCoding Result="Not Tested" Timeout="500" Description="Send Coding 2 from module" ScanDelay="250"/>
        <StartModuleKeepAlive Result="Not Tested" Timeout="500" Description="Start sending keep alive messages"/>
        <StartEolSession Result="Not Tested" Timeout="500" Description="Command module to begin EOL session" ScanDelay="250"/>
        <StopModuleKeepAlive Result="Not Tested" Timeout="500" Description="Stop sending keep alive messages"/>
        <InitWinCcrtInterface Result="Not Tested" Timeout="1000" Description="Initialize interface with WinCcrt system"/>
        <ValveFiringTest Result="Not Tested" Timeout="10000" Description="Fire each ABS valve"
            Prompt1="MaintainBrake"/>
		<DisplaySpeedTimeGraph Result="" Timeout="5000" Description="Display Speed Time Graph" ScanDelay="250"/>
        <RemoveSpeedTimeGraph Result="" Timeout="5000" Description="Remove Speed Time Graph" ScanDelay="250"/>
    </TestSteps>

