<Window x:Class="RomessSteeringwheelInclinometerInterface.CommunicationSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Communication Settings" Height="300" Width="300">
    <Grid>
        <ComboBox Name="CommSelectBox"  HorizontalAlignment="Left" Margin="19,36,0,0" VerticalAlignment="Top" Width="120" SelectedIndex="0" SelectedValuePath="Content">
            <ComboBoxItem Name="USB">USB</ComboBoxItem>
            <ComboBoxItem Name="Bluetooth">Bluetooth</ComboBoxItem>
        </ComboBox>
        <Label Content="Communication Protocol" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0"/>
        <Button x:Name="CommSettingsSaveButton" Content="Save" HorizontalAlignment="Left" Margin="19,239,0,0" VerticalAlignment="Top" Width="75" RenderTransformOrigin="-0.173,1.95"/>
        <Button x:Name="CommSettingsCancelButton" Content="Cancel" HorizontalAlignment="Left" VerticalAlignment="Top" Width="75" Margin="195,239,0,0" Click="CommSettingsCancelButton_Click"/>

    </Grid>
</Window>
