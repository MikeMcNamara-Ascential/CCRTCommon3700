<BoschDCU>
    <Setup>
        <!-- Communication Settings -->
        <CheckSumLength>1</CheckSumLength>
        <CommunicationBus>CAN</CommunicationBus>
        <CommunicationProtocol>KeywordProtocol2000</CommunicationProtocol>
        <DataByteCountIndex>3</DataByteCountIndex>
        <DataHeaderLength>2</DataHeaderLength>
        <DataStartIndex>6</DataStartIndex>
        <ModuleRequestID>0x024B</ModuleRequestID>
        <ModuleResponseDelay>500</ModuleResponseDelay>
        <ModuleResponseEndDelay>0</ModuleResponseEndDelay>
        <NegativeResponseCodeIndex>2</NegativeResponseCodeIndex>
        <NegativeResponseValue>0x7F</NegativeResponseValue>
        <NumberOfRetries>3</NumberOfRetries>
        <ResponsePendingReads>3</ResponsePendingReads>
        <SentMessageIdentifierIndex>0</SentMessageIdentifierIndex>
        <ValidResponseOffset>0x40</ValidResponseOffset>
        <!-- Tester Present Settings -->
        <KeepAliveResponseRequired>Yes</KeepAliveResponseRequired>
        <ModuleKeepAliveTime>500</ModuleKeepAliveTime>
        <!-- Module Behavior Settings -->
        <AutomaticallyEnterDiagnosticMode>Yes</AutomaticallyEnterDiagnosticMode>
        <EnterDiagnosticModeMessageTag>EnterDiagnosticMode</EnterDiagnosticModeMessageTag>
        <DtcData>
            <DtcCountIndex>1</DtcCountIndex>
            <BytesPerDtc>4</BytesPerDtc>
            <DtcStartByte>1</DtcStartByte>
        </DtcData>
        <NegativeResponseCodes>
            <Code_0x11>Service Not Supported</Code_0x11>
            <Code_0x12>SubFunction Not Supported / Invalid Format</Code_0x12>
            <Code_0x22>Conditions Not Correct or Request Sequence Error</Code_0x22>
            <Code_0x31>Request Out Of Range</Code_0x31>
            <Code_0x33>Security Access Denied / Security Access Requested</Code_0x33>
            <Code_0x35>Invalid Key</Code_0x35>
            <Code_0x36>Exceed Number Of Attempts</Code_0x36>
            <Code_0x37>Required Time Delay Not Expired</Code_0x37>
            <Code_0x78>Request Correctly Received / Response Pending</Code_0x78>
            <Code_0x7F>Service Not Supported in Active Diagnostic Session</Code_0x7F>
            <Code_0x85>General Programming Failure</Code_0x85>
            <Code_0xE3>Device Control Limits Exceeded</Code_0xE3>
            <EnterDiagnosticMode>0x10</EnterDiagnosticMode>
            <ResponsePending>0x78</ResponsePending>
            <ModuleBusy>0x21</ModuleBusy>
        </NegativeResponseCodes>
        <Communication>
            <Debug>On</Debug>
            <Name>/home/CCRT/Rewrite/GryphonCCan</Name>
            <BufferSize>4096</BufferSize>
            <CommSize>1</CommSize>
            <Timeout>10000000</Timeout>
            <Retries>3</Retries>
        </Communication>
        <Logging>
            <Status>Disabled</Status>
            <ProcessName>BoschDCU</ProcessName>
            <AdditionalLogFile>/Communication/BoschDCU.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
    </Setup>
    <SerialMessages>
        <!-- ============ Message Table ============ -->
        <VehicleMessages>
            <EnterDiagnosticMode>
                <TransmitMessage>InitiateDiagnosticOperation</TransmitMessage>
                <TransmitInterpretation>DiagnosticLevel_3</TransmitInterpretation>
                <ReplyMessage>InitiateDiagnosticOperationResponse</ReplyMessage>
                <ReplyInterpretation/>
            </EnterDiagnosticMode>

            <EnterNormalMode>
                <TransmitMessage>EnterNormalMode</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>EnterNormalMode</ReplyMessage>
                <ReplyInterpretation/>
             </EnterNormalMode>

            <DisableNormalComms>
                <TransmitMessage>DisableNormalComms</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>DisableNormalComms</ReplyMessage>
                <ReplyInterpretation/>
             </DisableNormalComms>

            <ExitDiagnosticMode>
                <TransmitMessage>EnterNormalMode</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>EnterNormalMode</ReplyMessage>
                <ReplyInterpretation/>
            </ExitDiagnosticMode>

            <LockModule>
                <TransmitMessage>WriteDid</TransmitMessage>
                <TransmitInterpretation>MecClear</TransmitInterpretation>
                <ReplyMessage>WriteDid</ReplyMessage>
                <ReplyInterpretation/>
            </LockModule>

            <ReadSecuritySeed>
                <TransmitMessage>ReadSecuritySeed</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ReadSecuritySeed</ReplyMessage>
                <ReplyInterpretation>SecuritySeed</ReplyInterpretation>
            </ReadSecuritySeed> 

            <UnlockSecurity>
                <TransmitMessage>UnlockModule</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>UnlockModule</ReplyMessage>
                <ReplyInterpretation/>
            </UnlockSecurity>

            <ModuleKeepAlive>
                <TransmitMessage>TesterPresent</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>TesterPresentResponse</ReplyMessage>
                <ReplyInterpretation/>
            </ModuleKeepAlive>

            <ReadFaults>
                <TransmitMessage>ReadFaults</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ReadFaults</ReplyMessage>
                <ReplyInterpretation/>
            </ReadFaults>

            <ReadPartNumber>
                <TransmitMessage>ReadDid</TransmitMessage>
                <TransmitInterpretation>PartNumber</TransmitInterpretation>
                <ReplyMessage>ReadDidResponse</ReplyMessage>
                <ReplyInterpretation>EndModelPartNumber</ReplyInterpretation>
            </ReadPartNumber>

            <ReadOxygenSensor1Bank1Sensor>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>OxygenSensor1Bank1</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>OxygenSensor</ReplyInterpretation>
            </ReadOxygenSensor1Bank1Sensor>

            <ReadOxygenSensor1Bank2Sensor>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>OxygenSensor1Bank2</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>OxygenSensor</ReplyInterpretation>
            </ReadOxygenSensor1Bank2Sensor>

            <ReadOxygenSensor2Bank1Sensor>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>OxygenSensor2Bank1</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>OxygenSensor</ReplyInterpretation>
            </ReadOxygenSensor2Bank1Sensor>                                                        

            <ReadOxygenSensor2Bank2Sensor>
                <TransmitMessage>ReadPid</TransmitMessage>
                <TransmitInterpretation>OxygenSensor2Bank2</TransmitInterpretation>
                <ReplyMessage>ReadPidResponse</ReplyMessage>
                <ReplyInterpretation>OxygenSensor</ReplyInterpretation>
            </ReadOxygenSensor2Bank2Sensor>

            <ReadVIN>
                <TransmitMessage>ReadDid</TransmitMessage>
                <TransmitInterpretation>Vin</TransmitInterpretation>
                <ReplyMessage>ReadDidResponse</ReplyMessage>
                <ReplyInterpretation>Vin</ReplyInterpretation>
            </ReadVIN>

            <ClearFaults>
                <TransmitMessage>ClearFaults</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ClearFaults</ReplyMessage>
                <ReplyInterpretation>FaultsCleared</ReplyInterpretation>
            </ClearFaults>

            <IsModuleLocked>
                <TransmitMessage>ReadDid</TransmitMessage>
                <TransmitInterpretation>MecValue</TransmitInterpretation>
                <ReplyMessage>ReadDidResponse</ReplyMessage>
                <ReplyInterpretation>IsModuleLocked</ReplyInterpretation>
            </IsModuleLocked>

            <ReadSerialNumber>
                <TransmitMessage>ReadDid</TransmitMessage>
                <TransmitInterpretation>SerialNumber</TransmitInterpretation>
                <ReplyMessage>ReadDidResponse</ReplyMessage>
                <ReplyInterpretation>SerialNumber</ReplyInterpretation>
            </ReadSerialNumber>
        </VehicleMessages>
        <!-- ============ Message Formats ============ -->
        <TransmitMessages>
            <InitiateDiagnosticOperation>0x10,0x??</InitiateDiagnosticOperation>
            <EnterNormalMode>0x20,</EnterNormalMode>
            <DisableNormalComms>0x28,</DisableNormalComms>
            <ReadDid>0x1A,0x??</ReadDid>
            <ReadEngineDid>0x09,0x??</ReadEngineDid>
            <ReadPid>0x22,0x??,0x??</ReadPid>
            <ReadDPid>0xAA,0x??,0x??</ReadDPid>
            <ReadSecuritySeed>0x27,0x01</ReadSecuritySeed>
            <UnlockModuleSecurity>0x27,0x02,0x??,0x??</UnlockModuleSecurity>
            <ReadMemoryLocation>0x23,0x??,0x??,0x??,0x??,0x??,0x??</ReadMemoryLocation>
            <RunCpid>0xAE,0x??,0x??,0x??</RunCpid>
            <TesterPresent>0x3E</TesterPresent>
            <WriteDid>0x3B,0x??,0x??</WriteDid>
            <ClearFaults>0x04</ClearFaults>
            <ReadFaults>0xA9,0x81,0x32</ReadFaults>
        </TransmitMessages>
        <!-- ============ Message PIDs/LIDs ============ -->
        <TransmitInterpretations>
            <DiagnosticLevel_3>0x03</DiagnosticLevel_3>
            <MecClear>0xA0,0x00</MecClear>
            <MecValue>0xA0</MecValue>
            <OxygenSensor1Bank1>0x17,0x5C</OxygenSensor1Bank1>
            <OxygenSensor1Bank2>0x17,0x64</OxygenSensor1Bank2>
            <OxygenSensor2Bank1>0x17,0x68</OxygenSensor2Bank1>
            <OxygenSensor2Bank2>0x17,0x70</OxygenSensor2Bank2>
            <PartNumber>0xCB</PartNumber>
            <Vin>0x90</Vin>
            <SerialNumber>0x98</SerialNumber>
        </TransmitInterpretations>
        <!-- ============ Message Responses ============ -->
        <ReplyMessages>
            <InitiateDiagnosticOperationResponse>
                <Reply_0>0x50</Reply_0>
                <Reply_1>0x7F,0x10,0x??</Reply_1>
            </InitiateDiagnosticOperationResponse>

            <EnterNormalMode>
                <Reply_0>0x60</Reply_0>
                <Reply_1>0x7F,0x20,0x??</Reply_1>
            </EnterNormalMode>

            <DisableNormalComms>
                <Reply_0>0x68</Reply_0>
                <Reply_1>0x7F,0x28,0x??</Reply_1>
            </DisableNormalComms>

            <ReadDidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x5A,0x??</Reply_0>
                <Reply_1>0x7F,0x1A,0x??</Reply_1>
            </ReadDidResponse>

            <ReadEngineDidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x49,0x??</Reply_0>
                <Reply_1>0x7F,0x09,0x??</Reply_1>
            </ReadEngineDidResponse>

            <ReadPidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x62,0x??</Reply_0>
                <Reply_1>0x7F,0x22,0x??</Reply_1>
            </ReadPidResponse>

            <ReadDPidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x??,0x??</Reply_0>
                <Reply_1>0x7F,0xAA,0x??</Reply_1>
            </ReadDPidResponse>

            <ReadSecuritySeed>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x67,0x01,0x??,0x??</Reply_0>
                <Reply_1>0x7F,0x27,0x??</Reply_1>
            </ReadSecuritySeed>

            <UnlockModuleSecurity>
                <Reply_00>0x67,0x02,0x34</Reply_00>
                <Reply_01>0x7F,0x27,0x??</Reply_01>
            </UnlockModuleSecurity>

            <ReadMemoryLocation>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x63,0x??,0x??,0x??,0x??,0x??,0x??</Reply_0>
                <Reply_1>0x7F,0x23,0x??</Reply_1>
            </ReadMemoryLocation>

            <RunCpidResponse>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0xEE,0x??,0x??</Reply_0>
                <Reply_1>0x7F,0xAE,0x??</Reply_1>
            </RunCpidResponse>

            <TesterPresentResponse>
                <Reply_0>0x7E</Reply_0>
                <Reply_1>0x7F,0x3E,0x??</Reply_1>
            </TesterPresentResponse>

            <WriteDid>
                <Reply_0 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x7B,0x??</Reply_0>
                <Reply_1>0x7F,0x3B,0x??</Reply_1>
            </WriteDid>

            <ClearFaults>
                <Reply_01>0x44</Reply_01>
                <Reply_02>0x7F,0x04,0x??</Reply_02>
            </ClearFaults>

            <ReadFaults>
                <Reply_01 lengthType="Variable" ReplyTimeout="10000" endGapTime="2000">0x81,0x??</Reply_01>
                <Reply_02>0x7F,0xA9,0x??</Reply_02>
            </ReadFaults>
        </ReplyMessages>
        <!-- ============ Data Translations ============ -->
        <ReplyInterpretations>
            <SecuritySeed>
                <Integer type="unsigned" bits="32" scale="1" offset="0">
                    <Byte1 input_index="2" mask="0xFF" output_index="3"/>
                    <Byte2 input_index="3" mask="0xFF" output_index="2"/>
                    <Byte3 input_index="4" mask="0xFF" output_index="1"/>
                    <Byte4 input_index="5" mask="0xFF" output_index="0"/>
                </Integer>
            </SecuritySeed>

            <OxygenSensor>
                <Float scale="0.00434" offset="0">
                    <Integer type="unsigned" scale="1" offset="0">
                        <Byte0 input_index="3" mask="0xFF" output_index="0"/>
                    </Integer>
                </Float>
            </OxygenSensor>

            <EndModelPartNumber>
                <String>
                    <Substring format="%08d">
                        <Integer type="unsigned" scale="1" offset="0">
                            <Byte1 input_index="2" mask="0xFF" output_index="3"/>
                            <Byte2 input_index="3" mask="0xFF" output_index="2"/>
                            <Byte3 input_index="4" mask="0xFF" output_index="1"/>
                            <Byte4 input_index="5" mask="0xFF" output_index="0"/>
                        </Integer>
                    </Substring>
                </String>
            </EndModelPartNumber>

            <Vin>
                <String>
                    <Substring format="%17s">
                        <chars input_index="2" mask="0xFF" length="17"/>
                    </Substring>
                </String>
            </Vin>

            <FaultsCleared>
                <Boolean>
                    <Byte01 input_index="0" mask="0xFF" compare="0x44"/>
                </Boolean>
            </FaultsCleared>

            <IsModuleLocked>
                <Boolean>
                    <Byte01 input_index="2" mask="0xFF" compare="0x00"/>
                </Boolean>
            </IsModuleLocked>

            <SerialNumber>
                <String>
                    <Substring00>
                        <chars input_index="2" mask="0xFF" length="1">
                            <StringSubstitute00 condition="equals" compare="0x00" replace=""/>
                            <StringSubstitute01 condition="not equal" compare="0x00" replace="?"/>
                        </chars>
                    </Substring00>
                    <Substring01 format="%16s">
                        <chars input_index="3" mask="0xFF" length="16"/>
                    </Substring01>
                </String>
            </SerialNumber>
        </ReplyInterpretations>
    </SerialMessages>
</BoschDCU>
