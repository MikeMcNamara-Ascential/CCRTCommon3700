<BaseBrake>
    <Setup>
        <Name>Brake</Name>
        <Debug>Off</Debug>
        <DebugLevel>0</DebugLevel>
        <ProcessPriority>11</ProcessPriority>
        <Communication>
            <Comm>IPC</Comm>
            <Type>Server</Type>
            <Name>component/BaseBrake</Name>
            <Debug>Off</Debug>
            <BufferSize>1024</BufferSize>
            <Timeout>0</Timeout>
        </Communication>
        <ThreadPool>
            <Debug>Off</Debug>
            <MinBlockedLimit>2</MinBlockedLimit>
            <MaxBlockedLimit>4</MaxBlockedLimit>
            <Increment>2</Increment>
            <Maximum>50</Maximum>
        </ThreadPool>
        <NotificationList>
            <Setup>
                <Debug>Off</Debug>
                <StartOnCreate>Off</StartOnCreate>
                <LowWater>1</LowWater>
                <HighWater>3</HighWater>
                <Maximum>5</Maximum>
                <Increment>1</Increment>
            </Setup>
        </NotificationList>
        <Logging>
            <Debug>Off</Debug>
            <MessageTimeout>100</MessageTimeout>
            <AdditionalLogMaxSize>10</AdditionalLogMaxSize>
            <AdditionalLogMaxFiles>5</AdditionalLogMaxFiles>
            <Status>Enable</Status>
            <ProcessName>BaseBrake</ProcessName>
            <AdditionalLogFile>/Components/BaseBrake</AdditionalLogFile>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
        <TagList>
            <!-- There are no publish tags for the base brake test component -->
            <PublishTags/>
            <SubscribeTags>
                <Abort/>
                <BrakePedalForce/>
                <Clutch/>
                <Declutch/>
                <DriveAxle/>
                <ForegroundTestInProgress/>
                <MachineType/>
                <MotorMode/>
                <RollsUpElevDown/>
                <VehiclePresent/>
                <ZerospeedToPLC/>
            </SubscribeTags>
        </TagList>
        <DataTags>
            <Abort>Abort</Abort>
            <Boost>Boost</Boost>
            <BoostMode>Boost</BoostMode>
            <BrakeActive>BrakeActive</BrakeActive>
            <BrakeDomain>BrakeDomain</BrakeDomain>
            <BrakeTarget>BrakeTarget</BrakeTarget>
            <Clutch>Clutch</Clutch>
            <CommandTorque>CommandTorque</CommandTorque>
            <Declutch>Declutch</Declutch>
            <DriveAxle>DriveAxle</DriveAxle>
            <ForegroundTestInProgress>ForegroundTestInProgress</ForegroundTestInProgress>
            <FourWheelDriveEquipped>FourWDSelected</FourWheelDriveEquipped>
            <FrontBalanceBGColor>FrontBalanceBGColor</FrontBalanceBGColor>
            <FrontBalanceTest>FrontBalanceTest</FrontBalanceTest>
            <FrontBalanceValue>FrontBalanceValue</FrontBalanceValue>
            <LeftFrontDragBGColor>LFDragBGColor</LeftFrontDragBGColor>
            <LeftFrontDragValue>LFDragValue</LeftFrontDragValue>
            <LeftFrontForce>LFForce</LeftFrontForce>
            <LeftFrontForceBGColor>LFForceBGColor</LeftFrontForceBGColor>
            <LeftFrontForceValue>LFForceValue</LeftFrontForceValue>
            <LeftFrontSpeed>LFSpeed</LeftFrontSpeed>
            <LFSpeed>LFSpeed</LFSpeed>
            <LossCompensationMode>LossCompensationMode</LossCompensationMode>
            <MachineType>MachineType</MachineType>
            <MachineType3600>3600</MachineType3600>
            <MotorMode>MotorMode</MotorMode>
            <NeutralLamp>NeutralLamp</NeutralLamp>
            <Rear>Rear</Rear>
            <RetainersUp>RollsUpElevDown</RetainersUp>
            <RightFrontDragBGColor>RFDragBGColor</RightFrontDragBGColor>
            <RightFrontDragValue>RFDragValue</RightFrontDragValue>
            <RightFrontForce>RFForce</RightFrontForce>
            <RightFrontForceBGColor>RFForceBGColor</RightFrontForceBGColor>
            <RightFrontForceValue>RFForceValue</RightFrontForceValue>
            <RightFrontSpeed>RFSpeed</RightFrontSpeed>
            <SpeedTarget>SpeedTarget</SpeedTarget>
            <TagIndex>TagIndex</TagIndex>
            <TestResultBox1>TestResultBox1BGColor</TestResultBox1>
            <TestResultBox2>TestResultBox2BGColor</TestResultBox2>
            <TestResultBox3>TestResultBox3BGColor</TestResultBox3>
            <TorqueMode>Torque</TorqueMode>
            <VehiclePresent>VehiclePresent</VehiclePresent>
            <Zerospeed>ZerospeedToPLC</Zerospeed>
        </DataTags>
        <Parameters>
            <ICMName>mgr/ICM</ICMName>
            <KeepTestStatusOnExit>True</KeepTestStatusOnExit>
            <DisplayBrakeMeterUntilZeroSpeed>1</DisplayBrakeMeterUntilZeroSpeed>
            <StartSamplingAtMinimumForce>1</StartSamplingAtMinimumForce>
            <MinimumStartForce>500.0</MinimumStartForce>
            <BaseBrakeSampleCount>0</BaseBrakeSampleCount>
            <ExcessiveBrakeForceLimit>800.0</ExcessiveBrakeForceLimit>
            <NumberOfSamplesAboveLimit>10</NumberOfSamplesAboveLimit>
            <IcmForceArray>/dev/ArrayForce</IcmForceArray>
            <FailForExcessiveBrakeForce>1</FailForExcessiveBrakeForce>
            <IgnoreMachineConditions>0</IgnoreMachineConditions>
            <IncludeDragInBrakeForce>1</IncludeDragInBrakeForce>
            <FrontToRearBalanceUseFront>1</FrontToRearBalanceUseFront>
            <CurrentForces>/dev/Icm/Block/Force</CurrentForces>
            <TargetSpeedParameter>30</TargetSpeedParameter>
            <SpeedRangeParameter>30 35</SpeedRangeParameter>
            <ScanDelayParameter>500</ScanDelayParameter>
            <MaintainSpeedTime>1000</MaintainSpeedTime>
            <MaintainSpeedMinSpeed>25</MaintainSpeedMinSpeed>
            <MaintainSpeedMaxSpeed>35</MaintainSpeedMaxSpeed>
            <PreForcedAccelerateWait>3000</PreForcedAccelerateWait>
            <ForcedAccelerateSpeedStep>10</ForcedAccelerateSpeedStep>
            <ForcedAccelerateSpeedStepDelay>500</ForcedAccelerateSpeedStepDelay>
            <CurrentSpeeds>/dev/Icm/Block/Speed</CurrentSpeeds>
            <MotorLoadingAccelConst>0.0</MotorLoadingAccelConst>
            <MotorLoadingSpeedConst>50.0</MotorLoadingSpeedConst>
            <LogTaskStatInfo>Yes</LogTaskStatInfo>
            <StoreBrakePedalForce>1</StoreBrakePedalForce>
        </Parameters>
        <FaultList>/Configuration/Components/Common/SampleFaultList.xml</FaultList>
        <Prompts>
            <SlowDownToTargetSpeed PromptBox="1" Priority="0">SlowDownToTargetSpeed</SlowDownToTargetSpeed>
            <AccelerateToTargetSpeed PromptBox="1" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
            <NeutralPrompt PromptBox="1" Priority="0">ShiftToNeutral</NeutralPrompt>
            <RemoveFootFromBrake PromptBox="1" Priority="0">RemoveFootFromBrake</RemoveFootFromBrake>
            <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
            <EnterYesOrNo PromptBox="1" Priority="0">EnterYesOrNo</EnterYesOrNo>
            <PassOrFail PromptBox="1" Priority="0">OverallPassOrFail</PassOrFail>
            <MaintainSpeed PromptBox="1" Priority="0">MaintainSpeed</MaintainSpeed>
            <ShiftToReverse PromptBox="1" Priority="0">ApplyBrakeShiftToReverse</ShiftToReverse>
        </Prompts>
        <StatusCheckItems>
            <VehiclePresent>1</VehiclePresent>
            <RollsUpElevDown>1</RollsUpElevDown>
        </StatusCheckItems>
        <TestDomain>Foreground</TestDomain>
        <SystemTagsToReset>
            <BrakeActive>0</BrakeActive>
            <FrontBalanceBGColor>white</FrontBalanceBGColor>
            <FrontBalanceValue>0</FrontBalanceValue>
            <LFDragBGColor>white</LFDragBGColor>
            <LFDragValue>0</LFDragValue>
            <LFForceBGColor>white</LFForceBGColor>
            <LFForceDomain>0 500</LFForceDomain>
            <LFForceTarget>200 400</LFForceTarget>
            <LFForceValue>0</LFForceValue>
            <RFDragBGColor>white</RFDragBGColor>
            <RFDragValue>0</RFDragValue>
            <RFForceBGColor>white</RFForceBGColor>
            <RFForceDomain>0 500</RFForceDomain>
            <RFForceTarget>200 400</RFForceTarget>
            <RFForceValue>0</RFForceValue>
            <TestResultBox1BGColor>white</TestResultBox1BGColor>
            <TestResultBox2BGColor>white</TestResultBox2BGColor>
            <TestResultBox3BGColor>white</TestResultBox3BGColor>
        </SystemTagsToReset>
        <TaskMon>
            <Name>BaseBrakeTc</Name>
        </TaskMon>
    </Setup>
    <Objectives>
        <Initialize>
            <TestStep1>Initialize</TestStep1>
        </Initialize>
        <BrakeTest>
            <TestStep1>AccelerateToBrakeSpeed</TestStep1>
            <TestStep2>DragTest</TestStep2>
            <TestStep3>BrakeTest</TestStep3>
        </BrakeTest>
        <BrakeTestWithCoast>
            <TestStep1>AccelerateToBrakeSpeed</TestStep1>
            <TestStep2>Coast</TestStep2>
            <TestStep3>DragTest</TestStep3>
            <TestStep4>BrakeTest</TestStep4>
        </BrakeTestWithCoast>
        <AnalyzeBrakeTest>
            <TestStep1>AnalyzeDragTest</TestStep1>
            <TestStep2>AnalyzeBrakeTest</TestStep2>
            <TestStep3>AnalyzeBalance</TestStep3>
        </AnalyzeBrakeTest>
        <FinishUp>
            <TestStep0>DisableForceMeter</TestStep0>
            <TestStep1>FinishUp</TestStep1>
        </FinishUp>
        <CoastToStop>
            <TestStep1>CoastToStop</TestStep1>
        </CoastToStop>
        <BrakeToStop>
            <TestStep1>BrakeToStop</TestStep1>
        </BrakeToStop>
        <DisableForceMeter>
            <TestStep1>DisableForceMeter</TestStep1>
        </DisableForceMeter>
        <TireChunkingTest>
            <TestStep1>TireChunkingTest</TestStep1>
        </TireChunkingTest>
        <ExcessiveBrakeForceCheck>
            <TestStep1>ExcessiveBrakeForceCheck</TestStep1>
        </ExcessiveBrakeForceCheck>
        <AccelerateToTestSpeed>
            <TestStep1>AccelerateToTestSpeed</TestStep1>
        </AccelerateToTestSpeed>
        <EnableMotorLoading>
            <TestStep1>EnableMotorLoading</TestStep1>
        </EnableMotorLoading>
        <DisableMotorLoading>
            <TestStep1>DisableMotorLoading</TestStep1>
        </DisableMotorLoading>
        <MaintainSpeedForTime>
            <TestStep1>MaintainSpeedForTime</TestStep1>
        </MaintainSpeedForTime>
        <ReadMemoryStatistics>
            <TestStep1>ReadMemoryStatistics</TestStep1>
        </ReadMemoryStatistics>
    </Objectives>
    <TestSteps>
        <Initialize Result="" Timeout="10000" Description="Initialize for the BaseBrake test." Prompt1="Initialize" ZerospeedPrompt="BrakeToStop">Initialize the system for a new brake test</Initialize>
        <AccelerateToBrakeSpeed Result="" Timeout="1200000" Description="Accelerate to Brake Test Arm Speed" 
            SpeedTarget="63 73" ArmSpeed="60" Prompt1="AccelerateToTargetSpeed">Accelerate to brake test speed</AccelerateToBrakeSpeed>
        <Coast Result="" Timeout="70000" Description="Base Brake Component Coast" Prompt1="CoastDownToTargetSpeed" Prompt2="Blank" SpeedTarget="23 33" CoastEndSpeed="33">Perform Vehicle Coast</Coast>
        <CoastToStop Result="" Timeout="70000" Description="Base Brake Component Coast" Prompt1="CoastDownToTargetSpeed" Prompt2="Blank" SpeedTarget="23 33" CoastEndSpeed="33">Perform Vehicle Coast</CoastToStop>
        <DragTest Result="" Timeout="40000" Description="Base Brake Component Brake Drag Test" 
            Prompt1="ShiftToNeutral" Prompt1BGColor="180 255 180" Prompt2="Blank" 
            DragDelay="1000" DragSpeed="58" DragSamples="20">Perform Vehicle Drag Test</DragTest>
        <AnalyzeDragTest Result="" Timeout="10000" Description="Base Brake Component Brake Drag Test Analysis" 
            Prompt1="" Prompt2="" 
            FrontMaxDragForce="70" RearMaxDragForce="100">Perform Vehicle Drag Test Analysis</AnalyzeDragTest>
        <BrakeTest Result="" Timeout="40000" Description="Base Brake Component Brake Test" 
            StartBrakeSampleSpeed="55" EndBrakeSampleSpeed="40" 
            BrakeDomain="0 1000" BrakeTarget="500 800" 
            Prompt1="BrakeTest" Prompt1BGColor="white" Prompt2="BrakeModeratelyInGreenBand">Perform Vehicle BaseBrake Test</BrakeTest>
        <AnalyzeBrakeTest Result="" Timeout="20000" Description="Base Brake Component Brake Test Analysis" 
            FrontMinBrakeForce="500" RearMinBrakeForce="300" 
            FrontMaxBrakeForce="800" RearMaxBrakeForce="800" 
            Prompt1="" Prompt2="">Perform Vehicle BaseBrake Test Analysis</AnalyzeBrakeTest>
        <AnalyzeBalance Result="" Timeout="5000" Description="Base Brake Component Brake Balance Test" FrontSideToSideBalance="8" RearSideToSideBalance="8" TandemSideToSideBalance="20" BalanceFrontToRearMin="20" BalanceFrontToRearMax="80" BalanceTandemToRearMin="40" BalanceTandemToRearMax="60" Prompt1="" Prompt2="">Perform Vehicle Brake Balance Test</AnalyzeBalance>
        <BrakeToStop Result="" Timeout="1200000" Description="Brake The Vehicle To A Stop" Prompt1="BrakeToStop">Brake the vehicle to a stop</BrakeToStop>
        <FinishUp Result="" Timeout="30000" Description="Brake test finishup" Prompt1="" Prompt2="">Perform finishup to complete test</FinishUp>
        <DisableForceMeter Result="" Timeout="30000" Description="Disable The Brake Force Meter">Disable the brake force meter</DisableForceMeter>
        <TireChunkingTest Result="" Timeout="30000" Description="Check for excessive brake force">Check for excessive brake force</TireChunkingTest>
        <ExcessiveBrakeForceCheck Result="" Timeout="30000" Description="Check for excessive brake force">Check for excessive brake force</ExcessiveBrakeForceCheck>
        <AccelerateToTestSpeed Result="" Timeout="10000" Description="Accelerate to test speed" TargetSpeedParameter="TargetSpeedParameter" SpeedRangeParameter="SpeedRangeParameter" ScanDelayParameter="ScanDelayParameter" Prompt1Value1="32"/>
        <EnableMotorLoading Description="Apply a load to the drive axle of the vehicle" Result="" Timeout="2000"/>
        <DisableMotorLoading Description="Disable the loading of the drive axle of the vehicle" Result="" Timeout="2000"/>
        <MaintainSpeedForTime Result = "" Description="Prompt the operator to accelerate to and maintain speed" Timeout="30000"/>
        <ReadMemoryStatistics Result = "" Description="Read the current memory statistics" Timeout="10000"/>
    </TestSteps>
</BaseBrake>
