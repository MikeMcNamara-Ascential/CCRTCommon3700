    <ShiftLeverTesting>

      <TestStep50>NeutralGateTest</TestStep50>

      <!-- <TestStep55>AutostickOperationTest</TestStep55> -->

    </ShiftLeverTesting>

    <ReverseTesting>

      <TestStep60>AccelerateInReverse</TestStep60>

    </ReverseTesting>

    <StartRatioMonitor>

      <TestStep65>StartRatioMonitor</TestStep65>

      <TestStep70>StartLockUpMonitor</TestStep70>

