    <!-- ============================================================================================== -->
    <Objectives>

        <AbsTests>
            <TestStep00>SpeedSensorCheck</TestStep00>
            <TestStep05>StartBrakeSwitchTest</TestStep05>
        </AbsTests>

        <DragTest>
            <TestStep00>MazdaDragTest</TestStep00>
        </DragTest>

        <BaseBrakeTest>
            <TestStep05>MazdaFrontBrakeForce</TestStep05>
        </BaseBrakeTest>

        <AbsLfTest>
            <TestStep10>BrakeTestStart</TestStep10>
            <TestStep15>AbsLfTest</TestStep15>
            <TestStep25>BrakeTestStop</TestStep25>
            <TestStep30 AltValue="500">TestHeadWait</TestStep30>
        </AbsLfTest>

        <AbsRfTest>
            <TestStep10>BrakeTestStart</TestStep10>
            <TestStep20>AbsRfTest</TestStep20>
            <TestStep25>BrakeTestStop</TestStep25>
            <TestStep30 AltValue="500">TestHeadWait</TestStep30>
        </AbsRfTest>

        <ParkBrakeTest>
            <TestStep30>MazdaParkBrakeForce</TestStep30>
        </ParkBrakeTest>

        <RearBaseBrakeTest>
            <TestStep35>MazdaRearBrakeForce</TestStep35>
        </RearBaseBrakeTest>

        <AbsLrTest>
            <TestStep40>BrakeTestStart</TestStep40>
            <TestStep45>AbsLrTest</TestStep45>
            <TestStep55>BrakeTestStop</TestStep55>
            <TestStep60 AltValue="500">TestHeadWait</TestStep60>
        </AbsLrTest>

        <AbsRrTest>
            <TestStep10>BrakeTestStart</TestStep10>
            <TestStep50>AbsRrTest</TestStep50>
            <TestStep55>BrakeTestStop</TestStep55>
            <TestStep60 AltValue="500">TestHeadWait</TestStep60>
            <TestStep99>BrakeTestComplete</TestStep99>
        </AbsRrTest>

        <DiagnosticClearRoutine>
            <TestStep00>ClearDiagnosticRoutine</TestStep00>
        </DiagnosticClearRoutine>

        <FaultCheckRoutine>
            <TestStep00>FaultCheckRoutine</TestStep00>
            <TestStep05>ReportOverallBrakeResults</TestStep05>
            <TestStep99>StopRollers</TestStep99>
        </FaultCheckRoutine>

        <Setup>
            <TestStep00>Initialize</TestStep00>
        </Setup>

        <StopRollers>
            <TestStep99>StopRollers</TestStep99>
        </StopRollers>

    </Objectives>

