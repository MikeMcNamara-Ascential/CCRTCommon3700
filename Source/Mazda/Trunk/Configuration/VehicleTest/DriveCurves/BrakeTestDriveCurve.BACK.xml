<DriveCurve Description="Mazda Brake Test drive curve">

    <Components Debug="Off">
        <Brake>
            <ComponentName>MazdaBrakeTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
            <ConfigFile>BrakeTC.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Brake</ConfigPath>
        </Brake>
        <Machine>
            <ComponentName>MazdaMachineTc.qxe</ComponentName>
            <ComponentPath>/ApplicationLayer/Bin</ComponentPath>
            <ConfigFile>MachineTC.xml</ConfigFile>
            <ConfigPath>/Configuration/Components/Machine</ConfigPath>
        </Machine>
    </Components>

    <Test Result="Not Tested" Debug="Off">
        <!-- Test Setup -->
        <TestPhase000 Description="Setup the system for testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Setup machine" Result="" Timeout="" Component="Machine">
                    <Initialize/>
                </Objective0>
                <Objective1 Description="Setup brake test component" Result="" Timeout="" Component="Brake">
                    <Setup/>
                </Objective1>
            </ForegroundObjectives>
        </TestPhase000>
        <TestPhase005 Description="Place machine in testing state" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Clear Diagnostics Test" Result="" Timeout="" Component="Brake">
                    <DiagnosticClearRoutine/>
                </Objective0>
                <Objective1 Description="Move to test state" Result="" Timeout="" Component="Machine">
                    <MachineStartup/>
                </Objective1>
            </ForegroundObjectives>
        </TestPhase005>


        <!-- ABS Test Sequence -->
        <TestPhase100 Description="Wheel speed sensor test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Speed sensor testing" Result="" Timeout="" Component="Brake">
                    <AbsTests/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase100>
        <TestPhase105 Description="Drag test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Drag testing" Result="" Timeout="" Component="Brake">
                    <DragTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase105>
        <TestPhase106 Description="Brake test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Front Base Brake testing" Result="" Timeout="" Component="Brake">
                    <BaseBrakeTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase106>
        <TestPhase107 Description="Abs Wheel Specific Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="LF ABS testing" Result="" Timeout="" Component="Brake">
                    <AbsLfTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase107>
        <TestPhase110 Description="Abs Wheel Specific Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="RF ABS testing" Result="" Timeout="" Component="Brake">
                    <AbsRfTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase110>

        <TestPhase112 Description="Park brake testing" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Park brake force measurement" Result="" Timeout="" Component="Brake">
                    <ParkBrakeTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase112>

        <TestPhase113 Description="Rear base brake test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Rear base brake force measurement" Result="" Timeout="" Component="Brake">
                    <RearBaseBrakeTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase113>

        <TestPhase115 Description="Left rear ABS test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="LR ABS Testing" Result="" Timeout="" Component="Brake">
                    <AbsLrTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase115>

        <TestPhase120 Description="Abs Wheel Specific Test" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="RR ABS Testing" Result="" Timeout="" Component="Brake">
                    <AbsRrTest/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase120>


        <!-- Finishup Testing -->
        <TestPhase400 Description="Fault Check" Result="" Timeout="">
            <ForegroundObjectives Result="" Timeout="">
                <Objective0 Description="Fault Check" Result="" Timeout="" Component="Brake">
                    <FaultCheckRoutine/>
                </Objective0>
            </ForegroundObjectives>
        </TestPhase400>

    </Test>
</DriveCurve>
