<SerialServerConfig>
    <Verbose>0x1F</Verbose>
    <Setup>
        <Demo>0</Demo>
        <MgrPool lowWater="2" hiWater="5" maximum="10" increment="1"/>
        <Logging>
            <ProcessName>mgr/SerialServer</ProcessName>
            <AdditionalLogFile>/Servers/SerialServer.log</AdditionalLogFile>
            <Status>Enabled</Status>
            <LocalEcho>Disabled</LocalEcho>
            <Debug>Off</Debug>
            <Verbose>0x01</Verbose>
        </Logging>
        <LogicalPorts>

            <RollData enabled="1" driver="$(USR_ROOT)/ServicesLayer/Bin/RawCommProxy.qxe">
                <Setup>
                    <!-- RS-422 Port -->
                    <SerialDevice>/dev/sl7804/ser1</SerialDevice>
                    <MgrPool lowWater="2" hiWater="10" maximum="15" increment="1" priority="35"/>
                    <Protocol>
                        <Baud>19200</Baud>
                        <Parity>None</Parity>
                        <DataBits>8</DataBits>
                        <StopBits>1</StopBits>
                        <Reflection>0</Reflection>
                        <ByteGap>0</ByteGap>
                        <MssgGap>0</MssgGap>
                        <Interrupts>TxRx</Interrupts>
                        <FifoSize>1024</FifoSize>
                    </Protocol>
                    <Logging>
                        <ProcessName>logport/RollData</ProcessName>
                        <AdditionalLogFile>/Servers/RollData.log</AdditionalLogFile>
                        <Status>Disabled</Status>
                        <LocalEcho>Disabled</LocalEcho>
                        <Verbose>0x3F</Verbose>
                    </Logging>
                    <CommLog>
                        <ContentType>RAW</ContentType>
                        <Setup>
                            <Logging>
                                <ProcessName>RollData_Comm</ProcessName>
                                <AdditionalLogFile>/Communication/RollData_Comm.log</AdditionalLogFile>
                                <Status>Enabled</Status>
                                <LocalEcho>Disabled</LocalEcho>
                                <Verbose>0x1f</Verbose>
                                <Debug>Off</Debug>
                            </Logging>
                        </Setup>
                    </CommLog>
                </Setup>
            </RollData>

        </LogicalPorts>
    </Setup>
</SerialServerConfig>
