         <ParkBrakeSpeedValue>5</ParkBrakeSpeedValue>
         <ParkPawlApplyForce>250</ParkPawlApplyForce>
         <ParkPawlDriverDelay>2000</ParkPawlDriverDelay>
         <ParkPawlMaxDistance>20</ParkPawlMaxDistance>
         <ParkPawlMinDistance>50</ParkPawlMinDistance>
         <ParkPawlPrepTime>5000</ParkPawlPrepTime>
         <ParkPawlSpeedValue>5</ParkPawlSpeedValue>
         <PreForcedAccelerateWait>3000</PreForcedAccelerateWait>
         <ReleaseParkBrakePrompt>ReleaseParkBrake</ReleaseParkBrakePrompt>
         <ResetCommHardware Values="Yes or No">No</ResetCommHardware>
         <ReverseSpeedTarget>5 10</ReverseSpeedTarget>
         <ReverseTestSpeed>5</ReverseTestSpeed>
         <ScanDelayParameter>500</ScanDelayParameter>
         <SetOperatorConsoleTo4WDPrompt>SetOperatorConsoleTo4WD</SetOperatorConsoleTo4WDPrompt>
         <SpeedometerSpeedTarget>22 28</SpeedometerSpeedTarget>
         <SpeedometerStableTime>6000</SpeedometerStableTime>
         <SpeedometerTestHighLimit>28</SpeedometerTestHighLimit>
         <SpeedometerTestLowLimit>22</SpeedometerTestLowLimit>
         <SpeedRangeParameter>30 35</SpeedRangeParameter>
         <TargetSpeed40kph>24.85</TargetSpeed40kph>
         <TargetSpeedParameter>30</TargetSpeedParameter>
         <TimeFormat>%H:%M:%S</TimeFormat>
         <UnidirectionalParkBrakeTest>No</UnidirectionalParkBrakeTest>
         <UnidirectionalParkPawlTest>No</UnidirectionalParkPawlTest>
         <UsePlcYesNoButtons>True</UsePlcYesNoButtons>
      </Parameters>
      <FaultList>/Configuration/Components/Common/SampleFaultList.xml</FaultList>
      <Prompts>
         <SlowDownToTargetSpeed PromptBox="1" Priority="0">SlowDownToTargetSpeed</SlowDownToTargetSpeed>
         <AccelerateToTargetSpeed PromptBox="1" Priority="0">AccelerateToTargetSpeed</AccelerateToTargetSpeed>
         <NeutralPrompt PromptBox="1" Priority="0">ShiftToNeutral</NeutralPrompt>
         <RemoveFootFromBrake PromptBox="1" Priority="0">RemoveFootFromBrake</RemoveFootFromBrake>
         <ZeroSpeed PromptBox="1" Priority="0">BrakeToStop</ZeroSpeed>
         <CableConnect PromptBox="1" Priority="0">CableDisconnected</CableConnect>
         <EnterYesOrNo PromptBox="1" Priority="0">EnterYesOrNo</EnterYesOrNo>
         <PassOrFail PromptBox="1" Priority="0">OverallPassOrFail</PassOrFail>
         <MaintainSpeed PromptBox="1" Priority="0">MaintainSpeed</MaintainSpeed>
         <ShiftToReverse PromptBox="1" Priority="0">ApplyBrakeShiftToReverse</ShiftToReverse>
      </Prompts>
      <StatusCheckItems>
         <VehiclePresent>1</VehiclePresent>
         <RollsUpElevDown>1</RollsUpElevDown>
      </StatusCheckItems>
      <TestDomain>Foreground</TestDomain>
      <SystemTagsToReset>
         <VINDisplayBGColor>white</VINDisplayBGColor>
         <SpeedoTestBGColor>white</SpeedoTestBGColor>
      </SystemTagsToReset>
      <TaskMon>
         <Name>MachineTc_Speedometer</Name>
      </TaskMon>
   </Setup>
   <Objectives>
      <Initialize>
         <TestStep1>Initialize</TestStep1>
         <TestStep2>MachineReady</TestStep2>
