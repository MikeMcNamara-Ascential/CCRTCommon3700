<TestResultServerConfig>
  <Setup>
    <AddForceArray Value="Yes or No">Yes</AddForceArray>
    <AddSpeedArray Value="Yes or No">Yes</AddSpeedArray>
    <SpeedArrayPath>/TestResults/Machine/BrakeForceData/Speed1.log</SpeedArrayPath>
    <ForceArrayPath>/TestResults/Machine/BrakeForceData/BrakeForce1.log</ForceArrayPath>
    <Debug>Off</Debug>
    <IncludeAbortInAllFailures Value="Yes or No">No</IncludeAbortInAllFailures>
    <VINLength>11</VINLength>
    <UpdateTestLampStatus Value="Yes or No">Yes</UpdateTestLampStatus>
    <Communication>
      <Comm>IPC</Comm>
      <Debug>Off</Debug>
      <Name>core/TestResultServer</Name>
      <BufferSize>2000</BufferSize>
      <Timeout>1000</Timeout>
      <Type>Server</Type>
    </Communication>
    <DataTags>
      <StartTest>StartVehicleTest1</StartTest>
      <AllFailures>AllFailures1</AllFailures>
      <OverallTest>OverallTest1</OverallTest>
      <VehicleBuild>VehicleBuild1</VehicleBuild>
      <Vin>VIN1</Vin>
      <ClearScrollBox>ClearScrollBox1</ClearScrollBox>
      <DriverNumber>DriverNumber1</DriverNumber>
      <DriveCurve>DriveCurve1</DriveCurve>
      <KeyPress>KeyPress</KeyPress>
    </DataTags>
    <Logging>
      <Debug>Off</Debug>
      <AdditionalLogFile>/Servers/TestResultServer.log</AdditionalLogFile>
      <ProcessName>core/TestResultServer</ProcessName>
      <Status>Enabled</Status>
      <LocalEcho>Disabled</LocalEcho>
      <Verbose>0x1F</Verbose>
    </Logging>
    <TagList>
      <SubscribeTags>
        <StartVehicleTest/>
        <StartLossCompensation/>
        <OverallTest/>
        <VehicleBuild/>
        <DriverNumber/>
        <VIN/>
        <DriveCurve/>
        <KeyPress/>
      </SubscribeTags>
    </TagList>
    <VehicleBuildItems>
      <DriveCurve/>
    </VehicleBuildItems>
    <TestResults>
      <TestResultPath>/TestResults/Vehicle/</TestResultPath>
      <TestResultFile>TestResultIndex</TestResultFile>
      <NumberOfTests>1000</NumberOfTests>
      <ClearBuildOnOverall>0</ClearBuildOnOverall>
    </TestResults>
    <ThreadPool>
      <Debug>Off</Debug>
      <Increment>2</Increment>
      <MaxBlockedLimit>7</MaxBlockedLimit>
      <Maximum>10</Maximum>
      <MinBlockedLimit>2</MinBlockedLimit>
    </ThreadPool>
    <NotificationList>
      <Setup>
        <Debug>Off</Debug>
        <HighWater>3</HighWater>
        <Increment>1</Increment>
        <LowWater>1</LowWater>
        <Maximum>5</Maximum>
        <StartOnCreate>No</StartOnCreate>
      </Setup>
    </NotificationList>
  </Setup>
</TestResultServerConfig>
