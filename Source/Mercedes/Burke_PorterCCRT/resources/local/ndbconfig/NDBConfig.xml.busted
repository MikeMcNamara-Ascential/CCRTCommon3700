<NamedDataBrokerConfig> <!-- DCBR: Added updates for LT and RT -->
    <Setup>
        <Communication>
            <BufferSize>2000</BufferSize>
            <Comm>IPC</Comm>
            <Debug>Off</Debug>
            <Name>core/NamedDataBroker</Name>
            <Timeout>1000</Timeout>
            <Type>Server</Type>
        </Communication>
        <Debug>Off</Debug>
        <Logging>
            <Status>Disabled</Status>
            <ProcessName>NamedDataBroker</ProcessName>
            <AdditionalLogFile Types="/Server/NamedDataBroker.log or Disabled">/Servers/NamedDataBroker.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x01</Verbose>
        </Logging>
        <Servers>
            <AIN Status="Available">mgr/AIN</AIN>
            <AOUT Status="Available">mgr/AOUT</AOUT>
            <DataServer Status="Available">core/DataServer</DataServer>
            <DIO Status="Available">mgr/DIO</DIO>
            <ICM Status="Available">mgr/ICM</ICM>
            <InputServer Status="Available">core/InputServer</InputServer>
            <FaultServer Status="Available">core/FaultServer</FaultServer>
            <Launcher Status="Available">core/Launcher</Launcher>
            <MachineDataBroker Status="Available">core/MachineDataBroker</MachineDataBroker>
            <MotorController Status="Available">core/MotorController</MotorController>
            <PLC Status="Available">mgr/PLC</PLC>
            <PromptServer Status="Available">core/PromptServer</PromptServer>
            <SystemMonitor Status="Available">core/SystemMonitor</SystemMonitor>
            <TestResultServer Status="Available">core/TestResultServer</TestResultServer>
            <VehicleDataBroker Status="Available">core/VehicleDataBroker</VehicleDataBroker>
            <VehicleTest Status="Available">application/VehicleTest</VehicleTest>
            <WorkCellController Status="Available">core/WorkCellController</WorkCellController>
        </Servers>
        <TagList>
            <PublishTags>
                <Abort DataType="bool">SystemMonitor</Abort>
                <AbortSignalFromPLC DataType="bool">PLC</AbortSignalFromPLC>
                <AbortTestPushButtonToPLC DataType="bool">PLC</AbortTestPushButtonToPLC>
