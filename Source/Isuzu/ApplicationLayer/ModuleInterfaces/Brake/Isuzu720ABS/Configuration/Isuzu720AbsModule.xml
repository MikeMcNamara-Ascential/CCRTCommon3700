<Isuzu720AbsModule>
    <Setup>
        <ModuleKeepAliveTime>500</ModuleKeepAliveTime>
        <KeepAliveResponseRequired>No</KeepAliveResponseRequired>
        <SwitchMonitorDelay>500</SwitchMonitorDelay>
        <EnterDiagnosticModeMessageTag>EnterDiagnosticMode</EnterDiagnosticModeMessageTag>
        <AutomaticallyEnterDiagnosticMode>No</AutomaticallyEnterDiagnosticMode>
        <ResponsePendingReads>3</ResponsePendingReads>
        <J1850PriorityCode>0x0C</J1850PriorityCode>
        <ModuleRequestID>0x29</ModuleRequestID>
        <TesterRequestID>0xF1</TesterRequestID>
        <DataByteCountIndex>3</DataByteCountIndex>
        <DataStartIndex>7</DataStartIndex>
        <DataHeaderLength>3</DataHeaderLength>
        <CheckSumLength>1</CheckSumLength>
        <NumberOfRetries>3</NumberOfRetries>
        <ValidResponseOffset>0x40</ValidResponseOffset>
        <SentMessageIdentifierIndex>0</SentMessageIdentifierIndex>
        <NegativeResponseValue>0x7F</NegativeResponseValue>
        <NegativeResponseCodeIndex>2</NegativeResponseCodeIndex>
        <ModuleResponseDelay>500</ModuleResponseDelay>
        <ModuleResponseEndDelay>0</ModuleResponseEndDelay>
        <DiagnosticRequestCode>0x0C</DiagnosticRequestCode>
        <DiagnosticResponseCode>0x0C</DiagnosticResponseCode>
        <WaitForSpontaneousReset>0</WaitForSpontaneousReset>
        <FirstPinionRegister>0x2820</FirstPinionRegister>
        <NumberOfPinionRegisters>3</NumberOfPinionRegisters>
        <PassFailRegister>0x4004</PassFailRegister>
        <MonthYearRegister>0x4005</MonthYearRegister>
        <DayRegister>0x4006</DayRegister>
        <NumberOfPartNumberReads>3</NumberOfPartNumberReads>
        <NumberOfTraceDataReads>3</NumberOfTraceDataReads>
        <TraceDataNumberOfCharacters>14</TraceDataNumberOfCharacters>
        <TraceabilityHeader>T</TraceabilityHeader>
        <DtcData>
            <DtcCountIndex>0</DtcCountIndex>
            <DtcStartByte>1</DtcStartByte>
            <BytesPerDtc>3</BytesPerDtc>
            <DTCType>BitEncoded</DTCType>
            <StopDTCReadOnZero>Yes</StopDTCReadOnZero>
        </DtcData>
        <NegativeResponseCodes>
            <Code_0x11>Mode Not Supported</Code_0x11>
            <Code_0x12>SubFunction Not Supported / Invalid Format</Code_0x12>
            <Code_0x22>Conditions Not Correct or Request Sequence Error</Code_0x22>
            <Code_0x23>Routine Not Complete</Code_0x23>
            <Code_0x31>Request Out Of Range</Code_0x31>
            <EnterDiagnosticMode>0x80</EnterDiagnosticMode>
            <ResponsePending>0x78</ResponsePending>
            <ModuleBusy>0x21</ModuleBusy>
        </NegativeResponseCodes>
        <Communication>
            <Debug>Off</Debug>
            <Name>/home/CCRT/Rewrite/GryphonJ1850</Name>
            <BufferSize>4096</BufferSize>
            <CommSize>1</CommSize>
            <Timeout>10000000</Timeout>
            <Retries>3</Retries>
        </Communication>
        <Logging>
            <Status>Enabled</Status>
            <ProcessName>720AbsModule</ProcessName>
            <AdditionalLogFile>/Communication/720AbsModule.log</AdditionalLogFile>
            <Debug>Off</Debug>
            <LocalEcho>Disabled</LocalEcho>
            <Verbose>0x3F</Verbose>
        </Logging>
    </Setup>
    <SerialMessages>
        <VehicleMessages>
            <EnterDiagnosticMode>
                <TransmitMessage>EnterDiagnosticMode</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>EnterDiagnosticMode</ReplyMessage>
                <ReplyInterpretation/>
            </EnterDiagnosticMode>
            <EnterNormalMode>
                <TransmitMessage>EnterNormalMode</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>EnterNormalMode</ReplyMessage>
                <ReplyInterpretation/>
            </EnterNormalMode>
            <ModuleKeepAlive>
                <TransmitMessage>KeepAlive</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>KeepAlive</ReplyMessage>
                <ReplyInterpretation/>
            </ModuleKeepAlive>
            <DisableDiagnosticSpeedLimit>
                <TransmitMessage>DisableSpeedLimit</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>DisableSpeedLimitResponse</ReplyMessage>
                <ReplyInterpretation/>
            </DisableDiagnosticSpeedLimit>
            <ReadPartNumberFirstNumber>
                <TransmitMessage>ReadDataBlock</TransmitMessage>
                <TransmitInterpretation>PartNumberFirstNumber</TransmitInterpretation>
                <ReplyMessage>PartNumberFirstNumberResponse</ReplyMessage>
                <ReplyInterpretation>PartNumber</ReplyInterpretation>
            </ReadPartNumberFirstNumber>
            <ReadPartNumberLastNumber>
                <TransmitMessage>ReadDataBlock</TransmitMessage>
                <TransmitInterpretation>PartNumberLastNumber</TransmitInterpretation>
                <ReplyMessage>PartNumberLastNumberResponse</ReplyMessage>
                <ReplyInterpretation>PartNumber</ReplyInterpretation>
            </ReadPartNumberLastNumber>
            <ClearFaults>
                <TransmitMessage>ClearFaults</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ClearFaults</ReplyMessage>
                <ReplyInterpretation>FaultsCleared</ReplyInterpretation>
            </ClearFaults>
            <ReadFaults>
                <TransmitMessage>ReadFaults</TransmitMessage>
                <TransmitInterpretation/>
                <ReplyMessage>ReadFaults</ReplyMessage>
                <ReplyInterpretation/>
            </ReadFaults>
            <ReadBrakeSwitch>
                <TransmitMessage>ReadDPIDs</TransmitMessage>
                <TransmitInterpretation>ReadOnceDPIDBrakeSwitch</TransmitInterpretation>
                <ReplyMessage>ReadDPIDs</ReplyMessage>
                <ReplyInterpretation>BrakeSwitchOnStatus</ReplyInterpretation>
            </ReadBrakeSwitch>
            <ReadSensorSpeeds>
                <TransmitMessage>ReadDPIDs</TransmitMessage>
                <TransmitInterpretation>ReadOnceDPIDWheelSpeed</TransmitInterpretation>
                <ReplyMessage>ReadDPIDs</ReplyMessage>
                <ReplyInterpretation/>
                <ReplyInterpretationLF>LfWheelSpeed</ReplyInterpretationLF>
                <ReplyInterpretationRF>RfWheelSpeed</ReplyInterpretationRF>
                <ReplyInterpretationLR>LrWheelSpeed</ReplyInterpretationLR>
                <ReplyInterpretationRR>RrWheelSpeed</ReplyInterpretationRR>
            </ReadSensorSpeeds>
            <DumpAllValves>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>DumpAll</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </DumpAllValves>
            <HoldAllValves>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>DumpAll</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </HoldAllValves>
            <ActuateLeftFrontRecovery>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>LfRecovery</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftFrontRecovery>
            <ActuateLeftFrontReduction>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>DumpAll</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftFrontReduction>

            <ActuateRightFrontRecovery>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>RfRecovery</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightFrontRecovery>
            <ActuateRightFrontReduction>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>DumpAll</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightFrontReduction>

            <ActuateLeftRearReduction>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>DumpAll</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftRearReduction>
            <ActuateLeftRearRecovery>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>LrRecovery</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateLeftRearRecovery>

            <ActuateRightRearReduction>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>DumpAll</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightRearReduction>
            <ActuateRightRearRecovery>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>RrRecovery</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </ActuateRightRearRecovery>
            <RecoverAllValves>
                <TransmitMessage>ValveControl</TransmitMessage>
                <TransmitInterpretation>Recovery</TransmitInterpretation>
                <ReplyMessage>ValveControl</ReplyMessage>
                <ReplyInterpretation/>
            </RecoverAllValves>
        </VehicleMessages>

        <TransmitMessages>
            <ClearFaults>0x14</ClearFaults>
            <DisableSpeedLimit>0xA8</DisableSpeedLimit>
            <ReadFaults>0x19,0xD2,0xFF,0x00</ReadFaults>
            <EnterNormalMode>0x20</EnterNormalMode>
            <DisableNormalMessageTransmission>0x28,0x??</DisableNormalMessageTransmission>
            <CancelDisableNormalMessageTransmission>0x29</CancelDisableNormalMessageTransmission>
            <ReadDPIDs>0x2A,0x??,0x??,0x??,0x??,0x??,0x??,0x??</ReadDPIDs>
            <ReadDataBlock>0x3C,0x??</ReadDataBlock>
            <EnterDiagnosticMode>0x28,0x00</EnterDiagnosticMode>
            <KeepAlive>0x3F</KeepAlive>
            <ValveControl>0xAE,0x01,0x??,0x??,0x??,0x??,0x??,0x??</ValveControl>
        </TransmitMessages>

        <TransmitInterpretations>
            <NormalMessageTransmissionLevel>0x00</NormalMessageTransmissionLevel>
            <ReadOnceDPIDWheelSpeed>0x01,0x01,0xFF,0xFF,0xFF,0xFF,0xFF</ReadOnceDPIDWheelSpeed>
            <ReadOnceDPIDValveControl>0x01,0x02,0xFF,0xFF,0xFF,0xFF,0xFF</ReadOnceDPIDValveControl>
            <ReadOnceDPIDExhustBrake>0x01,0x03,0xFF,0xFF,0xFF,0xFF,0xFF</ReadOnceDPIDExhustBrake>
            <ReadOnceDPIDBrakeSwitch>0x01,0x01,0xFF,0xFF,0xFF,0xFF,0xFF</ReadOnceDPIDBrakeSwitch>
            <PartNumberFirstNumber>0x85</PartNumberFirstNumber>
            <PartNumberLastNumber>0x86</PartNumberLastNumber>
            <DumpAll> 0x02,0x02,0xFF,0x55,0x00,0x00</DumpAll>
            <HoldAll>0x02,0x02,0xFF,0xFF,0x00,0x00</HoldAll>

            <LfRecovery>0x02,0x02,0xFF,0xCF,0x00,0x00</LfRecovery>
            <RfRecovery>0x02,0x02,0xFF,0x3F,0x00,0x00</RfRecovery>
            <LrRecovery>0x02,0x02,0xFF,0xFC,0x00,0x00</LrRecovery>
            <RrRecovery>0x02,0x02,0xFF,0xF3,0x00,0x00</RrRecovery>

            <LfReduction>0x02,0x00,0xFF,0x30,0x00,0x00</LfReduction>
            <RfReduction>0x02,0x00,0xFF,0xC0,0x00,0x00</RfReduction>
            <LrReduction>0x02,0x00,0xFF,0x03,0x00,0x00</LrReduction>
            <RrReduction>0x02,0x00,0xFF,0x0C,0x00,0x00</RrReduction>

            <Recovery>0x02,0x02,0xFF,0x00,0x00,0x00</Recovery>
        </TransmitInterpretations>

        <ReplyMessages>
            <EnterDiagnosticMode>
                <Reply_00 lengthType="Variable" ReplyTimeout="100" endGapTime="0">0x68,0x??</Reply_00>
            </EnterDiagnosticMode>
            <EnterNormalMode>
                <Reply_00>0x60</Reply_00>
                <Reply_02>0x20,0x??</Reply_02>
            </EnterNormalMode>
            <DisableSpeedLimitResponse>
                <Reply_00>0xE8</Reply_00>
            </DisableSpeedLimitResponse>
            <DisableNormalMessageTransmission>
                <Reply_00>0x68,0x??</Reply_00>
                <Reply_01>7F,0x28,0x??</Reply_01>
                <Reply_02>7F,0x28,0x??,0x??</Reply_02>
            </DisableNormalMessageTransmission>
            <CancelDisableNormalMessageTransmission>
                <Reply_00>0x69</Reply_00>
                <Reply_01>0x7F,0x29,0x??</Reply_01>
            </CancelDisableNormalMessageTransmission>
            <KeepAlive>
                <Reply_00>0x54</Reply_00>
            </KeepAlive>
            <ClearFaults>
                <Reply_01>0x54</Reply_01>
                <Reply_02>0x7F,0x14,0x??</Reply_02>
            </ClearFaults>
            <ReadFaults>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x59</Reply_00>
                <!--Reply_01>0x59,0x??,0x??,0x??</Reply_01-->
                <Reply_02>0x7F,0x19,0x??</Reply_02>
                <!--Reply_03>0x7F,0x19,0x??,0xFF,0x00,0x23</Reply_03-->
            </ReadFaults>
            <ReadDPIDs>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x6A,0x??,0x??,0x??,0x??,0x??,0x??,0x??</Reply_00>
                <Reply_01>0x7F,0x2A,0x??</Reply_01>
            </ReadDPIDs>
            <ReadDataBlock>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x7C,0x85,0x??</Reply_00>
                <Reply_01 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x7C,0x86,0x??</Reply_01>
                <Reply_02>0x7F,0x3C,0x??</Reply_02>
            </ReadDataBlock>
            <PartNumberFirstNumberResponse>
                <Reply_00 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x7C,0x85,0x??</Reply_00>
                <Reply_02>0x7F,0x3C,0x??</Reply_02>
            </PartNumberFirstNumberResponse>
            <PartNumberLastNumberResponse>
                <Reply_01 lengthType="Variable" ReplyTimeout="200" endGapTime="0">0x7C,0x86,0x??</Reply_01>
                <Reply_02>0x7F,0x3C,0x??</Reply_02>
            </PartNumberLastNumberResponse>
            <ValveControl>
                <Reply_00>0xEE,0x01,0xE1</Reply_00>
                <Reply_01>0x7F,0xAE,0x01,0x??</Reply_01>
            </ValveControl>
        </ReplyMessages>

        <ReplyInterpretations>
            <PartNumber>
                <String>
                    <Substring format="%5s">
                        <chars input_index="2" mask="0xFF" length="5"/>
                    </Substring>
                </String>
            </PartNumber>
            <FaultsCleared>
                <Boolean>
                    <Byte01 input_index="0" mask="0xFF" compare="0x54"/>
                </Boolean>
            </FaultsCleared>
            <BrakeSwitchOnStatus>
                <Boolean>
                    <Byte01 input_index="6" mask="0x04" compare="0x04"/>
                </Boolean>
            </BrakeSwitchOnStatus>
            <LfWheelSpeed>
                <Float scale="0.6213712" offset="0">
                    <Integer type="unsigned" bits="8" scale="1" offset="0">
                        <Byte1 input_index="2" mask="0xFF" output_index="0"/>
                    </Integer>
                </Float>
            </LfWheelSpeed>
            <RfWheelSpeed>
                <Float scale="0.6213712" offset="0">
                    <Integer type="unsigned" bits="8" scale="1" offset="0">
                        <Byte1 input_index="3" mask="0xFF" output_index="0"/>
                    </Integer>
                </Float>
            </RfWheelSpeed>
            <LrWheelSpeed>
                <Float scale="0.6213712" offset="0">
                    <Integer type="unsigned" bits="8" scale="1" offset="0">
                        <Byte1 input_index="4" mask="0xFF" output_index="0"/>
                    </Integer>
                </Float>
            </LrWheelSpeed>
            <RrWheelSpeed>
                <Float scale="0.6213712" offset="0">
                    <Integer type="unsigned" bits="8" scale="1" offset="0">
                        <Byte1 input_index="5" mask="0xFF" output_index="0"/>
                    </Integer>
                </Float>
            </RrWheelSpeed>
    


        </ReplyInterpretations>
    </SerialMessages>
</Isuzu720AbsModule>
