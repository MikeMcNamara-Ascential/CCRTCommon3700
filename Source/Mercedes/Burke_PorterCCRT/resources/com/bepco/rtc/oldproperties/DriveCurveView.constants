panel.brakeforce.boundingbox=true
panel.brakeforce.legend.visible=true
panel.brakeforce.reset.key=r
panel.brakeforce.header.visible=true
panel.brakeforce.footer.visible=true
panel.brakeforce.lf.color=lfcolor
panel.brakeforce.rf.color=rfcolor
panel.brakeforce.lr.color=lrcolor
panel.brakeforce.rr.color=rrcolor
