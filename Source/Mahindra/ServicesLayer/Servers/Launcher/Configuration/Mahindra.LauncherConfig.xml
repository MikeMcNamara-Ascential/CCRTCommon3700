            AddressValue="" PortValue="" VerboseMode="">Fault Server</FaultServer>

        <TestResultServer Name="TestResultServer.qxe" Path="/ServicesLayer/Bin/" 
            ConfigFile="TestResultServerConfig.xml" ConfigPath="/Configuration/Servers/" 
